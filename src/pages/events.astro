    dragHint: "Hover over images to explore structural details",
    zones: [
      { 
        icon:"🌿", 
        tag: "ZONE 01 · DENSE FOREST CANOPY", 
        h2: "High-Altitude Trekking & Mountain Rides", 
        body: "Cross dense mountain forests of Djurdjura and Kabylie. Walk secret tracks, conquer high passes on horseback, and bivouac under a vast starlit sky.", 
