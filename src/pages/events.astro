        pills: ["غوص سكوبا", "غوص حر عميق", "سفن غارقة", "مرجان عملاق"], 
        imgs: [13, 14, 5], 
        accent: "#9d4edd",
        bg: "#090317"
      },
    ],
    ctaTitle: "استعد لتلبية نداء\nالبرية المطلقة",
    ctaBody: "تُنظم رحلاتنا الرياضية في مجموعات محدودة للغاية للحفاظ على الخصوصية وحماية البيئة. انضم الآن لشبكة الواتساب VIP وسيتواصل معك مرشدونا الرياضيون فوراً.",
    ctaBtn: "💬 انضم فوراً لفرقة واتساب VIP",
