  en: {
    metaTitle: "AQA Events — Sovereign Wild Journeys & Extreme Sports Algeria",
    metaDesc: "Discover AQA Events: hiking, kayaking, apnea & scuba diving in Algeria. A high-end, majestic athletic showcase from forest to abyss.",
    metaKw: "hiking algeria, kayak alger, scuba diving algeria, aqa events, extreme sports, outdoor events",
    badge: "AQA SPORTS ACADEMY · WILD EVENTS",
