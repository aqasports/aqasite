        pills: ["Downhill MTB", "Run & Bike", "Coastal Triathlon", "Cliff Camping"], 
        imgs: [7, 8, 9], 
        accent: "#ffb703",
        bg: "#1c1503"
      },
      { 
        icon:"🌊", 
        tag: "ZONE 04 · HYDRO-SPACE OPEN BLUE", 
        h2: "Open Water Swims & Cape Crossings", 
        body: "Conquer the wild Mediterranean swell. Challenge legendary stone capes and train in elite open water endurance swimming with our pro guides.", 
        pills: ["Pro Open Water", "Cape Crossings", "Endurance Swim", "Maritime Raids"], 
        imgs: [10, 11, 12], 
        accent: "#00b4d8",
        bg: "#021422"
      },
      { 
        icon:"🤿", 
        tag: "ZONE 05: THE SILENT ABYSS", 
