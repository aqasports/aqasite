---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  lang?: string;
}

const { lang = 'fr' } = Astro.props;

const getRelativePath = (path, targetLang) => {
  if (targetLang === 'fr') return path;
  return `/${targetLang}${path === '/' ? '' : path}`;
};
---

<BaseLayout title="Événements & Compétitions | AQA Sports Academy — Algérie"
  description="Suivez les événements, compétitions et stages AQA Sports Academy. Championnats, galas de natation et rencontres aquatiques en Algérie."
  keywords="compétitions natation algérie, événements aquatiques alger, gala natation, stages natation algérie"
  currentPage="/events" lang={lang}>
  <Navbar currentPage="/events" lang={lang} />

<!-- NAVBAR -->
    

    

    <!-- Page Content -->
    <div class="page-hero">
        <span class="hero-badge">📅 Agenda AQA</span>
        <h1>Événements & Activités</h1>
        <div class="section-divider"></div>
        <p>Compétitions, stages, journées portes ouvertes et challenges — restez connecté à la vie d'AQA Sports Academy.</p>
    </div>

    <div class="container">
        <div class="events-grid">
            <!-- Event Card 1 -->
            <article class="event-card">
                <span class="event-tag">🏆 Compétition</span>
                <div class="event-img-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M8 21h8M12 17v4M17 4H7l-2 9h14L17 4zM9 13c0 1.66 1.34 3 3 3s3-1.34 3-3"/></svg>
                </div>
                <div class="event-body">
                    <div class="event-date">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Prochain événement
                    </div>
                    <h2 class="event-title">Challenge Inter-Groupes AQA</h2>
                    <p class="event-desc">Compétition interne entre tous les groupes de natation. Un moment de performance, de dépassement et de fierté collective pour nos athlètes.</p>
                    <div class="event-meta">
                        <span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Piscine Réghaia
                        </span>
                        <span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            Tous niveaux
                        </span>
                    </div>
                    <a href={getRelativePath('/inscription', lang)} class="event-cta">S'inscrire →</a>
                </div>
            </article>

            <!-- Event Card 2 -->
            <article class="event-card">
                <span class="event-tag">🌊 Stage</span>
                <div class="event-img-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
                </div>
                <div class="event-body">
                    <div class="event-date">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Stage intensif
                    </div>
                    <h2 class="event-title">Stage Vacances — Natation & Apnée</h2>
                    <p class="event-desc">Stage de 5 jours pendant les vacances scolaires. Programme intensif adapté aux enfants et adultes pour progresser rapidement.</p>
                    <div class="event-meta">
                        <span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Multi-piscines AQA
                        </span>
                        <span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            5 jours
                        </span>
                    </div>
                    <a href={getRelativePath('/inscription', lang)} class="event-cta">S'inscrire →</a>
                </div>
            </article>

            <!-- Event Card 3 -->
            <article class="event-card">
                <span class="event-tag">🎯 Portes Ouvertes</span>
                <div class="event-img-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div class="event-body">
                    <div class="event-date">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Bientôt
                    </div>
                    <h2 class="event-title">Journée Portes Ouvertes AQA</h2>
                    <p class="event-desc">Venez découvrir nos installations, rencontrer nos coachs et essayer une séance gratuite d'initiation. Idéal pour les nouvelles recrues.</p>
                    <div class="event-meta">
                        <span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            Gratuit
                        </span>
                        <span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Toutes piscines
                        </span>
                    </div>
                    <a href={getRelativePath('/infos', lang)} class="event-cta">En savoir plus →</a>
                </div>
            </article>
        </div>

        <!-- Coming Soon -->
        <div class="coming-soon-banner">
            <h2>🔔 Restez informé</h2>
            <p>De nouveaux événements et compétitions sont régulièrement planifiés. Abonnez-vous pour ne rien manquer.</p>
            <a href={getRelativePath('/', lang)} + '#footer' class="notify-btn">Me notifier par email</a>
        </div>
    </div>

    <!-- Footer -->

  <Footer  lang={lang} />
</BaseLayout>

<style>

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { background: #000; scroll-behavior: smooth; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: transparent;
            color: #fff;
            line-height: 1.6;
            overflow-x: hidden;
        }
        .bg-frame { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; border: none; z-index: -1; pointer-events: none; }
        .container { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem; }

        /* Page Hero */
        .page-hero {
            text-align: center;
            padding: 5rem 1rem 3rem;
            position: relative;
        }
        .page-hero h1 {
            font-size: clamp(2rem, 6vw, 3.5rem);
            font-weight: 800;
            background: linear-gradient(135deg, #00ffff, #0099ff, #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
        }
        .page-hero p {
            font-size: clamp(1rem, 3vw, 1.2rem);
            color: rgba(255,255,255,0.8);
            max-width: 700px;
            margin: 0 auto;
        }
        .hero-badge {
            display: inline-block;
            background: rgba(0,255,255,0.1);
            border: 1px solid rgba(0,255,255,0.4);
            color: #00ffff;
            padding: 0.4rem 1.2rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
        }
        .section-divider {
            width: 80px; height: 3px;
            background: linear-gradient(90deg, #00ffff, #0099ff);
            margin: 1.5rem auto;
            border-radius: 2px;
            box-shadow: 0 0 10px rgba(0,255,255,0.5);
        }

        /* Events Grid */
        .events-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
            margin: 3rem 0;
        }
        .event-card {
            background: rgba(0,153,255,0.05);
            border: 1px solid rgba(0,153,255,0.3);
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.3s ease;
            position: relative;
        }
        .event-card:hover {
            transform: translateY(-5px);
            border-color: #00ffff;
            box-shadow: 0 0 30px rgba(0,255,255,0.2);
        }
        .event-tag {
            position: absolute;
            top: 1rem; right: 1rem;
            background: linear-gradient(135deg, #0099ff, #00ffff);
            color: #000;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        .event-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            display: block;
            background: linear-gradient(135deg, #001a33, #003366);
        }
        .event-img-placeholder {
            width: 100%;
            height: 180px;
            background: linear-gradient(135deg, rgba(0,153,255,0.15), rgba(0,255,255,0.05));
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .event-img-placeholder svg { width: 60px; height: 60px; stroke: rgba(0,255,255,0.4); }
        .event-body { padding: 1.5rem; }
        .event-date {
            font-size: 0.8rem;
            color: #00ffff;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .event-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 0.8rem;
        }
        .event-desc {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.7);
            margin-bottom: 1.2rem;
            line-height: 1.5;
        }
        .event-meta {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .event-meta span {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.6);
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        .event-meta svg { width: 14px; height: 14px; stroke: #00ffff; }
        .event-cta {
            display: inline-block;
            margin-top: 1rem;
            padding: 0.6rem 1.5rem;
            background: linear-gradient(135deg, rgba(0,153,255,0.2), rgba(0,255,255,0.2));
            border: 1px solid rgba(0,255,255,0.4);
            border-radius: 25px;
            color: #00ffff;
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        .event-cta:hover {
            background: linear-gradient(135deg, rgba(0,153,255,0.4), rgba(0,255,255,0.4));
            transform: translateY(-2px);
        }

        /* Coming Soon Banner */
        .coming-soon-banner {
            background: linear-gradient(135deg, rgba(0,153,255,0.1), rgba(0,255,255,0.05));
            border: 1px solid rgba(0,255,255,0.3);
            border-radius: 20px;
            padding: 3rem;
            text-align: center;
            margin: 3rem 0;
        }
        .coming-soon-banner h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #00ffff;
            margin-bottom: 1rem;
        }
        .coming-soon-banner p {
            color: rgba(255,255,255,0.7);
            max-width: 500px;
            margin: 0 auto 1.5rem;
        }
        .notify-btn {
            display: inline-block;
            padding: 0.9rem 2rem;
            background: linear-gradient(135deg, #0099ff, #00ffff);
            color: #000;
            font-weight: 700;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        .notify-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 30px rgba(0,255,255,0.5);
        }

        @media (max-width: 768px) {
            .events-grid { grid-template-columns: 1fr; }
            .page-hero { padding: 4rem 1rem 2rem; }
        }
        @media (prefers-reduced-motion: reduce) {
            * { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
        }
    
</style>
