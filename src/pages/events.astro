    ctaHint: "Private secure terminal link. Join & wait for the launch transmission.",
  }
}[lang] || T.fr;
---

<BaseLayout title={T.metaTitle} description={T.metaDesc} keywords={T.metaKw} currentPage="/events" lang={lang}>
  <Navbar currentPage="/events" lang={lang} />

  <!-- ═══════════════════════════════════════
       LUXURY SENSORY CONTROL (MINIMAL PILL)
       ═══════════════════════════════════════ -->
  <div class="aq-sensory-console" aria-hidden="true">
    <button class="aq-sensory-btn" id="btnSensorySound">
      <span class="wave-spectrometer">
        <span></span><span></span><span></span><span></span><span></span>
      </span>
      <span class="btn-lbl" id="sensoryLabel">{T.soundToggle} [OFF]</span>
    </button>
    
    <!-- Ultra-minimal hidden frequency visualizer canvas -->
    <canvas id="sensoryCanvas" width="90" height="24"></canvas>
  </div>

  <!-- ═══════════════════════════════════════
       SOVEREIGN KINETIC CONTAINER
       ═══════════════════════════════════════ -->
  <div class="aq-luxury-scroller" id="luxuryScroller">
    
    <!-- ─── ATHLETIC HERO HEADER ─── -->
    <section class="aq-hero" id="aqHero">
      <!-- Full-bleed cinematic backdrop -->
      <div class="hero-video-wrap">
        <video class="hero-video" autoplay muted loop playsinline preload="metadata">
          <source src="/events/Fav%20main%20vid.mov" type="video/quicktime">
          <source src="/zero.mp4" type="video/mp4">
        </video>
        <div class="hero-video-mask"></div>
      </div>

      <div class="hero-inner">
        <span class="hero-badge">{T.badge}</span>
        <h1 class="hero-title">
          <span class="title-line title-line--1">{T.h1a}</span>
          <span class="title-line title-line--2">{T.h1b}</span>
          <span class="title-line title-line--3">{T.h1c}</span>
        </h1>
        <p class="hero-sub">{T.sub}</p>

        <!-- Symmetric Stats Grid -->
        <div class="hero-stats">
          <div class="stat-box"><span class="stat-number font-display">{T.stat1n}</span><span class="stat-lbl">{T.stat1l}</span></div>
          <div class="stat-divider"></div>
          <div class="stat-box"><span class="stat-number font-display">{T.stat2n}</span><span class="stat-lbl">{T.stat2l}</span></div>
          <div class="stat-divider"></div>
          <div class="stat-box"><span class="stat-number font-display">{T.stat3n}</span><span class="stat-lbl">{T.stat3l}</span></div>
        </div>

        <a href="#zone-0" class="hero-scroll-btn">
          <span>{T.scroll}</span>
          <div class="scroll-chevron">↓</div>
        </a>
      </div>
      
      <!-- Fades smoothly into deep dark page background -->
      <div class="hero-fade-out"></div>
    </section>

    <!-- ─── ADVENTURE ZONES DECK (1 to 5) ─── -->
    <div class="aq-deck" id="aqDeck">
      {T.zones.map((z, idx) => (
        <section 
          class="aq-deck-slide" 
          id={`zone-${idx}`} 
          data-zone-idx={idx}
          style={`--zone-accent: ${z.accent}; --zone-theme-bg: ${z.bg};`}
        >
          <div class="slide-bg-glow"></div>
          
          <div class="slide-grid">
            
            <!-- LEFT COLUMN: Narrative & Structured Details -->
            <div class="slide-narrative">
              <div class="watermark-index font-display">{String(idx + 1).padStart(2, '0')}</div>
              
              <div class="slide-meta">
                <span class="slide-icon">{z.icon}</span>
                <span class="slide-badge" style={`color: ${z.accent}; border-color: ${z.accent}30`}>{z.tag}</span>
              </div>
              
              <h2 class="slide-h2 font-display">{z.h2}</h2>
              <p class="slide-body">{z.body}</p>
              
              <!-- Structured Service Pills -->
              <div class="slide-pills">
                {z.pills.map(pill => (
                  <span class="slide-pill" style={`--accent-hover: ${z.accent}`}>
                    {pill}
                  </span>
                ))}
              </div>
            </div>

            <!-- RIGHT COLUMN: Perfectly Symmetrical 3D Hover Collage -->
            <div class="slide-gallery">
              <div class="collage-container" id={`collage-${idx}`}>
                <!-- Center Primary Card -->
                <div class="collage-card card--primary">
                  <div class="card-glass-glow"></div>
                  <img src={`/events/Fav%20img%20(${z.imgs[0]}).jpg`} alt={`AQA ${z.tag} Core`} loading="lazy" />
                </div>
                <!-- Overlapping Secondary Card -->
                <div class="collage-card card--secondary">
                  <div class="card-glass-glow"></div>
                  <img src={`/events/Fav%20img%20(${z.imgs[1]}).jpg`} alt={`AQA ${z.tag} Secondary`} loading="lazy" />
                </div>
                <!-- Overlapping Tertiary Card -->
                <div class="collage-card card--tertiary">
                  <div class="card-glass-glow"></div>
                  <img src={`/events/Fav%20img%20(${z.imgs[2]}).jpg`} alt={`AQA ${z.tag} Tertiary`} loading="lazy" />
                </div>
              </div>
              <p class="gallery-hint">{T.dragHint}</p>
            </div>
            
          </div>
        </section>
      ))}
    </div>

    <!-- ─── PLATINUM VIP FINALE ─── -->
    <section class="aq-finale" id="aqFinale">
      <div class="finale-waves" aria-hidden="true">
        <svg viewBox="0 0 1440 320" preserveAspectRatio="none"><path fill="rgba(255,255,255,0.02)" d="M0,96L48,112C96,128,192,160,288,186.7C384,213,480,235,576,218.7C672,203,768,149,864,138.7C960,128,1056,160,1152,176C1248,192,1344,192,1392,192L1440,192L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"/></svg>
      </div>

      <div class="finale-card">
        <div class="finale-card-outline"></div>
        <span class="finale-badge">AQA ATHLETIC CLUB · ELITE</span>
        <h2 class="finale-h2 font-display" set:html={T.ctaTitle.replace('\n', '<br/>')}></h2>
        <p class="finale-body">{T.ctaBody}</p>

        <a 
          href="https://chat.whatsapp.com/DcJm9dgx6WMLqsQmpreOZp" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="aq-whatsapp-btn"
          id="btnWaVIP"
        >
          <span class="btn-ripple-glow"></span>
          <span class="btn-wa-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </span>
          <span>{T.ctaBtn}</span>
        </a>

        <p class="finale-hint">{T.ctaHint}</p>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</BaseLayout>

<!-- ═══════════════════════════════════════════
     HIGH-END LUXURY CORE SCRIPT
     ═══════════════════════════════════════════ -->
<script>
document.addEventListener('astro:page-load', () => {
  const scroller = document.getElementById('luxuryScroller');
  if (!scroller) return;

  const btnSensorySound = document.getElementById('btnSensorySound');
  const sensoryLabel = document.getElementById('sensoryLabel');
  const sensoryCanvas = document.getElementById('sensoryCanvas') as HTMLCanvasElement;
  const slideSections = document.querySelectorAll('.aq-deck-slide');
  const body = document.body;

  // Real-time variables
  let activeZoneIdx = 0;
  let audioCtx: AudioContext | null = null;
  let audioActive = false;
  let masterGain: GainNode | null = null;
  let analyser: AnalyserNode | null = null;

  // Synth subchannels
  let synthGains = {
    forest: null as GainNode | null,
    river: null as GainNode | null,
    coast: null as GainNode | null,
    abyss: null as GainNode | null
  };

  // Sound oscs
  let windFilter: BiquadFilterNode | null = null;
  let windLfo: OscillatorNode | null = null;
  let riverFilter: BiquadFilterNode | null = null;
  let riverLfo: OscillatorNode | null = null;
  let wavesFilter: BiquadFilterNode | null = null;
  let wavesLfo: OscillatorNode | null = null;
  let abyssDrone1: OscillatorNode | null = null;
  let abyssDrone2: OscillatorNode | null = null;

  let canvasCtx = sensoryCanvas ? sensoryCanvas.getContext('2d') : null;
  let dataArray: Uint8Array = new Uint8Array(0);
  let rafId: number | null = null;

  // ═══════════════════════════════════════
  // LUXURY SCROLL & BG MORPH
  // ═══════════════════════════════════════
  const bgColors = ['#03170b', '#021a1d', '#1c1503', '#021422', '#090317'];

  function onScroll() {
    const scrollY = window.scrollY;
    const h = window.innerHeight;
    
    // Intersection calculations to morph background smoothly on scroll thresholds
    slideSections.forEach((section, idx) => {
      const rect = section.getBoundingClientRect();
      const overlapTop = Math.max(0, rect.top);
      const overlapBottom = Math.min(h, rect.bottom);
      const visibleHeight = Math.max(0, overlapBottom - overlapTop);
      
      // If slide dominates the screen (visible over 50%), trigger color shift
      if (visibleHeight > h * 0.45 && activeZoneIdx !== idx) {
        activeZoneIdx = idx;
        body.style.backgroundColor = bgColors[idx];
        morphSynthAudio(idx);
      }
    });

    // Reset when scrolling back to hero
    const heroRect = document.getElementById('aqHero')?.getBoundingClientRect();
    if (heroRect && heroRect.bottom > h * 0.6 && activeZoneIdx !== -1) {
      activeZoneIdx = -1;
      body.style.backgroundColor = '#04090e';
      morphSynthAudio(-1);
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // initial fire

  // ═══════════════════════════════════════
  // PROCEDURAL WEB AUDIO NATURAL SYNTH
  // ═══════════════════════════════════════
  function initAudioEngine() {
    try {
      const AudioCtxClass = window.AudioContext || (window as any).webkitAudioContext;
      audioCtx = new AudioCtxClass();

      // Clean Master limiters
      masterGain = audioCtx.createGain();
      masterGain.gain.setValueAtTime(0.25, audioCtx.currentTime);

      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 32;
      dataArray = new Uint8Array(analyser.frequencyBinCount);

      analyser.connect(audioCtx.destination);
      masterGain.connect(analyser);

      // Create individual channels
      synthGains.forest = audioCtx.createGain();
      synthGains.river = audioCtx.createGain();
      synthGains.coast = audioCtx.createGain();
      synthGains.abyss = audioCtx.createGain();

      Object.values(synthGains).forEach(gn => {
        gn.gain.setValueAtTime(0, audioCtx.currentTime);
        gn.connect(masterGain);
      });

      // White noise buffer
      const bufferSize = 2 * audioCtx.sampleRate;
      const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
      const output = noiseBuffer.getChannelData(0);
      for (let i = 0; i < bufferSize; i++) {
        output[i] = Math.random() * 2 - 1;
      }

      // 1. FOREST SOUNDSCAPE
      const forestNoise = audioCtx.createBufferSource();
      forestNoise.buffer = noiseBuffer;
      forestNoise.loop = true;

      windFilter = audioCtx.createBiquadFilter();
      windFilter.type = 'bandpass';
      windFilter.Q.value = 1.2;
      windFilter.frequency.value = 350;

      windLfo = audioCtx.createOscillator();
      windLfo.type = 'sine';
      windLfo.frequency.value = 0.05; // 20s wind surge LFO
      
      const windLfoGain = audioCtx.createGain();
      windLfoGain.gain.value = 120;

      windLfo.connect(windLfoGain);
      windLfoGain.connect(windFilter.frequency);
      forestNoise.connect(windFilter);
      windFilter.connect(synthGains.forest);

      windLfo.start();
      forestNoise.start();
      triggerSoftChirp();

      // 2. RIVER BUBBLES
      const riverNoise = audioCtx.createBufferSource();
      riverNoise.buffer = noiseBuffer;
      riverNoise.loop = true;

      riverFilter = audioCtx.createBiquadFilter();
      riverFilter.type = 'bandpass';
      riverFilter.Q.value = 4.0;
      riverFilter.frequency.value = 580;

      riverLfo = audioCtx.createOscillator();
      riverLfo.frequency.value = 0.45;
      const riverLfoGain = audioCtx.createGain();
      riverLfoGain.gain.value = 180;

      riverLfo.connect(riverLfoGain);
      riverLfoGain.connect(riverFilter.frequency);
      riverNoise.connect(riverFilter);
      riverFilter.connect(synthGains.river);

      riverLfo.start();
      riverNoise.start();

      // 3. OCEAN SURF
      const surfNoise = audioCtx.createBufferSource();
      surfNoise.buffer = noiseBuffer;
      surfNoise.loop = true;

      wavesFilter = audioCtx.createBiquadFilter();
      wavesFilter.type = 'lowpass';
      wavesFilter.frequency.value = 150;

      wavesLfo = audioCtx.createOscillator();
      wavesLfo.frequency.value = 0.1; // 10s period waves
      const wavesLfoGain = audioCtx.createGain();
      wavesLfoGain.gain.value = 0.4;

      const wavesModGain = audioCtx.createGain();
      wavesModGain.gain.value = 0;

      wavesLfo.connect(wavesLfoGain);
      wavesLfoGain.connect(wavesModGain.gain);
      surfNoise.connect(wavesFilter);
      wavesFilter.connect(wavesModGain);
      wavesModGain.connect(synthGains.coast);

      wavesLfo.start();
      surfNoise.start();

      // 4. ABYSSAL SUB-DRONE
      abyssDrone1 = audioCtx.createOscillator();
      abyssDrone1.type = 'sine';
      abyssDrone1.frequency.value = 39.0;

      abyssDrone2 = audioCtx.createOscillator();
      abyssDrone2.type = 'sine';
      abyssDrone2.frequency.value = 40.0;

      const droneGain = audioCtx.createGain();
      droneGain.gain.value = 0.45;

      abyssDrone1.connect(droneGain);
      abyssDrone2.connect(droneGain);
      droneGain.connect(synthGains.abyss);

      abyssDrone1.start();
      abyssDrone2.start();

      triggerCalmSonar();
    } catch (e) {
      console.warn("Failed to init high-end Web Audio synth:", e);
    }
  }

  // Synthesizes occasional delicate bird pings for Forest
  function triggerSoftChirp() {
    if (!audioActive || !audioCtx || !synthGains.forest) return;
    
    const count = 1 + Math.floor(Math.random() * 2);
    let st = audioCtx.currentTime;

    for (let i = 0; i < count; i++) {
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = 'sine';
      const f = 2000 + Math.random() * 600;
      osc.frequency.setValueAtTime(f, st);
      osc.frequency.exponentialRampToValueAtTime(f * 1.4, st + 0.07);

      gain.gain.setValueAtTime(0.012, st);
      gain.gain.exponentialRampToValueAtTime(0.0001, st + 0.07);

      osc.connect(gain);
      gain.connect(synthGains.forest);

      osc.start(st);
      osc.stop(st + 0.08);
      st += 0.14;
    }

    setTimeout(triggerSoftChirp, 7000 + Math.random() * 7000);
  }

  // Synthesizes submarine echoing sonar ping for deep Abyss
  function triggerCalmSonar() {
    if (!audioActive || !audioCtx || !synthGains.abyss) {
      setTimeout(triggerCalmSonar, 2000);
      return;
    }

    if (activeZoneIdx === 4) {
      const st = audioCtx.currentTime;
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      
      osc.type = 'sine';
      osc.frequency.setValueAtTime(987.77, st); // B5 note
      osc.frequency.exponentialRampToValueAtTime(980, st + 0.35);

      gain.gain.setValueAtTime(0.04, st);
      gain.gain.exponentialRampToValueAtTime(0.0001, st + 2.5);

      const delay = audioCtx.createDelay();
      delay.delayTime.setValueAtTime(0.5, st);
      const feedback = audioCtx.createGain();
      feedback.gain.setValueAtTime(0.4, st);

      osc.connect(gain);
      gain.connect(synthGains.abyss); // dry

      gain.connect(delay);
      delay.connect(feedback);
      feedback.connect(delay);
      feedback.connect(synthGains.abyss); // wet feedback delay

      osc.start(st);
      osc.stop(st + 2.8);
    }

    setTimeout(triggerCalmSonar, 10000 + Math.random() * 2000);
  }

  // Smooth environmental audio crossfades
  function morphSynthAudio(zoneIdx: number) {
    if (!audioCtx || !audioActive) return;

    const t = audioCtx.currentTime;
    const targets = { forest: 0, river: 0, coast: 0, abyss: 0 };

    if (zoneIdx === 0) {
      targets.forest = 0.35;
    } else if (zoneIdx === 1) {
      targets.forest = 0.08;
      targets.river = 0.45;
    } else if (zoneIdx === 2) {
      targets.river = 0.1;
      targets.coast = 0.55;
    } else if (zoneIdx === 3) {
      targets.coast = 0.25;
      targets.abyss = 0.05;
    } else if (zoneIdx === 4) {
      targets.abyss = 0.5;
    }

    if (synthGains.forest) synthGains.forest.gain.setTargetAtTime(targets.forest, t, 0.5);
    if (synthGains.river) synthGains.river.gain.setTargetAtTime(targets.river, t, 0.5);
    if (synthGains.coast) synthGains.coast.gain.setTargetAtTime(targets.coast, t, 0.5);
    if (synthGains.abyss) synthGains.abyss.gain.setTargetAtTime(targets.abyss, t, 0.5);
  }

  // Draw delicate micro-spectrometer waves in console pill
  function drawVisualizer() {
    if (!canvasCtx || !analyser || !audioActive) {
      if (canvasCtx && sensoryCanvas) {
        canvasCtx.clearRect(0, 0, sensoryCanvas.width, sensoryCanvas.height);
      }
      rafId = requestAnimationFrame(drawVisualizer);
      return;
    }

    analyser.getByteFrequencyData(dataArray);
    canvasCtx.clearRect(0, 0, sensoryCanvas.width, sensoryCanvas.height);

    const barWidth = 3;
    const gap = 2;
    let x = 6;
    
    // Select active accent color dynamically matching zones
    const activeColor = scroller.style.getPropertyValue('--zone-accent') || '#00ffff';

    canvasCtx.fillStyle = activeColor;
    for (let i = 0; i < analyser.frequencyBinCount; i++) {
      const h = (dataArray[i] / 255) * sensoryCanvas.height * 0.85;
      canvasCtx.fillRect(x, sensoryCanvas.height - h - 2, barWidth, h);
      x += barWidth + gap;
    }

    rafId = requestAnimationFrame(drawVisualizer);
  }

  // Trigger sound engine activation on click
  btnSensorySound?.addEventListener('click', () => {
    if (!audioActive) {
      audioActive = true;
      btnSensorySound.classList.add('engaged');
      if (sensoryLabel) sensoryLabel.innerText = "SOUNDSCAPE [ON]";
      
      if (!audioCtx) {
        initAudioEngine();
      } else if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
      
      morphSynthAudio(activeZoneIdx);
    } else {
      audioActive = false;
      btnSensorySound.classList.remove('engaged');
      if (sensoryLabel) sensoryLabel.innerText = "SOUNDSCAPE [OFF]";
      
      if (audioCtx) {
        audioCtx.suspend();
      }
    }
  });

  // Start visualizer draw loop
  drawVisualizer();

  // ═══════════════════════════════════════
  // LUXURY 3D CARD COLLAGE TILT PHYSICS
  // ═══════════════════════════════════════
  document.querySelectorAll('.collage-container').forEach(collage => {
    collage.addEventListener('mousemove', (e: MouseEvent) => {
      const r = (collage as HTMLElement).getBoundingClientRect();
      // Calculate cursor offset percentage from center of collage
      const xPct = (e.clientX - r.left) / r.width - 0.5;
      const yPct = (e.clientY - r.top) / r.height - 0.5;
      
      // Tilt primary and overlapping cards satisfying premium depth physics
      const primary = collage.querySelector('.card--primary') as HTMLElement;
      const secondary = collage.querySelector('.card--secondary') as HTMLElement;
      const tertiary = collage.querySelector('.card--tertiary') as HTMLElement;

      if (primary) {
        primary.style.transform = `perspective(800px) rotateY(${xPct * 25}deg) rotateX(${yPct * -25}deg) translateZ(0px)`;
      }
      if (secondary) {
        secondary.style.transform = `perspective(800px) rotateY(${xPct * 35}deg) rotateX(${yPct * -35}deg) translateZ(40px) translate(${xPct * 15}px, ${yPct * 15}px)`;
      }
      if (tertiary) {
        tertiary.style.transform = `perspective(800px) rotateY(${xPct * 45}deg) rotateX(${yPct * -45}deg) translateZ(80px) translate(${xPct * 30}px, ${yPct * 30}px)`;
      }
    });

    collage.addEventListener('mouseleave', () => {
      // Smoothly reset transformations on cursor escape
      collage.querySelectorAll('.collage-card').forEach(c => {
        (c as HTMLElement).style.transform = '';
      });
    });
  });

  // Cleanup listeners on Astro navigation transitions
  document.addEventListener('astro:before-swap', () => {
    if (rafId) cancelAnimationFrame(rafId);
    if (audioCtx) {
      audioCtx.close();
      audioCtx = null;
    }
    window.removeEventListener('scroll', onScroll);
  });
});
</script>

