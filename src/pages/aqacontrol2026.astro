  let currentCategory = 'homme';

  async function loadLiveDashboard() {
    try {
      const schRes = await fetch('/api/schedule');
      if (schRes.ok) {
        const contentType = schRes.headers.get('content-type') || '';
        if (!contentType.includes('text/html')) {
          currentSchedule = await schRes.json();
        }
      }

      Object.keys(currentSchedule).forEach(locKey => {
        const loc = currentSchedule[locKey];
        if (loc && loc.categories) {
          Object.keys(loc.categories).forEach(catKey => {
            const cat = loc.categories[catKey];
            if (cat && cat.coaches) {
              cat.coaches.forEach(coach => {
                if (coach.slots) {
                  coach.slots.forEach(slot => {
                    if (slot.type === 'complet') {
                      slot.type = slot.total <= 5 ? 'max5' : 'g10';
                    }
                  });
                }
              });
            }
          });
        }
      });
    } catch (e) {
      console.warn("Failed to load live scheduler data.");
    }

    initSelectors();
    renderPlanning();
    renderFormations();
    renderInfrastructures();
    initCountersInput();
