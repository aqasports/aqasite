  // ==================== DASHBOARD ====================
  function updateDashboardStats() {
    document.getElementById('dashInfraCount').textContent = currentInfrastructures.length;
    document.getElementById('dashFormationsCount').textContent = currentFormations.filter(f => f.active).length;

    let globalCapacity = 0;
    let globalTaken = 0;
    const locationStatsContainer = document.getElementById('dashLocationStats');
    const alertsContainer = document.getElementById('dashAlertsList');

    locationStatsContainer.innerHTML = '';
    alertsContainer.innerHTML = '';

    Object.keys(currentSchedule).forEach(locKey => {
      const loc = currentSchedule[locKey];
      let locCapacity = 0;
      let locTaken = 0;

      if (loc && loc.categories) {
        Object.keys(loc.categories).forEach(catKey => {
          const cat = loc.categories[catKey];
          if (cat && cat.coaches) {
            cat.coaches.forEach(coach => {
              if (coach.slots) {
                coach.slots.forEach(slot => {
                  const cap = parseInt(slot.total) || 0;
                  const taken = parseInt(slot.taken) || 0;
                  locCapacity += cap;
                  locTaken += taken;
                  globalCapacity += cap;
                  globalTaken += taken;

                  const occupancy = cap > 0 ? (taken / cap) * 100 : 0;
                  if (occupancy >= 100) {
                    const el = document.createElement('div');
                    el.className = 'dash-alert alert-danger';
                    el.innerHTML = `🚨 <strong>[Complet]</strong> ${loc.name || locKey} — Coach ${coach.name} (${slot.day} à ${slot.time}) · <strong>${taken}/${cap} places</strong>`;
                    alertsContainer.appendChild(el);
                  } else if (occupancy >= 85) {
                    const el = document.createElement('div');
                    el.className = 'dash-alert alert-warning';
                    el.innerHTML = `⚠️ <strong>[Presque Saturé]</strong> ${loc.name || locKey} — Coach ${coach.name} (${slot.day} à ${slot.time}) · <strong>${taken}/${cap} (${Math.round(occupancy)}%)</strong>`;
                    alertsContainer.appendChild(el);
                  } else if (taken === 0 && cap > 0) {
                    const el = document.createElement('div');
                    el.className = 'dash-alert alert-info';
                    el.innerHTML = `ℹ️ <strong>[Groupe Vide]</strong> ${loc.name || locKey} — Coach ${coach.name} (${slot.day} à ${slot.time}) · <strong>0/${cap} places libres</strong>`;
                    alertsContainer.appendChild(el);
                  }
                });
              }
            });
          }
        });
      }

      const locOccupancy = locCapacity > 0 ? Math.round((locTaken / locCapacity) * 100) : 0;
      const row = document.createElement('div');
      row.className = 'dash-location-row';
      row.innerHTML = `
        <div class="loc-row-header">
          <strong>📍 ${loc.name || locKey}</strong>
          <span>${locTaken}/${locCapacity} places (${locOccupancy}%)</span>
        </div>
        <div class="tel-bar-wrap">
          <div class="tel-bar" style="width: ${locOccupancy}%; background-color: ${locOccupancy > 85 ? '#ef4444' : '#00f2ff'}"></div>
        </div>
      `;
      locationStatsContainer.appendChild(row);
    });

    document.getElementById('dashCapacity').textContent = globalCapacity;
    document.getElementById('dashTaken').textContent = globalTaken;

    if (alertsContainer.children.length === 0) {
      alertsContainer.innerHTML = '<div class="no-alerts">✓ Aucun groupe en saturation ou alerte pour le moment.</div>';
    }
  }

