  // On page load: if token stored in session, verify it against the server with client-side fallback
  async function checkExistingSession() {
    if (!adminToken) return; // no token → show login
    let valid = false;
    let isServerError = false;

    try {
      const res = await fetch('/api/verify-token', {
        headers: authHeaders()
      });
      if (res.status === 404 || res.status === 405) {
        isServerError = true;
      } else {
        const contentType = res.headers.get('content-type') || '';
        if (contentType.includes('text/html')) {
          isServerError = true;
        } else {
          const data = await res.json();
          if (res.ok && data.success) {
            valid = true;
          }
        }
      }
    } catch (e) {
      isServerError = true;
    }

    if (isServerError) {
      if (/^[a-f0-9]{64}$/i.test(adminToken)) {
        valid = true;
      }
    }

    if (valid) {
      showAdminPanel();
    } else {
      sessionStorage.removeItem(SESSION_KEY);
      adminToken = '';
    }
  }

  checkExistingSession();

  // ==================== CORE DATA ====================
  let currentSchedule = JSON.parse(JSON.stringify(scheduleData));
  let currentFormations = JSON.parse(JSON.stringify(formationsData));
  let currentInfrastructures = JSON.parse(JSON.stringify(infrastructuresData));
  let currentCounters = JSON.parse(JSON.stringify(countersData));

