    document.getElementById('countAthletes').value = currentCounters.athletes || 500;
    document.getElementById('countCoaches').value = currentCounters.coaches || 8;
    document.getElementById('countPools').value = currentCounters.pools || 3;
    document.getElementById('countSatisfaction').value = currentCounters.satisfaction || 98;
  }

  document.getElementById('saveCountersBtn').addEventListener('click', async () => {
    const status = document.getElementById('saveCountersStatus');
    status.textContent = 'Sauvegarde...'; status.className = 'save-status';
    currentCounters.athletes = parseInt(document.getElementById('countAthletes').value) || 500;
    currentCounters.coaches = parseInt(document.getElementById('countCoaches').value) || 8;
    currentCounters.pools = parseInt(document.getElementById('countPools').value) || 3;
    currentCounters.satisfaction = parseInt(document.getElementById('countSatisfaction').value) || 98;
    try {
      const { ok, data } = await safeFetchJson('/api/save-counters', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ counters: currentCounters })
      });
      if (ok && data.success) { status.textContent = '✓ Compteurs sauvegardés !'; status.className = 'save-status success'; }
      else { status.textContent = '❌ ' + (data.message || data.error || 'Erreur'); status.className = 'save-status error'; }
    } catch(e) { status.textContent = '❌ Réseau: ' + e.message; status.className = 'save-status error'; }
  });

  // ==================== DEPLOY ====================
  document.getElementById('deployGitBtn').addEventListener('click', async () => {
    const statusEl = document.getElementById('deployStatus');
    const consoleLogs = document.getElementById('deployLogsConsole');
    statusEl.textContent = 'Déploiement en cours... 🚀';
    statusEl.className = 'deploy-status active';
    consoleLogs.textContent = '>>> Lancement de deploy-now.bat...\n>>> Connexion au serveur Git...\n';
    try {
      const { ok, data } = await safeFetchJson('/api/deploy', {
        method: 'POST',
        headers: authHeaders()
      });
      if (ok && data.success) {
        statusEl.textContent = '✓ Site Déployé avec succès !';
        statusEl.className = 'deploy-status success';
        consoleLogs.textContent += '\n[STDOUT]\n' + data.stdout;
      } else {
        statusEl.textContent = '❌ Échec de déploiement';
        statusEl.className = 'deploy-status error';
        consoleLogs.textContent += '\n[ERROR]\n' + (data.message || 'Erreur inconnue') + '\n' + (data.stderr || '');
      }
    } catch(e) {
      statusEl.textContent = '❌ Échec réseau: ' + e.message;
      statusEl.className = 'deploy-status error';
      consoleLogs.textContent += '\n[NET_ERROR]\n' + e.message;
    }
  });

  // ==================== SETTINGS TAB ====================

  // Load current config from server (slug display)
  async function loadSettingsConfig() {
    try {
      const { ok, data } = await safeFetchJson('/api/admin-config');
      if (ok) {
        const slug = data.loginSlug || 'aqacontrol2026';
        document.getElementById('currentSlugDisplay').textContent = slug;
        document.getElementById('urlSlugDisplay').textContent = slug;
        document.getElementById('urlOriginDisplay').textContent = window.location.origin + '/';
      }
    } catch(e) {
      document.getElementById('urlOriginDisplay').textContent = window.location.origin + '/';
    }
  }
  loadSettingsConfig();

  // Copy URL button
  document.getElementById('copyUrlBtn').addEventListener('click', () => {
    const url = document.getElementById('urlOriginDisplay').textContent + document.getElementById('urlSlugDisplay').textContent;
    navigator.clipboard.writeText(url).then(() => {
      const btn = document.getElementById('copyUrlBtn');
      btn.style.color = 'var(--color-success)';
      setTimeout(() => btn.style.color = '', 1500);
    });
  });

  // Password strength meter
  document.getElementById('newPassword').addEventListener('input', (e) => {
    const pwd = e.target.value;
    const strengthBox = document.getElementById('passwordStrength');
    const fill = document.getElementById('strengthFill');
    const label = document.getElementById('strengthLabel');
    if (!pwd) { strengthBox.style.display = 'none'; return; }
    strengthBox.style.display = 'flex';
    let score = 0;
    if (pwd.length >= 8) score++;
    if (pwd.length >= 12) score++;
    if (/[A-Z]/.test(pwd)) score++;
    if (/[0-9]/.test(pwd)) score++;
    if (/[^A-Za-z0-9]/.test(pwd)) score++;
    const levels = ['Très faible', 'Faible', 'Moyen', 'Fort', 'Très fort', 'Excellent'];
    const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e', '#10b981', '#00f2ff'];
    fill.style.width = ((score / 5) * 100) + '%';
    fill.style.background = colors[score] || colors[0];
    label.textContent = levels[score] || levels[0];
    label.style.color = colors[score] || colors[0];
  });

  // Password change handler
  document.getElementById('savePasswordBtn').addEventListener('click', async () => {
    const status = document.getElementById('savePasswordStatus');
    const currentPwd = document.getElementById('currentPassword').value;
    const newPwd = document.getElementById('newPassword').value;
    const confirmPwd = document.getElementById('confirmPassword').value;

    status.textContent = ''; status.className = 'save-status';

    if (!currentPwd || !newPwd || !confirmPwd) {
      status.textContent = '❌ Tous les champs sont requis.'; status.className = 'save-status error'; return;
    }
    if (newPwd.length < 8) {
      status.textContent = '❌ Minimum 8 caractères.'; status.className = 'save-status error'; return;
    }
    if (newPwd !== confirmPwd) {
      status.textContent = '❌ Les mots de passe ne correspondent pas.'; status.className = 'save-status error'; return;
    }

    // Verify current password
    const currentHash = await sha256(currentPwd);
    if (currentHash !== adminToken) {
      status.textContent = '❌ Mot de passe actuel incorrect.'; status.className = 'save-status error'; return;
    }

    status.textContent = 'Mise à jour...'; 
    const newHash = await sha256(newPwd);

    // Try to save to server
    try {
      const { ok, data } = await safeFetchJson('/api/save-admin-config', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ passwordHash: newHash })
      });
      if (ok && data.success) {
        status.textContent = '✓ Mot de passe mis à jour ! Déconnexion dans 3s...';
        status.className = 'save-status success';
      } else {
        status.textContent = '❌ Erreur serveur: ' + (data.message || data.error || 'erreur');
        status.className = 'save-status error';
      }
    } catch(e) {
      status.textContent = '❌ ' + e.message;
      status.className = 'save-status error';
    }

    // Auto logout after 3s so user re-authenticates with new password
    setTimeout(() => {
      sessionStorage.removeItem(SESSION_KEY);
      adminToken = newHash; // update in-memory token
      document.getElementById('adminPanel').style.display = 'none';
      document.getElementById('loginOverlay').style.display = 'flex';
      document.getElementById('currentPassword').value = '';
      document.getElementById('newPassword').value = '';
      document.getElementById('confirmPassword').value = '';
      document.getElementById('passwordStrength').style.display = 'none';
    }, 3000);
  });

  // URL slug change - live preview
  document.getElementById('newSlugInput').addEventListener('input', (e) => {
    const raw = e.target.value.toLowerCase().replace(/[^a-z0-9-]/g, '');
    e.target.value = raw;
    const preview = document.getElementById('slugPreviewBox');
    const previewUrl = document.getElementById('slugPreviewUrl');
    if (raw.length > 2) {
      preview.style.display = 'flex';
      previewUrl.textContent = window.location.origin + '/' + raw;
    } else {
      preview.style.display = 'none';
    }
  });

  // URL slug save handler
  document.getElementById('saveSlugBtn').addEventListener('click', async () => {
    const status = document.getElementById('saveSlugStatus');
    const slug = document.getElementById('newSlugInput').value.trim();

    status.textContent = ''; status.className = 'save-status';

    if (!slug || slug.length < 3) {
      status.textContent = '❌ URL trop courte (min 3 caractères).'; status.className = 'save-status error'; return;
    }
    if (!/^[a-z0-9-]+$/.test(slug)) {
      status.textContent = '❌ Lettres minuscules, chiffres et tirets uniquement.'; status.className = 'save-status error'; return;
    }

    status.textContent = 'Application en cours...';

    try {
      const { ok, data } = await safeFetchJson('/api/save-admin-config', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ loginSlug: slug })
      });
      if (ok && data.success) {
        document.getElementById('currentSlugDisplay').textContent = slug;
        document.getElementById('urlSlugDisplay').textContent = slug;
        status.textContent = '✓ URL mise à jour ! Accessible sur : ' + window.location.origin + '/' + slug;
        status.className = 'save-status success';
        document.getElementById('newSlugInput').value = '';
        document.getElementById('slugPreviewBox').style.display = 'none';
      } else {
        status.textContent = '❌ Erreur serveur: ' + (data.message || data.error || 'Serveur non disponible'); 
        status.className = 'save-status error';
      }
    } catch(e) {
      status.textContent = '❌ ' + e.message; 
      status.className = 'save-status error';
    }
  });

</script>


