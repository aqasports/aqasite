---
import BaseLayout from '../layouts/BaseLayout.astro';
import scheduleData from '../data/schedule.json';
import formationsData from '../data/formation.json';
import infrastructuresData from '../data/infrastructure.json';
import countersData from '../data/counters.json';
---

<BaseLayout
  title="AQA Control Center | Admin Portal v3.0"
  description="Administration centrale de l'académie AQA Sports."
  currentPage="/aqacontrol2026"
>

  <!-- ==================== LOGIN SCREEN OVERLAY ==================== -->
  <div id="loginOverlay" class="login-overlay">
    <div class="login-card">
      <div class="login-logo-wrap">
        <img src="https://i.ibb.co/08WDCFj/Turquoise-Modern-Warning-with-Rays-Instagram-Post.png" alt="AQA Logo" class="login-logo">
      </div>
      <h1 class="login-title">AQA Control Center</h1>
      <p class="login-sub">Accès réservé aux administrateurs AQA Sports</p>

      <div class="login-meme">
        <div class="tenor-gif-embed" data-postid="15088356" data-share-method="host" data-aspect-ratio="1.33333" data-width="100%">
          <a href="https://tenor.com/view/irrelevant-rust-playrust-egoism-who-are-you-gif-15088356">Irrelevant Rust GIF</a>
        </div>
        <script type="text/javascript" async src="https://tenor.com/embed.js"></script>
        <p class="meme-label">👁️ who are you</p>
      </div>

      <form id="loginForm" class="login-form" autocomplete="off">
        <div class="login-field">
          <label for="adminPassword">🔐 Mot de passe administrateur</label>
          <input type="password" id="adminPassword" class="login-input" placeholder="••••••••••••" autofocus>
        </div>
        <div id="loginError" class="login-error" style="display:none;">❌ Mot de passe incorrect. Réessayez.</div>
        <button type="submit" id="loginBtn" class="login-btn">
          <span id="loginBtnText">Accéder au panneau</span>
          <span id="loginBtnSpinner" style="display:none;">⏳ Vérification...</span>
        </button>
      </form>
    </div>
  </div>

  <!-- ==================== MAIN ADMIN PANEL ==================== -->
  <div id="adminPanel" class="admin-wrapper" style="display:none;">

    <!-- SIDEBAR -->
    <aside class="admin-sidebar">
      <div class="sidebar-header">
        <a href="/">
          <img src="https://i.ibb.co/08WDCFj/Turquoise-Modern-Warning-with-Rays-Instagram-Post.png" alt="AQA Logo" class="logo">
        </a>
        <div>
          <h2 class="sidebar-title">AQA Control Center</h2>
          <span class="version-badge">v3.0 Dynamic</span>
        </div>
      </div>

      <nav class="sidebar-nav">
        <button class="nav-tab-btn active" data-tab="dashboard">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1"></rect><rect x="14" y="3" width="7" height="5" rx="1"></rect><rect x="14" y="12" width="7" height="9" rx="1"></rect><rect x="3" y="16" width="7" height="5" rx="1"></rect></svg>
          Tableau de Bord
        </button>

        <button class="nav-tab-btn" data-tab="planning">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          Gestion Planning
        </button>

        <button class="nav-tab-btn" data-tab="formations">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path></svg>
          Gestion Formations
        </button>

        <button class="nav-tab-btn" data-tab="infrastructures">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          Infrastructures (Piscines)
        </button>

        <button class="nav-tab-btn" data-tab="counters">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
          Compteurs Accueil
        </button>

        <button class="nav-tab-btn" data-tab="settings">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
          Paramètres Connexion
        </button>
      </nav>

      <div class="sidebar-footer">
        <button id="deployGitBtn" class="btn btn-primary btn-deploy">🚀 Déployer sur GitHub</button>
        <div id="deployStatus" class="deploy-status">Système synchronisé</div>
        <button id="logoutBtn" class="btn btn-logout">🔒 Déconnexion</button>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="admin-main">

      <!-- DASHBOARD TAB -->
      <section id="tab-dashboard" class="admin-section active">
        <div class="section-title-bar">
          <h2>📊 Tableau de Bord & Statistiques</h2>
          <p class="section-desc">Aperçu global de l'occupation et de la capacité de l'académie en temps réel.</p>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon icon-blue">🏢</div>
            <div class="stat-info">
              <span class="stat-label">Infrastructures</span>
              <span class="stat-value" id="dashInfraCount">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-teal">🎓</div>
            <div class="stat-info">
              <span class="stat-label">Formations Actives</span>
              <span class="stat-value" id="dashFormationsCount">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-cyan">👥</div>
            <div class="stat-info">
              <span class="stat-label">Capacité Totale</span>
              <span class="stat-value" id="dashCapacity">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-purple">✓</div>
            <div class="stat-info">
              <span class="stat-label">Inscriptions</span>
              <span class="stat-value" id="dashTaken">0</span>
            </div>
          </div>
        </div>

        <div class="dashboard-details glass-panel">
          <h3>📊 Occupation par Infrastructure</h3>
          <div id="dashLocationStats" class="dash-location-stats"></div>
        </div>

        <div class="dashboard-details glass-panel" style="margin-top: 1.5rem;">
          <h3>⚠️ Alertes Capacité & Groupes Saturation</h3>
          <div id="dashAlertsList" class="dash-alerts-list"></div>
        </div>

        <div class="dashboard-details glass-panel" style="margin-top: 1.5rem;">
          <h3>💻 Console de Déploiement</h3>
          <pre id="deployLogsConsole" class="terminal-logs">Console en attente d'instruction...</pre>
        </div>
      </section>

      <!-- PLANNING TAB -->
      <section id="tab-planning" class="admin-section">
        <div class="section-title-bar">
          <h2>📅 Planificateur de Séances & Horaires</h2>
          <p class="section-desc">Gérez la capacité des coachs et des groupes par piscine partenaire.</p>
        </div>

        <div class="control-panel glass-panel">
          <div class="selectors">
            <div class="field-group">
              <label for="locationSelect">📍 Emplacement :</label>
              <select id="locationSelect" class="form-control"></select>
            </div>
            <div class="field-group">
              <label for="categorySelect">👥 Catégorie :</label>
              <select id="categorySelect" class="form-control"></select>
            </div>
          </div>
          <div class="action-buttons">
            <button id="addCoachBtn" class="btn btn-secondary btn-icon">➕ Ajouter un Coach</button>
          </div>
        </div>

        <div id="editorContainer" class="editor-container"></div>

        <div class="save-bar">
          <button id="savePlanningBtn" class="btn btn-primary">Enregistrer le Planning</button>
          <span id="savePlanningStatus" class="save-status"></span>
        </div>
      </section>

      <!-- FORMATIONS TAB -->
      <section id="tab-formations" class="admin-section">
        <div class="section-title-bar">
          <h2>🎓 Catalogue des Formations & Masterclasses</h2>
          <p class="section-desc">Ajoutez, modifiez ou activez des programmes de certification de l'académie.</p>
        </div>

        <div class="control-panel glass-panel">
          <button id="addFormationBtn" class="btn btn-secondary">➕ Créer une Formation</button>
        </div>

        <div id="formationsContainer" class="formations-editor-grid"></div>

        <div class="save-bar">
          <button id="saveFormationsBtn" class="btn btn-primary">Enregistrer les Formations</button>
          <span id="saveFormationsStatus" class="save-status"></span>
        </div>
      </section>

      <!-- INFRASTRUCTURES TAB -->
      <section id="tab-infrastructures" class="admin-section">
        <div class="section-title-bar">
          <h2>🏢 Administration des Infrastructures</h2>
          <p class="section-desc">Gérez les piscines partenaires et centres d'entraînement AQA.</p>
        </div>

        <div class="control-panel glass-panel">
          <button id="addInfrastructureBtn" class="btn btn-secondary">➕ Créer une Infrastructure</button>
        </div>

        <div id="infrastructuresContainer" class="infrastructures-editor-grid"></div>

        <div class="save-bar">
          <button id="saveInfrastructuresBtn" class="btn btn-primary">Enregistrer les Infrastructures</button>
          <span id="saveInfrastructuresStatus" class="save-status"></span>
        </div>
      </section>

      <!-- COUNTERS TAB -->
      <section id="tab-counters" class="admin-section">
        <div class="section-title-bar">
          <h2>🔟 Compteurs de Performance Accueil</h2>
          <p class="section-desc">Modifiez en temps réel les statistiques clés affichées sur la page d'accueil.</p>
        </div>

        <div class="counters-panel glass-panel">
          <div class="counters-editor-grid">
            <div class="counter-field-group">
              <label for="countAthletes">👥 Athlètes formés :</label>
              <input type="number" id="countAthletes" class="form-control" min="0">
            </div>
            <div class="counter-field-group">
              <label for="countCoaches">🏊 Coachs d'élite :</label>
              <input type="number" id="countCoaches" class="form-control" min="0">
            </div>
            <div class="counter-field-group">
              <label for="countPools">🏢 Infrastructures partenaires :</label>
              <input type="number" id="countPools" class="form-control" min="0">
            </div>
            <div class="counter-field-group">
              <label for="countSatisfaction">⭐ Satisfaction client (%) :</label>
              <input type="number" id="countSatisfaction" class="form-control" min="0" max="100">
            </div>
          </div>
        </div>

        <div class="save-bar">
          <button id="saveCountersBtn" class="btn btn-primary">Enregistrer les Compteurs</button>
          <span id="saveCountersStatus" class="save-status"></span>
        </div>
      </section>

      <!-- SETTINGS TAB -->
      <section id="tab-settings" class="admin-section">
        <div class="section-title-bar">
          <h2>⚙️ Paramètres de Connexion</h2>
          <p class="section-desc">Modifiez votre mot de passe et l'URL secrète d'accès au panneau d'administration.</p>
        </div>

        <!-- Current Settings Card -->
        <div class="glass-panel settings-info-card">
          <div class="settings-info-row">
            <div class="settings-info-item">
              <span class="settings-info-label">🔐 Mot de passe actuel</span>
              <span class="settings-info-value">••••••••••••</span>
            </div>
            <div class="settings-info-item">
              <span class="settings-info-label">🔗 URL d'accès actuelle</span>
              <span class="settings-info-value" id="currentSlugDisplay">aqacontrol2026</span>
            </div>
          </div>
          <div class="settings-url-preview">
            <span class="url-prefix" id="urlOriginDisplay"></span><span class="url-slug" id="urlSlugDisplay">aqacontrol2026</span>
            <button class="btn-copy" id="copyUrlBtn" title="Copier l'URL">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          </div>
        </div>

        <div class="settings-grid">

          <!-- Change Password -->
          <div class="glass-panel settings-panel">
            <div class="settings-panel-header">
              <span class="settings-panel-icon">🔑</span>
              <div>
                <h3>Changer le Mot de Passe</h3>
                <p>Votre nouveau mot de passe sera actif immédiatement.</p>
              </div>
            </div>

            <div class="settings-form">
              <div class="field-group">
                <label for="currentPassword">Mot de passe actuel :</label>
                <input type="password" id="currentPassword" class="form-control" placeholder="••••••••">
              </div>
              <div class="field-group">
                <label for="newPassword">Nouveau mot de passe :</label>
                <input type="password" id="newPassword" class="form-control" placeholder="Minimum 8 caractères">
              </div>
              <div class="field-group">
                <label for="confirmPassword">Confirmer le nouveau mot de passe :</label>
                <input type="password" id="confirmPassword" class="form-control" placeholder="Répétez le mot de passe">
              </div>

              <div class="password-strength" id="passwordStrength" style="display:none;">
                <div class="strength-bar"><div id="strengthFill" class="strength-fill"></div></div>
                <span id="strengthLabel">Faible</span>
              </div>

              <div class="save-bar" style="border:none; padding:0; margin-top:1.5rem;">
                <button id="savePasswordBtn" class="btn btn-primary">🔑 Mettre à jour le mot de passe</button>
                <span id="savePasswordStatus" class="save-status"></span>
              </div>
            </div>
          </div>

          <!-- Change Login URL -->
          <div class="glass-panel settings-panel">
            <div class="settings-panel-header">
              <span class="settings-panel-icon">🔗</span>
              <div>
                <h3>Changer l'URL de Connexion</h3>
                <p>L'ancienne URL ne sera plus accessible pour des raisons de sécurité. Seule la nouvelle URL secrète vous permettra de vous connecter.</p>
              </div>
            </div>

            <div class="settings-form">
              <div class="field-group">
                <label for="newSlugInput">Nouvelle URL secrète :</label>
                <div class="slug-input-wrap">
                  <span class="slug-prefix">aqasports.com/</span>
                  <input type="text" id="newSlugInput" class="form-control slug-input" placeholder="mon-url-secrete" maxlength="60">
                </div>
                <small class="slug-hint">Lettres, chiffres et tirets uniquement. Exemple : <code>monpanneauaqa</code></small>
              </div>

              <div id="slugPreviewBox" class="slug-preview" style="display:none;">
                <span class="slug-preview-label">Aperçu :</span>
                <span id="slugPreviewUrl" class="slug-preview-url"></span>
              </div>

              <div class="save-bar" style="border:none; padding:0; margin-top:1.5rem;">
                <button id="saveSlugBtn" class="btn btn-primary">🔗 Appliquer la nouvelle URL</button>
                <span id="saveSlugStatus" class="save-status"></span>
              </div>
            </div>
          </div>

        </div>

        <!-- Danger Zone -->
        <div class="glass-panel danger-zone">
          <h3>⚠️ Zone Sensible</h3>
          <p>Après avoir changé le mot de passe ou l'URL, vous serez déconnecté automatiquement. Notez vos nouvelles informations avant de sauvegarder.</p>
        </div>

      </section>

    </main>
  </div>

</BaseLayout>

<!-- BIND Astro Data into JS environment variables -->
<script is:inline define:vars={{ scheduleData, formationsData, infrastructuresData, countersData }}>

  // ==================== AUTH LAYER ====================
  const SESSION_KEY = 'aqa_admin_token';
  let adminToken = sessionStorage.getItem(SESSION_KEY) || '';

  function authHeaders() {
    return {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${adminToken}`
    };
  }

  async function safeFetchJson(url, options = {}) {
    const res = await fetch(url, options);
    const contentType = res.headers.get('content-type') || '';
    if (contentType.includes('text/html')) {
      throw new Error("L'environnement actuel est en lecture seule (site statique public). Veuillez exécuter l'application localement à l'adresse http://localhost:3000/aqacontrol2026 pour modifier les données, puis cliquez sur 'Déployer sur GitHub' pour publier vos modifications.");
    }
    let data;
    try {
      data = await res.json();
    } catch (e) {
      throw new Error("Réponse du serveur invalide (impossible de décoder le JSON).");
    }
    return { ok: res.ok, status: res.status, data };
  }

  // Pure JavaScript SHA-256 fallback for insecure contexts (HTTP on non-localhost)
  function sha256_pure(ascii) {
    function rightRotate(value, amount) {
      return (value >>> amount) | (value << (32 - amount));
    }
    var mathPow = Math.pow;
    var maxWord = mathPow(2, 32);
    var lengthProperty = 'length';
    var i, j;
    var result = '';
    var words = [];
    var asciiLength = ascii[lengthProperty];
    var hash = sha256_pure.h = sha256_pure.h || [];
    var k = sha256_pure.k = sha256_pure.k || [];
    var primeCounter = k[lengthProperty];
    var isComposite = {};
    for (var candidate = 2; primeCounter < 64; candidate++) {
      if (!isComposite[candidate]) {
        for (i = 0; i < 313; i += candidate) {
          isComposite[i] = 1;
        }
        hash[primeCounter] = (mathPow(candidate, .5) * maxWord) | 0;
        k[primeCounter++] = (mathPow(candidate, 1 / 3) * maxWord) | 0;
      }
    }
    ascii += '\x80';
    while (ascii[lengthProperty] % 64 - 56) ascii += '\x00';
    for (i = 0; i < ascii[lengthProperty]; i++) {
      j = ascii.charCodeAt(i);
      if (j >> 8) return ''; // ASCII only
      words[i >> 2] |= j << (24 - (i % 4) * 8);
    }
    words[words[lengthProperty]] = ((asciiLength * 8) / maxWord) | 0;
    words[words[lengthProperty]] = (asciiLength * 8);
    for (j = 0; j < words[lengthProperty]; ) {
      var w = words.slice(j, j += 16);
      var oldHash = hash.slice(0);
      for (i = 0; i < 64; i++) {
        var wItem = w[i];
        if (i >= 16) {
          w[i] = wItem = (
            (rightRotate(w[i - 2], 17) ^ rightRotate(w[i - 2], 19) ^ (w[i - 2] >>> 10)) +
            w[i - 7] +
            (rightRotate(w[i - 15], 7) ^ rightRotate(w[i - 15], 18) ^ (w[i - 15] >>> 3)) +
            w[i - 16]
          ) | 0;
        }
        var temp1 = (
          hash[7] +
          (rightRotate(hash[4], 6) ^ rightRotate(hash[4], 11) ^ rightRotate(hash[4], 25)) +
          ((hash[4] & hash[5]) ^ (~hash[4] & hash[6])) +
          k[i] +
          wItem
        );
        var temp2 = (
          (rightRotate(hash[0], 2) ^ rightRotate(hash[0], 13) ^ rightRotate(hash[0], 22)) +
          ((hash[0] & hash[1]) ^ (hash[0] & hash[2]) ^ (hash[1] & hash[2]))
        );
        hash = [(temp1 + temp2) | 0].concat(hash);
        hash[4] = (hash[4] + temp1) | 0;
        hash.pop();
      }
      for (i = 0; i < 8; i++) {
        hash[i] = (hash[i] + oldHash[i]) | 0;
      }
    }
    for (i = 0; i < 8; i++) {
      var byteVal = hash[i] >>> 0;
      result += (byteVal.toString(16).padStart(8, '0'));
    }
    return result;
  }

  // Hash a string with SHA-256 using the browser's built-in Web Crypto API with pure JS fallback
  async function sha256(str) {
    if (window.crypto && window.crypto.subtle) {
      try {
        const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
        return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
      } catch (e) {
        console.warn("Web Crypto API failed, falling back to pure JS", e);
      }
    }
    return sha256_pure(str);
  }

  // LOGIN FORM HANDLER — server-side verified auth with client-side fallback
  document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const pwd = document.getElementById('adminPassword').value;
    const btn = document.getElementById('loginBtn');
    const errDiv = document.getElementById('loginError');
    const btnText = document.getElementById('loginBtnText');
    const btnSpinner = document.getElementById('loginBtnSpinner');

    errDiv.style.display = 'none';
    btnText.style.display = 'none';
    btnSpinner.style.display = 'inline';
    btn.disabled = true;

    const KNOWN_HASH = '65cdacaf34486fbb5c32641665f6f5a1a6985aa89dbe66286f85bbdd4be34fd5';
    let token = '';
    let authenticated = false;
    let isServerError = false;

    try {
      const res = await fetch('/api/admin-auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwd })
      });

      if (res.status === 404 || res.status === 405) {
        isServerError = true;
      } else {
        const contentType = res.headers.get('content-type') || '';
        if (contentType.includes('text/html')) {
          isServerError = true;
        } else {
          const data = await res.json();
          if (res.ok && data.success) {
            token = data.token;
            authenticated = true;
          } else {
            errDiv.style.display = 'block';
            errDiv.textContent = '❌ ' + (data.error || 'Mot de passe incorrect. Réessayez.');
            document.getElementById('adminPassword').value = '';
            document.getElementById('adminPassword').focus();
            btnText.style.display = 'inline';
            btnSpinner.style.display = 'none';
            btn.disabled = false;
            return;
          }
        }
      }
    } catch(err) {
      isServerError = true;
    }

    if (isServerError) {
      try {
        const inputHash = await sha256(pwd);
        if (inputHash === KNOWN_HASH) {
          token = inputHash;
          authenticated = true;
        } else {
          errDiv.style.display = 'block';
          errDiv.textContent = '❌ Mot de passe incorrect. Réessayez.';
          document.getElementById('adminPassword').value = '';
          document.getElementById('adminPassword').focus();
        }
      } catch(err2) {
        errDiv.style.display = 'block';
        errDiv.textContent = '❌ Erreur de chiffrement locale.';
      }
    }

    if (authenticated) {
      adminToken = token;
      sessionStorage.setItem(SESSION_KEY, adminToken);
      showAdminPanel();
    }

    btnText.style.display = 'inline';
    btnSpinner.style.display = 'none';
    btn.disabled = false;
  });

