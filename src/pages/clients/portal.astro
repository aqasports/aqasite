              <button class="portal-btn-secondary wiz-btn-prev" id="wizPrevBtn" style="display: none;">{localT.wizPrev}</button>
              <button class="portal-btn-primary wiz-btn-next" id="wizNextBtn">{localT.wizNext}</button>
              <button class="portal-btn-primary wiz-btn-submit" id="wizSubmitBtn" style="display: none;">{localT.wizSubmit}</button>
            </div>

          </div>

        </div>

      </div>

    </div>

  </main>

  <NotificationToast />
  <Footer lang={lang} />
</BaseLayout>

<script is:inline define:vars={{ lang, badgeDefinitions, localT }}>
  document.addEventListener('astro:page-load', () => {
    
    // Redirection helper if token is missing
    const redirectToLogin = () => {
      if (lang === 'fr') window.location.href = '/clients';
      else window.location.href = `/${lang}/clients`;
    };

    const token = localStorage.getItem('aqa_member_token');
    if (!token) {
      redirectToLogin();
      return;
    }

    const loader = document.getElementById('portalLoader');
    const content = document.getElementById('portalContent');
    const statePending = document.getElementById('statePending');
    const stateMember = document.getElementById('stateMember');
    const stateNonMember = document.getElementById('stateNonMember');
    const logoutBtn = document.getElementById('logoutBtn');

    // Handle logout
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => {
        localStorage.removeItem('aqa_member_token');
        localStorage.removeItem('aqa_member_info');
        redirectToLogin();
      });
    }

    // =====================================================
    // UNIFIED TAB SWITCHER — sidebar + mobile bottom nav
    // =====================================================
    const switchTab = (targetPanelId) => {
      // Deactivate all panels
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      // Activate target
      const target = document.getElementById(targetPanelId);
      if (target) {
        target.classList.add('active');
        // Animate skill bars when tech panel opens
        if (targetPanelId === 'tabTechPanel') animateSkillBars();
      }
    };

    const initTabs = () => {
      // Sidebar nav buttons
      document.querySelectorAll('.snav-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.snav-btn').forEach(b => b.classList.remove('active'));
          document.querySelectorAll('.mbn-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          // Sync mobile bottom nav
          const tabId = btn.dataset.tab;
          document.querySelectorAll('.mbn-btn').forEach(b => {
            if (b.dataset.tab === tabId) b.classList.add('active');
          });
          switchTab(tabId);
        });
      });

      // Mobile bottom nav buttons
      document.querySelectorAll('.mbn-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.mbn-btn').forEach(b => b.classList.remove('active'));
          document.querySelectorAll('.snav-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const tabId = btn.dataset.tab;
          document.querySelectorAll('.snav-btn').forEach(b => {
            if (b.dataset.tab === tabId) b.classList.add('active');
          });
          switchTab(tabId);
        });
      });

      // Legacy non-member tab-btn (activities / wizard)
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const nav = btn.closest('.tab-navigation');
          if (nav) nav.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          switchTab(btn.dataset.tab);
        });
      });
    };
    initTabs();

    // Skill bar animation (fires when tech tab opens)
    function animateSkillBars() {
      ['Respiration', 'Kick', 'Bras', 'Endurance'].forEach(key => {
        const fill = document.getElementById(`tech${key}Fill`);
        if (fill) {
          const targetW = fill.style.width;
          fill.style.width = '0%';
          setTimeout(() => { fill.style.width = targetW; }, 80);
        }
      });
      // Also animate the presence ring
      animatePresenceRing();
    }

    function animatePresenceRing() {
      const ring = document.getElementById('presenceRing');
      if (!ring) return;
      const circ = 2 * Math.PI * 50; // r=50
      const target = parseFloat(ring.dataset.target || 0);
      const offset = circ - (target / 100) * circ;
      ring.style.transition = 'stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1)';
      ring.style.strokeDashoffset = offset;
    }


    // Lightbox modal functionality
    const setupLightbox = () => {
      const lightbox = document.getElementById('galleryLightbox');
      const lightboxImg = document.getElementById('lightboxImg');
      const closeBtn = document.getElementById('closeLightboxBtn');

      if (!lightbox || !lightboxImg || !closeBtn) return;

      closeBtn.addEventListener('click', () => {
        lightbox.style.display = 'none';
      });

      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) {
          lightbox.style.display = 'none';
        }
      });
    };
    setupLightbox();

    function getGroupsFromSubscription(sub) {
      if (!sub) return [];
      if (Array.isArray(sub.groups) && sub.groups.length > 0) {
        return sub.groups;
      }
      if (sub.poolKey && sub.coachName && sub.slotDay && sub.slotTime) {
        return [{
          poolKey: sub.poolKey,
          coachName: sub.coachName,
          slotDay: sub.slotDay,
          slotTime: sub.slotTime
        }];
      }
      return [];
    }

    function renderInteractiveSlots(containerId, noticeId, scheduleData, poolKey, category, tier, currentSelectedGroups = [], onSelectionChange = null) {
      const container = document.getElementById(containerId);
      const noticeEl = document.getElementById(noticeId);
      if (!container) return;

      container.innerHTML = '';
      
      const pool = scheduleData[poolKey];
      if (!pool || !pool.categories || !pool.categories[category]) {
        container.innerHTML = '<div style="grid-column: 1/-1; text-align: center; color: var(--text-secondary); padding: 2rem 0;">Aucun créneau disponible pour ces choix.</div>';
        if (noticeEl) noticeEl.textContent = '';
        return;
      }

      const categoryObj = pool.categories[category];
      const maxLimit = { 'Starter': 1, 'Silver': 2, 'Gold': 3, 'Diamond': 4, 'Emerald': 5 }[tier] || 1;
      
      if (noticeEl) {
        noticeEl.textContent = `Limite pour la formule ${tier} : maximum ${maxLimit} créneau(x) d'entraînement par semaine.`;
      }

      let selectedGroups = [...currentSelectedGroups];

      const updateCardSelectionStates = () => {
        container.querySelectorAll('.schedule-select-card').forEach(card => {
          const gCoach = card.dataset.coach;
          const gDay = card.dataset.day;
          const gTime = card.dataset.time;
          const isSel = selectedGroups.some(g => g.coachName === gCoach && g.slotDay === gDay && g.slotTime === gTime);
          if (isSel) {
            card.classList.add('selected');
            if (!card.querySelector('.checkmark-icon')) {
              const check = document.createElement('div');
              check.className = 'checkmark-icon';
              check.innerHTML = '✓';
              card.appendChild(check);
            }
          } else {
            card.classList.remove('selected');
            const check = card.querySelector('.checkmark-icon');
            if (check) check.remove();
          }
        });
      };

      categoryObj.coaches.forEach(coach => {
        if (!coach.slots) return;
        coach.slots.forEach(slot => {
          const remaining = slot.total - slot.taken;
          const isFull = remaining <= 0;
          
          const card = document.createElement('div');
          card.className = `schedule-select-card glass-panel ${isFull ? 'disabled' : ''}`;
          card.dataset.coach = coach.name;
          card.dataset.day = slot.day;
          card.dataset.time = slot.time;
          
          card.innerHTML = `
            <div class="day-time">
              <span class="day">${slot.day}</span>
              <span class="time">${slot.time}</span>
            </div>
            <div class="coach-name" style="font-size:0.95rem; font-weight:700; color:var(--text-primary); margin-bottom:0.4rem;">${coach.name}</div>
            <div class="capacity-status" style="font-size:0.8rem; color:${isFull ? '#ef4444' : 'var(--text-secondary)'};">
              ${isFull ? 'Complet' : `${remaining} places restantes`}
            </div>
          `;
          
          card.addEventListener('click', () => {
            if (isFull) return;
            
            const gCoach = card.dataset.coach;
            const gDay = card.dataset.day;
            const gTime = card.dataset.time;
            
            const existingIdx = selectedGroups.findIndex(g => g.coachName === gCoach && g.slotDay === gDay && g.slotTime === gTime);
            
            if (existingIdx !== -1) {
              selectedGroups.splice(existingIdx, 1);
            } else {
              if (selectedGroups.length >= maxLimit) {
                window.showToast(`Votre formule (${tier}) ne permet de choisir que maximum ${maxLimit} créneau(x).`, "info");
                return;
              }
              selectedGroups.push({
                poolKey: poolKey,
                coachName: gCoach,
                slotDay: gDay,
                slotTime: gTime
              });
            }
            updateCardSelectionStates();
            if (onSelectionChange) {
              onSelectionChange(selectedGroups);
            }
          });
          
          container.appendChild(card);
        });
      });

      updateCardSelectionStates();
    }

    // Fetch member profile
    let _redirecting = false; // guard against double-redirect
    async function fetchProfile() {
      try {
        const response = await fetch('/api/member/profile', {
          method: 'GET',
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });

        // Any auth failure → clear token and leave
        if (response.status === 401 || response.status === 403) {
          localStorage.removeItem('aqa_member_token');
          localStorage.removeItem('aqa_member_info');
          _redirecting = true;
          redirectToLogin();
          return;
        }

        const data = await response.json();
        if (data.success) {
          renderDashboard(data.profile);
        } else {
          // API returned success:false — token is likely invalid/expired
          localStorage.removeItem('aqa_member_token');
          localStorage.removeItem('aqa_member_info');
          _redirecting = true;
          redirectToLogin();
        }
      } catch (e) {
        console.error("Failed to load user profile:", e);
        // Network error — do NOT remove the token (could be transient)
        // Show an error state instead of looping
        _redirecting = true;
        if (loader) loader.style.display = 'none';
        if (content) {
          content.style.display = 'block';
          const errDiv = document.createElement('div');
          errDiv.style.cssText = 'text-align:center;padding:4rem 2rem;color:rgba(255,255,255,0.5);';
          errDiv.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="48" height="48" style="margin:0 auto 1rem;display:block;color:#ef4444"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><p style="font-size:1rem;color:#fff;font-weight:700;margin-bottom:0.5rem">Connexion impossible</p><p style="font-size:0.85rem">Veuillez vérifier votre connexion et <a href="/clients/portal" style="color:#00f2ff">réessayer</a>.</p>';
          content.appendChild(errDiv);
        }
      } finally {
        if (!_redirecting) {
          if (loader) {
            loader.classList.add('fade-out');
            setTimeout(() => { loader.style.display = 'none'; }, 400);
          }
          if (content) content.style.display = 'block';
        }
      }
    }


    // ─────────────────────────────────────────────────
    // PARTICLE CANVAS — Hero Banner Background
    // ─────────────────────────────────────────────────
    function initParticleCanvas() {
      const canvas = document.getElementById('heroParticleCanvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let animId;

      const resize = () => {
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
      };
      resize();
      window.addEventListener('resize', resize);

      const particles = Array.from({ length: 55 }, () => ({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        r: Math.random() * 2.5 + 0.5,
        dx: (Math.random() - 0.5) * 0.4,
        dy: (Math.random() - 0.5) * 0.4,
        opacity: Math.random() * 0.5 + 0.1
      }));

      const draw = () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => {
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(0, 242, 255, ${p.opacity})`;
          ctx.shadowColor = '#00f2ff';
          ctx.shadowBlur = 6;
          ctx.fill();
          p.x += p.dx;
          p.y += p.dy;
          if (p.x < 0 || p.x > canvas.width) p.dx *= -1;
          if (p.y < 0 || p.y > canvas.height) p.dy *= -1;
        });
        animId = requestAnimationFrame(draw);
      };
      draw();
    }

    fetchProfile();


    // Main Render logic
    function renderDashboard(profile) {
      if (profile.status === 'pending') {
        statePending.style.display = 'block';
        return;
      }

      if (!profile.isAqaMember) {
        stateNonMember.style.display = 'block';
        setupWizard(profile);
        return;
      }

      // Default Active Member Dashboard
      stateMember.style.display = 'block';

      // ── HERO & SIDEBAR POPULATION ──────────────────────────────────
      const tier = profile.membershipTier || 'Starter';
      const xp = profile.xp || 0;
      const initials = (profile.fullName || 'AQ')
        .split(' ').map(n => n[0]).slice(0, 2).join('').toUpperCase();

      // Name
      document.getElementById('memberName').textContent = profile.fullName || 'Athlete';

      // XP display + level bar
      document.getElementById('memberXP').textContent = xp;
      const xpEl = document.getElementById('heroXpChip');
      if (xpEl) { let c = 0; const t = xp; const s = setInterval(() => { c = Math.min(c + Math.ceil(t/50), t); xpEl.textContent = c; if(c>=t) clearInterval(s); }, 16); }

      // XP level label & bar fill
      const levels = [{name:'Rookie',min:0},{name:'Novice',min:100},{name:'Confirmé',min:300},{name:'Avancé',min:600},{name:'Expert',min:1000},{name:'Elite',min:1500},{name:'Champion',min:2500}];
      let lvl = levels[0], nextLvl = levels[1];
      for (let i = levels.length-1; i >= 0; i--) { if (xp >= levels[i].min) { lvl = levels[i]; nextLvl = levels[i+1] || levels[i]; break; } }
      const xpPct = nextLvl.min > lvl.min ? Math.min(100, Math.round(((xp - lvl.min) / (nextLvl.min - lvl.min)) * 100)) : 100;
      const heroXpLabel = document.getElementById('heroXpLabel');
      const heroXpFill = document.getElementById('heroXpFill');
      if (heroXpLabel) heroXpLabel.textContent = lvl.name;
      if (heroXpFill) setTimeout(() => { heroXpFill.style.width = xpPct + '%'; }, 300);

      // Tier chip
      const heroTierChip = document.getElementById('heroTierChip');
      if (heroTierChip) { heroTierChip.textContent = tier; heroTierChip.className = `hero-tier-chip tier-${tier.toLowerCase()}`; }

      // Sidebar tier badge + name
      const sidebarName = document.getElementById('sidebarMemberName');
      const sidebarTier = document.getElementById('sidebarTierBadge');
      if (sidebarName) sidebarName.textContent = profile.fullName || '—';
      if (sidebarTier) { sidebarTier.textContent = tier; sidebarTier.className = `sidebar-tier-badge tier-${tier.toLowerCase()}`; }

      // Pool chip
      const poolKey = profile.subscription?.poolKey;
      const poolLabel = poolKey === 'reghaia' ? 'Reghaia' : poolKey === 'cheraga' ? 'Cheraga' : '—';
      const heroPoolLabel = document.getElementById('heroPoolLabel');
      if (heroPoolLabel) heroPoolLabel.textContent = poolLabel;

      // Sessions stat chip
      const sessions = (profile.presence || []).filter(p => p.present).length;
      const heroSess = document.getElementById('heroSessionCount');
      if (heroSess) { let c=0; const s=setInterval(()=>{ c=Math.min(c+1,sessions); heroSess.textContent=c; if(c>=sessions) clearInterval(s); },30); }

      // Streak stat chip
      const presence = [...(profile.presence || [])].reverse();
      let streak = 0;
      for (const s of presence) { if (s.present) streak++; else break; }
      const heroStreak = document.getElementById('heroStreak');
      if (heroStreak) heroStreak.textContent = streak;

      // Avatar — profile form, hero, sidebar all in sync
      const setAllAvatars = (src) => {
        ['profileAvatarImg','heroAvatarImg','sidebarAvatarImg'].forEach(id => {
          const el = document.getElementById(id); if(el) { el.src = src; el.style.display = 'block'; }
        });
        ['profileAvatarLetters','heroAvatarLetters','sidebarAvatarLetters'].forEach(id => {
          const el = document.getElementById(id); if(el) el.style.display = 'none';
        });
      };
      const setAllInitials = (text) => {
        ['profileAvatarImg','heroAvatarImg','sidebarAvatarImg'].forEach(id => {
          const el = document.getElementById(id); if(el) el.style.display = 'none';
        });
        ['profileAvatarLetters','heroAvatarLetters','sidebarAvatarLetters'].forEach(id => {
          const el = document.getElementById(id); if(el) { el.textContent = text; el.style.display = 'flex'; }
        });
      };
      if (profile.profilePhotoUrl) setAllAvatars(profile.profilePhotoUrl);
      else setAllInitials(initials);

      // XP progress ring on hero
      const heroXpRing = document.getElementById('heroXpRing');
      if (heroXpRing) {
        const circ = 2 * Math.PI * 45; // r=45
        heroXpRing.style.strokeDasharray = circ;
        heroXpRing.style.strokeDashoffset = circ;
        setTimeout(() => { heroXpRing.style.strokeDashoffset = circ - (xpPct / 100) * circ; }, 400);
      }

      // Sidebar logout button (new sidebar has its own button)
      document.getElementById('logoutBtnSidebar')?.addEventListener('click', () => {
        localStorage.removeItem('aqa_member_token');
        localStorage.removeItem('aqa_member_info');
        window.location.href = '/clients';
      });


      // Start particle canvas
      initParticleCanvas();



      // Render Membership Card with Holo gradients
      const card = document.getElementById('memberCard');
      // tier already declared in hero block above
      card.className = `virtual-card card-tier-${tier.toLowerCase()}`;

      
      // Setup dynamic 3D tilt and reflection effect
      if (card && !card._tiltBound) {
        card._tiltBound = true;
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = ((centerY - y) / centerY) * 15; // Max 15 degrees tilt
          const rotateY = ((x - centerX) / centerX) * 15;
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
          
          const percentX = (x / rect.width) * 100;
          const percentY = (y / rect.height) * 100;
          card.style.setProperty('--shine-x', `${percentX}%`);
          card.style.setProperty('--shine-y', `${percentY}%`);
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
        });
      }
      document.getElementById('cardTier').textContent = tier.toUpperCase();
      document.getElementById('cardId').textContent = `ID: AQA-${profile.id.slice(0,6).toUpperCase()}`;
      document.getElementById('cardHolder').textContent = profile.fullName;
      
      const expiryDate = profile.subscription?.endDate || '-';
      document.getElementById('cardExpiry').textContent = expiryDate;

      // QR Code pointing to public stats page
      const statsUrl = window.location.origin + `/clients/stats?id=${profile.id}`;
      document.getElementById('cardQrCode').src = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(statsUrl)}`;

      // Subscription Widget
      document.getElementById('subTierVal').textContent = tier;
      document.getElementById('subPoolVal').textContent = profile.subscription?.poolKey === 'reghaia' ? 'Piscine Reghaia' : (profile.subscription?.poolKey === 'cheraga' ? 'Piscine Cheraga' : '-');
      const activeGroups = getGroupsFromSubscription(profile.subscription);
      if (activeGroups.length > 0) {
        document.getElementById('subCoachVal').textContent = [...new Set(activeGroups.map(g => g.coachName))].join(', ');
        document.getElementById('subSlotVal').innerHTML = activeGroups.map(g => `<div style="margin-bottom:0.25rem;">${g.slotDay} - ${g.slotTime} (${g.coachName})</div>`).join('');
      } else {
        document.getElementById('subCoachVal').textContent = profile.subscription?.coachName || '-';
        document.getElementById('subSlotVal').textContent = profile.subscription?.slotDay && profile.subscription?.slotTime ? `${profile.subscription.slotDay} - ${profile.subscription.slotTime}` : '-';
      }
      document.getElementById('subExpiryVal').textContent = expiryDate;

      // Populate Personal Info form fields
      document.getElementById('editFullName').value = profile.fullName || '';
      document.getElementById('editPhone').value = profile.phone || '';
      document.getElementById('editGender').value = profile.gender || 'homme';
      document.getElementById('editBirthDate').value = profile.birthDate || '';

      // Populate avatar pic or initials
      const avatarImg = document.getElementById('profileAvatarImg');
      const avatarLetters = document.getElementById('profileAvatarLetters');
      if (profile.profilePhotoUrl) {
        avatarImg.src = profile.profilePhotoUrl;
        avatarImg.style.display = 'block';
        avatarLetters.style.display = 'none';
      } else {
        avatarImg.style.display = 'none';
        avatarLetters.style.display = 'flex';
        avatarLetters.textContent = (profile.fullName || 'AQA')
          .split(' ')
          .map(n => n[0])
          .slice(0, 3)
          .join('')
          .toUpperCase();
      }


      // =============================================
      // PHASE 4: Premium Inline Form Validation Utils
      // =============================================
      const SVG_CHECK = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
      const SVG_X = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>`;

      /** Wraps a .form-group with validation wrappers if not already done */
      function wrapFormGroup(input, label, hintText = '') {
        const existingWrap = input.closest('.form-field-wrap');
        if (existingWrap) return existingWrap;
        
        const group = input.closest('.form-group') || input.parentElement;
        group.classList.add('form-field-wrap');
        
        // Wrap input in an input-row div for icon positioning
        const row = document.createElement('div');
        row.className = 'form-input-row';
        input.parentNode.insertBefore(row, input);
        row.appendChild(input);
        
        // Add icon span
        const iconSpan = document.createElement('span');
        iconSpan.className = 'field-icon';
        row.appendChild(iconSpan);
        
        // Add hint message span
        const hint = document.createElement('span');
        hint.className = 'field-hint';
        hint.textContent = hintText;
        row.after(hint);
        
        return group;
      }

      function setFieldState(group, state, message = '') {
        if (!group) return;
        group.classList.remove('has-error', 'has-success', 'shaking');
        const iconSpan = group.querySelector('.field-icon');
        const hintSpan = group.querySelector('.field-hint');
        if (iconSpan) { iconSpan.className = 'field-icon'; iconSpan.innerHTML = ''; }
        if (hintSpan) { hintSpan.className = 'field-hint'; hintSpan.textContent = ''; }
        
        if (state === 'error') {
          group.classList.add('has-error');
          // Trigger shake then remove class
          requestAnimationFrame(() => {
            group.classList.add('shaking');
            setTimeout(() => group.classList.remove('shaking'), 450);
          });
          if (iconSpan) { iconSpan.innerHTML = SVG_X; iconSpan.classList.add('icon-error'); }
          if (hintSpan) { hintSpan.classList.add('error'); hintSpan.textContent = message; }
        } else if (state === 'success') {
          group.classList.add('has-success');
          if (iconSpan) { iconSpan.innerHTML = SVG_CHECK; iconSpan.classList.add('icon-success'); }
          if (hintSpan) { hintSpan.classList.add('success'); hintSpan.textContent = message; }
        }
      }

      /** Password strength: returns 0-4 */
      function passwordStrength(pw) {
        let s = 0;
        if (pw.length >= 8)             s++;
        if (/[A-Z]/.test(pw))           s++;
        if (/[0-9]/.test(pw))           s++;
        if (/[^A-Za-z0-9]/.test(pw))    s++;
        return s;
      }

      function attachPasswordStrengthMeter(input) {
        const group = input.closest('.form-field-wrap') || input.closest('.form-group');
        if (!group || group.querySelector('.pw-strength-bar')) return;
        const bar = document.createElement('div');
        bar.className = 'pw-strength-bar';
        bar.innerHTML = '<span></span><span></span><span></span><span></span>';
        const row = input.closest('.form-input-row') || input.parentElement;
        row.after(bar);
        
        input.addEventListener('input', () => {
          const s = passwordStrength(input.value);
          bar.className = `pw-strength-bar${s > 0 ? ' strength-' + s : ''}`;
          const hints = ['', 'Trop court', 'Faible — ajoutez des majuscules', 'Bon — ajoutez des symboles', '🔒 Mot de passe fort !'];
          const hintSpan = group.querySelector('.field-hint');
          if (hintSpan) {
            hintSpan.className = 'field-hint' + (s >= 3 ? ' success' : (s > 0 ? ' error' : ''));
            hintSpan.textContent = hints[s];
          }
        });
      }

      // Set up real-time validation on key profile form fields
      setTimeout(() => {
        const fullNameInput = document.getElementById('editFullName');
        const phoneInput = document.getElementById('editPhone');
        const newPasswordInput = document.getElementById('newPassword');
        const confirmPasswordInput = document.getElementById('confirmNewPassword');

        if (fullNameInput) {
          const g = wrapFormGroup(fullNameInput, null, 'Ex: Mohammed Amine Benali');
          fullNameInput.addEventListener('blur', () => {
            const v = fullNameInput.value.trim();
            if (!v || v.length < 3) setFieldState(g, 'error', 'Nom requis (min. 3 caractères)');
            else setFieldState(g, 'success', '✓ Valide');
          });
          fullNameInput.addEventListener('input', () => {
            if (fullNameInput.value.trim().length >= 3) setFieldState(g, 'success', '✓ Valide');
          });
        }

        if (phoneInput) {
          const g = wrapFormGroup(phoneInput, null, 'Ex: 0699123456');
          phoneInput.addEventListener('blur', () => {
            const v = phoneInput.value.replace(/\s/g, '');
            if (v && !/^[0-9+]{8,15}$/.test(v)) setFieldState(g, 'error', 'Numéro de téléphone invalide');
            else if (v) setFieldState(g, 'success', '✓ Valide');
            else setFieldState(g, '', '');
          });
        }

        if (newPasswordInput) {
          const g = wrapFormGroup(newPasswordInput, null, '');
          attachPasswordStrengthMeter(newPasswordInput);
        }

        if (confirmPasswordInput) {
          const g = wrapFormGroup(confirmPasswordInput, null, '');
          confirmPasswordInput.addEventListener('input', () => {
            const pw = document.getElementById('newPassword')?.value;
            if (confirmPasswordInput.value && pw) {
              if (confirmPasswordInput.value === pw) setFieldState(g, 'success', '✓ Les mots de passe correspondent');
              else setFieldState(g, 'error', 'Ne correspond pas');
            }
          });
        }
      }, 500); // Delay to let the profile data populate first
      // =============================================

      // Handle personal info submit
      const personalInfoForm = document.getElementById('personalInfoForm');
      const profileUpdateAlert = document.getElementById('profileUpdateAlert');
      personalInfoForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        profileUpdateAlert.style.display = 'none';
        profileUpdateAlert.className = 'alert-box';
        
        const updates = {
          fullName: document.getElementById('editFullName').value,
          phone: document.getElementById('editPhone').value,
          gender: document.getElementById('editGender').value,
          birthDate: document.getElementById('editBirthDate').value
        };

        const submitBtn = document.getElementById('btnUpdateProfile');
        submitBtn.disabled = true;

        try {
          const res = await fetch('/api/member/update-profile', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(updates)
          });
          const result = await res.json();
          if (result.success) {
            const successMsg = localT.profileUpdateSuccess || "Informations personnelles mises à jour !";
            profileUpdateAlert.textContent = successMsg;
            profileUpdateAlert.classList.add('alert-success');
            profileUpdateAlert.style.display = 'block';
            window.showToast(successMsg, "success");
            
            // Update UI elements in real time
            document.getElementById('memberName').textContent = updates.fullName;
            document.getElementById('cardHolder').textContent = updates.fullName;
          } else {
            const errMsg = result.error || "Une erreur est survenue.";
            profileUpdateAlert.textContent = errMsg;
            profileUpdateAlert.classList.add('alert-error');
            profileUpdateAlert.style.display = 'block';
            window.showToast(errMsg, "error");
          }
        } catch (err) {
          console.error(err);
          profileUpdateAlert.textContent = "Erreur de connexion.";
          profileUpdateAlert.classList.add('alert-error');
          profileUpdateAlert.style.display = 'block';
          window.showToast("Erreur de connexion.", "error");
        } finally {
          submitBtn.disabled = false;
        }
      });

      // Handle avatar file input change
      const fileInput = document.getElementById('avatarFileInput');
      const avatarUploadStatus = document.getElementById('avatarUploadStatus');
      fileInput.addEventListener('change', async () => {
        const file = fileInput.files[0];
        if (!file) return;

        avatarUploadStatus.textContent = "Envoi...";
        avatarUploadStatus.style.color = "var(--color-teal)";

        const reader = new FileReader();
        reader.onloadend = async () => {
          const base64Data = reader.result;
          try {
            const res = await fetch('/api/member/update-profile', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
              },
              body: JSON.stringify({ profilePhotoData: base64Data })
            });
            const result = await res.json();
            if (result.success && result.profilePhotoUrl) {
              avatarImg.src = result.profilePhotoUrl;
              avatarImg.style.display = 'block';
              avatarLetters.style.display = 'none';
              const successMsg = localT.profilePicSuccess || "Photo de profil mise à jour !";
              avatarUploadStatus.textContent = successMsg;
              avatarUploadStatus.style.color = "#10b981";
              window.showToast(successMsg, "success");
            } else {
              const errMsg = result.error || "Erreur lors de l'envoi.";
              avatarUploadStatus.textContent = errMsg;
              avatarUploadStatus.style.color = "#ef4444";
              window.showToast(errMsg, "error");
            }
          } catch (err) {
            avatarUploadStatus.textContent = "Erreur de connexion.";
            avatarUploadStatus.style.color = "#ef4444";
            window.showToast("Erreur de connexion.", "error");
          }
        };
        reader.readAsDataURL(file);
      });

      // Handle password change form submit
      const changePasswordForm = document.getElementById('changePasswordForm');
      const passwordAlert = document.getElementById('passwordAlert');
      changePasswordForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        passwordAlert.style.display = 'none';
        passwordAlert.className = 'alert-box';

        const currentPassword = document.getElementById('currentPassword').value;
        const newPassword = document.getElementById('newPassword').value;
        const confirmNewPassword = document.getElementById('confirmNewPassword').value;

        if (newPassword !== confirmNewPassword) {
          const mismatchMsg = localT.passwordErrorMismatch || "Les nouveaux mots de passe ne correspondent pas.";
          passwordAlert.textContent = mismatchMsg;
          passwordAlert.classList.add('alert-error');
          passwordAlert.style.display = 'block';
          window.showToast(mismatchMsg, "error");
          return;
        }

        const submitBtn = changePasswordForm.querySelector('button[type="submit"]');
        submitBtn.disabled = true;

        try {
          const res = await fetch('/api/member/change-password', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({ currentPassword, newPassword })
          });
          const result = await res.json();
          if (result.success) {
            const successMsg = localT.passwordSuccess || "Mot de passe modifié avec succès !";
            passwordAlert.textContent = successMsg;
            passwordAlert.classList.add('alert-success');
            passwordAlert.style.display = 'block';
            window.showToast(successMsg, "success");
            changePasswordForm.reset();
          } else {
            const errMsg = result.error || "Une erreur est survenue.";
            passwordAlert.textContent = errMsg;
            passwordAlert.classList.add('alert-error');
            passwordAlert.style.display = 'block';
            window.showToast(errMsg, "error");
          }
        } catch (err) {
          console.error(err);
          passwordAlert.textContent = "Erreur de connexion.";
          passwordAlert.classList.add('alert-error');
          passwordAlert.style.display = 'block';
          window.showToast("Erreur de connexion.", "error");
        } finally {
          submitBtn.disabled = false;
        }
      });

      // Membership History timeline rendering
      const historyTimeline = document.getElementById('historyTimeline');
      historyTimeline.innerHTML = '';
      const historyList = profile.subscriptionHistory || [];
      
      // Fallback/Initial registration item if history is empty
      if (historyList.length === 0) {
        // Build one entry from initial subscription
        if (profile.subscription && profile.subscription.poolKey) {
          historyList.push({
            event: 'membership_approved',
            date: profile.subscription.startDate || profile.createdAt || new Date().toISOString().split('T')[0],
            details: {
              tier: profile.membershipTier || 'Starter',
              poolKey: profile.subscription.poolKey,
              coachName: profile.subscription.coachName,
              slotDay: profile.subscription.slotDay,
              slotTime: profile.subscription.slotTime
            }
          });
        } else {
          historyTimeline.innerHTML = `<div class="no-data-msg">${localT.historyNoData}</div>`;
        }
      }

      if (historyList.length > 0) {
        const sortedHistory = [...historyList].sort((a,b) => new Date(b.date) - new Date(a.date));
        sortedHistory.forEach(item => {
          const itemEl = document.createElement('div');
          itemEl.className = 'history-item';
          
          let eventTitle = '';
          if (item.event === 'membership_applied') eventTitle = localT.histMembershipApplied;
          else if (item.event === 'membership_approved') eventTitle = localT.histMembershipApproved;
          else if (item.event === 'change_requested') eventTitle = localT.histChangeRequested;
          else if (item.event === 'change_approved') eventTitle = localT.histChangeApproved;
          else if (item.event === 'change_rejected') eventTitle = localT.histChangeRejected;
          else if (item.event === 'membership_updated_by_admin') eventTitle = localT.histAdminUpdated;
          else eventTitle = item.event;

          const details = item.details || {};
          const poolName = details.poolKey === 'reghaia' ? 'Piscine Reghaia' : (details.poolKey === 'cheraga' ? 'Piscine Cheraga' : details.poolKey || '');
          
          const formattedDate = new Date(item.date).toLocaleDateString(lang === 'ar' ? 'ar-DZ' : 'fr-FR', {
            year: 'numeric', month: 'long', day: 'numeric'
          });

          itemEl.innerHTML = `
            <div class="history-dot"></div>
            <div class="history-content">
              <div class="history-header-row">
                <span class="history-event-title">${eventTitle}</span>
                <span class="history-date">${formattedDate}</span>
              </div>
              <div class="history-details">
                ${details.tier ? `<strong>${details.tier}</strong>` : ''}
                ${poolName ? ` &bull; ${poolName}` : ''}
                ${details.coachName ? ` &bull; Coach ${details.coachName}` : ''}
                ${details.slotTime ? ` &bull; ${details.slotTime}` : ''}
              </div>
            </div>
          `;
          historyTimeline.appendChild(itemEl);
        });
      }

      // Setup upgrade/change form toggle
      const btnOpenChange = document.getElementById('btnOpenChange');
      const changeSubForm = document.getElementById('changeSubForm');
      const btnCancelChange = document.getElementById('btnCancelChange');
      const changePendingNotice = document.getElementById('changePendingNotice');

      if (profile.subscriptionChangeRequest && profile.subscriptionChangeRequest.status === 'pending') {
        btnOpenChange.style.display = 'none';
        changePendingNotice.style.display = 'block';
      }

      let changeSelectedGroups = [];
      const renderChangeFormSlots = () => {
        const tier = document.getElementById('changeTier').value;
        const pool = document.getElementById('changePool').value;
        
        const loadAndRender = (sched) => {
          renderInteractiveSlots('changeSlotGrid', 'changeSlotsLimitNotice', sched, pool, profile.gender || 'homme', tier, changeSelectedGroups, (selected) => {
            changeSelectedGroups = selected;
          });
        };

        if (!schedule || Object.keys(schedule).length === 0) {
          fetch('/api/schedule')
            .then(res => res.json())
            .then(data => {
              schedule = data;
              loadAndRender(schedule);
            });
        } else {
          loadAndRender(schedule);
        }
      };

      document.getElementById('changeTier').addEventListener('change', () => {
        changeSelectedGroups = [];
        renderChangeFormSlots();
      });

      document.getElementById('changePool').addEventListener('change', () => {
        changeSelectedGroups = [];
        renderChangeFormSlots();
      });

      btnOpenChange.addEventListener('click', () => {
        document.getElementById('changeTier').value = profile.membershipTier || 'Starter';
        document.getElementById('changePool').value = profile.subscription?.poolKey || 'reghaia';
        changeSelectedGroups = getGroupsFromSubscription(profile.subscription);
        renderChangeFormSlots();

        changeSubForm.style.display = 'block';
        btnOpenChange.style.display = 'none';
      });

      btnCancelChange.addEventListener('click', () => {
        changeSubForm.style.display = 'none';
        btnOpenChange.style.display = 'block';
      });

      // Handle change request submit
      changeSubForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (changeSelectedGroups.length === 0) {
          window.showToast("Veuillez sélectionner au moins un créneau.", "error");
          return;
        }

        const reqData = {
          tier: document.getElementById('changeTier').value,
          groups: changeSelectedGroups
        };

        const submitBtn = changeSubForm.querySelector('button[type="submit"]');
        submitBtn.disabled = true;

        try {
          const res = await fetch('/api/member/change-subscription', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(reqData)
          });
          const result = await res.json();
          if (result.success) {
            changeSubForm.style.display = 'none';
            changePendingNotice.style.display = 'block';
            window.showToast("Demande de changement soumise avec succès !", "success");
          } else {
            window.showToast(result.error || "Une erreur est survenue lors de la soumission", "error");
          }
        } catch (err) {
          console.error('Failed to submit subscription change request:', err);
          window.showToast("Erreur de connexion.", "error");
        } finally {
          submitBtn.disabled = false;
        }
      });

      // Presence Timeline
      const timelineBox = document.getElementById('presenceTimelineBox');
      timelineBox.innerHTML = '';
      const presenceList = profile.presence || [];
      const presentCount = presenceList.filter(p => p.present).length;
      const totalCount = presenceList.length;
      const percent = totalCount > 0 ? Math.round((presentCount / totalCount) * 100) : 0;

      // Update Presence summary text & circular progress
      let summaryStr = localT.presenceSummary
        .replace('{present}', presentCount)
        .replace('{total}', totalCount)
        .replace('{percent}', percent);
      document.getElementById('presenceSummaryText').textContent = summaryStr;
      // Also update the ring center text
      const pctText = document.getElementById('presencePercentText');
      if (pctText) pctText.textContent = `${percent}%`;

      // Update circular progress ring — r=50 for 120px viewBox
      const circle = document.getElementById('presenceRing');
      if (circle) {
        const radius = 50;
        const circumference = 2 * Math.PI * radius; // 314.16
        circle.style.strokeDasharray = `${circumference}`;
        circle.style.strokeDashoffset = `${circumference}`; // start empty
        // Animate after short delay
        setTimeout(() => {
          circle.style.transition = 'stroke-dashoffset 1.4s cubic-bezier(0.4, 0, 0.2, 1)';
          circle.style.strokeDashoffset = `${circumference - (percent / 100) * circumference}`;
        }, 500);
      }

      if (presenceList.length === 0) {
        timelineBox.innerHTML = `<div class="no-data-msg">${localT.presenceNoData}</div>`;
      } else {
        // Build heatmap grid — last 84 sessions max, newest first
        const sorted = [...presenceList].sort((a,b) => new Date(b.date) - new Date(a.date)).slice(0, 84);
        sorted.forEach(item => {
          const cell = document.createElement('div');
          cell.className = `heatmap-cell ${item.present ? 'hm-present' : 'hm-absent'}`;
          cell.title = `${item.date} — ${item.present ? (localT.presencePresent || 'Présent') : (item.reason || localT.presenceAbsent || 'Absent')}`;
          timelineBox.appendChild(cell);
        });
      }


      // Technical Evaluation
      const tech = profile.suiviTechnique;
      if (tech && (tech.respiration > 0 || tech.kick > 0 || tech.bras > 0 || tech.endurance > 0 || tech.comments)) {
        document.getElementById('techRespirationVal').textContent = `${tech.respiration}/5`;
        document.getElementById('techRespirationFill').style.width = `${(tech.respiration / 5) * 100}%`;
        
        document.getElementById('techKickVal').textContent = `${tech.kick || tech.battement || 0}/5`;
        document.getElementById('techKickFill').style.width = `${((tech.kick || tech.battement || 0) / 5) * 100}%`;

        document.getElementById('techBrasVal').textContent = `${tech.bras}/5`;
        document.getElementById('techBrasFill').style.width = `${(tech.bras / 5) * 100}%`;

        document.getElementById('techEnduranceVal').textContent = `${tech.endurance}/5`;
        document.getElementById('techEnduranceFill').style.width = `${(tech.endurance / 5) * 100}%`;

        document.getElementById('techCommentsVal').textContent = tech.comments || '-';
      } else {
        document.getElementById('techEvaluationContainer').style.display = 'none';
        document.getElementById('noTechDataBox').style.display = 'block';
      }

      // Badges — premium card rendering
      const badgesGrid = document.getElementById('badgesGrid');
      badgesGrid.innerHTML = '';
      const userBadges = profile.badges || [];

      const badgeEmoji = {
        star:      '⭐',
        lightning: '⚡',
        timer:     '⏱️',
        wave:      '🌊',
        flame:     '🔥',
        shield:    '🛡️',
        trophy:    '🏆',
        medal:     '🏅',
        rocket:    '🚀',
        crown:     '👑'
      };

      const badgeKeys = Object.keys(badgeDefinitions);
      if (badgeKeys.length === 0) {
        badgesGrid.innerHTML = `
          <div class="empty-state-block">
            <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <p>Vos badges apparaîtront<br>après vos premières séances</p>
          </div>`;
      } else {
        badgeKeys.forEach(badgeId => {
          const badgeMeta = badgeDefinitions[badgeId];
          const isUnlocked = userBadges.includes(badgeId);
          const emoji = badgeEmoji[badgeMeta.type] || '🏅';

          const badgeEl = document.createElement('div');
          badgeEl.className = `badge-item ${isUnlocked ? 'unlocked' : 'locked'}`;
          badgeEl.title = badgeMeta.desc || badgeMeta.name;
          badgeEl.innerHTML = `
            <div class="badge-icon-wrap">${emoji}</div>
            <div class="badge-name">${badgeMeta.name}</div>
          `;
          badgesGrid.appendChild(badgeEl);
        });
      }

      // Gallery
      const galleryGrid = document.getElementById('galleryGrid');
      galleryGrid.innerHTML = '';
      const galleryPhotos = profile.gallery || [];
      if (galleryPhotos.length === 0) {
        galleryGrid.innerHTML = `
          <div class="empty-state-block" style="grid-column:1/-1">
            <svg viewBox="0 0 24 24" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <p>Les photos de vos séances<br>et exploits apparaîtront ici</p>
          </div>`;
      } else {
        galleryPhotos.forEach(url => {
          const card = document.createElement('div');
          card.className = 'gallery-img-card';
          card.innerHTML = `<img src="${url}" alt="Action Shot" loading="lazy">`;
          card.addEventListener('click', () => {
            const lightbox = document.getElementById('galleryLightbox');
            const lightboxImg = document.getElementById('lightboxImg');
            if (lightbox && lightboxImg) {
              lightboxImg.src = url;
              lightbox.style.display = 'flex';
            }
          });
          galleryGrid.appendChild(card);
        });
      }
    }

    // Step-by-Step wizard logic (for Non-Members)
    function setupWizard(profile) {
      let currentStep = 1;
      let selectedCategory = '';
      let selectedPool = '';
      let selectedFormula = '';
      let wizardSelectedGroups = [];
      let schedule = {};

      const nextBtn = document.getElementById('wizNextBtn');
      const prevBtn = document.getElementById('wizPrevBtn');
      const submitBtn = document.getElementById('wizSubmitBtn');
      const errorBanner = document.getElementById('wizardErrorMsg');

      // Bind activity card quick selection
      document.querySelectorAll('.select-activity-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          selectedCategory = btn.dataset.category;
          
          // Style step 1 options
          document.querySelectorAll('#wizStepContent1 .wizard-option-card').forEach(c => {
            c.classList.remove('selected');
            if (c.dataset.val === selectedCategory) c.classList.add('selected');
          });

          // Switch tab to Wizard
          const wizardTabBtn = document.getElementById('tabWizardBtn');
          if (wizardTabBtn) {
            wizardTabBtn.click();
            goToStep(2);
          }
        });
      });

      // Action Join Club on Hero banner
      const btnGoToWizard = document.getElementById('btnGoToWizard');
      if (btnGoToWizard) {
        btnGoToWizard.addEventListener('click', () => {
          const wizardTabBtn = document.getElementById('tabWizardBtn');
          if (wizardTabBtn) wizardTabBtn.click();
        });
      }

      // Step 1 Category selector
      document.querySelectorAll('#wizStepContent1 .wizard-option-card').forEach(card => {
        card.addEventListener('click', () => {
          document.querySelectorAll('#wizStepContent1 .wizard-option-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          selectedCategory = card.dataset.val;
          errorBanner.style.display = 'none';
        });
      });

      // Step 2 Pool selector
      document.querySelectorAll('#wizStepContent2 .wizard-option-card').forEach(card => {
        card.addEventListener('click', () => {
          document.querySelectorAll('#wizStepContent2 .wizard-option-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          selectedPool = card.dataset.val;
          errorBanner.style.display = 'none';
        });
      });

      // Step 3 Formula selector
      document.querySelectorAll('#wizStepContent3 .wizard-option-card').forEach(card => {
        card.addEventListener('click', () => {
          document.querySelectorAll('#wizStepContent3 .wizard-option-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          selectedFormula = card.dataset.val;
          errorBanner.style.display = 'none';
        });
      });

      // Navigation
      nextBtn.addEventListener('click', () => {
        if (validateStep(currentStep)) {
          if (currentStep === 3) {
            loadSlotsAndCoaches().then(() => {
              goToStep(currentStep + 1);
            });
          } else {
            goToStep(currentStep + 1);
          }
        }
      });

      prevBtn.addEventListener('click', () => {
        goToStep(currentStep - 1);
      });

      // Submit
      submitBtn.addEventListener('click', async () => {
        if (!document.getElementById('ruleCheck1').checked || 
            !document.getElementById('ruleCheck2').checked || 
            !document.getElementById('ruleCheck3').checked) {
          showError("Veuillez accepter toutes les regles et conditions pour continuer.");
          return;
        }

        submitBtn.disabled = true;
        errorBanner.style.display = 'none';

        try {
          const response = await fetch('/api/member/apply-membership', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
              tier: selectedFormula,
              groups: wizardSelectedGroups
            })
          });

          const resData = await response.json();
          if (resData.success) {
            window.location.reload();
          } else {
            showError(resData.error || "Une erreur est survenue lors de la soumission");
          }
        } catch (e) {
          showError("Erreur de connexion reseau: " + e.message);
        } finally {
          submitBtn.disabled = false;
        }
      });

      function showError(text) {
        errorBanner.textContent = text;
        errorBanner.style.display = 'block';
      }

      function validateStep(step) {
        errorBanner.style.display = 'none';
        if (step === 1 && !selectedCategory) {
          showError(localT.wizSelectCategory);
          return false;
        }
        if (step === 2 && !selectedPool) {
          showError(localT.wizSelectPool);
          return false;
        }
        if (step === 3 && !selectedFormula) {
          showError(localT.wizSelectFormula);
          return false;
        }
        if (step === 4) {
          if (wizardSelectedGroups.length === 0) {
            showError("Veuillez sélectionner au moins un créneau.");
            return false;
          }
        }
        return true;
      }

      function goToStep(step) {
        currentStep = step;
        errorBanner.style.display = 'none';

        // Toggle content views
        document.querySelectorAll('.wizard-step-content').forEach(el => el.classList.remove('active'));
        document.getElementById(`wizStepContent${step}`).classList.add('active');

        // Toggle step indicators
        document.querySelectorAll('.wizard-step-indicator').forEach(el => {
          const elStep = parseInt(el.dataset.step);
          el.classList.remove('active');
          if (elStep <= step) el.classList.add('active');
        });

        // Toggle footer buttons
        prevBtn.style.display = step > 1 ? 'block' : 'none';
        nextBtn.style.display = step < 5 ? 'block' : 'none';
        submitBtn.style.display = step === 5 ? 'block' : 'none';
      }

      async function loadSlotsAndCoaches() {
        const grid = document.getElementById('wizardSlotGrid');
        grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; color: var(--text-secondary); padding: 2rem 0;">Chargement des creneaux...</div>';
        try {
          const res = await fetch('/api/schedule');
          schedule = await res.json();
          
          renderInteractiveSlots('wizardSlotGrid', 'wizardSlotsLimitNotice', schedule, selectedPool, selectedCategory, selectedFormula, wizardSelectedGroups, (selected) => {
            wizardSelectedGroups = selected;
          });
        } catch (e) {
          grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; color: #ef4444; padding: 2rem 0;">Erreur de chargement des creneaux</div>';
        }
      }

    }

  });
</script>

