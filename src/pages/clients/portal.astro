<script is:inline define:vars={{ lang, badgeDefinitions, localT }}>
  document.addEventListener('astro:page-load', () => {
    
    // Redirection helper if token is missing
    const redirectToLogin = () => {
      if (lang === 'fr') window.location.href = '/clients';
      else window.location.href = `/${lang}/clients`;
    };

    const token = localStorage.getItem('aqa_member_token');
    if (!token) {
      redirectToLogin();
      return;
    }

    const loader = document.getElementById('portalLoader');
    const content = document.getElementById('portalContent');
    const statePending = document.getElementById('statePending');
    const stateMember = document.getElementById('stateMember');
    const stateNonMember = document.getElementById('stateNonMember');
    const logoutBtn = document.getElementById('logoutBtn');

    // Handle logout
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => {
        localStorage.removeItem('aqa_member_token');
        localStorage.removeItem('aqa_member_info');
        redirectToLogin();
      });
    }

    // Dynamic Tab Logic
    const initTabs = () => {
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const wrapper = btn.closest('.portal-welcome-bar, .non-member-welcome-bar').nextElementSibling;
          
          btn.closest('.tab-navigation').querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          wrapper.querySelectorAll('.tab-panel').forEach(panel => {
            panel.classList.remove('active');
          });

          const targetPanel = document.getElementById(btn.dataset.tab);
          if (targetPanel) {
            targetPanel.classList.add('active');
          }
        });
      });
    };
    initTabs();

    // Lightbox modal functionality
    const setupLightbox = () => {
      const lightbox = document.getElementById('galleryLightbox');
      const lightboxImg = document.getElementById('lightboxImg');
      const closeBtn = document.getElementById('closeLightboxBtn');

      if (!lightbox || !lightboxImg || !closeBtn) return;

      closeBtn.addEventListener('click', () => {
        lightbox.style.display = 'none';
      });

      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) {
          lightbox.style.display = 'none';
        }
      });
    };
    setupLightbox();

    // Fetch member profile
    async function fetchProfile() {
      try {
        const response = await fetch('/api/member/profile', {
          method: 'GET',
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });
        
        if (response.status === 401 || response.status === 403) {
          localStorage.removeItem('aqa_member_token');
          redirectToLogin();
          return;
        }

        const data = await response.json();
        if (data.success) {
          renderDashboard(data.profile);
        } else {
          redirectToLogin();
        }
      } catch (e) {
        console.error("Failed to load user profile:", e);
        redirectToLogin();
      } finally {
        if (loader) loader.style.display = 'none';
        if (content) content.style.display = 'block';
      }
    }

    fetchProfile();

    // Main Render logic
    function renderDashboard(profile) {
      if (profile.status === 'pending') {
        statePending.style.display = 'block';
        return;
      }

      if (!profile.isAqaMember) {
        stateNonMember.style.display = 'block';
        setupWizard(profile);
        return;
      }

      // Default Active Member Dashboard
      stateMember.style.display = 'block';
      
      // Basic info
      document.getElementById('memberName').textContent = profile.fullName;
      document.getElementById('memberXP').textContent = profile.xp || 0;

      // Render Membership Card with Holo gradients
      const card = document.getElementById('memberCard');
      const tier = profile.membershipTier || 'Starter';
      card.className = `virtual-card card-tier-${tier.toLowerCase()}`;
      
      // Setup dynamic 3D tilt and reflection effect
      if (card && !card._tiltBound) {
        card._tiltBound = true;
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = ((centerY - y) / centerY) * 15; // Max 15 degrees tilt
          const rotateY = ((x - centerX) / centerX) * 15;
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
          
          const percentX = (x / rect.width) * 100;
          const percentY = (y / rect.height) * 100;
          card.style.setProperty('--shine-x', `${percentX}%`);
          card.style.setProperty('--shine-y', `${percentY}%`);
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
        });
      }
      document.getElementById('cardTier').textContent = tier.toUpperCase();
      document.getElementById('cardId').textContent = `ID: AQA-${profile.id.slice(0,6).toUpperCase()}`;
      document.getElementById('cardHolder').textContent = profile.fullName;
      
      const expiryDate = profile.subscription?.endDate || '-';
      document.getElementById('cardExpiry').textContent = expiryDate;

      // QR Code pointing to public stats page
      const statsUrl = window.location.origin + `/clients/stats?id=${profile.id}`;
      document.getElementById('cardQrCode').src = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(statsUrl)}`;

      // Subscription Widget
      document.getElementById('subTierVal').textContent = tier;
      document.getElementById('subPoolVal').textContent = profile.subscription?.poolKey === 'reghaia' ? 'Piscine Reghaia' : (profile.subscription?.poolKey === 'cheraga' ? 'Piscine Cheraga' : '-');
      document.getElementById('subCoachVal').textContent = profile.subscription?.coachName || '-';
      document.getElementById('subSlotVal').textContent = profile.subscription?.slotDay && profile.subscription?.slotTime ? `${profile.subscription.slotDay} - ${profile.subscription.slotTime}` : '-';
      document.getElementById('subExpiryVal').textContent = expiryDate;

      // Setup upgrade/change form toggle
      const btnOpenChange = document.getElementById('btnOpenChange');
      const changeSubForm = document.getElementById('changeSubForm');
      const btnCancelChange = document.getElementById('btnCancelChange');
      const changePendingNotice = document.getElementById('changePendingNotice');

      if (profile.subscriptionChangeRequest && profile.subscriptionChangeRequest.status === 'pending') {
        btnOpenChange.style.display = 'none';
        changePendingNotice.style.display = 'block';
      }

      btnOpenChange.addEventListener('click', () => {
        changeSubForm.style.display = 'block';
        btnOpenChange.style.display = 'none';
      });

      btnCancelChange.addEventListener('click', () => {
        changeSubForm.style.display = 'none';
        btnOpenChange.style.display = 'block';
      });

      // Handle change request submit
      changeSubForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const reqData = {
          tier: document.getElementById('changeTier').value,
          poolKey: document.getElementById('changePool').value,
          coachName: document.getElementById('changeCoach').value,
          slotDay: document.getElementById('changeSlot').value.split(' ')[0] || 'Samedi',
          slotTime: document.getElementById('changeSlot').value
        };

        const submitBtn = changeSubForm.querySelector('button[type="submit"]');
        submitBtn.disabled = true;

        try {
          const res = await fetch('/api/member/change-subscription', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(reqData)
          });
          const result = await res.json();
          if (result.success) {
            changeSubForm.style.display = 'none';
            changePendingNotice.style.display = 'block';
          }
        } catch (err) {
          console.error('Failed to submit subscription change request:', err);
        } finally {
          submitBtn.disabled = false;
        }
      });

      // Presence Timeline
      const timelineBox = document.getElementById('presenceTimelineBox');
      timelineBox.innerHTML = '';
      const presenceList = profile.presence || [];
      const presentCount = presenceList.filter(p => p.present).length;
      const totalCount = presenceList.length;
      const percent = totalCount > 0 ? Math.round((presentCount / totalCount) * 100) : 0;

      // Update Presence summary text & circular progress
      let summaryStr = localT.presenceSummary
        .replace('{present}', presentCount)
        .replace('{total}', totalCount)
        .replace('{percent}', percent);
      document.getElementById('presenceSummaryText').textContent = summaryStr;
      
      // Update circular progress ring
      document.getElementById('presencePercentText').textContent = `${percent}%`;
      const circle = document.getElementById('presenceRing');
      if (circle) {
        const radius = circle.r.baseVal.value;
        const circumference = radius * 2 * Math.PI;
        circle.style.strokeDasharray = `${circumference}`;
        const offset = circumference - (percent / 100) * circumference;
        circle.style.strokeDashoffset = offset;
      }

      if (presenceList.length === 0) {
        timelineBox.innerHTML = `<div class="no-data-msg">${localT.presenceNoData}</div>`;
      } else {
        const sortedPresence = [...presenceList].sort((a,b) => new Date(b.date) - new Date(a.date));
        sortedPresence.forEach(item => {
          const block = document.createElement('div');
          block.className = `presence-timeline-item ${item.present ? 'status-present' : 'status-absent'}`;
          
          block.innerHTML = `
            <div class="presence-icon">
              ${item.present ? 
                '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="3" fill="none"><polyline points="20 6 9 17 4 12"></polyline></svg>' : 
                '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="3" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>'
              }
            </div>
            <div class="presence-info">
              <strong class="presence-date">${item.date}</strong>
              <span class="presence-status">${item.present ? localT.presencePresent : (item.reason || localT.presenceAbsent)}</span>
            </div>
          `;
          timelineBox.appendChild(block);
        });
      }

      // Technical Evaluation
      const tech = profile.suiviTechnique;
      if (tech && (tech.respiration > 0 || tech.kick > 0 || tech.bras > 0 || tech.endurance > 0 || tech.comments)) {
        document.getElementById('techRespirationVal').textContent = `${tech.respiration}/5`;
        document.getElementById('techRespirationFill').style.width = `${(tech.respiration / 5) * 100}%`;
        
        document.getElementById('techKickVal').textContent = `${tech.kick || tech.battement || 0}/5`;
        document.getElementById('techKickFill').style.width = `${((tech.kick || tech.battement || 0) / 5) * 100}%`;

        document.getElementById('techBrasVal').textContent = `${tech.bras}/5`;
        document.getElementById('techBrasFill').style.width = `${(tech.bras / 5) * 100}%`;

        document.getElementById('techEnduranceVal').textContent = `${tech.endurance}/5`;
        document.getElementById('techEnduranceFill').style.width = `${(tech.endurance / 5) * 100}%`;

        document.getElementById('techCommentsVal').textContent = tech.comments || '-';
      } else {
        document.getElementById('techEvaluationContainer').style.display = 'none';
        document.getElementById('noTechDataBox').style.display = 'block';
      }

      // Badges with custom SVG vector icons instead of emojis
      const badgesGrid = document.getElementById('badgesGrid');
      badgesGrid.innerHTML = '';
      const userBadges = profile.badges || [];

      const svgPaths = {
        star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>',
        lightning: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>',
        timer: '<circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>',
        wave: '<path d="M2 12a5 5 0 0 1 5-5 5 5 0 0 1 5 5 5 5 0 0 1 5-5 5 5 0 0 1 5 5"></path><path d="M2 17a5 5 0 0 1 5-5 5 5 0 0 1 5 5 5 5 0 0 1 5-5 5 5 0 0 1 5 5"></path>',
        flame: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path>'
      };

      Object.keys(badgeDefinitions).forEach(badgeId => {
        const badgeMeta = badgeDefinitions[badgeId];
        const isUnlocked = userBadges.includes(badgeId);
        
        const badgeEl = document.createElement('div');
        badgeEl.className = `badge-item ${isUnlocked ? 'unlocked' : 'locked'}`;
        badgeEl.innerHTML = `
          <div class="badge-icon-svg">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              ${svgPaths[badgeMeta.type]}
            </svg>
          </div>
          <div class="badge-name">${badgeMeta.name}</div>
          <div class="badge-desc">${badgeMeta.desc}</div>
        `;
        badgesGrid.appendChild(badgeEl);
      });

      // Gallery with full screen lightbox triggering
      const galleryGrid = document.getElementById('galleryGrid');
      galleryGrid.innerHTML = '';
      const galleryPhotos = profile.gallery || [];
      if (galleryPhotos.length === 0) {
        galleryGrid.innerHTML = `<div class="no-data-msg">${localT.noGalleryData}</div>`;
      } else {
        galleryPhotos.forEach(url => {
          const wrapper = document.createElement('div');
          wrapper.className = 'gallery-photo-item';
          wrapper.innerHTML = `<img src="${url}" alt="Action Shot" class="gallery-photo">`;
          wrapper.addEventListener('click', () => {
            const lightbox = document.getElementById('galleryLightbox');
            const lightboxImg = document.getElementById('lightboxImg');
            if (lightbox && lightboxImg) {
              lightboxImg.src = url;
              lightbox.style.display = 'flex';
            }
          });
          galleryGrid.appendChild(wrapper);
        });
      }
    }

    // Step-by-Step wizard logic (for Non-Members)
    function setupWizard(profile) {
      let currentStep = 1;
      let selectedCategory = '';
      let selectedPool = '';
      let selectedFormula = '';
      let selectedSlotText = '';
      let selectedCoach = '';
      let selectedSlotDay = '';
      let selectedSlotTime = '';
      let schedule = {};

      const nextBtn = document.getElementById('wizNextBtn');
      const prevBtn = document.getElementById('wizPrevBtn');
      const submitBtn = document.getElementById('wizSubmitBtn');
      const errorBanner = document.getElementById('wizardErrorMsg');

      // Bind activity card quick selection
      document.querySelectorAll('.select-activity-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          selectedCategory = btn.dataset.category;
          
          // Style step 1 options
          document.querySelectorAll('#wizStepContent1 .wizard-option-card').forEach(c => {
            c.classList.remove('selected');
            if (c.dataset.val === selectedCategory) c.classList.add('selected');
          });

          // Switch tab to Wizard
          const wizardTabBtn = document.getElementById('tabWizardBtn');
          if (wizardTabBtn) {
            wizardTabBtn.click();
            goToStep(2);
          }
        });
      });

      // Action Join Club on Hero banner
      const btnGoToWizard = document.getElementById('btnGoToWizard');
      if (btnGoToWizard) {
        btnGoToWizard.addEventListener('click', () => {
          const wizardTabBtn = document.getElementById('tabWizardBtn');
          if (wizardTabBtn) wizardTabBtn.click();
        });
      }

      // Step 1 Category selector
      document.querySelectorAll('#wizStepContent1 .wizard-option-card').forEach(card => {
        card.addEventListener('click', () => {
          document.querySelectorAll('#wizStepContent1 .wizard-option-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          selectedCategory = card.dataset.val;
          errorBanner.style.display = 'none';
        });
      });

      // Step 2 Pool selector
      document.querySelectorAll('#wizStepContent2 .wizard-option-card').forEach(card => {
        card.addEventListener('click', () => {
          document.querySelectorAll('#wizStepContent2 .wizard-option-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          selectedPool = card.dataset.val;
          errorBanner.style.display = 'none';
        });
      });

      // Step 3 Formula selector
      document.querySelectorAll('#wizStepContent3 .wizard-option-card').forEach(card => {
        card.addEventListener('click', () => {
          document.querySelectorAll('#wizStepContent3 .wizard-option-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          selectedFormula = card.dataset.val;
          errorBanner.style.display = 'none';
        });
      });

      // Navigation
      nextBtn.addEventListener('click', () => {
        if (validateStep(currentStep)) {
          if (currentStep === 3) {
            loadSlotsAndCoaches().then(() => {
              goToStep(currentStep + 1);
            });
          } else {
            goToStep(currentStep + 1);
          }
        }
      });

      prevBtn.addEventListener('click', () => {
        goToStep(currentStep - 1);
      });

      // Submit
      submitBtn.addEventListener('click', async () => {
        if (!document.getElementById('ruleCheck1').checked || 
            !document.getElementById('ruleCheck2').checked || 
            !document.getElementById('ruleCheck3').checked) {
          showError("Veuillez accepter toutes les regles et conditions pour continuer.");
          return;
        }

        submitBtn.disabled = true;
        errorBanner.style.display = 'none';

        try {
          const response = await fetch('/api/member/apply-membership', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
              tier: selectedFormula,
              poolKey: selectedPool,
              coachName: selectedCoach,
              slotDay: selectedSlotDay,
              slotTime: selectedSlotTime
            })
          });

          const resData = await response.json();
          if (resData.success) {
            window.location.reload();
          } else {
            showError(resData.error || "Une erreur est survenue lors de la soumission");
          }
        } catch (e) {
          showError("Erreur de connexion reseau: " + e.message);
        } finally {
          submitBtn.disabled = false;
        }
      });

      function showError(text) {
        errorBanner.textContent = text;
        errorBanner.style.display = 'block';
      }

      function validateStep(step) {
        errorBanner.style.display = 'none';
        if (step === 1 && !selectedCategory) {
          showError(localT.wizSelectCategory);
          return false;
        }
        if (step === 2 && !selectedPool) {
          showError(localT.wizSelectPool);
          return false;
        }
        if (step === 3 && !selectedFormula) {
          showError(localT.wizSelectFormula);
          return false;
        }
        if (step === 4) {
          const selectVal = document.getElementById('wizardSlotSelect').value;
          if (!selectVal) {
            showError(localT.wizSelectSlot);
            return false;
          }
          // Parse values
          const parts = selectVal.split('|');
          selectedCoach = parts[0];
          selectedSlotDay = parts[1];
          selectedSlotTime = parts[2];
        }
        return true;
      }

      function goToStep(step) {
        currentStep = step;
        errorBanner.style.display = 'none';

        // Toggle content views
        document.querySelectorAll('.wizard-step-content').forEach(el => el.classList.remove('active'));
        document.getElementById(`wizStepContent${step}`).classList.add('active');

        // Toggle step indicators
        document.querySelectorAll('.wizard-step-indicator').forEach(el => {
          const elStep = parseInt(el.dataset.step);
          el.classList.remove('active');
          if (elStep <= step) el.classList.add('active');
        });

        // Toggle footer buttons
        prevBtn.style.display = step > 1 ? 'block' : 'none';
        nextBtn.style.display = step < 5 ? 'block' : 'none';
        submitBtn.style.display = step === 5 ? 'block' : 'none';
      }

      async function loadSlotsAndCoaches() {
        const select = document.getElementById('wizardSlotSelect');
        select.innerHTML = '<option value="">Chargement des creneaux...</option>';
        try {
          const res = await fetch('/api/schedule');
          schedule = await res.json();
          select.innerHTML = `<option value="">-- ${localT.wizSelectSlot} --</option>`;
          
          const pool = schedule[selectedPool];
          if (!pool || !pool.categories || !pool.categories[selectedCategory]) {
            select.innerHTML = '<option value="">Aucun creneau disponible pour ces choix.</option>';
            return;
          }

          const categoryObj = pool.categories[selectedCategory];
          let foundAny = false;

          categoryObj.coaches.forEach(coach => {
            if (!coach.slots) return;
            coach.slots.forEach(slot => {
              foundAny = true;
              const remaining = slot.total - slot.taken;
              const isFull = remaining <= 0;
              const val = `${coach.name}|${slot.day}|${slot.time}`;
              const placesText = isFull ? `[${localT.slotFull}]` : `(${remaining} ${remaining > 1 ? localT.placesLeftPlural : localT.placesLeft})`;
              
              const option = document.createElement('option');
              option.value = val;
              option.textContent = `${slot.day} ${slot.time} - ${coach.name} ${placesText}`;
              if (isFull) option.disabled = true;
              select.appendChild(option);
            });
          });

          if (!foundAny) {
            select.innerHTML = '<option value="">Aucun creneau configure pour cette categorie.</option>';
          }

        } catch (e) {
          select.innerHTML = '<option value="">Erreur de chargement des creneaux</option>';
        }
      }

    }

  });
</script>

