---

<BaseLayout title={localT.metaTitle} currentPage="/clients/portal" lang={lang}>
  
  <!-- Mini Header -->
  <header class="portal-header">
    <div class="container header-container">
      <div class="header-logo">
        <a href="/">
          <span class="logo-accent">AQA</span> Sports ERP
        </a>
      </div>
      <div class="header-actions">
        <button id="logoutBtn" class="portal-logout-btn">{localT.logout}</button>
      </div>
    </div>
  </header>

  <!-- Loader Overlay with Premium Shimmer Skeletons -->
  <div id="portalLoader" class="portal-loader-overlay">
    <div class="skeleton-wrapper">
      <div class="skeleton-header-row">
        <div class="skeleton-logo skeleton-shimmer-container"></div>
        <div class="skeleton-btn skeleton-shimmer-container"></div>
      </div>
      
      <div class="skeleton-welcome skeleton-shimmer-container" style="margin-top: 1.5rem;"></div>
      
      <div class="skeleton-grid">
        <!-- Col 1 -->
        <div class="skeleton-col">
          <!-- Card Skeleton -->
          <div class="skeleton-card virtual-card-skeleton skeleton-shimmer-container">
            <div class="skeleton-title" style="width: 30%;"></div>
            <div class="skeleton-line short"></div>
            <div class="skeleton-line medium" style="margin-top: auto;"></div>
            <div class="skeleton-line short"></div>
          </div>
          
          <!-- Form Skeleton -->
          <div class="skeleton-card">
            <div class="skeleton-title skeleton-shimmer-container"></div>
            <div class="skeleton-circle-wrap">
              <div class="skeleton-avatar skeleton-shimmer-container"></div>
              <div class="skeleton-line short skeleton-shimmer-container"></div>
            </div>
            <div class="skeleton-field">
              <div class="skeleton-label skeleton-shimmer-container"></div>
              <div class="skeleton-input skeleton-shimmer-container"></div>
            </div>
            <div class="skeleton-field">
              <div class="skeleton-label skeleton-shimmer-container"></div>
              <div class="skeleton-input skeleton-shimmer-container"></div>
            </div>
            <div class="skeleton-button-full skeleton-shimmer-container"></div>
          </div>
        </div>
        
        <!-- Col 2 -->
        <div class="skeleton-col">
          <!-- Details Skeleton -->
          <div class="skeleton-card">
            <div class="skeleton-title skeleton-shimmer-container"></div>
            <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 0.5rem;">
              <div class="skeleton-line long skeleton-shimmer-container"></div>
              <div class="skeleton-line long skeleton-shimmer-container"></div>
              <div class="skeleton-line long skeleton-shimmer-container"></div>
