---

<BaseLayout title={localT.metaTitle} currentPage="/clients/portal" lang={lang}>
  
  <!-- Mini Header -->
  <header class="portal-header">
    <div class="container header-container">
      <div class="header-logo">
        <a href="/">
          <span class="logo-accent">AQA</span> Sports ERP
        </a>
      </div>
      <div class="header-actions">
        <button id="logoutBtn" class="portal-logout-btn">{localT.logout}</button>
      </div>
    </div>
  </header>

  <!-- Loader Overlay -->
  <div id="portalLoader" class="portal-loader-overlay">
    <div class="spinner"></div>
    <p>{localT.loading}</p>
  </div>

  <!-- MAIN PORTAL WRAPPER -->
  <main id="portalContent" class="container portal-main" style="display: none;">
    
    <!-- PENDING APPROVAL CONTAINER -->
    <div id="statePending" class="glass-panel state-panel" style="display: none;">
      <div class="state-icon">&#9203;</div>
      <h2>{localT.pendingTitle}</h2>
      <p>{localT.pendingDesc}</p>
      <a href="https://wa.me/213540454907?text=Bonjour%2C%20je%20viens%20de%20m%27inscrire%20sur%20l%27espace%20membre%20et%20j%27attend%20ma%20validation." target="_blank" rel="noopener" class="portal-btn-primary">
        {localT.whatsappSupport}
      </a>
    </div>

    <!-- REGISTERED ACTIVE MEMBER PORTAL -->
    <div id="stateMember" style="display: none;">
      
      <!-- Welcome Line -->
      <div class="portal-welcome-bar">
        <h2>{localT.hello}, <span id="memberName">Athlete</span> !</h2>
        <div class="user-xp-badge">
          <span class="xp-val" id="memberXP">0</span> <span class="xp-lbl">{localT.xpText}</span>
        </div>
      </div>

      <div class="portal-grid">
        
        <!-- COLUMN LEFT: Card & Sub -->
        <div class="portal-col">
          
          <!-- Virtual Card -->
          <div id="memberCard" class="virtual-card">
            <div class="card-chip"></div>
            <div class="card-logo">AQA SPORTS</div>
            <div class="card-tier-label" id="cardTier">Tier</div>
            <div class="card-number" id="cardId">ID: AQA-0000</div>
            <div class="card-holder" id="cardHolder">NAME</div>
            <div class="card-expiry" id="cardExpiry">Expiry</div>
            <div class="card-qr-box">
              <img id="cardQrCode" src="" alt="Scan QR">
              <span class="qr-tooltip">{localT.scanTooltip}</span>
            </div>
          </div>

          <!-- Subscription Info -->
          <div class="glass-panel portal-widget">
            <h3>{localT.subInfo}</h3>
            
            <div class="sub-details-list">
              <div class="sub-detail-row">
                <span>{localT.subTier}</span>
                <strong id="subTierVal">-</strong>
              </div>
              <div class="sub-detail-row">
                <span>{localT.subPool}</span>
                <strong id="subPoolVal">-</strong>
              </div>
              <div class="sub-detail-row">
                <span>{localT.subCoach}</span>
                <strong id="subCoachVal">-</strong>
              </div>
              <div class="sub-detail-row">
                <span>{localT.subSlot}</span>
                <strong id="subSlotVal">-</strong>
              </div>
              <div class="sub-detail-row">
                <span>{localT.subExpiry}</span>
                <strong id="subExpiryVal">-</strong>
              </div>
            </div>

            <!-- Upgrade/Change Box -->
            <div id="changeSubContainer" class="change-sub-wrap">
              <button id="btnOpenChange" class="portal-btn-secondary">{localT.btnChangeSub}</button>
              
              <!-- Change request pending notice -->
              <div id="changePendingNotice" class="change-pending-notice" style="display: none;">
                &#9888; {localT.changePending}
              </div>

              <!-- Inline Change Form -->
              <form id="changeSubForm" class="change-sub-form" style="display: none;">
                <h4>{localT.changeSubTitle}</h4>
                <p class="form-desc">{localT.changeSubDesc}</p>
                
                <div class="form-group">
                  <label>{localT.labelNewTier}</label>
                  <select id="changeTier" class="form-control" required>
                    <option value="Starter">Starter</option>
                    <option value="Silver">Silver</option>
                    <option value="Gold">Gold</option>
                    <option value="Diamond">Diamond</option>
                  </select>
                </div>

                <div class="form-group">
                  <label>{localT.labelNewPool}</label>
                  <select id="changePool" class="form-control" required>
                    <option value="reghaia">Reghaia</option>
                    <option value="cheraga">Cheraga</option>
                  </select>
                </div>

                <div class="form-group">
                  <label>{localT.labelNewCoach}</label>
                  <input type="text" id="changeCoach" class="form-control" placeholder="Nom du coach desire" required>
                </div>

                <div class="form-group">
                  <label>{localT.labelNewSlot}</label>
                  <input type="text" id="changeSlot" class="form-control" placeholder="Ex: Samedi 21h - 23h" required>
                </div>

                <div class="form-actions">
                  <button type="submit" class="portal-btn-primary">{localT.btnSubmitChange}</button>
                  <button type="button" id="btnCancelChange" class="portal-btn-cancel">{localT.btnCancelChange}</button>
                </div>
              </form>
            </div>

          </div>

        </div>

        <!-- COLUMN RIGHT: Stats, Tech, Badges -->
        <div class="portal-col">
          
          <!-- Presence Tracker -->
          <div class="glass-panel portal-widget">
            <h3>{localT.presenceTracker}</h3>
            <div id="presenceSummaryText" class="presence-summary-text">Summary</div>
            
            <div class="presence-history-timeline">
              <h4>{localT.presenceTimeline}</h4>
              <div id="presenceTimelineBox" class="presence-timeline-grid">
                <!-- Timeline items populate here -->
              </div>
            </div>
          </div>

          <!-- Technical Evaluation -->
          <div class="glass-panel portal-widget">
            <h3>{localT.suiviTechnique}</h3>
            <div id="techEvaluationContainer">
              <div class="tech-progress-group">
                <div class="tech-lbl-row">
                  <span>{localT.techRespiration}</span>
                  <span id="techRespirationVal">0/5</span>
                </div>
                <div class="tech-bar-bg"><div id="techRespirationFill" class="tech-bar-fill"></div></div>
              </div>
              <div class="tech-progress-group">
                <div class="tech-lbl-row">
                  <span>{localT.techKick}</span>
                  <span id="techKickVal">0/5</span>
                </div>
                <div class="tech-bar-bg"><div id="techKickFill" class="tech-bar-fill"></div></div>
              </div>
              <div class="tech-progress-group">
                <div class="tech-lbl-row">
                  <span>{localT.techBras}</span>
                  <span id="techBrasVal">0/5</span>
                </div>
                <div class="tech-bar-bg"><div id="techBrasFill" class="tech-bar-fill"></div></div>
              </div>
              <div class="tech-progress-group">
                <div class="tech-lbl-row">
                  <span>{localT.techEndurance}</span>
                  <span id="techEnduranceVal">0/5</span>
                </div>
                <div class="tech-bar-bg"><div id="techEnduranceFill" class="tech-bar-fill"></div></div>
              </div>

              <div class="coach-comments-box">
                <strong>{localT.coachComments}</strong>
                <p id="techCommentsVal">-</p>
              </div>
            </div>
            <div id="noTechDataBox" style="display: none;" class="no-data-msg">
              {localT.noTechData}
            </div>
          </div>

          <!-- Badges & Achievements -->
          <div class="glass-panel portal-widget">
            <h3>{localT.achievements}</h3>
            <div class="badges-earned-title">{localT.badgesEarned}</div>
            <div id="badgesGrid" class="badges-grid-container">
              <!-- Badges populate here -->
            </div>
          </div>

          <!-- Photo Gallery -->
          <div class="glass-panel portal-widget">
            <h3>{localT.galleryTitle}</h3>
            <div id="galleryGrid" class="gallery-grid-container">
              <!-- Gallery items populate here -->
            </div>
          </div>

        </div>

      </div>
    </div>

    <!-- NON-MEMBER COMMUNITY PORTAL -->
    <div id="stateNonMember" style="display: none;">
      <div class="non-member-hero">
        <h2>{localT.nonMemberTitle}</h2>
        <div class="divider"></div>
        <p>{localT.nonMemberDesc}</p>
        <a href={getRelativePath('/inscription', lang)} class="portal-btn-primary action-btn">
          {localT.btnJoinClub}
        </a>
      </div>

      <div class="portal-grid">
        
        <!-- Interactive Slots Preview -->
        <div class="glass-panel portal-widget">
          <h3>{localT.slotsPreviewTitle}</h3>
          <div class="slots-preview-grid" id="slotsPreviewApp" data-schedule={JSON.stringify(scheduleData)}>
            <!-- Interactive preview populated via JS -->
          </div>
        </div>

        <!-- Club Benefits & Community Gallery -->
        <div class="glass-panel portal-widget">
          <h3>{localT.benefitsTitle}</h3>
          
          <div class="benefits-grid">
            <div class="benefit-card">
              <div class="benefit-icon">&#127946;</div>
              <h4>{localT.benefit1Title}</h4>
              <p>{localT.benefit1Desc}</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">&#128202;</div>
              <h4>{localT.benefit2Title}</h4>
              <p>{localT.benefit2Desc}</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">&#128241;</div>
              <h4>{localT.benefit3Title}</h4>
              <p>{localT.benefit3Desc}</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">&#127941;</div>
              <h4>{localT.benefit4Title}</h4>
              <p>{localT.benefit4Desc}</p>
            </div>
          </div>

        </div>

      </div>
    </div>

  </main>

  <Footer lang={lang} />
</BaseLayout>

<script is:inline define:vars={{ lang, badgeDefinitions, localT }}>
  document.addEventListener('astro:page-load', () => {
    // Redirection helper if token is missing
    const redirectToLogin = () => {
      if (lang === 'fr') window.location.href = '/clients';
      else window.location.href = `/${lang}/clients`;
    };

    const token = localStorage.getItem('aqa_member_token');
    if (!token) {
      redirectToLogin();
      return;
    }

    const loader = document.getElementById('portalLoader');
    const content = document.getElementById('portalContent');
    const statePending = document.getElementById('statePending');
    const stateMember = document.getElementById('stateMember');
    const stateNonMember = document.getElementById('stateNonMember');
    const logoutBtn = document.getElementById('logoutBtn');

    // Handle logout
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => {
        localStorage.removeItem('aqa_member_token');
        localStorage.removeItem('aqa_member_info');
        redirectToLogin();
      });
    }

    // Fetch member profile
    async function fetchProfile() {
      try {
        const response = await fetch('/api/member/profile', {
          method: 'GET',
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });
        
        if (response.status === 401 || response.status === 403) {
          localStorage.removeItem('aqa_member_token');
          redirectToLogin();
          return;
        }

        const data = await response.json();
        if (data.success) {
          renderDashboard(data.profile);
        } else {
          redirectToLogin();
        }
      } catch (e) {
        console.error("Failed to load user profile:", e);
        redirectToLogin();
      } finally {
        if (loader) loader.style.display = 'none';
        if (content) content.style.display = 'block';
      }
    }

    fetchProfile();

    // Render logic
    function renderDashboard(profile) {
      if (profile.status === 'pending') {
        statePending.style.display = 'block';
        return;
      }

      if (!profile.isAqaMember) {
        stateNonMember.style.display = 'block';
        renderNonMemberSlots();
        return;
      }

      // Default Active Member Dashboard
      stateMember.style.display = 'block';
      
      // Basic info
      document.getElementById('memberName').textContent = profile.fullName;
      document.getElementById('memberXP').textContent = profile.xp || 0;

      // Render Membership Card
      const card = document.getElementById('memberCard');
      const tier = profile.membershipTier || 'Starter';
      card.className = `virtual-card card-tier-${tier.toLowerCase()}`;
      document.getElementById('cardTier').textContent = tier.toUpperCase();
      document.getElementById('cardId').textContent = `ID: AQA-${profile.id.slice(0,6).toUpperCase()}`;
      document.getElementById('cardHolder').textContent = profile.fullName;
      
      const expiryDate = profile.subscription?.endDate || '-';
      document.getElementById('cardExpiry').textContent = expiryDate;

      // QR Code pointing to public stats page
      const statsUrl = window.location.origin + `/clients/stats?id=${profile.id}`;
      document.getElementById('cardQrCode').src = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(statsUrl)}`;

      // Subscription Widget
      document.getElementById('subTierVal').textContent = tier;
      document.getElementById('subPoolVal').textContent = profile.subscription?.poolKey === 'reghaia' ? 'Piscine Reghaia' : (profile.subscription?.poolKey === 'cheraga' ? 'Piscine Cheraga' : '-');
      document.getElementById('subCoachVal').textContent = profile.subscription?.coachName || '-';
      document.getElementById('subSlotVal').textContent = profile.subscription?.slotDay && profile.subscription?.slotTime ? `${profile.subscription.slotDay} - ${profile.subscription.slotTime}` : '-';
      document.getElementById('subExpiryVal').textContent = expiryDate;

      // Setup upgrade/change form toggle
      const btnOpenChange = document.getElementById('btnOpenChange');
      const changeSubForm = document.getElementById('changeSubForm');
      const btnCancelChange = document.getElementById('btnCancelChange');
      const changePendingNotice = document.getElementById('changePendingNotice');

      if (profile.subscriptionChangeRequest && profile.subscriptionChangeRequest.status === 'pending') {
        btnOpenChange.style.display = 'none';
        changePendingNotice.style.display = 'block';
      }

      btnOpenChange.addEventListener('click', () => {
        changeSubForm.style.display = 'block';
        btnOpenChange.style.display = 'none';
      });

      btnCancelChange.addEventListener('click', () => {
        changeSubForm.style.display = 'none';
        btnOpenChange.style.display = 'block';
      });

      // Handle change request submit
      changeSubForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const reqData = {
          tier: document.getElementById('changeTier').value,
          poolKey: document.getElementById('changePool').value,
          coachName: document.getElementById('changeCoach').value,
          slotDay: document.getElementById('changeSlot').value.split(' ')[0] || 'Samedi',
          slotTime: document.getElementById('changeSlot').value
        };

        const submitBtn = changeSubForm.querySelector('button[type="submit"]');
        submitBtn.disabled = true;

        try {
          const res = await fetch('/api/member/change-subscription', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(reqData)
          });
          const result = await res.json();
          if (result.success) {
            changeSubForm.style.display = 'none';
            changePendingNotice.style.display = 'block';
          }
        } catch (err) {
          console.error('Failed to submit subscription change request:', err);
        } finally {
          submitBtn.disabled = false;
        }
      });

      // Presence Timeline
      const timelineBox = document.getElementById('presenceTimelineBox');
      timelineBox.innerHTML = '';
      const presenceList = profile.presence || [];
      const presentCount = presenceList.filter(p => p.present).length;
      const totalCount = presenceList.length;
      const percent = totalCount > 0 ? Math.round((presentCount / totalCount) * 100) : 0;

      // Update Presence summary text
      let summaryStr = localT.presenceSummary
        .replace('{present}', presentCount)
        .replace('{total}', totalCount)
        .replace('{percent}', percent);
      document.getElementById('presenceSummaryText').textContent = summaryStr;

      if (presenceList.length === 0) {
        timelineBox.innerHTML = `<div class="no-data-msg">${localT.presenceNoData}</div>`;
      } else {
        // Sort descending by date
        const sortedPresence = [...presenceList].sort((a,b) => new Date(b.date) - new Date(a.date));
        sortedPresence.forEach(item => {
          const block = document.createElement('div');
          block.className = `presence-timeline-item ${item.present ? 'status-present' : 'status-absent'}`;
          
          // Use western standard digits for Arabic dates if scanned
          const dateStr = item.date; 
          
          block.innerHTML = `
            <div class="presence-icon">${item.present ? '&#10004;' : '&#10008;'}</div>
            <div class="presence-info">
              <strong class="presence-date">${dateStr}</strong>
              <span class="presence-status">${item.present ? localT.presencePresent : (item.reason || localT.presenceAbsent)}</span>
            </div>
          `;
          timelineBox.appendChild(block);
        });
      }

      // Technical Evaluation
      const tech = profile.suiviTechnique;
      if (tech && (tech.respiration > 0 || tech.battement > 0 || tech.bras > 0 || tech.endurance > 0 || tech.comments)) {
        document.getElementById('techRespirationVal').textContent = `${tech.respiration}/5`;
        document.getElementById('techRespirationFill').style.width = `${(tech.respiration / 5) * 100}%`;
        
        document.getElementById('techKickVal').textContent = `${tech.kick}/5`;
        document.getElementById('techKickFill').style.width = `${(tech.kick / 5) * 100}%`;

        document.getElementById('techBrasVal').textContent = `${tech.bras}/5`;
        document.getElementById('techBrasFill').style.width = `${(tech.bras / 5) * 100}%`;

        document.getElementById('techEnduranceVal').textContent = `${tech.endurance}/5`;
        document.getElementById('techEnduranceFill').style.width = `${(tech.endurance / 5) * 100}%`;

        document.getElementById('techCommentsVal').textContent = tech.comments || '-';
      } else {
        document.getElementById('techEvaluationContainer').style.display = 'none';
        document.getElementById('noTechDataBox').style.display = 'block';
      }

      // Badges
      const badgesGrid = document.getElementById('badgesGrid');
      badgesGrid.innerHTML = '';
      const userBadges = profile.badges || [];

      Object.keys(badgeDefinitions).forEach(badgeId => {
        const badgeMeta = badgeDefinitions[badgeId];
        const isUnlocked = userBadges.includes(badgeId);
        
        const badgeEl = document.createElement('div');
        badgeEl.className = `badge-item ${isUnlocked ? 'unlocked' : 'locked'}`;
        badgeEl.innerHTML = `
          <div class="badge-icon">${badgeMeta.symbol}</div>
          <div class="badge-name">${badgeMeta.name}</div>
          <div class="badge-desc">${badgeMeta.desc}</div>
        `;
        badgesGrid.appendChild(badgeEl);
      });

      // Gallery
      const galleryGrid = document.getElementById('galleryGrid');
      galleryGrid.innerHTML = '';
      const galleryPhotos = profile.gallery || [];
      if (galleryPhotos.length === 0) {
        galleryGrid.innerHTML = `<div class="no-data-msg">${localT.noGalleryData}</div>`;
      } else {
        galleryPhotos.forEach(url => {
          const wrapper = document.createElement('div');
          wrapper.className = 'gallery-photo-item';
          wrapper.innerHTML = `<img src="${url}" alt="Action Shot" class="gallery-photo">`;
          galleryGrid.appendChild(wrapper);
        });
      }
    }

    // Render available slots interactive grid (for Non-Members)
    function renderNonMemberSlots() {
      const container = document.getElementById('slotsPreviewApp');
      if (!container) return;
      
      const schedule = JSON.parse(container.dataset.schedule || '{}');
      container.innerHTML = '';

      Object.keys(schedule).forEach(poolKey => {
        const pool = schedule[poolKey];
        if (!pool || !pool.categories) return;

        const poolCard = document.createElement('div');
        poolCard.className = 'pool-preview-card glass-panel';
        
        let poolTitle = pool.name || poolKey;
        if (poolKey === 'reghaia') poolTitle = lang === 'ar' ? 'مسبح الرغاية' : 'Piscine Reghaia';
        else if (poolKey === 'cheraga') poolTitle = lang === 'ar' ? 'مسبح الشراقة' : 'Piscine Cheraga';
        
        let poolHtml = `<h4>${poolTitle}</h4><div class="pool-slots-list">`;

        let slotsFound = false;

        Object.keys(pool.categories).forEach(catKey => {
          const category = pool.categories[catKey];
          if (!category || !category.coaches) return;

          category.coaches.forEach(coach => {
            if (!coach.slots) return;
            coach.slots.forEach(slot => {
              slotsFound = true;
              const remaining = slot.total - slot.taken;
              const isFull = remaining <= 0;
              
              let statusClass = isFull ? 'slot-full' : (remaining <= 3 ? 'slot-low' : 'slot-available');
              let placesText = '';
              if (isFull) {
                placesText = localT.slotFull;
              } else {
                const suffix = remaining > 1 ? localT.placesLeftPlural : localT.placesLeft;
                placesText = `${remaining} ${suffix}`;
              }

              poolHtml += `
                <div class="slot-preview-item ${statusClass}">
                  <span class="slot-time">${slot.day} - ${slot.time}</span>
                  <span class="slot-coach">${coach.name}</span>
                  <span class="slot-count">${placesText}</span>
                </div>
              `;
            });
          });
        });

        if (!slotsFound) {
          poolHtml += `<div class="no-data-msg">Aucun creneau disponible.</div>`;
        }

        poolHtml += '</div>';
        poolCard.innerHTML = poolHtml;
        container.appendChild(poolCard);
      });
    }

  });
</script>

