    object-fit: contain;
  }
  .qr-tooltip {
    position: absolute;
    bottom: 125%;
    left: 50%;
    transform: translateX(-50%);
    background: #000;
    color: var(--color-teal);
    font-size: 0.7rem;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    border: 1px solid rgba(0, 242, 255, 0.3);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: var(--transition-smooth);
  }
  .card-qr-box:hover .qr-tooltip {
    opacity: 1;
    bottom: 115%;
  }

  /* Holographic Tier Colors */
  .card-tier-starter {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_starter.png') no-repeat center center / cover;
    box-shadow: 0 0 25px rgba(0, 242, 255, 0.15);
  }
  .card-tier-silver {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_silver.png') no-repeat center center / cover;
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 0 25px rgba(255, 255, 255, 0.15);
  }
  .card-tier-gold {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_gold.png') no-repeat center center / cover;
    border-color: rgba(245, 158, 11, 0.4);
    box-shadow: 0 0 30px rgba(245, 158, 11, 0.25);
  }
  .card-tier-diamond {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_diamond.png') no-repeat center center / cover;
    border-color: rgba(168, 85, 247, 0.5);
    box-shadow: 0 0 35px rgba(168, 85, 247, 0.4);
  }
  .card-tier-emerald {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_emerald.png') no-repeat center center / cover;
    border-color: rgba(16, 185, 129, 0.5);
    box-shadow: 0 0 35px rgba(16, 185, 129, 0.4);
  }

  /* Subscription Widget details */
  .sub-details-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .sub-detail-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    padding-bottom: 0.5rem;
  }
  .sub-detail-row span {
    color: var(--text-secondary);
  }
  .sub-detail-row strong {
    color: #fff;
  }

  /* Upgrade change request styling */
  .change-sub-wrap {
    margin-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1.5rem;
  }
  .change-sub-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
    background: rgba(0,0,0,0.2);
    padding: 1.25rem;
    border-radius: 12px;
    border: var(--border-glass);
  }
  .change-sub-form h4 {
    font-size: 1rem;
    color: #fff;
  }
  .form-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: -0.5rem;
  }
  .form-actions {
    display: flex;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }
  .portal-btn-cancel {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--text-secondary);
    border-radius: 50px;
    padding: 0.6rem 1.2rem;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    transition: var(--transition-smooth);
  }
  .portal-btn-cancel:hover {
    background: rgba(255,255,255,0.05);
    color: #fff;
  }
  .change-pending-notice {
    background: rgba(243, 156, 18, 0.08);
    border: 1px solid rgba(243, 156, 18, 0.25);
    color: #f39c12;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  /* Presence tracking stats UI */
  .presence-stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
    background: rgba(255, 255, 255, 0.01);
    border-radius: 16px;
    padding: 1.5rem;
    border: var(--border-glass);
  }
  .circular-progress {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 0 auto 1rem auto;
  }
  .progress-ring {
    transform: rotate(-90deg);
  }
  .progress-ring-circle {
    stroke-dasharray: 314.16;
    stroke-dashoffset: 314.16;
    transition: stroke-dashoffset 0.8s ease-in-out;
    stroke-linecap: round;
  }
  .progress-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    color: #fff;
  }
  .presence-summary-text-center {
    font-weight: 700;
    font-size: 1.05rem;
    color: #fff;
    text-align: center;
  }

  /* Presence Timeline */
  .presence-history-timeline h4 {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }
  .presence-timeline-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 1rem;
  }
  .presence-timeline-item {
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: var(--border-glass);
  }
  .presence-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .status-present {
    border-left: 3px solid #10b981;
  }
  .status-present .presence-icon {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
  }
  .status-absent {
    border-left: 3px solid #ef4444;
  }
  .status-absent .presence-icon {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }
  .presence-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .presence-date {
    font-size: 0.8rem;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .presence-status {
    font-size: 0.75rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Technical Skill Bars */
  .tech-progress-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .tech-lbl-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .tech-bar-bg {
    height: 8px;
    background: rgba(255,255,255,0.03);
    border: var(--border-glass);
    border-radius: 50px;
    overflow: hidden;
  }
  .tech-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-blue), var(--color-teal));
    border-radius: 50px;
    box-shadow: 0 0 10px rgba(0, 242, 255, 0.4);
    width: 0;
    transition: width 0.8s ease-in-out;
  }
  .coach-comments-box {
    margin-top: 1.5rem;
    background: rgba(0, 242, 255, 0.02);
    border-left: 3px solid var(--color-teal);
    border-radius: 0 10px 10px 0;
    padding: 1rem 1.25rem;
  }
  .coach-comments-box strong {
    display: block;
    font-size: 0.85rem;
    color: var(--color-teal);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .coach-comments-box p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-primary);
  }

  /* Badges earned */
  .badges-earned-title {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1.25rem;
  }
  .badges-grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 1.25rem;
  }
  .badge-item {
    background: rgba(255, 255, 255, 0.015);
    border: var(--border-glass);
    border-radius: 16px;
    padding: 1.25rem 0.75rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: var(--transition-smooth);
  }
  .badge-icon-svg {
    margin-bottom: 0.25rem;
    transition: var(--transition-smooth);
    color: var(--text-muted);
  }
  .badge-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    color: #fff;
  }
  .badge-desc {
    font-size: 0.7rem;
    color: var(--text-secondary);
    line-height: 1.3;
  }
  .badge-item.unlocked .badge-icon-svg {
    color: var(--color-teal);
    filter: drop-shadow(0 0 8px rgba(0, 242, 255, 0.35));
  }
  .badge-item.unlocked:hover {
    border-color: var(--color-teal);
    box-shadow: var(--shadow-glow);
    transform: translateY(-3px);
  }
  .badge-item.unlocked:hover .badge-icon-svg {
    transform: scale(1.15);
  }
  .badge-item.locked {
    opacity: 0.25;
    cursor: not-allowed;
  }

  /* Gallery Photos */
  .gallery-grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 1rem;
  }
  .gallery-photo-item {
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    border: var(--border-glass);
    cursor: pointer;
    transition: var(--transition-smooth);
  }
  .gallery-photo-item:hover {
    transform: scale(1.05);
    border-color: var(--color-teal);
    box-shadow: 0 0 15px rgba(0, 242, 255, 0.3);
  }
  .gallery-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Action Lightbox full screen modal */
  .lightbox-overlay {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    background: rgba(3, 7, 18, 0.95);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-close {
    position: absolute;
    top: 2rem; right: 2rem;
    background: transparent;
    border: none;
    font-size: 3rem;
    color: #fff;
    cursor: pointer;
    z-index: 2001;
    transition: var(--transition-smooth);
  }
  .lightbox-close:hover {
    color: var(--color-teal);
    transform: scale(1.1);
  }
  .lightbox-content {
    max-width: 90%;
    max-height: 85%;
    border-radius: 16px;
    overflow: hidden;
    border: var(--border-glass);
    box-shadow: 0 10px 30px rgba(0,0,0,0.8);
    animation: zoomIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .lightbox-content img {
    max-width: 100%;
    max-height: 80vh;
    display: block;
    object-fit: contain;
  }
  @keyframes zoomIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Non-Member Views */
  .non-member-welcome-bar {
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .non-member-hero-banner {
    text-align: center;
    background: linear-gradient(135deg, rgba(0, 136, 255, 0.08), rgba(0, 242, 255, 0.04));
    border: 1px solid rgba(0, 242, 255, 0.2);
    border-radius: 20px;
    padding: 3rem 2rem;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .non-member-hero-banner p {
    font-size: 1.15rem;
    line-height: 1.6;
    max-width: 750px;
    margin: 0;
  }
  .widget-subtitle {
    font-size: 1.4rem;
    color: #fff;
    margin-bottom: 1.5rem;
    border-left: 3px solid var(--color-teal);
    padding-left: 0.75rem;
  }

  /* Sports Catalog Cards */
  .sports-catalog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  .sport-catalog-card {
    background: rgba(15, 23, 42, 0.4);
    border-radius: 20px;
    overflow: hidden;
    border: var(--border-glass);
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
  }
  .sport-catalog-card:hover {
    border-color: rgba(0, 242, 255, 0.25);
    box-shadow: var(--shadow-glow);
    transform: translateY(-5px);
  }
  .sport-card-image {
    height: 180px;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .sport-card-image::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; width: 100%; height: 50%;
    background: linear-gradient(to top, rgba(15, 23, 42, 1), transparent);
  }
  .sport-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
    justify-content: space-between;
    background: rgba(15, 23, 42, 0.6);
  }
  .sport-card-content h4 {
    font-size: 1.25rem;
    margin: 0;
    color: #fff;
  }
  .sport-card-content p {
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    color: var(--text-secondary);
  }
  .sport-card-btn {
    background: rgba(0, 242, 255, 0.05);
    border: 1px solid rgba(0, 242, 255, 0.2);
    color: var(--color-teal);
    font-family: var(--font-display);
    font-weight: 700;
    padding: 0.65rem 1.25rem;
    border-radius: 50px;
    cursor: pointer;
    transition: var(--transition-smooth);
    width: 100%;
    margin-top: 0.5rem;
  }
  .sport-card-btn:hover {
    background: linear-gradient(135deg, var(--color-blue), var(--color-teal));
    color: #000;
    border-color: transparent;
    box-shadow: 0 4px 15px rgba(0, 242, 255, 0.35);
  }

  /* Benefits */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .benefit-card {
    background: rgba(0,0,0,0.25);
    border-radius: 16px;
    padding: 1.5rem;
    border: var(--border-glass);
    transition: var(--transition-smooth);
  }
  .benefit-card:hover {
    border-color: rgba(0, 242, 255, 0.15);
    transform: translateY(-2px);
  }
  .benefit-card-icon {
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .benefit-card h4 {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 0.5rem;
  }
  .benefit-card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* WIZARD CONTAINER AND COMPONENT */
  .wizard-container {
    max-width: 750px;
    margin: 0 auto;
    padding: 2.5rem;
    box-shadow: 0 15px 40px rgba(0,0,0,0.6);
  }
  .wizard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .wizard-step-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-weight: 600;
    font-family: var(--font-display);
    font-size: 0.85rem;
    transition: var(--transition-smooth);
  }
  .step-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
  }
  .wizard-step-indicator.active {
    color: var(--color-teal);
  }
  .wizard-step-indicator.active .step-num {
    border-color: var(--color-teal);
    background: rgba(0, 242, 255, 0.1);
    box-shadow: 0 0 10px rgba(0, 242, 255, 0.2);
  }

  /* Wizard Content step panels */
  .wizard-step-content {
    display: none;
    animation: fadeIn 0.4s ease-out forwards;
  }
  .wizard-step-content.active {
    display: block;
  }
  .wizard-step-content h3 {
    font-size: 1.3rem;
    color: #fff;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  /* Option selection cards for Steps 1, 2, 3 */
  .wizard-selection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 1.25rem;
  }
  .grid-formula {
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  }
  .wizard-option-card {
    background: rgba(0, 0, 0, 0.25);
    border-radius: 16px;
    border: var(--border-glass);
    padding: 1.5rem 1rem;
    text-align: center;
    cursor: pointer;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    position: relative;
  }
  .wizard-option-card:hover {
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.02);
  }
  .wizard-option-card.selected {
    border-color: var(--color-teal);
    background: rgba(0, 242, 255, 0.03);
    box-shadow: var(--shadow-glow);
  }
  .option-icon {
    color: var(--text-secondary);
    transition: var(--transition-smooth);
  }
  .wizard-option-card.selected .option-icon {
    color: var(--color-teal);
  }
  .wizard-option-card h4 {
    font-size: 0.95rem;
    margin: 0;
    color: #fff;
  }
  .wizard-option-card p {
    font-size: 0.75rem;
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.3;
  }

  /* Formula specific properties */
  .formula-badge {
    background: rgba(255,255,255,0.05);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--text-secondary);
  }
  .formula-price {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--color-teal);
  }
  .formula-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: var(--text-secondary);
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 0.75rem;
    width: 100%;
  }
  .text-gold {
    color: #fbbf24 !important;
    background: rgba(245, 158, 11, 0.1) !important;
  }
  .text-purple {
    color: #c084fc !important;
    background: rgba(168, 85, 247, 0.1) !important;
  }

  /* Step 4 Form controls */
  .wizard-form-group {
    max-width: 450px;
    margin: 2rem auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .wizard-form-group label {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .form-control {
    width: 100%;
    background: rgba(0, 0, 0, 0.4);
    border: var(--border-glass);
    border-radius: 10px;
    padding: 0.8rem 1.2rem;
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: var(--transition-smooth);
    outline: none;
  }
  .form-control:focus {
    border-color: var(--color-teal);
    box-shadow: 0 0 10px rgba(0, 242, 255, 0.2);
  }

  /* Step 5 Validation Checkbox styling */
  .wizard-validation-panel {
    background: rgba(0, 0, 0, 0.25);
    padding: 2rem;
    border-radius: 16px;
    max-width: 550px;
    margin: 0 auto;
  }
  .rules-header {
    font-size: 0.95rem;
    color: #fff;
    margin-bottom: 1.25rem;
  }
  .rules-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .checkbox-container {
    display: flex;
    position: relative;
    padding-left: 35px;
    cursor: pointer;
    font-size: 0.88rem;
    user-select: none;
    align-items: flex-start;
  }
  .checkbox-container input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0; width: 0;
  }
  .checkbox-checkmark {
    position: absolute;
    top: 2px;
    left: 0;
    height: 20px;
    width: 20px;
    background-color: rgba(255,255,255,0.05);
    border: var(--border-glass);
    border-radius: 5px;
    transition: var(--transition-smooth);
  }
  .checkbox-container:hover input ~ .checkbox-checkmark {
    background-color: rgba(255,255,255,0.1);
  }
  .checkbox-container input:checked ~ .checkbox-checkmark {
    background-color: var(--color-teal);
    border-color: transparent;
  }
  .checkbox-checkmark:after {
    content: "";
    position: absolute;
    display: none;
  }
  .checkbox-container input:checked ~ .checkbox-checkmark:after {
    display: block;
  }
  .checkbox-container .checkbox-checkmark:after {
    left: 7px;
    top: 3px;
    width: 6px;
