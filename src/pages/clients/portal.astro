  .hero-stat-chip.gold .chip-val { color: #ffd700; text-shadow: 0 0 12px rgba(255,215,0,0.4); }
  .hero-stat-chip.purple .chip-val { color: #c4b5fd; }
  .chip-lbl { font-size: 0.62rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 1.2px; font-weight: 600; }

  /* ── TAB PANELS ────────────────────────────── */
  .tab-panels-wrapper { padding: 2rem 2.5rem 4rem; }
  .tab-panel { display: none; }
  .tab-panel.active {
    display: block;
    animation: panelSlide 0.3s ease-out forwards;
  }
  @keyframes panelSlide {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── PROFILE TAB ────────────────────────────── */
  .profile-top-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 2rem;
  }
  .profile-card-col { flex-shrink: 0; }
  .sub-details-panel {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sub-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .sub-panel-header h3 { margin: 0; font-size: 1rem; color: var(--color-teal); }
  .sub-details-grid { display: flex; flex-direction: column; gap: 0.9rem; }
  .sub-detail-item {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.04);
    transition: border-color 0.2s;
  }
  .sub-detail-item:hover { border-color: rgba(0,242,255,0.15); }
  .sub-detail-icon {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(0,242,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-teal);
  }
  .sub-detail-body { display: flex; flex-direction: column; gap: 0.2rem; }
  .sub-detail-lbl { font-size: 0.7rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.8px; }
  .sub-detail-val { font-size: 0.9rem; font-weight: 700; color: #fff; }
  .change-pending-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: #fbbf24;
    background: rgba(251,191,36,0.08);
    border: 1px solid rgba(251,191,36,0.2);
    border-radius: 8px;
    padding: 0.6rem 1rem;
  }

  .profile-bottom-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 0;
  }
  .personal-info-widget, .password-change-widget {
    padding: 1.75rem;
  }
  .widget-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0,242,255,0.08);
    position: relative;
  }
  .widget-header::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, var(--color-teal), transparent);
    border-radius: 2px;
  }
  .widget-icon-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-teal);
  }
  .widget-icon-title h3 { margin: 0; font-size: 1rem; font-weight: 700; }
  .widget-desc { font-size: 0.82rem; color: rgba(255,255,255,0.4); margin: 0.5rem 0 1.25rem; }

  /* Floating label inputs */
  .floating-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .floating-field {
    position: relative;
  }
  .floating-field .form-control {
    width: 100%;
    padding: 1.1rem 1rem 0.4rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #fff;
    font-size: 0.9rem;
    font-family: var(--font-display);
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .floating-field select.form-control { padding-top: 1.1rem; }
  .floating-field .form-control:focus {
    outline: none;
    border-color: var(--color-teal);
    box-shadow: 0 0 0 3px rgba(0,242,255,0.1);
  }
  .floating-field label {
    position: absolute;
    top: 0.4rem;
    left: 1rem;
    font-size: 0.68rem;
    color: var(--color-teal);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 600;
    pointer-events: none;
  }
  .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  /* Buttons */
  .btn-primary-glow {
    padding: 0.9rem 2rem;
    background: linear-gradient(135deg, #0066cc, #00c8ff);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.2s;
    box-shadow: 0 4px 20px rgba(0,136,255,0.25);
  }
  .btn-primary-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.4s;
  }
  .btn-primary-glow:hover::after { transform: translateX(100%); }
  .btn-primary-glow:hover { box-shadow: 0 6px 25px rgba(0,136,255,0.4); transform: translateY(-1px); }
  .btn-outline-teal {
    padding: 0.6rem 1.25rem;
    background: transparent;
    border: 1px solid rgba(0,242,255,0.35);
    border-radius: 8px;
    color: var(--color-teal);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-outline-teal:hover { background: rgba(0,242,255,0.08); }
  .btn-ghost {
    padding: 0.85rem 1.5rem;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    color: rgba(255,255,255,0.5);
    font-family: var(--font-display);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.25); color: #fff; }
  .full-width-btn { width: 100%; }
  .form-actions { display: flex; gap: 1rem; }

  /* History section inside password widget */
  .membership-history-wrap { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.06); }
  .history-section-title { font-size: 0.85rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; margin: 0 0 1rem; }

  /* ── TECH PANEL ─────────────────────────────── */
  .tech-panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .tech-presence-card, .tech-skills-card { padding: 1.75rem; }

  /* Circular progress ring */
  .presence-ring-block {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin: 1.25rem 0;
  }
  .circular-progress-wrap {
    position: relative;
    width: 120px;
    height: 120px;
    flex-shrink: 0;
  }
  .progress-ring-svg { width: 120px; height: 120px; transform: rotate(-90deg); }
  .progress-ring-bg { fill: none; stroke: rgba(255,255,255,0.06); }
  .progress-ring-fill {
    fill: none;
    stroke: var(--color-teal, #00f2ff);
    stroke-linecap: round;
    filter: drop-shadow(0 0 6px rgba(0,242,255,0.5));
  }
  .ring-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .ring-pct { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: #fff; line-height: 1; }
  .ring-sub { font-size: 0.65rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; }
  .presence-summary-block { font-size: 0.82rem; color: rgba(255,255,255,0.5); line-height: 1.6; }

  /* Heatmap */
  .presence-heatmap { margin-top: 1.5rem; }
  .heatmap-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.35); margin: 0 0 0.75rem; }
  .heatmap-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 4px;
  }
  .heatmap-cell {
    aspect-ratio: 1;
    border-radius: 3px;
    transition: transform 0.15s, box-shadow 0.15s;
    cursor: default;
  }
  .heatmap-cell:hover { transform: scale(1.4); }
  .hm-present {
    background: rgba(0,242,255,0.55);
    box-shadow: 0 0 5px rgba(0,242,255,0.35);
  }
  .hm-absent { background: rgba(255,255,255,0.06); }
  /* Heatmap Legend */
  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.75rem;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .heatmap-legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .heatmap-dot {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* Skill bars */
  .skill-bar-group { margin-bottom: 1.25rem; }
  .skill-bar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem; }
  .skill-name { font-size: 0.82rem; color: rgba(255,255,255,0.7); font-weight: 600; }
  .skill-score { font-size: 0.78rem; color: var(--color-teal); font-weight: 700; font-family: var(--font-display); }
  .skill-track {
    height: 8px;
    background: rgba(255,255,255,0.06);
    border-radius: 99px;
    overflow: hidden;
  }
  .skill-fill {
    height: 100%;
    background: linear-gradient(90deg, #0088ff, #00f2ff);
    border-radius: 99px;
    transition: width 1s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 0 0 8px rgba(0,242,255,0.3);
  }
  .coach-comment-card {
    margin-top: 1.75rem;
    padding: 1.25rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
  }
  .coach-comment-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-teal);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .coach-comment-text { font-size: 0.875rem; color: rgba(255,255,255,0.6); line-height: 1.6; margin: 0; }

  /* ── REWARDS PANEL ──────────────────────────── */
  .rewards-panel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .badges-widget, .gallery-widget { padding: 1.75rem; }
  .badges-hex-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
    min-height: 120px;
    align-content: flex-start;
  }
  /* Badge item styles */
  .badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    width: 72px;
    cursor: default;
  }
  .badge-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(0,242,255,0.07);
    border: 1px solid rgba(0,242,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    transition: all 0.2s;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }
  .badge-item:hover .badge-icon-wrap {
    border-color: rgba(0,242,255,0.5);
    box-shadow: 0 0 16px rgba(0,242,255,0.2);
    transform: translateY(-2px);
  }
  .badge-name {
    font-size: 0.6rem;
    color: rgba(255,255,255,0.5);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.3;
  }
  .badge-item.locked .badge-icon-wrap {
    background: rgba(255,255,255,0.03);
    border-color: rgba(255,255,255,0.06);
    filter: grayscale(1);
    opacity: 0.4;
  }
  /* Empty state for badges and gallery */
  .empty-state-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2.5rem 1rem;
    color: rgba(255,255,255,0.25);
    text-align: center;
    width: 100%;
  }
  .empty-state-block svg { opacity: 0.3; }
  .empty-state-block p { font-size: 0.82rem; line-height: 1.5; margin: 0; }
  .gallery-masonry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 1rem;
    min-height: 120px;
  }
  .gallery-img-card {
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    position: relative;
    transition: all 0.2s;
  }
  .gallery-img-card:hover { border-color: rgba(0,242,255,0.2); transform: scale(1.02); }
  .gallery-img-card img { width: 100%; height: 100%; object-fit: cover; }

  /* ── TOOLS PANEL ─────────────────────────────── */
  .tools-panel { padding: 1.75rem; }
  .tools-grid-premium { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 1.5rem; }
  .tool-card-premium {
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.03);
    overflow: hidden;
    transition: all 0.25s;
    position: relative;
  }
  .tool-card-premium:hover {
    border-color: rgba(0,242,255,0.2);
    background: rgba(0,242,255,0.04);
    transform: translateY(-3px);
  }
  .tool-card-inner { padding: 1.75rem 1.5rem; text-align: center; }
  .tool-glow-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(0,242,255,0.08);
    border: 1px solid rgba(0,242,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: var(--color-teal);
    transition: box-shadow 0.2s;
  }
  .tool-card-premium:hover .tool-glow-icon { box-shadow: 0 0 20px rgba(0,242,255,0.2); }
  .tool-card-inner h4 { margin: 0 0 0.5rem; font-size: 0.95rem; color: #fff; }
  .tool-card-inner p { font-size: 0.78rem; color: rgba(255,255,255,0.4); line-height: 1.5; margin: 0 0 1rem; }
  .tool-coming-pill {
    display: inline-block;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    background: rgba(251,191,36,0.1);
    border: 1px solid rgba(251,191,36,0.25);
    color: #fbbf24;
    font-weight: 700;
  }

  /* ── CHANGE SUB PANEL ────────────────────────── */
  .change-sub-panel { padding: 1.75rem; margin-bottom: 2rem; }
  .change-sub-form { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1.25rem; }
  .panel-desc { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin: 0.5rem 0 0; }

  /* Alert box */
  .alert-box {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.82rem;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.7);
  }

  /* ── MOBILE BOTTOM NAV ──────────────────────── */
  .mobile-bottom-nav { display: none; }

  /* ── CORE LAYOUT (keep) ─────────────────────── */
  .portal-main {
    padding-top: 3rem;
    padding-bottom: 5rem;
    min-height: 80vh;
  }

  .state-panel {
    max-width: 600px;
    margin: 4rem auto;
    padding: 3rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .state-icon-svg {
    color: var(--color-teal);
    animation: pulse 2s infinite ease-in-out;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.08); opacity: 1; }
  }

  .portal-welcome-bar, .non-member-welcome-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .portal-welcome-bar h2, .non-member-welcome-bar h2 {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0;
  }
  .user-xp-badge {
    background: linear-gradient(135deg, rgba(0, 136, 255, 0.15), rgba(0, 242, 255, 0.15));
    border: var(--border-active);
    border-radius: 50px;
    padding: 0.4rem 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: var(--shadow-glow);
    margin-top: 0.5rem;
  }
  .xp-val {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--color-teal);
  }
  .xp-lbl {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-secondary);
  }

  /* Navigation Tabs */
  .tab-navigation {
    padding: 0.35rem;
    border-radius: 50px;
    display: flex;
    gap: 0.25rem;
    background: rgba(15, 23, 42, 0.4);
    border: var(--border-glass);
  }
  .tab-btn {
    background: transparent;
    border: none;
    color: var(--text-secondary);
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: var(--transition-smooth);
  }
  .tab-btn:hover {
    color: #fff;
  }
  .tab-btn.active {
    background: linear-gradient(135deg, var(--color-blue), var(--color-teal));
    color: #000;
    font-weight: 700;
    box-shadow: 0 4px 15px rgba(0, 242, 255, 0.25);
  }

  /* Tab panels wrapper */
  .tab-panels-wrapper {
    position: relative;
    width: 100%;
  }
  .tab-panel {
    display: none;
    animation: fadeIn 0.4s ease-out forwards;
  }
  .tab-panel.active {
    display: block;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Dashboard Grid */
  .portal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .portal-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .portal-widget {
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  .portal-widget h3 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    color: var(--color-teal);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.75rem;
  }

  /* Virtual Membership Card styling with shine */
  .virtual-card {
    width: 100%;
    max-width: 370px;
    aspect-ratio: 5 / 3;
    border-radius: 20px;
    padding: 1.5rem;
    position: relative;
    color: #fff;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 15px 35px rgba(0,0,0,0.8);
    border: 1px solid rgba(255, 255, 255, 0.15);
    transform-style: preserve-3d;
    perspective: 1000px;
    transition: transform 0.1s ease, box-shadow 0.3s ease;
  }
  .card-shine {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at var(--shine-x, 50%) var(--shine-y, 50%), rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0) 65%);
    pointer-events: none;
    mix-blend-mode: overlay;
    z-index: 2;
    transition: opacity 0.3s ease;
    opacity: 0;
  }
  .virtual-card:hover .card-shine {
    opacity: 1;
  }
  .virtual-card > * {
    position: relative;
    z-index: 3;
  }
  .card-chip {
    display: none;
  }
  .card-logo {
    display: none;
  }
  .card-tier-label {
    position: absolute;
    left: 45%;
    top: 22%;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 2px;
    color: var(--color-teal);
    text-transform: uppercase;
    opacity: 0.95;
  }
  .card-number {
    position: absolute;
    left: 45%;
    top: 54%;
    font-family: monospace;
    font-size: 0.82rem;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    margin: 0;
  }
  .card-holder {
    position: absolute;
    left: 45%;
    top: 38%;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 50%;
  }
  .card-expiry {
    position: absolute;
    left: 45%;
    top: 68%;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }
  .card-qr-box {
    position: absolute;
    left: 9%;
    top: 50%;
    transform: translateY(-50%);
    width: 22%;
    height: 22%;
    background: #fff;
    padding: 3px;
    border-radius: 6px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    cursor: pointer;
    transition: var(--transition-smooth);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-qr-box img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .qr-tooltip {
    position: absolute;
    bottom: 125%;
    left: 50%;
    transform: translateX(-50%);
    background: #000;
    color: var(--color-teal);
    font-size: 0.7rem;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    border: 1px solid rgba(0, 242, 255, 0.3);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: var(--transition-smooth);
  }
  .card-qr-box:hover .qr-tooltip {
    opacity: 1;
    bottom: 115%;
  }

  /* Holographic Tier Colors */
  .card-tier-starter {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_starter.png') no-repeat center center / cover;
    box-shadow: 0 0 25px rgba(0, 242, 255, 0.15);
  }
  .card-tier-silver {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_silver.png') no-repeat center center / cover;
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 0 25px rgba(255, 255, 255, 0.15);
  }
  .card-tier-gold {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_gold.png') no-repeat center center / cover;
    border-color: rgba(245, 158, 11, 0.4);
    box-shadow: 0 0 30px rgba(245, 158, 11, 0.25);
  }
  .card-tier-diamond {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_diamond.png') no-repeat center center / cover;
    border-color: rgba(168, 85, 247, 0.5);
    box-shadow: 0 0 35px rgba(168, 85, 247, 0.4);
  }
  .card-tier-emerald {
    background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35)), url('/images/card_emerald.png') no-repeat center center / cover;
    border-color: rgba(16, 185, 129, 0.5);
    box-shadow: 0 0 35px rgba(16, 185, 129, 0.4);
  }

  /* Subscription Widget details */
  .sub-details-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .sub-detail-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    padding-bottom: 0.5rem;
  }
  .sub-detail-row span {
    color: var(--text-secondary);
  }
  .sub-detail-row strong {
    color: #fff;
  }

  /* Upgrade change request styling */
  .change-sub-wrap {
    margin-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1.5rem;
  }
  .change-sub-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
    background: rgba(0,0,0,0.2);
    padding: 1.25rem;
    border-radius: 12px;
    border: var(--border-glass);
  }
  .change-sub-form h4 {
    font-size: 1rem;
    color: #fff;
  }
  .form-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: -0.5rem;
  }
  .form-actions {
    display: flex;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }
  .portal-btn-cancel {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--text-secondary);
    border-radius: 50px;
    padding: 0.6rem 1.2rem;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    transition: var(--transition-smooth);
  }
  .portal-btn-cancel:hover {
    background: rgba(255,255,255,0.05);
    color: #fff;
  }
  .change-pending-notice {
    background: rgba(243, 156, 18, 0.08);
    border: 1px solid rgba(243, 156, 18, 0.25);
    color: #f39c12;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  /* Presence tracking stats UI */
  .presence-stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
    background: rgba(255, 255, 255, 0.01);
    border-radius: 16px;
    padding: 1.5rem;
    border: var(--border-glass);
  }
  .circular-progress {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 0 auto 1rem auto;
  }
  .progress-ring {
    transform: rotate(-90deg);
  }
  .progress-ring-circle {
    stroke-dasharray: 314.16;
    stroke-dashoffset: 314.16;
    transition: stroke-dashoffset 0.8s ease-in-out;
    stroke-linecap: round;
  }
  .progress-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    color: #fff;
  }
  .presence-summary-text-center {
    font-weight: 700;
    font-size: 1.05rem;
    color: #fff;
    text-align: center;
  }

  /* Presence Timeline */
  .presence-history-timeline h4 {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }
  .presence-timeline-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 1rem;
  }
  .presence-timeline-item {
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: var(--border-glass);
  }
  .presence-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .status-present {
    border-left: 3px solid #10b981;
  }
  .status-present .presence-icon {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
  }
  .status-absent {
    border-left: 3px solid #ef4444;
  }
  .status-absent .presence-icon {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }
  .presence-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .presence-date {
    font-size: 0.8rem;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .presence-status {
    font-size: 0.75rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Technical Skill Bars */
  .tech-progress-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .tech-lbl-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .tech-bar-bg {
    height: 8px;
    background: rgba(255,255,255,0.03);
    border: var(--border-glass);
    border-radius: 50px;
    overflow: hidden;
  }
  .tech-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-blue), var(--color-teal));
    border-radius: 50px;
    box-shadow: 0 0 10px rgba(0, 242, 255, 0.4);
    width: 0;
    transition: width 0.8s ease-in-out;
  }
  .coach-comments-box {
    margin-top: 1.5rem;
    background: rgba(0, 242, 255, 0.02);
    border-left: 3px solid var(--color-teal);
    border-radius: 0 10px 10px 0;
    padding: 1rem 1.25rem;
  }
  .coach-comments-box strong {
    display: block;
    font-size: 0.85rem;
    color: var(--color-teal);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .coach-comments-box p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-primary);
  }

  /* Badges earned */
  .badges-earned-title {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1.25rem;
  }
  .badges-grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 1.25rem;
  }
  .badge-item {
    background: rgba(255, 255, 255, 0.015);
    border: var(--border-glass);
    border-radius: 16px;
    padding: 1.25rem 0.75rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: var(--transition-smooth);
  }
  .badge-icon-svg {
    margin-bottom: 0.25rem;
    transition: var(--transition-smooth);
    color: var(--text-muted);
  }
  .badge-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    color: #fff;
  }
  .badge-desc {
    font-size: 0.7rem;
    color: var(--text-secondary);
    line-height: 1.3;
  }
  .badge-item.unlocked .badge-icon-svg {
    color: var(--color-teal);
    filter: drop-shadow(0 0 8px rgba(0, 242, 255, 0.35));
  }
  .badge-item.unlocked:hover {
    border-color: var(--color-teal);
    box-shadow: var(--shadow-glow);
    transform: translateY(-3px);
  }
  .badge-item.unlocked:hover .badge-icon-svg {
    transform: scale(1.15);
  }
  .badge-item.locked {
    opacity: 0.25;
    cursor: not-allowed;
  }

  /* Gallery Photos */
  .gallery-grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 1rem;
  }
  .gallery-photo-item {
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    border: var(--border-glass);
    cursor: pointer;
    transition: var(--transition-smooth);
  }
  .gallery-photo-item:hover {
    transform: scale(1.05);
    border-color: var(--color-teal);
    box-shadow: 0 0 15px rgba(0, 242, 255, 0.3);
  }
  .gallery-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Action Lightbox full screen modal */
  .lightbox-overlay {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    background: rgba(3, 7, 18, 0.95);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-close {
    position: absolute;
    top: 2rem; right: 2rem;
    background: transparent;
    border: none;
    font-size: 3rem;
    color: #fff;
    cursor: pointer;
    z-index: 2001;
    transition: var(--transition-smooth);
  }
  .lightbox-close:hover {
    color: var(--color-teal);
    transform: scale(1.1);
  }
  .lightbox-content {
    max-width: 90%;
    max-height: 85%;
    border-radius: 16px;
    overflow: hidden;
    border: var(--border-glass);
    box-shadow: 0 10px 30px rgba(0,0,0,0.8);
    animation: zoomIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .lightbox-content img {
    max-width: 100%;
    max-height: 80vh;
    display: block;
    object-fit: contain;
  }
  @keyframes zoomIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Non-Member Views */
  .non-member-welcome-bar {
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .non-member-hero-banner {
    text-align: center;
    background: linear-gradient(135deg, rgba(0, 136, 255, 0.08), rgba(0, 242, 255, 0.04));
    border: 1px solid rgba(0, 242, 255, 0.2);
    border-radius: 20px;
    padding: 3rem 2rem;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .non-member-hero-banner p {
    font-size: 1.15rem;
    line-height: 1.6;
    max-width: 750px;
    margin: 0;
  }
  .widget-subtitle {
    font-size: 1.4rem;
    color: #fff;
    margin-bottom: 1.5rem;
    border-left: 3px solid var(--color-teal);
    padding-left: 0.75rem;
  }

  /* Sports Catalog Cards */
  .sports-catalog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  .sport-catalog-card {
    background: rgba(15, 23, 42, 0.4);
    border-radius: 20px;
    overflow: hidden;
    border: var(--border-glass);
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
  }
  .sport-catalog-card:hover {
    border-color: rgba(0, 242, 255, 0.25);
    box-shadow: var(--shadow-glow);
    transform: translateY(-5px);
  }
  .sport-card-image {
    height: 180px;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .sport-card-image::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; width: 100%; height: 50%;
    background: linear-gradient(to top, rgba(15, 23, 42, 1), transparent);
  }
  .sport-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
    justify-content: space-between;
    background: rgba(15, 23, 42, 0.6);
  }
  .sport-card-content h4 {
    font-size: 1.25rem;
    margin: 0;
    color: #fff;
  }
  .sport-card-content p {
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    color: var(--text-secondary);
  }
  .sport-card-btn {
    background: rgba(0, 242, 255, 0.05);
    border: 1px solid rgba(0, 242, 255, 0.2);
    color: var(--color-teal);
    font-family: var(--font-display);
    font-weight: 700;
    padding: 0.65rem 1.25rem;
    border-radius: 50px;
    cursor: pointer;
    transition: var(--transition-smooth);
    width: 100%;
    margin-top: 0.5rem;
  }
  .sport-card-btn:hover {
    background: linear-gradient(135deg, var(--color-blue), var(--color-teal));
    color: #000;
    border-color: transparent;
    box-shadow: 0 4px 15px rgba(0, 242, 255, 0.35);
  }

  /* Benefits */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .benefit-card {
    background: rgba(0,0,0,0.25);
    border-radius: 16px;
    padding: 1.5rem;
    border: var(--border-glass);
    transition: var(--transition-smooth);
  }
  .benefit-card:hover {
    border-color: rgba(0, 242, 255, 0.15);
    transform: translateY(-2px);
  }
  .benefit-card-icon {
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .benefit-card h4 {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 0.5rem;
  }
  .benefit-card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* WIZARD CONTAINER AND COMPONENT */
  .wizard-container {
    max-width: 750px;
    margin: 0 auto;
    padding: 2.5rem;
    box-shadow: 0 15px 40px rgba(0,0,0,0.6);
  }
  .wizard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .wizard-step-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-weight: 600;
    font-family: var(--font-display);
    font-size: 0.85rem;
    transition: var(--transition-smooth);
  }
  .step-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
  }
  .wizard-step-indicator.active {
    color: var(--color-teal);
  }
  .wizard-step-indicator.active .step-num {
    border-color: var(--color-teal);
    background: rgba(0, 242, 255, 0.1);
    box-shadow: 0 0 10px rgba(0, 242, 255, 0.2);
  }

  /* Wizard Content step panels */
  .wizard-step-content {
    display: none;
    animation: fadeIn 0.4s ease-out forwards;
  }
  .wizard-step-content.active {
    display: block;
  }
  .wizard-step-content h3 {
    font-size: 1.3rem;
    color: #fff;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  /* Option selection cards for Steps 1, 2, 3 */
  .wizard-selection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 1.25rem;
  }
  .grid-formula {
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  }
  .wizard-option-card {
    background: rgba(0, 0, 0, 0.25);
    border-radius: 16px;
    border: var(--border-glass);
    padding: 1.5rem 1rem;
    text-align: center;
    cursor: pointer;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    position: relative;
  }
  .wizard-option-card:hover {
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.02);
  }
  .wizard-option-card.selected {
    border-color: var(--color-teal);
    background: rgba(0, 242, 255, 0.03);
    box-shadow: var(--shadow-glow);
  }
  .option-icon {
    color: var(--text-secondary);
    transition: var(--transition-smooth);
  }
  .wizard-option-card.selected .option-icon {
    color: var(--color-teal);
  }
  .wizard-option-card h4 {
    font-size: 0.95rem;
    margin: 0;
    color: #fff;
  }
  .wizard-option-card p {
    font-size: 0.75rem;
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.3;
  }

  /* Formula specific properties */
  .formula-badge {
    background: rgba(255,255,255,0.05);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--text-secondary);
  }
  .formula-price {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--color-teal);
  }
  .formula-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: var(--text-secondary);
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 0.75rem;
    width: 100%;
  }
  .text-gold {
    color: #fbbf24 !important;
    background: rgba(245, 158, 11, 0.1) !important;
  }
  .text-purple {
    color: #c084fc !important;
    background: rgba(168, 85, 247, 0.1) !important;
  }

  /* Step 4 Form controls */
  .wizard-form-group {
    max-width: 450px;
    margin: 2rem auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .wizard-form-group label {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .form-control {
    width: 100%;
    background: rgba(0, 0, 0, 0.4);
    border: var(--border-glass);
    border-radius: 10px;
    padding: 0.8rem 1.2rem;
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: var(--transition-smooth);
    outline: none;
  }
  .form-control:focus {
    border-color: var(--color-teal);
    box-shadow: 0 0 10px rgba(0, 242, 255, 0.2);
  }
  /* === PREMIUM INLINE VALIDATION STATES === */
  .form-field-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-field-wrap label {
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.5);
    transition: color 0.25s;
  }
  .form-field-wrap:focus-within label {
    color: var(--color-teal);
  }
  .form-field-wrap.has-error label { color: #ff5252; }
  .form-field-wrap.has-success label { color: #00e676; }

  .form-input-row {
    position: relative;
  }
  .form-input-row .form-control {
    padding-right: 2.8rem;
  }
  .field-icon {
