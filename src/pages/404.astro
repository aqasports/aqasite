---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Page introuvable | AQA Sports Academy" currentPage="/404">
  <Navbar />

  <style>
    .error-page {
      min-height: 80vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 4rem 1rem;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .error-code {
      font-size: clamp(6rem, 20vw, 12rem);
      font-weight: 900;
      background: linear-gradient(135deg, #00ffff, #0099ff, #ffffff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
      margin-bottom: 1rem;
      filter: drop-shadow(0 0 30px rgba(0, 255, 255, 0.4));
    }

    .error-title {
      font-size: clamp(1.2rem, 4vw, 2rem);
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 1rem;
    }

    .error-subtitle {
      font-size: clamp(0.95rem, 2.5vw, 1.1rem);
      color: rgba(255, 255, 255, 0.7);
      max-width: 500px;
      line-height: 1.7;
      margin-bottom: 3rem;
    }

    .error-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
    }

    .btn-primary {
      background: linear-gradient(135deg, #0099ff, #00ffff);
      color: #000000;
      padding: 0.9rem 2rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      border: 2px solid #00ffff;
      transition: all 0.3s ease;
      box-shadow: 0 0 25px rgba(0, 153, 255, 0.5);
    }

    .btn-primary:hover {
      background: linear-gradient(135deg, #00ffff, #0099ff);
      transform: translateY(-3px);
      box-shadow: 0 0 40px rgba(0, 255, 255, 0.7);
    }

    .btn-secondary {
      background: rgba(0, 153, 255, 0.1);
      color: #ffffff;
      padding: 0.9rem 2rem;
      border-radius: 50px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      border: 2px solid rgba(0, 153, 255, 0.4);
      transition: all 0.3s ease;
    }

    .btn-secondary:hover {
      background: rgba(0, 153, 255, 0.25);
      border-color: #00ffff;
      transform: translateY(-3px);
    }

    .logo-aqa {
      width: 80px;
      margin-bottom: 2rem;
      filter: drop-shadow(0 0 15px rgba(0, 255, 255, 0.6));
      animation: pulse 3s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.08); opacity: 0.85; }
    }
  </style>

  <div class="error-page">
    <img
      src="https://i.ibb.co/08WDCFj/Turquoise-Modern-Warning-with-Rays-Instagram-Post.png"
      alt="AQA Logo"
      class="logo-aqa"
    />
    <div class="error-code">404</div>
    <h1 class="error-title" data-i18n="error_title">Page introuvable</h1>
    <p class="error-subtitle" data-i18n="error_subtitle">
      Cette page n'existe pas ou a été déplacée.<br />
      Retournez à l'accueil et continuez votre progression.
    </p>
    <div class="error-links">
      <a href="/" class="btn-primary" data-i18n="error_home">← Retour à l'accueil</a>
      <a href="/tarifs" class="btn-secondary" data-i18n="nav_tarifs">Tarifs</a>
      <a href="/groupes" class="btn-secondary" data-i18n="nav_groupes">Groupes</a>
      <a href="/inscription" class="btn-secondary" data-i18n="nav_inscription">Inscription</a>
    </div>
  </div>

  <Footer />
</BaseLayout>
