<section class="section">
    <div class="listen-wrapper">
        <div class="listen-trigger" onclick="toggleListenSection()" id="listenBtn">
            <div class="trigger-text">
                <div class="icon-pulse">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00ffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
                </div>
                We Listen — Votre avis compte
            </div>
            <svg class="trigger-arrow" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>

        <div class="listen-container" id="listenContent">
            <iframe 
                id="listenFrame"
                src="listen-section.html" 
                style="width:100%; height:1200px; border:none; display:block;"
                allow="microphone *; camera *"
                allowfullscreen
                sandbox="allow-same-origin allow-scripts allow-forms allow-popups allow-modals allow-downloads"
                title="We Listen Section">
            </iframe>
        </div>
    </div>
</section>

<script>
// Auto-resize iframe
document.addEventListener('DOMContentLoaded', function() {
    const iframe = document.getElementById('listenFrame');
    
    iframe.addEventListener('load', function() {
        setTimeout(() => {
            try {
                const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
                const height = iframeDoc.body.scrollHeight;
                iframe.style.height = (height + 100) + 'px';
            } catch(e) {
                console.log('Using default height');
            }
        }, 500);
    });
});
</script>






<script>
       // Loading Screen
    window.addEventListener('load', () => {
        setTimeout(() => {
            document.getElementById('loadingScreen').classList.add('hidden');
        }, 2000);
    });
    
    // Intersection Observer for Sections
    const observerOptions = {
        threshold: 0.2,
        rootMargin: '0px'
    };

    const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                
                // Animate children elements
                const stats = entry.target.querySelectorAll('.stat-card');
                stats.forEach((stat, index) => {
                    setTimeout(() => {
                        stat.classList.add('visible');
                        animateNumber(stat.querySelector('.stat-number'));
                    }, index * 100);
                });

                const buttons = entry.target.querySelectorAll('.nav-btn');
                buttons.forEach((btn, index) => {
                    setTimeout(() => {
                        btn.classList.add('visible');
                    }, index * 50);
                });

                const galleryItems = entry.target.querySelectorAll('.gallery-item');
                galleryItems.forEach((item, index) => {
                    setTimeout(() => {
                        item.classList.add('visible');
                    }, index * 100);
                });

                const reviews = entry.target.querySelectorAll('.review-card');
                reviews.forEach((review, index) => {
                    setTimeout(() => {
                        review.classList.add('visible');
                    }, index * 150);
                });
            }
        });
    }, observerOptions);

    // Observe all sections
    document.querySelectorAll('.section').forEach(section => {
        sectionObserver.observe(section);
    });

    // Animated Counter for Stats
document.addEventListener('DOMContentLoaded', () => {
    const statCards = document.querySelectorAll('.stat-card');
    
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting && !entry.target.classList.contains('counted')) {
                entry.target.classList.add('counted');
                animateCard(entry.target);
            }
        });
    }, {
        threshold: 0.5
    });

    statCards.forEach(card => observer.observe(card));

    function animateCard(card) {
        const delay = parseInt(card.getAttribute('data-delay')) || 0;
        
        setTimeout(() => {
            card.classList.add('visible');
            const numberElement = card.querySelector('.stat-number');
            animateNumber(numberElement);
        }, delay);
    }

    function animateNumber(element) {
        const target = parseInt(element.getAttribute('data-target'));
        const suffix = element.getAttribute('data-suffix') || '';
        const duration = 2000;
        let current = 0;
        const increment = target / 60;
        
        const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
                element.textContent = target + suffix;
                clearInterval(timer);
            } else {
                element.textContent = Math.floor(current) + suffix;
            }
        }, duration / 60);
    }
});
// Simple form handler
document.addEventListener('DOMContentLoaded', () => {
    const submitBtn = document.getElementById('submitBtn');
    const formContainer = document.getElementById('listenFormContainer');
    const thankYouMessage = document.getElementById('thankYouMessage');
    const newMessageBtn = document.getElementById('newMessageBtn');

    submitBtn?.addEventListener('click', async () => {
        const name = document.getElementById('userName').value.trim();
        const email = document.getElementById('userEmail').value.trim();
        const message = document.getElementById('messageText').value.trim();

        if (!name && !email && !message) {
            alert('Veuillez remplir au moins un champ');
            return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Envoi...';

        try {
            // Simulate sending
            await new Promise(resolve => setTimeout(resolve, 1000));
            
            formContainer.style.display = 'none';
            thankYouMessage.style.display = 'block';
        } catch (error) {
            alert('Erreur lors de l\'envoi');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Envoyer';
        }
    });

    newMessageBtn?.addEventListener('click', () => {
        document.getElementById('userName').value = '';
        document.getElementById('userEmail').value = '';
        document.getElementById('messageText').value = '';
        formContainer.style.display = 'block';
        thankYouMessage.style.display = 'none';
    });
});

async function loadFooter() {
    try {
        const response = await fetch('footer.html');
        const footerHTML = await response.text();
        document.getElementById('footer-container').innerHTML = footerHTML;
    } catch (error) {
        console.error('Error loading footer:', error);
    }
}

document.addEventListener('DOMContentLoaded', loadFooter);
// Toggle We Listen Section
function toggleListenSection() {
    const btn = document.getElementById('listenBtn');
    const content = document.getElementById('listenContent');
    
    // Toggle Classes
    btn.classList.toggle('active');
    content.classList.toggle('open');

    // Smooth scroll if opening
    if (content.classList.contains('open')) {
        setTimeout(() => {
            content.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 300); // Small delay to allow expansion to start
    }
}
</script>
