<style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        /* Loading Screen */
        .loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            transition: opacity 0.5s ease, visibility 0.5s ease;
        }

        .loading-screen.hidden {
            opacity: 0;
            visibility: hidden;
        }

        .loading-logo {
            width: 150px;
            height: 150px;
            margin-bottom: 2rem;
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }

        .loading-bar-container {
            width: 300px;
            height: 4px;
            background: rgba(0, 153, 255, 0.2);
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }

        .loading-bar {
            height: 100%;
            background: linear-gradient(90deg, #0099ff, #00ffff);
            border-radius: 10px;
            width: 0%;
            animation: loadProgress 2s ease-out forwards;
            box-shadow: 0 0 20px rgba(0, 255, 255, 0.6);
        }

        @keyframes loadProgress {
            to { width: 100%; }
        }

        .loading-text {
            margin-top: 1rem;
            color: #00ffff;
            font-size: 0.9rem;
            letter-spacing: 2px;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: transparent;
            color: #ffffff;
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
            min-height: 100vh;
        }

        .bg-logo {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 80vw;
            height: 80vh;
            background-image: url('https://i.imgur.com/3dcksCn.png');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            opacity: 0.1;
            z-index: -2;
            pointer-events: none;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border: 0px solid transparent;
            background: linear-gradient(45deg, #00ffff, #0099ff, #0066ff, #3333ff, #6600ff, #9900ff, #cc00ff, #ff0099, #ff0066, #ff3333) border-box;
            -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            z-index: -1;
            animation: neonGlow 4s ease-in-out infinite alternate;
        }

        @keyframes neonGlow {
            0%, 100% {
                filter: drop-shadow(0 0 10px #00ffff) drop-shadow(0 0 20px #0099ff) drop-shadow(0 0 30px #0066ff);
            }
            50% {
                filter: drop-shadow(0 0 20px #00ffff) drop-shadow(0 0 40px #0099ff) drop-shadow(0 0 60px #0066ff);
            }
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        /* Hero section */
        .hero {
            text-align: center;
            padding: 3rem 0;
            margin-bottom: 3rem;
            animation: slideIn 1s ease-out;
        }

        .hero-video {
            margin: 2rem auto;
            max-width: 600px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 0 40px rgba(0, 255, 255, 0.4);
            border: 1px solid rgba(0, 153, 255, 0.5);
            background: rgba(0, 153, 255, 0.1);
            position: relative;
            animation: videoReveal 1s ease-out 0.8s both;
        }
 @keyframes videoReveal {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        .hero-video::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #00ffff, #0099ff, #00ffff);
            border-radius: 20px;
            z-index: -1;
            animation: neonPulse 3s ease-in-out infinite alternate;
        }

        @keyframes neonPulse {
            0%, 100% {
                opacity: 0.6;
                filter: blur(1px);
            }
            50% {
                opacity: 1;
                filter: blur(0px);
            }
        }

        .transformation-video {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 17px;
            background: #000;
            max-height: 400px;
            object-fit: cover;
        }

        .hero h1 {
            font-size: clamp(2rem, 8vw, 3.5rem);
            font-weight: 800;
            background: linear-gradient(135deg, #00ffff, #0099ff, #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
            text-shadow: 0 0 30px rgba(0, 255, 255, 0.3);
            line-height: 1.2;
             animation: titleSlide 1s ease-out 0.5s both;
        }
 @keyframes titleSlide {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .hero h2 {
            font-size: clamp(1.2rem, 4vw, 1.8rem);
            font-weight: 600;
            color: #00ffff;
            margin-bottom: 1.5rem;
            text-shadow: 0 0 15px rgba(0, 255, 255, 0.5);
        }

        .hero p {
            font-size: clamp(1rem, 3vw, 1.2rem);
            opacity: 0.9;
            max-width: 800px;
            margin: 0 auto 2.5rem;
            color: #ffffff;
            line-height: 1.6;
            animation: fadeIn 1s ease-out 1s forwards;
        }

        /* Section Styling */
        .section {
            margin: 1rem 0;
            padding: 3rem 0;
            position: relative;
            opacity: 0;
            transform: translateY(50px);
            transition: all 0.8s ease;
        }
 .section.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }

       .section-title {
            font-size: clamp(1.8rem, 5vw, 2.5rem);
            font-weight: 700;
            background: linear-gradient(135deg, #00ffff, #0099ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
            position: relative;
            display: inline-block;
        }
  .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, #00ffff, #0099ff);
            transition: width 0.8s ease;
            box-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
        }
 .section.visible .section-title::after {
            width: 80%;
        }
        .section-subtitle {
            font-size: clamp(1rem, 3vw, 1.2rem);
            color: rgba(255, 255, 255, 0.8);
        }

        .section-divider {
            width: 80px;
            height: 3px;
            background: linear-gradient(90deg, #00ffff, #0099ff);
            margin: 1.5rem auto;
            border-radius: 2px;
            box-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
        }

        /* Navigation Buttons */
        .nav-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }

         .nav-btn {
            background: linear-gradient(135deg, rgba(0, 153, 255, 0.1), rgba(0, 255, 255, 0.1));
            border: 2px solid rgba(0, 153, 255, 0.5);
            color: #ffffff;
            padding: 1.5rem 1rem;
            text-decoration: none;
            border-radius: 20px;
            font-weight: 700;
            font-size: clamp(0.9rem, 3vw, 1.1rem);
            transition: all 0.4s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
            min-height: 100px;
            justify-content: center;
            opacity: 0;
            transform: translateY(20px);
        }
  .nav-btn.visible {
            animation: btnAppear 0.5s ease forwards;
        }

        @keyframes btnAppear {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }


        .nav-btn::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(0, 255, 255, 0.1), transparent);
            transform: rotate(45deg);
            transition: all 0.6s ease;
            opacity: 0;
        }

        .nav-btn:hover::before {
            opacity: 1;
            animation: shimmer 1.5s ease-in-out;
        }

        @keyframes shimmer {
            0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
            100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
        }

        .nav-btn:hover {
            background: linear-gradient(135deg, rgba(0, 153, 255, 0.3), rgba(0, 255, 255, 0.3));
            border-color: #00ffff;
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 0 30px rgba(0, 255, 255, 0.5);
        }

        .nav-btn-icon svg {
            width: 28px;
            height: 28px;
            stroke: #00ffff;
            stroke-width: 2.2;
            transition: transform 0.25s ease;
                        filter: drop-shadow(0 0 3px rgba(0, 255, 255, 0.5));

        }

        .nav-btn:hover .nav-btn-icon svg {
               transform: scale(1.15) rotate(5deg);
        }

       /* Stats Section */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin: 3rem 0;
}

.stat-card {
    background: rgba(0, 153, 255, 0.1);
    border: 2px solid rgba(0, 153, 255, 0.3);
    border-radius: 20px;
    padding: 2rem;
    text-align: center;
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(30px) scale(0.9);
    position: relative;
    overflow: hidden;
}
.stat-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(0, 255, 255, 0.1), transparent);
    animation: statRotate 10s linear infinite;
    opacity: 0;
}
.stat-card:hover::before {
    opacity: 1;
}
@keyframes statRotate {
    to { transform: rotate(360deg); }
}

.stat-card.visible {
    animation: statAppear 0.6s ease forwards;
}

@keyframes statAppear {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.stat-card:hover {
    transform: translateY(-5px);
    border-color: #00ffff;
    box-shadow: 0 0 30px rgba(0, 255, 255, 0.3);
}

.stat-number {
    font-size: 3rem;
    font-weight: 800;
    background: linear-gradient(135deg, #00ffff, #0099ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    z-index: 1;
}
.stat-label {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 0.5rem;
}

