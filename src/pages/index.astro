.listen-wrapper {
    width: 100%;
    max-width: 900px;
    margin: 4rem auto;
    padding: 0 1rem;
    position: relative;
    z-index: 10;
}

/* The Horizontal Trigger Button */
.listen-trigger {
    width: 100%;
    background: rgba(0, 20, 40, 0.6); /* Darker transparent bg */
    border: 1px solid rgba(0, 255, 255, 0.3);
    border-radius: 50px; /* Pill shape */
    padding: 1.5rem 2rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    backdrop-filter: blur(10px);
    box-shadow: 0 0 20px rgba(0, 153, 255, 0.1);
    position: relative;
    overflow: hidden;
}

/* Glowing Border Effect on Hover */
.listen-trigger::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: 50px;
    padding: 2px; /* Border width */
    background: linear-gradient(90deg, transparent, #00ffff, #0099ff, transparent);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.5;
    transition: opacity 0.3s ease;
}

.listen-trigger:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 0 40px rgba(0, 255, 255, 0.3);
    background: rgba(0, 20, 40, 0.8);
}

.listen-trigger:hover::before {
    opacity: 1;
}

/* Text Styling */
.trigger-text {
    font-size: 1.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, #ffffff, #00ffff);
