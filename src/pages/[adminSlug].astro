      });

      // Build inline slots grids for each pending member
      pendingMembers.forEach(m => {
        const slotGrid = pendingContainer.querySelector(`#inline-slots-grid-${m.id}`);
        const slotNotice = pendingContainer.querySelector(`#inline-slots-notice-${m.id}`);
        const poolSel = pendingContainer.querySelector(`.inline-pool-${m.id}`);
        const catSel = pendingContainer.querySelector(`.inline-cat-${m.id}`);
        const tierSel = pendingContainer.querySelector(`.inline-tier-${m.id}`);
        if (!slotGrid || !poolSel || !tierSel) return;

        // Local inline selected groups store keyed by member id
        window._pendingGroups = window._pendingGroups || {};
        window._pendingGroups[m.id] = getAdminGroupsFromSub(m.subscription);

        function renderInlineGrid(memberId) {
          const pool = pendingContainer.querySelector(`.inline-pool-${memberId}`)?.value;
          const cat = pendingContainer.querySelector(`.inline-cat-${memberId}`)?.value || 'homme';
          const tier = pendingContainer.querySelector(`.inline-tier-${memberId}`)?.value || 'Silver';
          const grid = pendingContainer.querySelector(`#inline-slots-grid-${memberId}`);
          const notice = pendingContainer.querySelector(`#inline-slots-notice-${memberId}`);
          if (!grid || !pool || !currentSchedule[pool]) {
            if (grid) grid.innerHTML = '<div style="color:var(--text-muted);font-size:0.8rem;padding:0.5rem;">Selectionnez une piscine.</div>';
            return;
          }
          const maxLimit = { 'Starter': 1, 'Silver': 2, 'Gold': 3, 'Diamond': 4, 'Emerald': 5 }[tier] || 1;
          if (notice) notice.textContent = `Max ${maxLimit} creneau(x) pour ${tier}.`;
          grid.innerHTML = '';
          const catData = currentSchedule[pool]?.categories?.[cat];
          if (!catData || !catData.coaches) {
            grid.innerHTML = '<div style="color:var(--text-muted);font-size:0.8rem;padding:0.5rem;">Aucun creneau.</div>';
            return;
          }
          const gKey = (g) => `${g.poolKey}|${g.coachName}|${g.slotDay}|${g.slotTime}`;
          catData.coaches.forEach(coach => {
            if (!coach.slots) return;
            coach.slots.forEach(slot => {
              const remaining = (slot.total || 10) - (slot.taken || 0);
              const isFull = remaining <= 0;
              const gData = { poolKey: pool, coachName: coach.name, slotDay: slot.day, slotTime: slot.time };
              const key = gKey(gData);
              const card = document.createElement('div');
              card.dataset.key = key;
              card.style.cssText = `padding:0.5rem 0.75rem;border-radius:8px;border:1px solid rgba(255,255,255,${window._pendingGroups[memberId]?.some(g => gKey(g) === key) ? '0.5' : '0.08'});background:${window._pendingGroups[memberId]?.some(g => gKey(g) === key) ? 'rgba(0,242,255,0.1)' : 'transparent'};cursor:${isFull ? 'not-allowed' : 'pointer'};opacity:${isFull ? '0.5' : '1'};font-size:0.78rem;`;
              card.innerHTML = `<strong style="color:#fff;">${slot.day} ${slot.time}</strong><div style="color:var(--text-secondary);">${coach.name}</div><div style="color:${isFull ? '#ef4444' : '#34d399'};">${isFull ? 'Complet' : remaining + ' places'}</div>`;
              card.addEventListener('click', () => {
                if (isFull) return;
                if (!window._pendingGroups[memberId]) window._pendingGroups[memberId] = [];
                const idx = window._pendingGroups[memberId].findIndex(g => gKey(g) === key);
                if (idx !== -1) {
                  window._pendingGroups[memberId].splice(idx, 1);
                } else {
                  const curTier = pendingContainer.querySelector(`.inline-tier-${memberId}`)?.value || 'Silver';
                  const curMax = { 'Starter': 1, 'Silver': 2, 'Gold': 3, 'Diamond': 4, 'Emerald': 5 }[curTier] || 1;
                  if (window._pendingGroups[memberId].length >= curMax) {
                    if (notice) notice.textContent = `Limite: max ${curMax} creneau(x) pour ${curTier}.`;
                    return;
                  }
                  window._pendingGroups[memberId].push(gData);
                }
                renderInlineGrid(memberId);
              });
              grid.appendChild(card);
            });
          });
        }

        renderInlineGrid(m.id);
        if (poolSel) poolSel.addEventListener('change', () => renderInlineGrid(m.id));
        if (catSel) catSel.addEventListener('change', () => renderInlineGrid(m.id));
        if (tierSel) tierSel.addEventListener('change', () => renderInlineGrid(m.id));
      });

      // Bind approve/reject button events
      pendingContainer.querySelectorAll('.approve-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;
          const tier = pendingContainer.querySelector(`.inline-tier-${id}`)?.value || 'Silver';
          const pool = pendingContainer.querySelector(`.inline-pool-${id}`)?.value || 'reghaia';
          const cat = pendingContainer.querySelector(`.inline-cat-${id}`)?.value || 'homme';
          const enddate = pendingContainer.querySelector(`.inline-enddate-${id}`)?.value || '';
          const selectedGroups = (window._pendingGroups && window._pendingGroups[id]) ? window._pendingGroups[id] : [];

          if (selectedGroups.length === 0) {
            alert('Veuillez selectionner au moins un creneau avant d\'approuver.');
            return;
          }

          btn.disabled = true;
          try {
            const res = await fetch('/api/admin/members/approve', {
              method: 'POST',
              headers: authHeaders(),
              body: JSON.stringify({
                memberId: id,
                membershipTier: tier,
                poolKey: pool,
                groups: selectedGroups,
                endDate: enddate
              })
            });
            const data = await res.json();
            if (data.success) {
              if (window._pendingGroups) delete window._pendingGroups[id];
              loadAdminMembers();
            } else {
              alert(data.error);
            }
          } catch (e) {
            console.error(e);
          } finally {
            btn.disabled = false;
          }
        });
      });

      pendingContainer.querySelectorAll('.reject-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;
          if (!confirm("Voulez-vous rejeter cette inscription ?")) return;
          btn.disabled = true;
          try {
            const res = await fetch('/api/admin/members/update', {
              method: 'POST',
              headers: authHeaders(),
              body: JSON.stringify({
                memberId: id,
                status: 'suspended'
              })
            });
            const data = await res.json();
            if (data.success) {
              loadAdminMembers();
            }
          } catch(e) {
            console.error(e);
          } finally {
            btn.disabled = false;
          }
        });
      });
    }

    // Render Subscription Change Requests
    const changesContainer = document.getElementById('pendingChangesContainer');
    const changeRequests = currentMembers.filter(m => m.subscriptionChangeRequest && m.subscriptionChangeRequest.status === 'pending');
    changesContainer.innerHTML = '';

    if (changeRequests.length === 0) {
      changesContainer.innerHTML = '<div style="color: var(--text-muted); font-style: italic; padding: 1rem 0;">Aucune demande de modification d\'abonnement en attente.</div>';
