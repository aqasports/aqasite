        card.style.gap = '1rem';

        card.innerHTML = `
          <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
            <div>
              <h4 style="font-size: 1.1rem; color: #fff; margin: 0;">${m.fullName}</h4>
              <p style="font-size: 0.85rem; color: var(--text-secondary); margin: 0.25rem 0 0 0;">Demande de changement soumise le ${new Date(req.requestedAt).toLocaleDateString('fr-FR')}</p>
            </div>
            <div style="display: flex; gap: 0.5rem;">
              <button class="btn btn-primary approve-change-btn" data-id="${m.id}" style="padding: 0.45rem 1rem; font-size: 0.85rem;">Approuver</button>
              <button class="btn btn-secondary reject-change-btn" data-id="${m.id}" style="padding: 0.45rem 1rem; font-size: 0.85rem; border-color: #ff4d4d; color: #ff4d4d; background: transparent;">Rejeter</button>
            </div>
          </div>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; background: rgba(0,0,0,0.2); padding: 1rem; border-radius: 10px;">
            <div>
              <strong style="color: var(--text-muted); font-size: 0.8rem; display: block; margin-bottom: 0.25rem;">CRENEAU ACTUEL :</strong>
              <span style="font-size: 0.9rem;">Formule: ${m.membershipTier || 'Starter'}</span><br>
              ${(() => {
                const curGroups = getAdminGroupsFromSub(m.subscription);
                if (curGroups.length === 0) return '<span style="font-size:0.85rem;color:var(--text-muted);">Aucun creneau actif</span>';
                return curGroups.map(g => `<span style="font-size:0.85rem;display:block;margin-top:0.2rem;"><b>${g.coachName || ''}</b> &mdash; ${g.slotDay || ''} ${g.slotTime || ''} (${g.poolKey === 'reghaia' ? 'Reghaia' : 'Cheraga'})</span>`).join('');
              })()}
            </div>
            <div style="border-left: 1px solid rgba(255,255,255,0.05); padding-left: 1rem;">
              <strong style="color: var(--color-teal); font-size: 0.8rem; display: block; margin-bottom: 0.25rem;">CRENEAU DEMANDE :</strong>
              <span style="font-size: 0.9rem; font-weight: bold; color: #fff;">Formule: ${req.tier}</span><br>
              ${(() => {
                const reqGroups = getAdminGroupsFromSub(req);
                if (reqGroups.length === 0) return `<span style="font-size:0.85rem;color:#fff;display:block;margin-top:0.2rem;"><b>${req.coachName || '-'}</b> &mdash; ${req.slotDay || ''} ${req.slotTime || ''} (${req.poolKey === 'reghaia' ? 'Reghaia' : (req.poolKey === 'cheraga' ? 'Cheraga' : '-')})</span>`;
                return reqGroups.map(g => `<span style="font-size:0.85rem;color:#fff;font-weight:600;display:block;margin-top:0.2rem;"><b>${g.coachName || ''}</b> &mdash; ${g.slotDay || ''} ${g.slotTime || ''} (${g.poolKey === 'reghaia' ? 'Reghaia' : 'Cheraga'})</span>`).join('');
              })()}
            </div>
          </div>
        `;
        changesContainer.appendChild(card);
      });

      changesContainer.querySelectorAll('.approve-change-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;
          btn.disabled = true;
          try {
            const res = await fetch('/api/admin/members/approve-change', {
              method: 'POST',
              headers: authHeaders(),
              body: JSON.stringify({
                memberId: id,
                action: 'approve'
              })
            });
            const data = await res.json();
            if (data.success) {
              loadAdminMembers();
            }
          } catch(e) {
            console.error(e);
          } finally {
            btn.disabled = false;
          }
        });
      });

      changesContainer.querySelectorAll('.reject-change-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;
          btn.disabled = true;
          try {
            const res = await fetch('/api/admin/members/approve-change', {
              method: 'POST',
              headers: authHeaders(),
              body: JSON.stringify({
                memberId: id,
                action: 'reject'
              })
            });
            const data = await res.json();
            if (data.success) {
              loadAdminMembers();
            }
          } catch(e) {
            console.error(e);
          } finally {
            btn.disabled = false;
          }
        });
      });
    }

    // Render Active Members Table
    const tableBody = document.getElementById('membersTableBody');
    tableBody.innerHTML = '';

    const search = document.getElementById('memberSearch').value.toLowerCase();
    const filterStatus = document.getElementById('memberFilterStatus').value;
    const filterPool = document.getElementById('memberFilterPool').value;

    const filtered = currentMembers.filter(m => {
      // Search
      const matchSearch = m.fullName.toLowerCase().includes(search) || 
                          m.email.toLowerCase().includes(search) || 
                          (m.phone && m.phone.toLowerCase().includes(search));
      if (!matchSearch) return false;

      // Status filter
      if (filterStatus !== 'all') {
        if (filterStatus === 'non-member') {
          if (m.isAqaMember) return false;
        } else {
          if (m.status !== filterStatus || !m.isAqaMember) return false;
        }
      }

      // Pool filter
      if (filterPool !== 'all') {
        if (!m.subscription || m.subscription.poolKey !== filterPool) return false;
      }

      return true;
    });

    if (filtered.length === 0) {
      tableBody.innerHTML = `<tr><td colspan="6" style="padding: 1.5rem 0.5rem; text-align: center; color: var(--text-muted); font-style: italic;">Aucun membre trouve matching les filtres.</td></tr>`;
      return;
    }

    filtered.forEach(m => {
      const tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid rgba(255,255,255,0.03)';
      
      let statusBadge = '';
      if (!m.isAqaMember) {
        statusBadge = `<span style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); color: var(--text-secondary); padding: 0.2rem 0.6rem; border-radius: 50px; font-size: 0.75rem;">Communaute</span>`;
      } else if (m.status === 'active') {
        statusBadge = `<span style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); color: #34d399; padding: 0.2rem 0.6rem; border-radius: 50px; font-size: 0.75rem;">Actif</span>`;
      } else if (m.status === 'pending') {
        statusBadge = `<span style="background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.3); color: #fbbf24; padding: 0.2rem 0.6rem; border-radius: 50px; font-size: 0.75rem;">Attente</span>`;
      } else {
        statusBadge = `<span style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #f87171; padding: 0.2rem 0.6rem; border-radius: 50px; font-size: 0.75rem;">Suspendu</span>`;
      }

      const poolStr = m.subscription?.poolKey === 'reghaia' ? 'Reghaia' : (m.subscription?.poolKey === 'cheraga' ? 'Cheraga' : '-');
      const creneauStr = getAdminGroupsDisplay(m.subscription);

      tr.innerHTML = `
        <td style="padding: 1rem 0.5rem;">
          <strong style="color: #fff; display: block;">${m.fullName}</strong>
          <small style="color: var(--text-secondary);">${m.email}</small>
        </td>
        <td style="padding: 1rem 0.5rem;">${statusBadge}</td>
        <td style="padding: 1rem 0.5rem;">${m.membershipTier || '-'}</td>
        <td style="padding: 1rem 0.5rem;">${poolStr}</td>
        <td style="padding: 1rem 0.5rem;">${creneauStr}</td>
        <td style="padding: 1rem 0.5rem; font-weight: bold; color: var(--color-teal);">${m.xp || 0}</td>
        <td style="padding: 1rem 0.5rem; text-align: right;">
          <button class="btn btn-secondary manage-member-btn" data-id="${m.id}" style="padding: 0.3rem 0.75rem; font-size: 0.8rem; margin-right: 0.4rem;">Gerer</button>
          <button class="btn btn-secondary link-member-btn" data-id="${m.id}" style="padding: 0.3rem 0.75rem; font-size: 0.8rem; border-color: rgba(0, 242, 255, 0.2); color: var(--color-teal); background: transparent;">Fiche</button>
        </td>
      `;

      tr.querySelector('.manage-member-btn').addEventListener('click', () => openMemberEditModal(m));
      tr.querySelector('.link-member-btn').addEventListener('click', () => {
        window.open(`/clients/stats?id=${m.id}`, '_blank');
      });

      tableBody.appendChild(tr);
    });
  }

  // Bind Search and Filter actions
  document.getElementById('memberSearch').addEventListener('input', renderAdminMembers);
  document.getElementById('memberFilterStatus').addEventListener('change', renderAdminMembers);
  document.getElementById('memberFilterPool').addEventListener('change', renderAdminMembers);

  // Modal actions
  const editModal = document.getElementById('memberEditModal');
  const closeEditModalBtn = document.getElementById('closeEditModalBtn');

  if (closeEditModalBtn) {
    closeEditModalBtn.addEventListener('click', () => {
      editModal.style.display = 'none';
      selectedMember = null;
    });
  }

  // Bind editPool / editGender / editTier change events to re-render the slot grid
  ['editPool', 'editGender', 'editTier'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('change', () => {
      adminSelectedGroups = [];
      renderAdminInteractiveSlots();
    });
  });

  // Handle modal sub-tabs switching
  document.querySelectorAll('.modal-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.modal-tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.modal-tab-content').forEach(c => c.style.display = 'none');
      
      btn.classList.add('active');
      const tabContent = document.getElementById(`modal-tab-${btn.dataset.modaltab}`);
      if (tabContent) tabContent.style.display = 'block';
    });
  });

  // Open Edit Modal & Populate details
  function openMemberEditModal(member) {
    selectedMember = member;
    document.getElementById('editModalTitle').textContent = `Gerer : ${member.fullName}`;
    
    // Reset Alert
    const modalAlert = document.getElementById('modalAlert');
    modalAlert.style.display = 'none';

    // Populate Tab 1: Profile & Sub
    document.getElementById('editFullName').value = member.fullName || '';
    document.getElementById('editPhone').value = member.phone || '';
    document.getElementById('editBirthDate').value = member.birthDate || '';
    document.getElementById('editGender').value = member.gender || 'homme';
    document.getElementById('editTier').value = member.membershipTier || 'Starter';
    document.getElementById('editStatus').value = member.status || 'active';
    document.getElementById('editPool').value = member.subscription?.poolKey || '';
    document.getElementById('editCoach').value = member.subscription?.coachName || '';
    document.getElementById('editSlot').value = member.subscription?.slotTime ? `${member.subscription.slotDay || ''} ${member.subscription.slotTime}`.trim() : '';
    document.getElementById('editEndDate').value = member.subscription?.endDate || '';

    // Pre-populate adminSelectedGroups from member's current subscription
    adminSelectedGroups = getAdminGroupsFromSub(member.subscription);
    // Render the slot selection grid (pool must be set first)
    renderAdminInteractiveSlots();

    // Populate Tab 2: Presence Timeline
    renderModalPresenceTab();

    // Populate Tab 3: Suivi Technique
    const tech = member.suiviTechnique || { respiration: 0, kick: 0, bras: 0, endurance: 0, comments: '' };
    document.getElementById('suiviRespiration').value = tech.respiration || 0;
    document.getElementById('lblRespiration').textContent = `Respiration / Appuis (${tech.respiration || 0}/5) :`;
    
    document.getElementById('suiviKick').value = tech.kick || 0;
    document.getElementById('lblKick').textContent = `Battement de jambes (${tech.kick || 0}/5) :`;
    
    document.getElementById('suiviBras').value = tech.bras || 0;
    document.getElementById('lblBras').textContent = `Mouvement de bras (${tech.bras || 0}/5) :`;
    
    document.getElementById('suiviEndurance').value = tech.endurance || 0;
    document.getElementById('lblEndurance').textContent = `Endurance / Souffle (${tech.endurance || 0}/5) :`;

    document.getElementById('suiviComments').value = tech.comments || '';

    // Populate Tab 4: Gamification
    document.getElementById('rewardsXP').value = member.xp || 0;
    const userBadges = member.badges || [];
    ['first_dive', 'crawling_king', 'apnea_master', 'butterfly_king', 'endurance_pro'].forEach(badgeId => {
      document.getElementById(`badgeCheck_${badgeId}`).checked = userBadges.includes(badgeId);
    });

    // Populate Tab 5: Gallery
    renderModalGalleryTab();

    // Force activation of first tab on open
    document.querySelector('.modal-tab-btn[data-modaltab="profile"]').click();

    // Display
    editModal.style.display = 'flex';
  }

  // Interactive label updates for sliders
  ['Respiration', 'Kick', 'Bras', 'Endurance'].forEach(id => {
    const slider = document.getElementById(`suivi${id}`);
    const lbl = document.getElementById(`lbl${id}`);
    slider.addEventListener('input', () => {
      let titleStr = '';
      if (id === 'Respiration') titleStr = 'Respiration / Appuis';
      else if (id === 'Kick') titleStr = 'Battement de jambes';
      else if (id === 'Bras') titleStr = 'Mouvement de bras';
      else if (id === 'Endurance') titleStr = 'Endurance / Souffle';
      lbl.textContent = `${titleStr} (${slider.value}/5) :`;
    });
  });

  // Modal Form Submissions handlers
  
  // Submit Profile & Subscription Edit
  document.getElementById('modalProfileForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!selectedMember) return;
    
    const alertBox = document.getElementById('modalAlert');
    alertBox.style.display = 'none';

    // Build groups array: prefer adminSelectedGroups if any, else fall back to legacy fields
    const editPoolVal = document.getElementById('editPool').value;
    const resolvedGroups = adminSelectedGroups.length > 0 ? adminSelectedGroups : getAdminGroupsFromSub(selectedMember.subscription);
    const firstGroup = resolvedGroups[0] || {};
    const sub = {
      category: document.getElementById('editGender').value,
      groups: resolvedGroups,
      poolKey: editPoolVal || firstGroup.poolKey || '',
      coachName: resolvedGroups.map(g => g.coachName).join(', ') || document.getElementById('editCoach').value,
      slotDay: resolvedGroups.map(g => g.slotDay).join(', ') || document.getElementById('editSlot').value.split(' ')[0] || 'Samedi',
      slotTime: resolvedGroups.map(g => g.slotTime).join(', ') || document.getElementById('editSlot').value,
      startDate: selectedMember.subscription?.startDate || new Date().toISOString().split('T')[0],
      endDate: document.getElementById('editEndDate').value,
      status: document.getElementById('editStatus').value === 'active' ? 'active' : 'inactive'
    };

    const payload = {
      memberId: selectedMember.id,
      fullName: document.getElementById('editFullName').value,
      phone: document.getElementById('editPhone').value,
      birthDate: document.getElementById('editBirthDate').value,
      gender: document.getElementById('editGender').value,
      isAqaMember: document.getElementById('editTier').value !== 'Non-Membre',
      status: document.getElementById('editStatus').value,
      membershipTier: document.getElementById('editTier').value,
      subscription: sub
    };

    try {
      const res = await fetch('/api/admin/members/update', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        showAlertInModal('Fiche membre enregistree avec succes', 'success');
        
        // Refresh local memory and table
        const idx = currentMembers.findIndex(m => m.id === selectedMember.id);
        if (idx !== -1) {
          // Update properties locally
          Object.assign(currentMembers[idx], payload);
          selectedMember = currentMembers[idx];
        }
        renderAdminMembers();
      } else {
        showAlertInModal(data.error || 'Erreur lors de la sauvegarde', 'error');
      }
    } catch(err) {
      showAlertInModal('Erreur reseau', 'error');
    }
  });

  // Submit Presence
  document.getElementById('modalPresenceForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!selectedMember) return;

    const date = document.getElementById('presenceDateInput').value;
    const present = document.getElementById('presenceStatusInput').value === 'true';
    const reason = document.getElementById('presenceReasonInput').value;

    try {
      const res = await fetch('/api/admin/members/presence', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({
          memberId: selectedMember.id,
          date,
          present,
          reason
        })
      });
      const data = await res.json();
      if (data.success) {
        selectedMember.presence = data.presence;
        
        // Update global memory
        const idx = currentMembers.findIndex(m => m.id === selectedMember.id);
        if (idx !== -1) currentMembers[idx].presence = data.presence;

        document.getElementById('modalPresenceForm').reset();
        renderModalPresenceTab();
        renderAdminMembers();
        showAlertInModal('Presence ajoutee avec succes', 'success');
      }
    } catch(err) {
      console.error(err);
    }
  });

  // Submit Suivi Technique
  document.getElementById('modalSuiviForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!selectedMember) return;

    const payload = {
      memberId: selectedMember.id,
      respiration: parseInt(document.getElementById('suiviRespiration').value),
      battement: parseInt(document.getElementById('suiviKick').value),
      bras: parseInt(document.getElementById('suiviBras').value),
      endurance: parseInt(document.getElementById('suiviEndurance').value),
      comments: document.getElementById('suiviComments').value
    };

    try {
      const res = await fetch('/api/admin/members/suivi', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        selectedMember.suiviTechnique = payload;
        
        // Update global memory
        const idx = currentMembers.findIndex(m => m.id === selectedMember.id);
        if (idx !== -1) currentMembers[idx].suiviTechnique = payload;

        showAlertInModal('Evaluation technique mise a jour', 'success');
      }
    } catch(err) {
      console.error(err);
    }
  });

  // Submit Rewards (XP & Badges)
  document.getElementById('modalRewardsForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!selectedMember) return;

    const xp = parseInt(document.getElementById('rewardsXP').value) || 0;
    const badges = [];
    ['first_dive', 'crawling_king', 'apnea_master', 'butterfly_king', 'endurance_pro'].forEach(badgeId => {
      if (document.getElementById(`badgeCheck_${badgeId}`).checked) {
        badges.push(badgeId);
      }
    });

    const payload = {
      memberId: selectedMember.id,
      xp,
      badges
    };

    try {
      const res = await fetch('/api/admin/members/update', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        selectedMember.xp = xp;
        selectedMember.badges = badges;

        // Update global memory
        const idx = currentMembers.findIndex(m => m.id === selectedMember.id);
        if (idx !== -1) {
          currentMembers[idx].xp = xp;
          currentMembers[idx].badges = badges;
        }

        renderAdminMembers();
        showAlertInModal('Recompenses & XP enregistres avec succes', 'success');
      }
    } catch(err) {
      console.error(err);
    }
  });

  // Submit Gallery Action
  document.getElementById('modalGalleryForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!selectedMember) return;

    const fileInput = document.getElementById('galleryPhotoFile');
    if (!fileInput.files || fileInput.files.length === 0) {
      showAlertInModal('Veuillez selectionner un fichier image', 'error');
      return;
    }

    const file = fileInput.files[0];
    const uploadBtn = document.getElementById('galleryUploadBtn');
    const originalBtnText = uploadBtn.textContent;
    uploadBtn.disabled = true;
    uploadBtn.textContent = 'Envoi...';

    // Helper: read file as Base64 Data URL
    const readAsDataURL = (file) => {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.onerror = (error) => reject(error);
        reader.readAsDataURL(file);
      });
    };

    try {
      const fileData = await readAsDataURL(file);

      // Step 1: Upload image to Cloudinary (via Netlify serverless function)
      const uploadRes = await fetch('/api/admin/members/upload-image', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${adminToken}`
        },
        body: JSON.stringify({ fileData })
      });
      const uploadData = await uploadRes.json();
      if (!uploadData.success) {
        showAlertInModal(uploadData.error || 'Erreur d\'upload de l\'image', 'error');
        uploadBtn.disabled = false;
        uploadBtn.textContent = originalBtnText;
        return;
      }

      // Step 2: Add image path to member's gallery
      const res = await fetch('/api/admin/members/gallery', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({
          memberId: selectedMember.id,
          action: 'add',
          imageUrl: uploadData.imageUrl
        })
      });
      const data = await res.json();
      if (data.success) {
        selectedMember.gallery = data.gallery;

        // Update global memory
        const idx = currentMembers.findIndex(m => m.id === selectedMember.id);
        if (idx !== -1) currentMembers[idx].gallery = data.gallery;

        fileInput.value = '';
        renderModalGalleryTab();
        showAlertInModal('Photo ajoutee a la galerie', 'success');
      } else {
        showAlertInModal(data.error || 'Erreur lors de l\'enregistrement de la photo', 'error');
      }
    } catch(err) {
      console.error(err);
      showAlertInModal('Une erreur est survenue lors de l\'upload', 'error');
    } finally {
      uploadBtn.disabled = false;
      uploadBtn.textContent = originalBtnText;
    }
  });

  // Helper functions inside Modal
  function showAlertInModal(msg, type) {
    const alertBox = document.getElementById('modalAlert');
    alertBox.textContent = msg;
    alertBox.className = `auth-alert ${type}`;
    alertBox.style.display = 'block';
    
    // Auto hide success alerts after 3 seconds
    if (type === 'success') {
      setTimeout(() => {
        alertBox.style.display = 'none';
      }, 3000);
    }
  }

  function renderModalPresenceTab() {
    const list = document.getElementById('modalPresenceList');
    list.innerHTML = '';
    
    const presence = selectedMember.presence || [];
    const presentCount = presence.filter(p => p.present).length;
    document.getElementById('modalPresenceSummary').textContent = `Total : ${presentCount} / ${presence.length} seances present`;

    if (presence.length === 0) {
      list.innerHTML = '<div style="color: var(--text-muted); font-style: italic; font-size: 0.85rem; padding: 0.5rem 0;">Aucune seance enregistree.</div>';
      return;
    }

    // Sort descending by date
    const sorted = [...presence].sort((a,b) => new Date(b.date) - new Date(a.date));
    sorted.forEach(p => {
      const row = document.createElement('div');
      row.style.display = 'flex';
      row.style.justifyContent = 'space-between';
      row.style.alignItems = 'center';
      row.style.padding = '0.4rem 0.5rem';
      row.style.background = 'rgba(255,255,255,0.02)';
      row.style.borderRadius = '6px';
      row.style.borderLeft = p.present ? '3px solid #10b981' : '3px solid #ef4444';

      row.innerHTML = `
        <div style="font-size: 0.85rem;">
          <strong style="color: #fff;">${p.date}</strong> - 
          <span style="color: ${p.present ? '#34d399' : '#f87171'}">${p.present ? 'Present' : (p.reason || 'Absent')}</span>
        </div>
        <button class="delete-presence-btn" data-date="${p.date}" style="background: none; border: none; color: #f87171; cursor: pointer; font-size: 0.75rem;">Supprimer</button>
      `;

      row.querySelector('.delete-presence-btn').addEventListener('click', async () => {
        if (!confirm("Voulez-vous supprimer cette seance ?")) return;
        
        // Supprimer localement de la liste et renvoyer tout le tableau mis a jour
        const updatedPresence = selectedMember.presence.filter(item => item.date !== p.date);
        
        try {
          const res = await fetch('/api/admin/members/update', {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({
              memberId: selectedMember.id,
              presence: updatedPresence
            })
          });
          const data = await res.json();
          if (data.success) {
            selectedMember.presence = updatedPresence;
            const idx = currentMembers.findIndex(m => m.id === selectedMember.id);
            if (idx !== -1) currentMembers[idx].presence = updatedPresence;
            renderModalPresenceTab();
            renderAdminMembers();
            showAlertInModal('Seance supprimee', 'success');
          }
        } catch(err) {
          console.error(err);
        }
      });

      list.appendChild(row);
    });
  }

  function renderModalGalleryTab() {
    const grid = document.getElementById('modalGalleryGrid');
    grid.innerHTML = '';

    const gallery = selectedMember.gallery || [];
    if (gallery.length === 0) {
      grid.innerHTML = '<div style="grid-column: 1/-1; color: var(--text-muted); font-style: italic; font-size: 0.85rem; padding: 0.5rem 0;">Aucune photo dans la galerie.</div>';
      return;
    }

    gallery.forEach(url => {
      const item = document.createElement('div');
      item.style.position = 'relative';
      item.style.aspectRatio = '1';
      item.style.borderRadius = '8px';
      item.style.overflow = 'hidden';
      item.style.border = '1px solid rgba(255,255,255,0.08)';

      item.innerHTML = `
        <img src="${url}" style="width: 100%; height: 100%; object-fit: cover;">
        <button class="delete-photo-btn" data-url="${url}" style="position: absolute; top: 2px; right: 2px; background: rgba(0,0,0,0.6); border: none; color: #ff4d4d; border-radius: 50%; width: 22px; height: 22px; font-size: 0.8rem; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: bold;">&times;</button>
      `;

      item.querySelector('.delete-photo-btn').addEventListener('click', async () => {
        if (!confirm("Voulez-vous supprimer cette photo ?")) return;
        try {
          const res = await fetch('/api/admin/members/gallery', {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({
              memberId: selectedMember.id,
              action: 'remove',
              imageUrl: url
            })
          });
          const data = await res.json();
          if (data.success) {
            selectedMember.gallery = data.gallery;
            const idx = currentMembers.findIndex(m => m.id === selectedMember.id);
            if (idx !== -1) currentMembers[idx].gallery = data.gallery;
            renderModalGalleryTab();
            showAlertInModal('Photo supprimee de la galerie', 'success');
          }
        } catch(err) {
          console.error(err);
        }
      });

      grid.appendChild(item);
    });
  }

</script>





