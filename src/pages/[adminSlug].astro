---

import BaseLayout from '../layouts/BaseLayout.astro';
import StatsTracker from '../components/StatsTracker.astro';

import scheduleData from '../data/schedule.json';

import formationsData from '../data/formation.json';

import infrastructuresData from '../data/infrastructure.json';

import countersData from '../data/counters.json';

import adminConfig from '../../admin-config.json';



export function getStaticPaths() {

  const slugs = [adminConfig.loginSlug, ...(adminConfig.extraSlugs || [])].filter(Boolean);

  if (slugs.length === 0) slugs.push('aqacontrol2026');

  return slugs.map(slug => ({ params: { adminSlug: slug } }));

}



const { adminSlug } = Astro.params;

const passwordHash = adminConfig.passwordHash || '65cdacaf34486fbb5c32641665f6f5a1a6985aa89dbe66286f85bbdd4be34fd5';

---



<BaseLayout

  title="AQA Control Center | Admin Portal v3.0"

  description="Administration centrale de l'académie AQA Sports."

  currentPage={"/" + (adminConfig.loginSlug || "aqacontrol2026")}

  robots="noindex, nofollow"

>



  <!-- ==================== LOGIN SCREEN OVERLAY ==================== -->

  <div id="loginOverlay" class="login-overlay">

    <div class="login-card">

      <div class="login-logo-wrap">

        <img src="https://i.ibb.co/08WDCFj/Turquoise-Modern-Warning-with-Rays-Instagram-Post.png" alt="AQA Logo" class="login-logo">

      </div>

      <h1 class="login-title">AQA Control Center</h1>

      <p class="login-sub">Accès réservé aux administrateurs AQA Sports</p>



      <div class="login-meme">
        <img src="https://media0.giphy.com/media/v1.Y2lkPTc5MGI3NjExeTl5dG40ZzRpY3F1dTNkOWt0YjN4N2p0cGtkNm91aGR4cTZ6N3g1NCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9dg/F37vjAFGcM7mjbxfAb/giphy.gif" alt="Admin Authorization Meme">
        <p class="meme-label">who are you</p>
      </div>



      <form id="loginForm" class="login-form" autocomplete="off">

        <div class="login-field">

          <label for="adminPassword">Mot de passe administrateur</label>

          <input type="password" id="adminPassword" class="login-input" placeholder="••••••••••••" autofocus>

        </div>

        <div id="loginError" class="login-error" style="display:none;">Mot de passe incorrect. Réessayez.</div>

        <button type="submit" id="loginBtn" class="login-btn">

          <span id="loginBtnText">Accéder au panneau</span>

          <span id="loginBtnSpinner" style="display:none;">⏳ Vérification...</span>

        </button>

      </form>

    </div>

  </div>



  <!-- ==================== MAIN ADMIN PANEL ==================== -->

  <div id="adminPanel" class="admin-wrapper" style="display:none;">



    <!-- SIDEBAR -->

    <aside class="admin-sidebar">

      <div class="sidebar-header">

        <a href="/">

          <img src="https://i.ibb.co/08WDCFj/Turquoise-Modern-Warning-with-Rays-Instagram-Post.png" alt="AQA Logo" class="logo">

        </a>

        <div>

          <h2 class="sidebar-title">AQA Control Center</h2>

          <span class="version-badge">v3.0 Dynamic</span>

        </div>

      </div>



      <nav class="sidebar-nav">

        <button class="nav-tab-btn active" data-tab="dashboard">

          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1"></rect><rect x="14" y="3" width="7" height="5" rx="1"></rect><rect x="14" y="12" width="7" height="9" rx="1"></rect><rect x="3" y="16" width="7" height="5" rx="1"></rect></svg>

          Tableau de Bord

        </button>



        <button class="nav-tab-btn" data-tab="planning">

          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>

          Gestion Planning

        </button>



        <button class="nav-tab-btn" data-tab="formations">

          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path></svg>

          Gestion Formations

        </button>



        <button class="nav-tab-btn" data-tab="infrastructures">

          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>

          Infrastructures (Piscines)

        </button>



        <button class="nav-tab-btn" data-tab="counters">

          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>

          Compteurs Accueil

        </button>



        <button class="nav-tab-btn" data-tab="members">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          Gestion Membres
        </button>

        <button class="nav-tab-btn" data-tab="settings">

          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>

          Paramètres Connexion

        </button>

      </nav>



      <div class="sidebar-footer">

        <button id="deployGitBtn" class="btn btn-primary btn-deploy">Déployer sur GitHub</button>

        <div id="deployStatus" class="deploy-status">Système synchronisé</div>

        <button id="logoutBtn" class="btn btn-logout">Déconnexion</button>

      </div>

    </aside>



    <!-- MAIN CONTENT -->

    <main class="admin-main">



      <!-- DASHBOARD TAB -->

      <section id="tab-dashboard" class="admin-section active">

        <div class="section-title-bar">

          <h2>Tableau de Bord & Statistiques</h2>

          <p class="section-desc">Aperçu global de l'occupation et de la capacité de l'académie en temps réel.</p>

        </div>



        <div class="stats-grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; margin-bottom: 1.5rem;">

          <StatsTracker
            label="Infrastructures"
            valueId="dashInfraCount"
            color="teal"
            icon={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>`}
          />

          <StatsTracker
            label="Formations Actives"
            valueId="dashFormationsCount"
            color="gold"
            icon={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path></svg>`}
          />

          <StatsTracker
            label="Capacité Totale"
            valueId="dashCapacity"
            color="teal"
            icon={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`}
          />

          <StatsTracker
            label="Créneaux Pris"
            valueId="dashTaken"
            color="pink"
            trendId="dashTakenTrend"
            icon={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>`}
          />

          <StatsTracker
            label="Membres Actifs"
            valueId="dashActiveMembersCount"
            color="green"
            trendId="dashMembersTrend"
            icon={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`}
          />

        </div>



        <div class="dashboard-details glass-panel">

          <h3>Occupation par Infrastructure</h3>

          <div id="dashLocationStats" class="dash-location-stats"></div>

        </div>



        <div class="dashboard-details glass-panel" style="margin-top: 1.5rem;">

          <h3>Alertes Capacité & Groupes Saturation</h3>

          <div id="dashAlertsList" class="dash-alerts-list"></div>

        </div>



        <div class="dashboard-details glass-panel" style="margin-top: 1.5rem;">

          <h3>Console de Déploiement</h3>

          <pre id="deployLogsConsole" class="terminal-logs">Console en attente d'instruction...</pre>

        </div>

      </section>



      <!-- PLANNING TAB -->

      <section id="tab-planning" class="admin-section">

        <div class="section-title-bar">

          <h2>Planificateur de Séances & Horaires</h2>

          <p class="section-desc">Gérez la capacité des coachs et des groupes par piscine partenaire.</p>

        </div>



        <div class="control-panel glass-panel">

          <div class="selectors">

            <div class="field-group">

              <label for="locationSelect">Emplacement :</label>

              <select id="locationSelect" class="form-control"></select>

            </div>

            <div class="field-group">

              <label for="categorySelect">Catégorie :</label>

              <select id="categorySelect" class="form-control"></select>

            </div>

          </div>

          <div class="action-buttons">

            <button id="addCoachBtn" class="btn btn-secondary btn-icon">Ajouter un Coach</button>

          </div>

        </div>



        <div id="editorContainer" class="editor-container"></div>



        <div class="save-bar">

          <button id="savePlanningBtn" class="btn btn-primary">Enregistrer le Planning</button>

          <span id="savePlanningStatus" class="save-status"></span>

        </div>

      </section>



      <!-- FORMATIONS TAB -->

      <section id="tab-formations" class="admin-section">

        <div class="section-title-bar">

          <h2>Catalogue des Formations & Masterclasses</h2>

          <p class="section-desc">Ajoutez, modifiez ou activez des programmes de certification de l'académie.</p>

        </div>



        <div class="control-panel glass-panel">

          <button id="addFormationBtn" class="btn btn-secondary">Créer une Formation</button>

        </div>



        <div id="formationsContainer" class="formations-editor-grid"></div>



        <div class="save-bar">

          <button id="saveFormationsBtn" class="btn btn-primary">Enregistrer les Formations</button>

          <span id="saveFormationsStatus" class="save-status"></span>

        </div>

      </section>



      <!-- INFRASTRUCTURES TAB -->

      <section id="tab-infrastructures" class="admin-section">

        <div class="section-title-bar">

          <h2>Administration des Infrastructures</h2>

          <p class="section-desc">Gérez les piscines partenaires et centres d'entraînement AQA.</p>

        </div>



        <div class="control-panel glass-panel">

          <button id="addInfrastructureBtn" class="btn btn-secondary">Créer une Infrastructure</button>

        </div>



        <div id="infrastructuresContainer" class="infrastructures-editor-grid"></div>



        <div class="save-bar">

          <button id="saveInfrastructuresBtn" class="btn btn-primary">Enregistrer les Infrastructures</button>

          <span id="saveInfrastructuresStatus" class="save-status"></span>

        </div>

      </section>



      <!-- COUNTERS TAB -->

      <section id="tab-counters" class="admin-section">

        <div class="section-title-bar">

          <h2>Compteurs de Performance Accueil</h2>

          <p class="section-desc">Modifiez en temps réel les statistiques clés affichées sur la page d'accueil.</p>

        </div>



        <div class="counters-panel glass-panel">

          <div class="counters-editor-grid">

            <div class="counter-field-group">

              <label for="countAthletes">Athlètes formés :</label>

              <input type="number" id="countAthletes" class="form-control" min="0">

            </div>

            <div class="counter-field-group">

              <label for="countCoaches">Coachs d'élite :</label>

              <input type="number" id="countCoaches" class="form-control" min="0">

            </div>

            <div class="counter-field-group">

              <label for="countPools">Infrastructures partenaires :</label>

              <input type="number" id="countPools" class="form-control" min="0">

            </div>

            <div class="counter-field-group">

              <label for="countSatisfaction">⭐ Satisfaction client (%) :</label>

              <input type="number" id="countSatisfaction" class="form-control" min="0" max="100">

            </div>

          </div>

        </div>



        <div class="save-bar">

          <button id="saveCountersBtn" class="btn btn-primary">Enregistrer les Compteurs</button>

          <span id="saveCountersStatus" class="save-status"></span>

        </div>

      </section>



      <!-- MEMBERS TAB -->

      <section id="tab-members" class="admin-section">

        <div class="section-title-bar">

          <h2>Gestion des Membres & Inscriptions</h2>

          <p class="section-desc">Validez les inscriptions en attente, gerez les abonnements, suivez les presences et mettez a jour le suivi technique.</p>

        </div>



        <!-- Pending approvals -->

        <div class="dashboard-details glass-panel" style="margin-bottom: 2rem;">

          <h3>Demandes d'adhesion en attente (Verification requise)</h3>

          <div id="pendingMembersContainer" class="pending-members-grid" style="margin-top: 1rem; display: grid; grid-template-columns: 1fr; gap: 1.5rem;">

            <!-- Rendered dynamically -->

          </div>

        </div>



        <!-- Sub Change Requests -->

        <div class="dashboard-details glass-panel" style="margin-bottom: 2rem;">

          <h3>Demandes de modification d'abonnement / Formule</h3>

          <div id="pendingChangesContainer" class="pending-members-grid" style="margin-top: 1rem; display: grid; grid-template-columns: 1fr; gap: 1.5rem;">

            <!-- Rendered dynamically -->

          </div>

        </div>



        <!-- Search & Full Members Grid -->

        <div class="dashboard-details glass-panel">

          <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;">

            <div class="field-group" style="flex: 1; min-width: 250px;">

              <label for="memberSearch">Recherche :</label>

              <input type="text" id="memberSearch" class="form-control" placeholder="Rechercher par nom, email, telephone...">

            </div>

            <div class="field-group" style="width: 180px;">

              <label for="memberFilterStatus">Filtrer par statut :</label>

              <select id="memberFilterStatus" class="form-control">

                <option value="all">Tous les statuts</option>

                <option value="active">Actif</option>

                <option value="pending">En attente</option>

                <option value="suspended">Suspendu</option>

                <option value="non-member">Communaute</option>

              </select>

            </div>

            <div class="field-group" style="width: 180px;">

              <label for="memberFilterPool">Piscine :</label>

              <select id="memberFilterPool" class="form-control">

                <option value="all">Toutes les piscines</option>

                <option value="reghaia">Reghaia</option>

                <option value="cheraga">Cheraga</option>

              </select>

            </div>

          </div>



          <h3>Annuaire des Utilisateurs</h3>

          <div class="table-responsive" style="margin-top: 1rem; overflow-x: auto;">

            <table class="admin-members-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">

              <thead>

                <tr style="border-bottom: 1px solid rgba(255,255,255,0.08); color: var(--color-primary);">

                  <th style="padding: 1rem 0.5rem;">Nom</th>

                  <th style="padding: 1rem 0.5rem;">Statut</th>

                  <th style="padding: 1rem 0.5rem;">Formule</th>

                  <th style="padding: 1rem 0.5rem;">Creneau</th>

                  <th style="padding: 1rem 0.5rem;">XP</th>

                  <th style="padding: 1rem 0.5rem; text-align: right;">Actions</th>

                </tr>

              </thead>

              <tbody id="membersTableBody">

                <!-- Rendered dynamically -->

              </tbody>

            </table>

          </div>

        </div>



        <!-- Edit Modal Overlay -->

        <div id="memberEditModal" class="login-overlay" style="display: none; z-index: 1000; align-items: center; justify-content: center;">

          <div class="login-card" style="max-width: 750px; width: 90%; max-height: 90vh; overflow-y: auto; padding: 2.5rem; display: block; background: linear-gradient(145deg, #0a0a0a, #161a24); border: 2px solid rgba(0, 242, 255, 0.25); box-shadow: var(--shadow-glow-active);">

            

            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 1rem; margin-bottom: 1.5rem;">

              <h2 id="editModalTitle" style="font-family: var(--font-display); font-size: 1.4rem; color: var(--color-teal); margin: 0;">Gérer l'Athlète</h2>

              <button id="closeEditModalBtn" style="background: none; border: none; color: #ff4d4d; font-size: 2rem; cursor: pointer; line-height: 1;">&times;</button>

            </div>



            <!-- Tabs in modal -->

            <div style="display: flex; gap: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 1.5rem; overflow-x: auto; padding-bottom: 0.5rem;">

              <button class="modal-tab-btn active" data-modaltab="profile">Profil & Formule</button>

              <button class="modal-tab-btn" data-modaltab="presence">Presences</button>

              <button class="modal-tab-btn" data-modaltab="suivi">Suivi Technique</button>

              <button class="modal-tab-btn" data-modaltab="gamification">Recompenses & XP</button>

              <button class="modal-tab-btn" data-modaltab="gallery">Galerie</button>

            </div>



            <div id="modalAlert" class="auth-alert" style="display: none; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; margin-bottom: 1.5rem;"></div>



            <!-- Tab Content: Profile -->

            <div id="modal-tab-profile" class="modal-tab-content active">

              <form id="modalProfileForm" style="display: flex; flex-direction: column; gap: 1.25rem;">

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">

                  <div class="field-group">

                    <label>Nom complet :</label>

                    <input type="text" id="editFullName" class="form-control" required>

                  </div>

                  <div class="field-group">

                    <label>Telephone :</label>

                    <input type="text" id="editPhone" class="form-control">

                  </div>

                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">

                  <div class="field-group">

                    <label>Date de naissance :</label>

                    <input type="date" id="editBirthDate" class="form-control">

                  </div>

                  <div class="field-group">

                    <label>Categorie d'entrainement :</label>

                    <select id="editGender" class="form-control" required>

                      <option value="homme">Homme</option>

                      <option value="femme">Femme</option>

                      <option value="ados">Ados Garcon</option>

                      <option value="enfants">Enfant</option>

                      <option value="apnea">Apnee</option>

                    </select>

                  </div>

                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">

                  <div class="field-group">

                    <label>Formule / Tier :</label>

                    <select id="editTier" class="form-control" required>

                      <option value="Starter">Starter</option>
                      <option value="Silver">Silver</option>
                      <option value="Gold">Gold</option>
                      <option value="Diamond">Diamond</option>
                      <option value="Emerald">Emerald</option>
                      <option value="Non-Membre">Non-Membre (Communaute)</option>

                    </select>

                  </div>

                  <div class="field-group">

                    <label>Statut du compte :</label>

                    <select id="editStatus" class="form-control" required>

                      <option value="active">Actif</option>

                      <option value="pending">En attente</option>

                      <option value="suspended">Suspendu</option>

                    </select>

                  </div>

                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.75rem;">

                  <div class="field-group">

                    <label>Piscine :</label>

                    <select id="editPool" class="form-control">

                      <option value="">Non assigne</option>

                      <option value="reghaia">Reghaia</option>

                      <option value="cheraga">Cheraga</option>

                    </select>

                  </div>

                  <div style="display: none;">
                    <input type="text" id="editCoach">
                    <input type="text" id="editSlot">
                  </div>

                </div>

                <div id="adminSlotsSelectionContainer" class="field-group" style="display: none; margin-top: 1rem;">
                  <label id="adminSlotsSelectionLabel" style="font-weight: 600; color: #fff;">Créneaux d'entraînement (Sélection multiple) :</label>
                  <div id="adminSlotsGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.5rem; max-height: 200px; overflow-y: auto; padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); margin-top: 0.5rem;">
                    <!-- Dynamically populated checkboxes -->
                  </div>
                  <div id="adminSlotsLimitNotice" style="font-size: 0.85rem; color: var(--color-teal); margin-top: 0.5rem; font-weight: 600;"></div>
                </div>

                <div class="field-group">

                  <label>Date de fin d'abonnement :</label>

                  <input type="date" id="editEndDate" class="form-control">

                </div>

                <button type="submit" class="btn btn-primary" style="margin-top: 1rem;">Enregistrer les modifications</button>

              </form>

            </div>



            <!-- Tab Content: Presence -->

            <div id="modal-tab-presence" class="modal-tab-content" style="display: none;">

