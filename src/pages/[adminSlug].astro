            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
              <button class="btn btn-primary approve-btn" data-id="${m.id}" style="padding: 0.45rem 1rem; font-size: 0.85rem;">Approuver</button>
              <button class="btn btn-secondary reject-btn" data-id="${m.id}" style="padding: 0.45rem 1rem; font-size: 0.85rem; border-color: #ff4d4d; color: #ff4d4d; background: transparent;">Rejeter</button>
