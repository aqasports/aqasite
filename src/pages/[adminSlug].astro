              <div class="field-group">
                <label style="font-size: 0.75rem; color: var(--text-secondary);">Formule / Tier</label>
                <select class="form-control inline-tier-${m.id}" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">
                  <option value="Starter" ${m.membershipTier === 'Starter' ? 'selected' : ''}>Starter</option>
                  <option value="Silver" ${(!m.membershipTier || m.membershipTier === 'Silver') ? 'selected' : ''}>Silver</option>
                  <option value="Gold" ${m.membershipTier === 'Gold' ? 'selected' : ''}>Gold</option>
                  <option value="Diamond" ${m.membershipTier === 'Diamond' ? 'selected' : ''}>Diamond</option>
                  <option value="Emerald" ${m.membershipTier === 'Emerald' ? 'selected' : ''}>Emerald</option>
                </select>
              </div>
              <div class="field-group">
                <label style="font-size: 0.75rem; color: var(--text-secondary);">Piscine</label>
                <select class="form-control inline-pool-${m.id}" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">
                  <option value="reghaia" ${m.subscription?.poolKey === 'reghaia' ? 'selected' : ''}>Reghaia</option>
                  <option value="cheraga" ${m.subscription?.poolKey === 'cheraga' ? 'selected' : ''}>Cheraga</option>
                </select>
              </div>
              <div class="field-group">
                <label style="font-size: 0.75rem; color: var(--text-secondary);">Categorie</label>
                <select class="form-control inline-cat-${m.id}" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">
                  <option value="homme" ${(m.gender === 'homme' || !m.gender) ? 'selected' : ''}>Homme</option>
                  <option value="femme" ${m.gender === 'femme' ? 'selected' : ''}>Femme</option>
                  <option value="ados" ${m.gender === 'ados' ? 'selected' : ''}>Ados Garcon</option>
                  <option value="enfants" ${m.gender === 'enfants' ? 'selected' : ''}>Enfant</option>
                </select>
              </div>
              <div class="field-group">
                <label style="font-size: 0.75rem; color: var(--text-secondary);">Fin Abonnement</label>
                <input type="date" class="form-control inline-enddate-${m.id}" value="${new Date(Date.now() + 30*24*60*60*1000).toISOString().split('T')[0]}" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">
              </div>
            </div>
            <div class="field-group">
              <label style="font-size: 0.75rem; color: var(--text-secondary); font-weight:600;">Creneaux d'entrainement (cliquez pour selectionner)</label>
              <div id="inline-slots-grid-${m.id}" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.4rem; max-height: 180px; overflow-y: auto; background: rgba(0,0,0,0.2); border-radius: 8px; padding: 0.5rem; border: 1px solid rgba(255,255,255,0.08); margin-top: 0.4rem;">
                <div style="color:var(--text-muted);font-size:0.8rem;padding:0.5rem;">Chargement des creneaux...</div>
              </div>
              <div id="inline-slots-notice-${m.id}" style="font-size: 0.8rem; color: var(--color-teal); margin-top: 0.3rem;"></div>
