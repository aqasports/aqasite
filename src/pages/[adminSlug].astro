  // ==================== DASHBOARD ====================

  function updateDashboardStats() {

    document.getElementById('dashInfraCount').textContent = currentInfrastructures.length;

    document.getElementById('dashFormationsCount').textContent = currentFormations.filter(f => f.active).length;



    let globalCapacity = 0;

    let globalTaken = 0;

    const locationStatsContainer = document.getElementById('dashLocationStats');

    const alertsContainer = document.getElementById('dashAlertsList');



    locationStatsContainer.innerHTML = '';

    alertsContainer.innerHTML = '';



    Object.keys(currentSchedule).forEach(locKey => {

      const loc = currentSchedule[locKey];

      let locCapacity = 0;

      let locTaken = 0;



      if (loc && loc.categories) {

        Object.keys(loc.categories).forEach(catKey => {

          const cat = loc.categories[catKey];

          if (cat && cat.coaches) {

            cat.coaches.forEach(coach => {

              if (coach.slots) {

                coach.slots.forEach(slot => {

                  const cap = parseInt(slot.total) || 0;

                  const taken = parseInt(slot.taken) || 0;

                  locCapacity += cap;

                  locTaken += taken;

                  globalCapacity += cap;

                  globalTaken += taken;



                  const occupancy = cap > 0 ? (taken / cap) * 100 : 0;

                  if (occupancy >= 100) {

                    const el = document.createElement('div');

                    el.className = 'dash-alert alert-danger';

                    el.innerHTML = `<strong>[Complet]</strong> ${loc.name || locKey} — Coach ${coach.name} (${slot.day} à ${slot.time}) · <strong>${taken}/${cap} places</strong>`;

                    alertsContainer.appendChild(el);

                  } else if (occupancy >= 85) {

                    const el = document.createElement('div');

                    el.className = 'dash-alert alert-warning';

                    el.innerHTML = `<strong>[Presque Saturé]</strong> ${loc.name || locKey} — Coach ${coach.name} (${slot.day} à ${slot.time}) · <strong>${taken}/${cap} (${Math.round(occupancy)}%)</strong>`;

                    alertsContainer.appendChild(el);

                  } else if (taken === 0 && cap > 0) {

                    const el = document.createElement('div');

                    el.className = 'dash-alert alert-info';

                    el.innerHTML = `ℹ️ <strong>[Groupe Vide]</strong> ${loc.name || locKey} — Coach ${coach.name} (${slot.day} à ${slot.time}) · <strong>0/${cap} places libres</strong>`;

                    alertsContainer.appendChild(el);

                  }

                });

              }

            });

          }

        });

      }



      const locOccupancy = locCapacity > 0 ? Math.round((locTaken / locCapacity) * 100) : 0;
      const chartColorClass = locOccupancy > 85 ? 'chart-red' : 'chart-teal';
      const progressBgColor = locOccupancy > 85 ? '#ef4444' : '#00f2ff';

      const row = document.createElement('div');
      row.className = 'dash-location-row';
      row.innerHTML = `
        <div class="dash-location-info">
          <div class="loc-row-header">
            <strong>${loc.name || locKey}</strong>
            <span>${locTaken}/${locCapacity} places</span>
          </div>
          <div class="tel-bar-wrap">
            <div class="tel-bar" style="width: ${locOccupancy}%; background-color: ${progressBgColor}"></div>
          </div>
        </div>
        <svg viewBox="0 0 36 36" class="circular-chart ${chartColorClass}">
          <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
          <path class="circle" stroke-dasharray="${locOccupancy}, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
          <text x="18" y="20.35" class="percentage">${locOccupancy}%</text>
        </svg>
      `;

      locationStatsContainer.appendChild(row);
    });



    document.getElementById('dashCapacity').textContent = globalCapacity;

    document.getElementById('dashTaken').textContent = globalTaken;

    // Trend for taken slots
    const takenTrendEl = document.getElementById('dashTakenTrend');
    if (takenTrendEl) {
      const ratio = globalCapacity > 0 ? Math.round((globalTaken / globalCapacity) * 100) : 0;
      const cls = ratio >= 85 ? 'up' : (ratio < 30 ? 'down' : 'flat');
      takenTrendEl.textContent = `${ratio}% d'occupation`;
      takenTrendEl.className = `st-trend ${cls}`;
    }

    if (alertsContainer.children.length === 0) {

      alertsContainer.innerHTML = '<div class="no-alerts">Aucun groupe en saturation ou alerte pour le moment.</div>';

    }

  }

  // Count-up animation for StatsTracker .st-value elements
  function animateCountUp(el, target) {
    if (isNaN(target) || target === 0) { el.textContent = target; return; }
    let start = 0;
    const step = Math.max(1, Math.ceil(target / 50));
    el.textContent = '0';
    const timer = setInterval(() => {
      start = Math.min(start + step, target);
      el.textContent = start;
      if (start >= target) clearInterval(timer);
    }, 16);
  }

  // Live member count from admin API
  async function fetchLiveMemberCount() {
    const membersTrendEl = document.getElementById('dashMembersTrend');
    const membersCountEl = document.getElementById('dashActiveMembersCount');
    if (!membersCountEl) return;
    try {
      const token = localStorage.getItem('adminToken');
      if (!token) return;
      const res = await fetch('/api/admin/members', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) return;
      const data = await res.json();
      let members = [];
      if (data && Array.isArray(data.members)) members = data.members;
      else if (data && Array.isArray(data)) members = data;
      const active = members.filter(m => m.status === 'active').length;
      const pending = members.filter(m => m.status === 'pending').length;
      animateCountUp(membersCountEl, active);
      if (membersTrendEl && pending > 0) {
        membersTrendEl.textContent = `${pending} en attente`;
        membersTrendEl.className = 'st-trend up';
      } else if (membersTrendEl) {
        membersTrendEl.textContent = 'Tous actifs ✓';
        membersTrendEl.className = 'st-trend flat';
      }
    } catch (err) {
      console.warn('[Admin] Could not fetch live member count:', err);
      if (membersCountEl) membersCountEl.textContent = '—';
    }
  }



