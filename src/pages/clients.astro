    catApnea: "Apnee (AQA Apnea)",
    labelIsMember: "Etes-vous deja adherent a l'academie AQA ?",
    optionYes: "Oui, je suis deja inscrit",
    optionNo: "Non, je souhaite rejoindre la communaute",
    btnConnect: "Se connecter",
    btnRegister: "S'inscrire",
    errorLogin: "Email ou mot de passe incorrect.",
    errorGeneric: "Une erreur est survenue, veuillez reessayer.",
    registerSuccessPending: "Inscription reussie ! Votre compte a ete cree et est en attente de validation par l'administrateur. Nous vous contacterons rapidement.",
    registerSuccessActive: "Inscription reussie ! Vous pouvez maintenant vous connecter pour acceder a l'espace communaute.",
    alreadyRegistered: "Deja inscrit ? Connectez-vous ici",
    needAccount: "Pas encore de compte ? Enregistrez-vous ici",
    loading: "Chargement..."
  },
  ar: {
    metaTitle: "فضاء الاعضاء | اكاديمية اكا الرياضية",
    metaDesc: "قم بالولوج الى فضاء الاعضاء الخاص بك: جداول الحصص، متابعة التقدم، سجل المدفوعات ومعلومات المجموعة.",
    welcomeTitle: "مرحبا بكم في فضاء الرياضيين",
    welcomeDesc: "تابع تقدمك، واطلع على جداول السباحة والغوص، وسجل مدفوعاتك، واستعرض شارات الانجاز الخاصة بك.",
    tabLogin: "تسجيل الدخول",
    tabRegister: "انشاء حساب",
    labelEmail: "البريد الالكتروني :",
    labelPassword: "كلمة المرور :",
    labelFullName: "الاسم الكامل :",
    labelPhone: "رقم الهاتف :",
    labelBirthDate: "تاريخ الميلاد :",
    labelCategory: "فئة التدريب :",
    catMen: "رجال",
    catWomen: "نساء",
    catTeens: "مراهقون ذكور (13-16 سنة)",
    catKids: "اطفال (5-12 سنة)",
    catApnea: "غوص حر (أكا للغوص الحر)",
    labelIsMember: "هل انت مسجل بالفعل في اكاديمية اكا ؟",
    optionYes: "نعم، انا مشترك بالفعل",
    optionNo: "لا، اريد الانضمام الى المجتمع",
    btnConnect: "تسجيل الدخول",
    btnRegister: "تسجيل",
    errorLogin: "البريد الالكتروني او كلمة المرور غير صحيحة.",
    errorGeneric: "حدث خطا ما، يرجى المحاولة مرة اخرى.",
    registerSuccessPending: "تم التسجيل بنجاح! تم انشاء حسابك وهو قيد المراجعة من طرف الادارة. سنتصل بك قريبا.",
    registerSuccessActive: "تم التسجيل بنجاح! يمكنك الان تسجيل الدخول للولوج الى فضاء المجتمع.",
    alreadyRegistered: "مسجل بالفعل؟ سجل دخولك هنا",
    needAccount: "ليس لديك حساب؟ انشئ حسابا هنا",
    loading: "جاري التحميل..."
  },
  en: {
    metaTitle: "Members Area | AQA Sports Academy",
    metaDesc: "Access your AQA member space: session planning, progress tracking, payment history, and group information.",
    welcomeTitle: "Welcome to the Athlete Space",
    welcomeDesc: "Track your progress, check your swimming and apnea schedules, manage your subscriptions, and view your achievement badges.",
    tabLogin: "Sign In",
    tabRegister: "Create Account",
    labelEmail: "Email Address:",
    labelPassword: "Password:",
    labelFullName: "Full Name:",
    labelPhone: "Phone Number:",
    labelBirthDate: "Birth Date:",
    labelCategory: "Training Category:",
    catMen: "Men",
    catWomen: "Women",
    catTeens: "Teen Boys (13-16 years)",
    catKids: "Kids (5-12 years)",
    catApnea: "Apnea (AQA Apnea)",
    labelIsMember: "Are you already an AQA Academy member?",
    optionYes: "Yes, I am already a member",
    optionNo: "No, I want to join the community",
    btnConnect: "Sign In",
    btnRegister: "Register",
    errorLogin: "Incorrect email or password.",
    errorGeneric: "An error occurred, please try again.",
    registerSuccessPending: "Registration successful! Your account is created and pending approval by an administrator. We will contact you soon.",
    registerSuccessActive: "Registration successful! You can now log in to access the community space.",
    alreadyRegistered: "Already registered? Login here",
    needAccount: "Don't have an account? Sign up here",
    loading: "Loading..."
  }
};

const localT = pageTranslations[lang] || pageTranslations.fr;
---

<BaseLayout title={localT.metaTitle}
  description={localT.metaDesc}
  currentPage="/clients" lang={lang}>
  
  <Navbar currentPage="/clients" lang={lang} />

  <div class="auth-page-container">
    <div class="auth-grid container">
      
      <!-- Welcome Panel -->
      <div class="auth-welcome-panel">
        <span class="badge">&#9733; Espace Adherents</span>
        <h1>{localT.welcomeTitle}</h1>
        <div class="divider"></div>
        <p>{localT.welcomeDesc}</p>
        
        <div class="features-list">
          <div class="feature-item">
            <span class="icon-wrap">&#128200;</span>
            <div>
              <strong>Suivi de Progression</strong>
              <span>Visualisez vos seances, retours des coachs et notes techniques.</span>
            </div>
          </div>
          <div class="feature-item">
            <span class="icon-wrap">&#127941;</span>
            <div>
              <strong>XP et Badges</strong>
              <span>Gagnez des points d'experience et debloquez des badges virtuels.</span>
            </div>
          </div>
          <div class="feature-item">
            <span class="icon-wrap">&#128203;</span>
            <div>
              <strong>Planning & Formules</strong>
              <span>Consultez vos horaires et changez de creneau en ligne.</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Auth Form Card -->
      <div class="auth-form-panel">
        <div class="glass-panel auth-card">
          
          <div class="auth-tabs">
            <button id="tabLoginBtn" class="tab-btn active">{localT.tabLogin}</button>
            <button id="tabRegisterBtn" class="tab-btn">{localT.tabRegister}</button>
          </div>

          <div id="authAlert" class="auth-alert" style="display: none;"></div>

          <!-- LOGIN FORM -->
          <form id="loginForm" class="auth-form active" autocomplete="off">
            <div class="form-group">
              <label for="loginEmail">{localT.labelEmail}</label>
              <input type="email" id="loginEmail" required class="form-control" placeholder="nom@exemple.com">
            </div>

            <div class="form-group">
              <label for="loginPassword">{localT.labelPassword}</label>
              <input type="password" id="loginPassword" required class="form-control" placeholder="••••••••">
            </div>

            <button type="submit" class="auth-submit-btn">
              <span class="btn-text">{localT.btnConnect}</span>
              <span class="btn-spinner" style="display: none;">...</span>
            </button>

            <p class="form-toggle-link" id="linkToRegister">{localT.needAccount}</p>
          </form>

          <!-- REGISTER FORM -->
          <form id="registerForm" class="auth-form" autocomplete="off" style="display: none;">
            <div class="form-group">
              <label for="registerFullName">{localT.labelFullName}</label>
              <input type="text" id="registerFullName" required class="form-control" placeholder="Sid Ahmed">
            </div>

            <div class="form-group">
              <label for="registerEmail">{localT.labelEmail}</label>
              <input type="email" id="registerEmail" required class="form-control" placeholder="nom@exemple.com">
            </div>

            <div class="form-group">
              <label for="registerPassword">{localT.labelPassword}</label>
              <input type="password" id="registerPassword" required class="form-control" placeholder="Minimum 6 caracteres">
            </div>

            <div class="form-group">
              <label for="registerPhone">{localT.labelPhone}</label>
              <input type="tel" id="registerPhone" required class="form-control" placeholder="0540000000">
            </div>

            <div class="form-group">
              <label for="registerBirthDate">{localT.labelBirthDate}</label>
              <input type="date" id="registerBirthDate" required class="form-control">
            </div>

            <div class="form-group">
              <label for="registerCategory">{localT.labelCategory}</label>
              <select id="registerCategory" required class="form-control">
                <option value="homme">{localT.catMen}</option>
                <option value="femme">{localT.catWomen}</option>
                <option value="ados">{localT.catTeens}</option>
                <option value="enfants">{localT.catKids}</option>
                <option value="apnea">{localT.catApnea}</option>
              </select>
            </div>

            <div class="form-group checkbox-group">
              <label for="registerIsMember">{localT.labelIsMember}</label>
              <select id="registerIsMember" required class="form-control">
                <option value="true">{localT.optionYes}</option>
                <option value="false">{localT.optionNo}</option>
              </select>
            </div>

            <button type="submit" class="auth-submit-btn">
              <span class="btn-text">{localT.btnRegister}</span>
              <span class="btn-spinner" style="display: none;">...</span>
            </button>

            <p class="form-toggle-link" id="linkToLogin">{localT.alreadyRegistered}</p>
          </form>

        </div>
      </div>

    </div>
  </div>

  <Footer lang={lang} />
</BaseLayout>

<script is:inline define:vars={{ lang }}>
  // Inline JS client-side checking and redirection
  document.addEventListener('astro:page-load', () => {
    // Determine target URL for portal based on language
    const getPortalPath = () => {
      if (lang === 'fr') return '/clients/portal';
      return `/${lang}/clients/portal`;
    };

    // Auto redirect if token exists
    const token = localStorage.getItem('aqa_member_token');
    if (token) {
      window.location.href = getPortalPath();
      return;
    }

    const tabLoginBtn = document.getElementById('tabLoginBtn');
    const tabRegisterBtn = document.getElementById('tabRegisterBtn');
    const loginForm = document.getElementById('loginForm');
    const registerForm = document.getElementById('registerForm');
    const linkToRegister = document.getElementById('linkToRegister');
    const linkToLogin = document.getElementById('linkToLogin');
    const authAlert = document.getElementById('authAlert');

    // Tab switching
    function showLogin() {
      tabLoginBtn.classList.add('active');
      tabRegisterBtn.classList.remove('active');
      loginForm.style.display = 'block';
      registerForm.style.display = 'none';
      authAlert.style.display = 'none';
    }

    function showRegister() {
      tabRegisterBtn.classList.add('active');
      tabLoginBtn.classList.remove('active');
      registerForm.style.display = 'block';
      loginForm.style.display = 'none';
      authAlert.style.display = 'none';
    }

    if (tabLoginBtn) tabLoginBtn.addEventListener('click', showLogin);
    if (tabRegisterBtn) tabRegisterBtn.addEventListener('click', showRegister);
    if (linkToRegister) linkToRegister.addEventListener('click', showRegister);
    if (linkToLogin) linkToLogin.addEventListener('click', showLogin);

    // Form handlers
    if (loginForm) {
      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const email = document.getElementById('loginEmail').value;
        const password = document.getElementById('loginPassword').value;
        const submitBtn = loginForm.querySelector('.auth-submit-btn');
        const spinner = submitBtn.querySelector('.btn-spinner');
        const text = submitBtn.querySelector('.btn-text');

        // Reset alert
        authAlert.style.display = 'none';
        authAlert.className = 'auth-alert';

        // Show loading
        spinner.style.display = 'inline-block';
        text.style.display = 'none';
        submitBtn.disabled = true;

        try {
          const res = await fetch('/api/member/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
          });
          const data = await res.json();

          if (data.success) {
            localStorage.setItem('aqa_member_token', data.token);
            localStorage.setItem('aqa_member_info', JSON.stringify(data.member));
            
            // Redirect to dashboard portal
            window.location.href = getPortalPath();
          } else {
            authAlert.textContent = data.error || 'Email ou mot de passe incorrect.';
            authAlert.className = 'auth-alert error';
            authAlert.style.display = 'block';
          }
        } catch (err) {
          authAlert.textContent = 'Erreur lors de la connexion. Veuillez reessayer.';
          authAlert.className = 'auth-alert error';
          authAlert.style.display = 'block';
        } finally {
          spinner.style.display = 'none';
          text.style.display = 'inline-block';
          submitBtn.disabled = false;
        }
      });
    }

    if (registerForm) {
      registerForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const fullName = document.getElementById('registerFullName').value;
        const email = document.getElementById('registerEmail').value;
        const password = document.getElementById('registerPassword').value;
        const phone = document.getElementById('registerPhone').value;
        const birthDate = document.getElementById('registerBirthDate').value;
        const gender = document.getElementById('registerCategory').value;
        const isAqaMember = document.getElementById('registerIsMember').value === 'true';

        const submitBtn = registerForm.querySelector('.auth-submit-btn');
        const spinner = submitBtn.querySelector('.btn-spinner');
        const text = submitBtn.querySelector('.btn-text');

        // Reset alert
        authAlert.style.display = 'none';
        authAlert.className = 'auth-alert';

        // Show loading
        spinner.style.display = 'inline-block';
        text.style.display = 'none';
        submitBtn.disabled = true;

        try {
          const res = await fetch('/api/member/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password, fullName, phone, birthDate, gender, isAqaMember })
          });
          const data = await res.json();

          if (data.success) {
            authAlert.className = 'auth-alert success';
            if (isAqaMember) {
              authAlert.textContent = 'Inscription reussie ! Compte cree et en attente de validation par l\'administrateur.';
            } else {
              authAlert.textContent = 'Inscription reussie ! Vous pouvez maintenant vous connecter.';
            }
            authAlert.style.display = 'block';
            
            // Reset form
            registerForm.reset();
            
            // Scroll to top of panel
            document.querySelector('.auth-card').scrollIntoView({ behavior: 'smooth' });

            // Switch to login tab after 3 seconds
            setTimeout(() => {
              showLogin();
              document.getElementById('loginEmail').value = email;
            }, 3000);

          } else {
            authAlert.textContent = data.error || 'Erreur lors de la creation du compte.';
            authAlert.className = 'auth-alert error';
            authAlert.style.display = 'block';
          }
        } catch (err) {
          authAlert.textContent = 'Erreur de connexion reseau. Veuillez reessayer.';
          authAlert.className = 'auth-alert error';
          authAlert.style.display = 'block';
        } finally {
          spinner.style.display = 'none';
          text.style.display = 'inline-block';
          submitBtn.disabled = false;
        }
      });
    }
  });
</script>

<style>
  .auth-page-container {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 3rem 0;
  }
  .auth-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .auth-welcome-panel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .auth-welcome-panel h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    background: linear-gradient(135deg, var(--color-teal), var(--color-blue), #fff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .auth-welcome-panel p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .auth-welcome-panel .badge {
    display: inline-block;
    align-self: flex-start;
    background: rgba(0, 242, 255, 0.1);
    border: 1px solid rgba(0, 242, 255, 0.3);
    color: var(--color-teal);
    padding: 0.4rem 1.2rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .auth-welcome-panel .divider {
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, var(--color-teal), var(--color-blue));
    border-radius: 2px;
  }
  .features-list {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .feature-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .feature-item .icon-wrap {
    font-size: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: var(--border-glass);
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-teal);
    flex-shrink: 0;
  }
  .feature-item strong {
    display: block;
    color: #fff;
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }
  .feature-item span {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }
  
  .auth-form-panel {
    display: flex;
    justify-content: center;
  }
  .auth-card {
    width: 100%;
    max-width: 460px;
    padding: 2.5rem;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
  }
  .auth-card:hover {
    border-color: rgba(0, 242, 255, 0.3);
    box-shadow: var(--shadow-glow-active);
  }
  .auth-tabs {
    display: flex;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 2rem;
  }
  .tab-btn {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    padding: 0.75rem 0;
    cursor: pointer;
    transition: var(--transition-smooth);
    position: relative;
  }
  .tab-btn.active {
    color: var(--color-teal);
  }
  .tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-teal);
    box-shadow: 0 0 10px var(--color-teal);
  }
  .auth-alert {
    padding: 1rem;
    border-radius: 12px;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  .auth-alert.error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #fca5a5;
  }
  .auth-alert.success {
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: #a7f3d0;
  }
  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-group label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .form-control {
    background: rgba(0, 0, 0, 0.4);
    border: var(--border-glass);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: var(--transition-smooth);
    width: 100%;
  }
  .form-control:focus {
    outline: none;
    border-color: var(--color-teal);
    background: rgba(0, 0, 0, 0.6);
    box-shadow: 0 0 15px rgba(0, 242, 255, 0.15);
  }
  select.form-control {
    appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg fill='white' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/><path d='M0 0h24v24H0z' fill='none'/></svg>");
    background-repeat: no-repeat;
    background-position: right 12px center;
    padding-right: 2.5rem;
  }
  .auth-submit-btn {
    background: linear-gradient(135deg, var(--color-blue), var(--color-teal));
    border: none;
    border-radius: 50px;
    color: #000;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    padding: 0.9rem 0;
    cursor: pointer;
    transition: var(--transition-smooth);
    margin-top: 1rem;
    box-shadow: 0 4px 15px rgba(0, 136, 255, 0.3);
  }
  .auth-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 242, 255, 0.5);
  }
  .auth-submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }
  .form-toggle-link {
    font-size: 0.85rem;
    color: var(--color-teal);
    text-align: center;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: var(--transition-smooth);
  }
  .form-toggle-link:hover {
    color: var(--color-blue);
    text-decoration: underline;
  }
  
  @media (max-width: 992px) {
    .auth-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .auth-page-container {
      padding: 1rem 0 3rem;
    }
    .auth-welcome-panel {
      text-align: center;
      align-items: center;
    }
    .auth-welcome-panel .divider {
      margin: 0 auto;
    }
    .features-list {
      text-align: left;
    }
  }
</style>
