---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import storeData from '../data/store.json';

export interface Props {
  lang?: string;
}

const { lang = 'fr' } = Astro.props;
const products = storeData.filter((product) => product.active !== false);
const featuredProducts = products.filter((product) => product.featured).slice(0, 4);
const categories = ['Tout', ...Array.from(new Set(products.map((product) => product.category).filter(Boolean)))];

const getRelativePath = (path, targetLang) => {
  if (targetLang === 'fr') return path;
  return `/${targetLang}${path === '/' ? '' : path}`;
};
---

<BaseLayout
  title="AQA Store — Boutique Officielle AQA Sports"
  description="Boutique officielle AQA Sports : equipements de natation, apnee, packs performance et accessoires selectionnes par les coachs AQA."
  keywords="AQA Store, boutique natation Algerie, equipement natation, apnee, accessoires AQA Sports"
  currentPage="/store"
  lang={lang}
>
  <Navbar currentPage="/store" lang={lang} />

  <main class="store-shell">
    <section class="store-hero">
      <div class="hero-copy">
        <span class="eyebrow">Boutique officielle AQA Sports</span>
        <h1>AQA Store</h1>
        <p>Equipement aquatique, packs coachs et accessoires club selectionnes pour nager mieux, plus vite et avec le style AQA.</p>
        <div class="hero-actions">
          <a href="#catalogue" class="primary-action">Explorer</a>
          <a href={getRelativePath('/wear', lang)} class="secondary-action">AQA Wear</a>
        </div>
      </div>

      <div class="hero-product" aria-label="AQA Store featured products">
        <div class="hero-product-image">
          <img src="/images/logo.webp" alt="AQA Sports" loading="eager" />
        </div>
        <div class="hero-product-meta">
          <span>Selection coach</span>
          <strong>{products.length} produits</strong>
        </div>
      </div>
    </section>

    <section class="store-metrics" aria-label="AQA Store highlights">
      <div>
        <span>01</span>
        <strong>Selection AQA</strong>
        <p>Materiel retenu par les coachs.</p>
      </div>
      <div>
        <span>02</span>
        <strong>Commande rapide</strong>
        <p>Validation directe par WhatsApp.</p>
      </div>
      <div>
        <span>03</span>
        <strong>Packs clubs</strong>
        <p>Options pour nageurs, kids et apnee.</p>
      </div>
    </section>

    {featuredProducts.length > 0 && (
      <section class="featured-band" aria-label="Produits mis en avant">
        <div class="section-heading">
          <span>Featured</span>
          <h2>Selections du moment</h2>
        </div>
        <div class="featured-grid">
          {featuredProducts.map((product) => (
            <article class="featured-card">
              <img src={product.image} alt={product.title} loading="lazy" />
              <div>
                <span>{product.badge}</span>
                <h3>{product.title}</h3>
                <p>{product.priceLabel}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <section id="catalogue" class="catalogue-section">
      <div class="section-heading catalogue-heading">
        <div>
          <span>Catalogue</span>
          <h2>Shop AQA</h2>
        </div>
        <div class="category-tabs" role="tablist" aria-label="Categories produits">
          {categories.map((category, index) => (
            <button class={`category-tab${index === 0 ? ' active' : ''}`} type="button" data-category={category}>
              {category}
            </button>
          ))}
        </div>
      </div>

      <div class="products-grid">
        {products.map((product) => (
          <article class="product-card" data-product-card data-category={product.category}>
            <div class="product-image">
              <img src={product.image} alt={product.title} loading="lazy" />
              <span class="product-badge">{product.badge}</span>
              <button
                type="button"
                class="product-3d-btn"
                data-3d-trigger
                data-model="/models/astronaut.glb"
                data-title={product.title}
                title="Aperçu 3D interactif"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                  <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                  <line x1="12" y1="22.08" x2="12" y2="12"/>
                </svg>
                <span>3D</span>
              </button>
            </div>
            <div class="product-body">
              <div class="product-kicker">{product.category} · {product.inventory}</div>
              <h3>{product.title}</h3>
              <p>{product.summary}</p>
              <div class="product-tags">{product.details}</div>
              <div class="product-footer">
                <strong>{product.priceLabel}</strong>
                <button
                  type="button"
                  class="product-btn"
                  data-add-product
                  data-id={product.id}
                  data-title={product.title}
                  data-price={product.priceLabel}
                >
                  {product.ctaLabel || 'Ajouter'}
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <aside class="order-dock" aria-label="AQA Bag">
      <div>
        <span>AQA Bag</span>
        <strong id="bagCount">0 article</strong>
      </div>
      <button type="button" id="checkoutBtn">Commander</button>
    </aside>

    <section class="store-cta">
      <div>
        <span>Service AQA</span>
        <h2>Commande assistee par l'equipe</h2>
        <p>Les tailles, disponibilites et packs sont confirmes avant validation pour eviter les achats inutiles.</p>
      </div>
    <!-- 3D Preview Modal -->
    <div id="viewer3dModal" class="modal-3d-overlay" style="display: none;" role="dialog" aria-modal="true" aria-labelledby="modal3dTitle">
      <div class="modal-3d-container glass-panel double-bezel">
        <div class="modal-3d-header">
          <h3 id="modal3dTitle">Aperçu 3D du produit</h3>
          <button type="button" id="close3dModalBtn" class="close-3d-btn" aria-label="Fermer le visualiseur 3D">&times;</button>
        </div>
        <div class="modal-3d-body" id="modal3dBody">
          <!-- model-viewer injected here dynamically -->
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<script is:inline>
  const bag = new Map();
  const bagCount = document.getElementById('bagCount');
  const checkoutBtn = document.getElementById('checkoutBtn');

  function refreshBag() {
    const total = Array.from(bag.values()).reduce((sum, item) => sum + item.qty, 0);
    bagCount.textContent = total <= 1 ? `${total} article` : `${total} articles`;
    checkoutBtn.classList.toggle('is-ready', total > 0);
  }

  function bindProductEvents() {
    // Re-bind add-to-bag clicks
    document.querySelectorAll('[data-add-product]').forEach((button) => {
      // Clone button to remove previous event listeners and prevent duplication
      const newButton = button.cloneNode(true);
      button.parentNode.replaceChild(newButton, button);
    });

    document.querySelectorAll('[data-add-product]').forEach((button) => {
      button.addEventListener('click', () => {
        const item = {
          id: button.dataset.id,
          title: button.dataset.title,
          price: button.dataset.price,
          qty: 1
        };
        const current = bag.get(item.id);
        bag.set(item.id, current ? { ...current, qty: current.qty + 1 } : item);
        button.textContent = 'Ajouté';
        window.setTimeout(() => { button.textContent = button.getAttribute('data-original-label') || 'Ajouter'; }, 900);
        refreshBag();
      });
      button.setAttribute('data-original-label', button.textContent.trim());
    });

    // Re-bind 3D visualizer clicks
    document.querySelectorAll('[data-3d-trigger]').forEach((trigger) => {
      const newTrigger = trigger.cloneNode(true);
      trigger.parentNode.replaceChild(newTrigger, trigger);
    });

    const viewer3dModal = document.getElementById('viewer3dModal');
    const modal3dTitle = document.getElementById('modal3dTitle');
    const modal3dBody = document.getElementById('modal3dBody');

    document.querySelectorAll('[data-3d-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const modelUrl = trigger.getAttribute('data-model');
        const title = trigger.getAttribute('data-title') || 'Produit';

        if (!modelUrl) return;

        if (!window.customElements.get('model-viewer')) {
          const script = document.createElement('script');
          script.type = 'module';
          script.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js';
          document.head.appendChild(script);
        }

        modal3dTitle.textContent = `Visualisation 3D · ${title}`;
        modal3dBody.innerHTML = `
          <model-viewer
            src="${modelUrl}"
            ar
            auto-rotate
            camera-controls
            shadow-intensity="1"
            style="width: 100%; height: 100%; min-height: 400px; background-color: transparent; outline: none;"
          ></model-viewer>
        `;

        viewer3dModal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });
    });
  }

  function bindCategoryEvents() {
    document.querySelectorAll('.category-tab').forEach((tab) => {
      const newTab = tab.cloneNode(true);
      tab.parentNode.replaceChild(newTab, tab);
    });

    document.querySelectorAll('.category-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const category = tab.dataset.category;
        document.querySelectorAll('.category-tab').forEach((item) => item.classList.remove('active'));
        tab.classList.add('active');
        document.querySelectorAll('[data-product-card]').forEach((card) => {
          const isVisible = category === 'Tout' || card.dataset.category === category;
          card.classList.toggle('is-hidden', !isVisible);
        });
      });
    });
  }

  // Bind initial static HTML generated by Astro
  bindProductEvents();
  bindCategoryEvents();

  checkoutBtn.addEventListener('click', () => {
    const items = Array.from(bag.values());
    const lines = items.length
      ? items.map((item) => `- ${item.title} x${item.qty} (${item.price})`).join('%0A')
      : 'Je souhaite avoir des informations sur AQA Store.';
    const message = `Bonjour AQA Sports,%0AJe souhaite commander:%0A${lines}`;
    window.open(`https://wa.me/213540454907?text=${message}`, '_blank', 'noopener,noreferrer');
  });

  const viewer3dModal = document.getElementById('viewer3dModal');
  const modal3dBody = document.getElementById('modal3dBody');
  const close3dModalBtn = document.getElementById('close3dModalBtn');

  function close3dModal() {
    viewer3dModal.style.display = 'none';
    modal3dBody.innerHTML = '';
    document.body.style.overflow = '';
  }

  if (close3dModalBtn) close3dModalBtn.addEventListener('click', close3dModal);
  if (viewer3dModal) {
    viewer3dModal.addEventListener('click', (e) => {
      if (e.target === viewer3dModal) close3dModal();
    });
  }

  // ── MEDUSAJS BACKEND INTEGRATION (API FETCH & FALLBACK) ──────────
  async function fetchMedusaProducts() {
    try {
      // Default Publishable API Key token from database seed
      const publishableApiKey = 'pk_f5eda48bbe23501935242b496b9ebbefb2a552a67d7065b23a5278ad2e2953ef';
      const res = await fetch('http://localhost:9000/store/products?fields=*variants.prices,*categories', {
        headers: {
          'x-publishable-api-key': publishableApiKey
        }
      });
      if (!res.ok) throw new Error('API request failed');
      const data = await res.json();
      if (data && data.products && data.products.length > 0) {
        console.log('MedusaJS products successfully loaded:', data.products);
        renderMedusaProducts(data.products);
      }
    } catch (err) {
      console.log('MedusaJS backend offline or API error. Gracefully keeping local store.json fallback. Error:', err);
    }
  }

  function renderMedusaProducts(medusaProducts) {
    const productsGrid = document.querySelector('.products-grid');
    if (!productsGrid) return;

    const mappedProducts = medusaProducts.map((prod) => {
      let priceLabel = 'Sur commande';
      if (prod.variants && prod.variants.length > 0) {
        const firstVariant = prod.variants[0];
        if (firstVariant.prices && firstVariant.prices.length > 0) {
          const eurPrice = firstVariant.prices.find(p => p.currency_code === 'eur');
          if (eurPrice) {
            priceLabel = `${eurPrice.amount} €`;
          } else {
            const firstPrice = firstVariant.prices[0];
            priceLabel = `${firstPrice.amount} ${firstPrice.currency_code.toUpperCase()}`;
          }
        }
      }

      const category = (prod.categories && prod.categories.length > 0)
        ? prod.categories[0].name
        : 'Equipement';

      const image = prod.thumbnail || (prod.images && prod.images.length > 0 ? prod.images[0].url : '/images/logo.webp');
      const details = prod.variants ? prod.variants.map(v => v.title).join(', ') : '';

      return {
        id: prod.id,
        title: prod.title,
        category: category,
        badge: prod.metadata?.badge || 'Nouveau',
        image: image,
        priceLabel: priceLabel,
        inventory: 'Disponible',
        summary: prod.description || prod.subtitle || 'Produit AQA Sports haut de gamme.',
        details: details || 'Qualité club, entraînement',
        modelUrl: prod.metadata?.model_url || '/models/astronaut.glb',
        ctaLabel: 'Ajouter'
      };
    });

    let html = '';
    mappedProducts.forEach((product) => {
      html += `
        <article class="product-card" data-product-card data-category="${product.category}">
          <div class="product-image">
            <img src="${product.image}" alt="${product.title}" loading="lazy" />
            <span class="product-badge">${product.badge}</span>
            <button
              type="button"
              class="product-3d-btn"
              data-3d-trigger
              data-model="${product.modelUrl}"
              data-title="${product.title}"
              title="Aperçu 3D interactif"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
              <span>3D</span>
            </button>
          </div>
          <div class="product-body">
            <div class="product-kicker">${product.category} · ${product.inventory}</div>
            <h3>${product.title}</h3>
            <p>${product.summary}</p>
            <div class="product-tags">${product.details}</div>
            <div class="product-footer">
              <strong>${product.priceLabel}</strong>
              <button
                type="button"
                class="product-btn"
                data-add-product
                data-id="${product.id}"
                data-title="${product.title}"
                data-price="${product.priceLabel}"
              >
                ${product.ctaLabel}
              </button>
            </div>
          </div>
        </article>
      `;
    });

    productsGrid.innerHTML = html;

    const categories = ['Tout', ...new Set(mappedProducts.map(p => p.category))];
    const categoryTabsContainer = document.querySelector('.category-tabs');
    if (categoryTabsContainer) {
      categoryTabsContainer.innerHTML = categories.map((cat, idx) => `
        <button class="category-tab${idx === 0 ? ' active' : ''}" type="button" data-category="${cat}">
          ${cat}
        </button>
      `).join('');
    }

    bindProductEvents();
    bindCategoryEvents();
  }

  // Run on load
  fetchMedusaProducts();
</script>

<style>
  .store-shell {
    max-width: 1240px;
    margin: 0 auto;
    padding: 7rem 1.25rem 4rem;
  }

  .store-hero {
    min-height: 520px;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    align-items: center;
    gap: 3rem;
  }

  .eyebrow,
  .section-heading span,
  .store-cta span,
  .hero-product-meta span {
    display: inline-flex;
    color: var(--color-teal);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    margin-top: 0.8rem;
    font-size: clamp(3.5rem, 12vw, 8rem);
    line-height: 0.86;
    letter-spacing: 0;
    background: linear-gradient(135deg, #ffffff 5%, var(--color-teal) 45%, var(--color-blue) 95%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-copy p {
    max-width: 620px;
    margin-top: 1.5rem;
    font-size: clamp(1rem, 2vw, 1.22rem);
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .primary-action,
  .secondary-action,
  .store-cta a,
  .order-dock button {
    min-height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 0.8rem 1.25rem;
    font-weight: 800;
    border: 1px solid rgba(0, 242, 255, 0.35);
  }

  .primary-action,
  .store-cta a,
  .order-dock button.is-ready {
    background: linear-gradient(135deg, var(--color-blue), var(--color-teal));
    color: #020617;
  }

  .secondary-action,
  .order-dock button {
    background: rgba(15, 23, 42, 0.72);
    color: var(--color-teal);
  }

  .hero-product {
    position: relative;
    min-height: 440px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background:
      linear-gradient(145deg, rgba(0, 136, 255, 0.16), rgba(0, 242, 255, 0.04)),
      rgba(15, 23, 42, 0.55);
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
  }

  .hero-product::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 44px 44px;
    opacity: 0.16;
  }

  .hero-product-image {
    position: absolute;
    inset: 3rem;
    display: grid;
    place-items: center;
  }

  .hero-product-image img {
    width: min(78%, 330px);
    height: auto;
    filter: drop-shadow(0 0 35px rgba(0, 242, 255, 0.42));
  }

  .hero-product-meta {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: 8px;
    background: rgba(3, 7, 18, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px);
  }

  .hero-product-meta strong {
    color: #fff;
    font-size: 1.1rem;
  }

  .store-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 1.5rem 0 4rem;
  }

  .store-metrics div,
  .featured-card,
  .product-card,
  .store-cta,
  .order-dock {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: rgba(15, 23, 42, 0.62);
    backdrop-filter: blur(22px);
  }

  .store-metrics div {
    padding: 1.2rem;
  }

  .store-metrics span {
    color: var(--color-teal);
    font-weight: 900;
  }

  .store-metrics strong {
    display: block;
    margin-top: 0.45rem;
    color: #fff;
  }

  .store-metrics p {
    margin-top: 0.25rem;
    font-size: 0.9rem;
  }

  .section-heading {
    margin-bottom: 1.25rem;
  }

  .section-heading h2 {
    margin-top: 0.35rem;
    font-size: clamp(1.8rem, 4vw, 3rem);
    letter-spacing: 0;
  }

  .featured-grid,
  .products-grid {
    display: grid;
    gap: 1rem;
  }

  .featured-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .featured-card {
    overflow: hidden;
  }

  .featured-card img {
    width: 100%;
    aspect-ratio: 1.35;
    object-fit: cover;
    display: block;
  }

  .featured-card div {
    padding: 1rem;
  }

  .featured-card span,
  .product-kicker,
  .product-tags {
    color: var(--color-teal);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .featured-card h3 {
    margin-top: 0.45rem;
    font-size: 1rem;
    letter-spacing: 0;
  }

  .featured-card p {
    margin-top: 0.2rem;
    font-size: 0.88rem;
  }

  .catalogue-section {
    margin-top: 4rem;
  }

  .catalogue-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
  }

  .category-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .category-tab {
    min-height: 38px;
    padding: 0.55rem 0.9rem;
    border-radius: 8px;
    border: 1px solid rgba(0, 242, 255, 0.22);
    background: rgba(15, 23, 42, 0.72);
    color: rgba(255, 255, 255, 0.78);
    cursor: pointer;
    font-weight: 800;
  }

  .category-tab.active,
  .category-tab:hover {
    color: #020617;
    background: var(--color-teal);
  }

  .products-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .product-card {
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 242, 255, 0.42);
  }

  .product-card.is-hidden {
    display: none;
  }

  .product-image {
    position: relative;
    background: rgba(0, 0, 0, 0.25);
  }

  .product-image img {
    width: 100%;
    aspect-ratio: 1.08;
    object-fit: cover;
    display: block;
  }

  .product-badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    padding: 0.34rem 0.62rem;
    border-radius: 6px;
    background: rgba(3, 7, 18, 0.82);
    color: var(--color-teal);
    border: 1px solid rgba(0, 242, 255, 0.32);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .product-body {
    display: flex;
    min-height: 270px;
    flex-direction: column;
    padding: 1.1rem;
  }

  .product-body h3 {
    margin-top: 0.45rem;
    font-size: 1.28rem;
    letter-spacing: 0;
  }

  .product-body p {
    margin-top: 0.65rem;
    font-size: 0.94rem;
  }

  .product-tags {
    margin-top: 0.95rem;
  }

  .product-footer {
    display: flex;
    align-items: center;
