---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import storeData from '../data/store.json';

export interface Props {
  lang?: string;
}

const { lang = 'fr' } = Astro.props;
const products = storeData.filter((product) => product.active !== false);
const featuredProducts = products.filter((product) => product.featured).slice(0, 4);
const categories = ['Tout', ...Array.from(new Set(products.map((product) => product.category).filter(Boolean)))];

const getRelativePath = (path, targetLang) => {
  if (targetLang === 'fr') return path;
  return `/${targetLang}${path === '/' ? '' : path}`;
};
---

<BaseLayout
  title="AQA Store — Boutique Officielle AQA Sports"
  description="Boutique officielle AQA Sports : equipements de natation, apnee, packs performance et accessoires selectionnes par les coachs AQA."
  keywords="AQA Store, boutique natation Algerie, equipement natation, apnee, accessoires AQA Sports"
  currentPage="/store"
  lang={lang}
>
  <Navbar currentPage="/store" lang={lang} />

  <main class="store-shell">
    <section class="store-hero">
      <div class="hero-copy">
        <span class="eyebrow">Boutique officielle AQA Sports</span>
        <h1>AQA Store</h1>
        <p>Equipement aquatique, packs coachs et accessoires club selectionnes pour nager mieux, plus vite et avec le style AQA.</p>
        <div class="hero-actions">
          <a href="#catalogue" class="primary-action">Explorer</a>
          <a href={getRelativePath('/wear', lang)} class="secondary-action">AQA Wear</a>
        </div>
      </div>

      <div class="hero-product" aria-label="AQA Store featured products">
        <div class="hero-product-image">
          <img src="/images/logo.webp" alt="AQA Sports" loading="eager" />
        </div>
        <div class="hero-product-meta">
          <span>Selection coach</span>
          <strong>{products.length} produits</strong>
        </div>
      </div>
    </section>

    <section class="store-metrics" aria-label="AQA Store highlights">
      <div>
        <span>01</span>
        <strong>Selection AQA</strong>
        <p>Materiel retenu par les coachs.</p>
      </div>
      <div>
        <span>02</span>
        <strong>Commande rapide</strong>
        <p>Validation directe par WhatsApp.</p>
      </div>
      <div>
        <span>03</span>
        <strong>Packs clubs</strong>
        <p>Options pour nageurs, kids et apnee.</p>
      </div>
    </section>

    {featuredProducts.length > 0 && (
      <section class="featured-band" aria-label="Produits mis en avant">
        <div class="section-heading">
          <span>Featured</span>
          <h2>Selections du moment</h2>
        </div>
        <div class="featured-grid">
          {featuredProducts.map((product) => (
            <article class="featured-card">
              <img src={product.image} alt={product.title} loading="lazy" />
              <div>
                <span>{product.badge}</span>
                <h3>{product.title}</h3>
                <p>{product.priceLabel}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <section id="catalogue" class="catalogue-section">
      <div class="section-heading catalogue-heading">
        <div>
          <span>Catalogue</span>
          <h2>Shop AQA</h2>
        </div>
        <div class="category-tabs" role="tablist" aria-label="Categories produits">
          {categories.map((category, index) => (
            <button class={`category-tab${index === 0 ? ' active' : ''}`} type="button" data-category={category}>
              {category}
            </button>
          ))}
        </div>
      </div>

      <div class="products-grid">
        {products.map((product) => (
          <article class="product-card" data-product-card data-category={product.category}>
            <div class="product-image">
              <img src={product.image} alt={product.title} loading="lazy" />
              <span class="product-badge">{product.badge}</span>
            </div>
            <div class="product-body">
              <div class="product-kicker">{product.category} · {product.inventory}</div>
              <h3>{product.title}</h3>
              <p>{product.summary}</p>
              <div class="product-tags">{product.details}</div>
              <div class="product-footer">
                <strong>{product.priceLabel}</strong>
                <button
                  type="button"
                  class="product-btn"
                  data-add-product
                  data-id={product.id}
                  data-title={product.title}
                  data-price={product.priceLabel}
                >
                  {product.ctaLabel || 'Ajouter'}
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <aside class="order-dock" aria-label="AQA Bag">
      <div>
        <span>AQA Bag</span>
        <strong id="bagCount">0 article</strong>
      </div>
      <button type="button" id="checkoutBtn">Commander</button>
    </aside>

    <section class="store-cta">
      <div>
        <span>Service AQA</span>
        <h2>Commande assistee par l'equipe</h2>
        <p>Les tailles, disponibilites et packs sont confirmes avant validation pour eviter les achats inutiles.</p>
      </div>
      <a href="https://wa.me/213540454907?text=Bonjour%2C%20je%20souhaite%20commander%20un%20produit%20AQA%20Store" target="_blank" rel="noopener noreferrer">WhatsApp AQA</a>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<script is:inline>
  const bag = new Map();
  const bagCount = document.getElementById('bagCount');
  const checkoutBtn = document.getElementById('checkoutBtn');

  function refreshBag() {
    const total = Array.from(bag.values()).reduce((sum, item) => sum + item.qty, 0);
    bagCount.textContent = total <= 1 ? `${total} article` : `${total} articles`;
    checkoutBtn.classList.toggle('is-ready', total > 0);
  }

  document.querySelectorAll('[data-add-product]').forEach((button) => {
    button.addEventListener('click', () => {
      const item = {
        id: button.dataset.id,
        title: button.dataset.title,
        price: button.dataset.price,
        qty: 1
      };
      const current = bag.get(item.id);
      bag.set(item.id, current ? { ...current, qty: current.qty + 1 } : item);
      button.textContent = 'Ajoute';
      window.setTimeout(() => { button.textContent = button.getAttribute('data-original-label') || 'Ajouter'; }, 900);
      refreshBag();
    });
    button.setAttribute('data-original-label', button.textContent.trim());
  });

  document.querySelectorAll('.category-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const category = tab.dataset.category;
      document.querySelectorAll('.category-tab').forEach((item) => item.classList.remove('active'));
      tab.classList.add('active');
      document.querySelectorAll('[data-product-card]').forEach((card) => {
        const isVisible = category === 'Tout' || card.dataset.category === category;
        card.classList.toggle('is-hidden', !isVisible);
      });
    });
  });

  checkoutBtn.addEventListener('click', () => {
    const items = Array.from(bag.values());
    const lines = items.length
      ? items.map((item) => `- ${item.title} x${item.qty} (${item.price})`).join('%0A')
      : 'Je souhaite avoir des informations sur AQA Store.';
    const message = `Bonjour AQA Sports,%0AJe souhaite commander:%0A${lines}`;
    window.open(`https://wa.me/213540454907?text=${message}`, '_blank', 'noopener,noreferrer');
  });
</script>

<style>
  .store-shell {
    max-width: 1240px;
    margin: 0 auto;
    padding: 7rem 1.25rem 4rem;
  }

  .store-hero {
    min-height: 520px;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    align-items: center;
    gap: 3rem;
  }

  .eyebrow,
  .section-heading span,
  .store-cta span,
  .hero-product-meta span {
    display: inline-flex;
    color: var(--color-teal);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    margin-top: 0.8rem;
    font-size: clamp(3.5rem, 12vw, 8rem);
    line-height: 0.86;
    letter-spacing: 0;
    background: linear-gradient(135deg, #ffffff 5%, var(--color-teal) 45%, var(--color-blue) 95%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-copy p {
    max-width: 620px;
    margin-top: 1.5rem;
    font-size: clamp(1rem, 2vw, 1.22rem);
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .primary-action,
  .secondary-action,
  .store-cta a,
  .order-dock button {
    min-height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 0.8rem 1.25rem;
    font-weight: 800;
    border: 1px solid rgba(0, 242, 255, 0.35);
  }

  .primary-action,
  .store-cta a,
  .order-dock button.is-ready {
    background: linear-gradient(135deg, var(--color-blue), var(--color-teal));
    color: #020617;
  }

  .secondary-action,
  .order-dock button {
    background: rgba(15, 23, 42, 0.72);
    color: var(--color-teal);
  }

  .hero-product {
    position: relative;
    min-height: 440px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background:
      linear-gradient(145deg, rgba(0, 136, 255, 0.16), rgba(0, 242, 255, 0.04)),
      rgba(15, 23, 42, 0.55);
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
  }

  .hero-product::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 44px 44px;
    opacity: 0.16;
  }

  .hero-product-image {
    position: absolute;
    inset: 3rem;
    display: grid;
    place-items: center;
  }

  .hero-product-image img {
    width: min(78%, 330px);
    height: auto;
    filter: drop-shadow(0 0 35px rgba(0, 242, 255, 0.42));
  }

  .hero-product-meta {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: 8px;
    background: rgba(3, 7, 18, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px);
  }

  .hero-product-meta strong {
    color: #fff;
    font-size: 1.1rem;
  }

  .store-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 1.5rem 0 4rem;
  }

  .store-metrics div,
  .featured-card,
  .product-card,
  .store-cta,
  .order-dock {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: rgba(15, 23, 42, 0.62);
    backdrop-filter: blur(22px);
  }

  .store-metrics div {
    padding: 1.2rem;
  }

  .store-metrics span {
    color: var(--color-teal);
    font-weight: 900;
  }

  .store-metrics strong {
    display: block;
    margin-top: 0.45rem;
    color: #fff;
  }

  .store-metrics p {
    margin-top: 0.25rem;
    font-size: 0.9rem;
  }

  .section-heading {
    margin-bottom: 1.25rem;
  }

  .section-heading h2 {
    margin-top: 0.35rem;
    font-size: clamp(1.8rem, 4vw, 3rem);
    letter-spacing: 0;
  }

  .featured-grid,
  .products-grid {
    display: grid;
    gap: 1rem;
  }

  .featured-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .featured-card {
    overflow: hidden;
  }

  .featured-card img {
    width: 100%;
    aspect-ratio: 1.35;
    object-fit: cover;
    display: block;
  }

  .featured-card div {
    padding: 1rem;
  }

  .featured-card span,
  .product-kicker,
  .product-tags {
    color: var(--color-teal);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .featured-card h3 {
    margin-top: 0.45rem;
    font-size: 1rem;
    letter-spacing: 0;
  }

  .featured-card p {
    margin-top: 0.2rem;
    font-size: 0.88rem;
  }

  .catalogue-section {
    margin-top: 4rem;
  }

  .catalogue-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
  }

  .category-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .category-tab {
    min-height: 38px;
    padding: 0.55rem 0.9rem;
    border-radius: 8px;
    border: 1px solid rgba(0, 242, 255, 0.22);
    background: rgba(15, 23, 42, 0.72);
    color: rgba(255, 255, 255, 0.78);
    cursor: pointer;
    font-weight: 800;
  }

  .category-tab.active,
  .category-tab:hover {
    color: #020617;
    background: var(--color-teal);
  }

  .products-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .product-card {
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 242, 255, 0.42);
  }

  .product-card.is-hidden {
    display: none;
  }

  .product-image {
    position: relative;
    background: rgba(0, 0, 0, 0.25);
  }

  .product-image img {
    width: 100%;
    aspect-ratio: 1.08;
    object-fit: cover;
    display: block;
  }

  .product-badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    padding: 0.34rem 0.62rem;
    border-radius: 6px;
    background: rgba(3, 7, 18, 0.82);
    color: var(--color-teal);
    border: 1px solid rgba(0, 242, 255, 0.32);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .product-body {
    display: flex;
    min-height: 270px;
    flex-direction: column;
    padding: 1.1rem;
  }

  .product-body h3 {
    margin-top: 0.45rem;
    font-size: 1.28rem;
    letter-spacing: 0;
  }

  .product-body p {
    margin-top: 0.65rem;
    font-size: 0.94rem;
  }

  .product-tags {
    margin-top: 0.95rem;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .product-footer strong {
    color: #fff;
  }

  .product-btn {
    min-width: 92px;
    min-height: 40px;
    border: 1px solid rgba(0, 242, 255, 0.4);
    border-radius: 8px;
    background: rgba(0, 242, 255, 0.12);
    color: var(--color-teal);
    font-weight: 900;
    cursor: pointer;
  }

  .product-btn:hover {
    background: var(--color-teal);
    color: #020617;
  }

  .order-dock {
    position: sticky;
    z-index: 20;
    bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(520px, calc(100vw - 2rem));
    margin: 2rem auto 0;
    padding: 0.75rem;
    box-shadow: 0 20px 55px rgba(0, 0, 0, 0.45);
  }

  .order-dock span {
    display: block;
    color: var(--text-secondary);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .order-dock strong {
    color: #fff;
  }

  .store-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 3rem;
    padding: 2rem;
  }

  .store-cta h2 {
    margin-top: 0.4rem;
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    letter-spacing: 0;
  }

  .store-cta p {
    max-width: 620px;
    margin-top: 0.55rem;
  }

  @media (max-width: 980px) {
    .store-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-product {
      min-height: 340px;
    }

    .store-metrics,
    .featured-grid,
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .catalogue-heading,
    .store-cta {
      align-items: stretch;
      flex-direction: column;
    }

    .category-tabs {
      justify-content: flex-start;
    }
  }

  @media (max-width: 620px) {
    .store-shell {
      padding-top: 5.5rem;
    }

    .hero-actions,
    .store-metrics,
    .featured-grid,
    .products-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      display: grid;
    }

    .product-body {
      min-height: auto;
    }
  }
</style>
