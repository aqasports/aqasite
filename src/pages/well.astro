---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Bien-être & Fitness Aquatique | AQA Sports — Remise en Forme Algérie"
  description="Programmes bien-être et remise en forme aquatique AQA : aquagym, relaxation, récupération active. Accessible à tous les niveaux. Réghaia & Cheraga."
  keywords="bien-être aquatique algérie, aquagym alger, fitness piscine, remise en forme natation algérie"
  currentPage="/well"
>
  <Navbar currentPage="/well" />

<div class="bg-fixed"></div>

    

    
<div class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
        <div class="hero-tagline">Expertise Santé</div>
        <h1>AQA <span>Wellness</span></h1>
        <div class="hero-divider"></div>
        <p>Prévention • Thérapie • Transformation</p>
    </div>
</div>
    <section id="concept">
        <div class="container">
            <h2>Le Concept</h2>
            <div class="concept-grid">
                <div class="concept-text">
                    <p>
                        <strong style="color:#00ffff; font-size:1.2rem;">La santé ne s'attend pas, elle se construit.</strong><br>
                        AQA Wellness est une filière de santé intégrée dans AQA Sports, créée pour accompagner chaque personne vers une vie plus saine. Notre mission est d'aider à améliorer la santé globale, prévenir les maladies chroniques et récupérer efficacement.
                    </p>
                    <p>
                        Nous combinons plusieurs expertises pour offrir un accompagnement complet : activités sportives adaptées, thérapie, entraînement en piscine, et une approche scientifique de la prévention.
                    </p>
                    
                    <div class="features-row">
                        <div class="feature-item">
                            <i class="fas fa-heart-pulse"></i>
                            <h4>Prévention</h4>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-user-md"></i>
                            <h4>Experts</h4>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-water"></i>
                            <h4>Aquathérapie</h4>
                        </div>
                    </div>
                </div>
                <div class="concept-image">
                    <img src="https://health-e.in/wp-content/uploads/2023/09/family-shape-figure-with-heart-stethoscope.webp" alt="Coach AQA Wellness">
                </div>
            </div>
        </div>
    </section>

    <section id="available-programs">
        <div class="container">
            <h2>Nos Programmes</h2>
            <div class="programs-grid">

                <div class="card">
                    <span class="badge badge-free">GRATUIT</span>
                    <img src="https://logo-marque.com/wp-content/uploads/2022/03/Breast-Cancer-Logo.png?q=80&w=2070&auto=format&fit=crop" alt="Santé Naturelle" class="card-img-top">
                    <div class="card-body">
                        <h3 class="card-title">Éviter le Cancer</h3>
                        <div class="card-subtitle">Newsletter Quotidienne</div>
                        <p class="card-description">
                            Recevez chaque jour un conseil court, basé sur des preuves scientifiques, pour réduire vos risques. Nutrition, sommeil, activité physique et habitudes de vie saines directement sur votre fil.
                        </p>
                    </div>
                </div>

                <div class="card">
                    <span class="badge badge-paid">PAYANT</span>
                    <img src="https://monchiro.ca/wp-content/uploads/2018/11/monchiro-maux-de-dos-douleur-lombaire.jpg?q=80&w=2069&auto=format&fit=crop" alt="Aquathérapie" class="card-img-top">
                    <div class="card-body">
                        <h3 class="card-title">Atelier du Dos</h3>
                        <div class="card-subtitle">Rééducation en Piscine</div>
                        <p class="card-description">
                            Spécialement conçu pour soulager les douleurs lombaires. Encadré par des kinésithérapeutes, cet atelier utilise les bienfaits de l'eau pour la mobilité, le renforcement en décharge et la récupération.
                        </p>
                    </div>
                </div>

                <div class="card">
                    <span class="badge badge-paid">PAYANT</span>
                    <img src="https://artfulliving.com/wp-content/uploads/2022/05/ADULT-SUMMER-CAMP-FEATURE-1.jpg?q=80&w=1974&auto=format&fit=crop" alt="Training Camp" class="card-img-top">
                    <div class="card-body">
                        <h3 class="card-title">Camps AQA</h3>
                        <div class="card-subtitle">Transformations en 1 Semaine</div>
                        <p class="card-description">Immersion totale pour casser la routine et transformer votre vie.</p>
                        <ul class="camp-list">
                            <li><i class="fas fa-ban-smoking"></i> Arrêter de fumer</li>
                            <li><i class="fas fa-carrot"></i> Manger sain à vie</li>
                            <li><i class="fas fa-weight-scale"></i> Perdre du poids</li>
                            <li><i class="fas fa-spa"></i> Anti-stress & Thermes</li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section id="upcoming">
        <div class="container">
            <i class="fas fa-dna"></i>
            <h2>Innovation en cours...</h2>
            <p style="max-width: 600px; margin: 0 auto; font-size: 1.2rem;">
                De nouveaux protocoles de santé AQA sont en développement. Restez connectés pour découvrir nos prochaines avancées en matière de longévité et de performance.
            </p>
        </div>
    </section>

  <Footer />
</BaseLayout>

<style>

        /* --- RESET & CORE --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #050505;
            color: #ffffff;
            line-height: 1.6;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* --- BACKGROUND EFFECTS --- */
        .bg-fixed {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            z-index: -2;
            background: radial-gradient(circle at 50% 50%, #0a1a2a 0%, #000000 100%);
        }

        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(45deg, rgba(0,255,255,0.03), rgba(0,153,255,0.03));
            z-index: -1;
            pointer-events: none;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        /* --- TYPOGRAPHY --- */
        h1, h2, h3 {
            line-height: 1.2;
        }

    /* --- HERO SECTION (REFINED WELLNESS) --- */
.hero {
    position: relative;
    height: 80vh; /* Taller for a more "cinematic" feel */
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-bottom: 2rem;
    overflow: hidden;
}

.hero-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    /* Deeper vignette to focus eye on center text */
    background: radial-gradient(circle, rgba(0,0,0,0.2) 0%, rgba(5,5,5,1) 90%),
                url('https://images.unsplash.com/photo-1544367563-12123d89a576?q=80&w=2070&auto=format&fit=crop');
    background-size: cover;
    background-position: center;
    z-index: -1;
}

.hero-content {
    z-index: 1;
    padding: 2rem;
    max-width: 900px;
}

.hero-tagline {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 5px;
    color: #00ffff;
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 0.9;
}

.hero h1 {
    font-family: 'Segoe UI', sans-serif;
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -1px;
}

.hero h1 span {
    display: block; /* Moves Wellness to its own line for better impact */
    font-weight: 300;
    letter-spacing: 12px;
    margin-right: -12px; /* Offsets the last letter spacing to keep it centered */
    color: #00ffff;
    font-size: 0.6em; /* Makes Wellness slightly smaller and more elegant */
    margin-top: 0.5rem;
}

.hero-divider {
    width: 60px;
    height: 4px;
    background: #ffffff; /* White divider is cleaner for medical concepts */
    margin: 2rem auto;
    border-radius: 2px;
}

.hero p {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: #cbd5e1;
    font-weight: 300;
    letter-spacing: 2px;
    text-transform: uppercase;
}
       /* --- SECTION STYLES --- */
        section {
            padding: 4rem 0;
        }

        section h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            text-align: center;
            margin-bottom: 3rem;
            color: #fff;
            position: relative;
            display: inline-block;
            left: 50%;
            transform: translateX(-50%);
        }
        
        section h2::after {
            content: '';
            display: block;
            width: 60%;
            height: 3px;
            background: linear-gradient(90deg, transparent, #00ffff, transparent);
            margin: 10px auto 0;
        }

        /* --- CONCEPT SECTION (Split Layout) --- */
        .concept-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }

        .concept-image img {
            width: 100%;
            border-radius: 20px;
            box-shadow: 0 0 30px rgba(0, 153, 255, 0.2);
            border: 1px solid rgba(0, 255, 255, 0.3);
        }

        .concept-text p {
            font-size: 1.15rem;
            color: #ddd;
            margin-bottom: 1.5rem;
        }

        /* --- FEATURES ICONS --- */
        .features-row {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 2rem;
            margin-top: 3rem;
            text-align: center;
        }
        .feature-item {
            flex: 1;
            min-width: 200px;
            padding: 1.5rem;
            background: rgba(255,255,255,0.03);
            border-radius: 15px;
            border: 1px solid rgba(0,255,255,0.1);
        }
        .feature-item i {
            font-size: 2.5rem;
            color: #00ffff;
            margin-bottom: 1rem;
        }
        .feature-item h4 {
            font-size: 1.2rem;
            margin-bottom: 0.5rem;
        }

        /* --- PROGRAMS GRID --- */
        .programs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
        }

        .card {
            background: rgba(10, 20, 30, 0.6);
            border: 1px solid rgba(0, 153, 255, 0.3);
            border-radius: 20px;
            overflow: hidden;
            backdrop-filter: blur(10px);
            transition: all 0.4s ease;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .card:hover {
            transform: translateY(-10px);
            border-color: #00ffff;
            box-shadow: 0 0 40px rgba(0, 255, 255, 0.15);
        }

        .card-img-top {
            width: 100%;
            height: 220px;
            object-fit: cover;
            border-bottom: 1px solid rgba(0, 153, 255, 0.2);
        }

        .card-body {
            padding: 2rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            padding: 0.4rem 1rem;
            border-radius: 50px;
            font-weight: 800;
            font-size: 0.8rem;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 2;
        }

        .badge-free { background: linear-gradient(135deg, #00ff88, #00ffff); color: #000; }
        .badge-paid { background: linear-gradient(135deg, #ff9900, #ffcc00); color: #000; }

        .card-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #00ffff;
            margin-bottom: 0.5rem;
        }

        .card-subtitle {
            font-size: 1rem;
            color: #aaa;
            margin-bottom: 1rem;
            font-style: italic;
        }

        .card-description {
            color: #e0e0e0;
            font-size: 1rem;
            margin-bottom: 1.5rem;
        }

        .camp-list {
            list-style: none;
            display: grid;
            gap: 0.8rem;
            margin-top: auto;
            background: rgba(0,0,0,0.2);
            padding: 1rem;
            border-radius: 10px;
        }

        .camp-list li {
            display: flex;
            align-items: center;
            font-size: 0.95rem;
            color: #ccc;
        }

        .camp-list li i {
            color: #00ffff;
            width: 25px;
            margin-right: 10px;
        }

        /* --- UPCOMING SECTION --- */
        #upcoming {
            text-align: center;
            background: linear-gradient(180deg, rgba(0,0,0,0), rgba(0, 153, 255, 0.1));
            border-top: 1px solid rgba(0, 153, 255, 0.2);
        }

        #upcoming i {
            font-size: 3rem;
            color: #00ffff;
            margin-bottom: 1rem;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.1); opacity: 1; text-shadow: 0 0 20px #00ffff; }
            100% { transform: scale(1); opacity: 0.8; }
        }

        footer {
            background: #000;
            border-top: 2px solid #0099ff;
            padding: 0;
            margin-top: 0;
        }

        /* --- RESPONSIVE --- */
        @media (max-width: 768px) {
            .concept-grid { grid-template-columns: 1fr; }
            .hero h1 { font-size: 2.8rem; }
            .card-img-top { height: 180px; }
            .hero { height: 60vh; }
            .hero-content { padding: 1.5rem; width: 90%; }
        }
    
</style>
