                                    <td class="pricing-highlight"><span class="price-value">51,900 DA</span><div class="price-savings">Économisez 5,100 DA</div></td>
                                    <td class="pricing-highlight"><span class="price-value">115,000 DA</span><div class="price-savings">Économisez 4,400 DA</div></td>
                                </tr>
                                <tr>
                                    <td>9 Mois</td>
                                    <td class="pricing-highlight"><span class="price-value">57,900 DA</span><div class="price-savings">Économisez 7,800 DA</div></td>
