    <script>
    (function(){
        // 1. Tab Switching Logic
        const buttons = document.querySelectorAll('.category-btn');
        const sections = document.querySelectorAll('.content-section');

        function setActive(category) {
            // Update buttons
            buttons.forEach(btn => {
                const isTarget = btn.getAttribute('data-category') === category;
                btn.classList.toggle('active', isTarget);
                btn.setAttribute('aria-selected', isTarget);
            });

            // Update sections
            sections.forEach(sec => {
                const isTarget = sec.id === category;
                sec.classList.toggle('active', isTarget);
            });
        }

        buttons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const cat = btn.getAttribute('data-category');
                setActive(cat);
            });
        });

        // 2. Highlight Best Value in Tables
        function highlightBestValue(){
            const tables = document.querySelectorAll('table');
            tables.forEach(table => {
                const rows = table.querySelectorAll('tbody tr');
                rows.forEach(row => {
                    const cells = Array.from(row.querySelectorAll('td:not(:first-child)'));
                    let bestValue = null;
                    let bestCell = null;

                    cells.forEach(cell => {
                        const priceText = cell.querySelector('.price-value')?.textContent || cell.textContent;
                        if (priceText) {
                            const price = parseInt(String(priceText).replace(/[^0-9]/g, ''));
                            if (!isNaN(price)) {
                                if (bestValue === null || price < bestValue) {
                                    bestValue = price;
                                    bestCell = cell;
                                }
                            }
                        }
                    });

                    if (bestCell && cells.length > 1) {
                        bestCell.style.borderLeft = '4px solid #00ff88';
                    }
                });
            });
        }

        // 3. Footer Loader
        async function loadFooter() {
            try {
                const response = await fetch('footer.html');
                if (response.ok) {
                    const footerHTML = await response.text();
                    document.getElementById('footer-container').innerHTML = footerHTML;
                }
            } catch (error) {
                console.error('Error loading footer:', error);
            }
        }

        // 4. Global Info Popup
        window.showInfo = function(type){
            alert(`Plus d'informations sur ${type} - Contactez-nous au 0540454907 ou par email à aqa.sports.academy@gmail.com`);
        };

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            highlightBestValue();
            loadFooter();
        });

    })();
    </script>

  <Footer />
