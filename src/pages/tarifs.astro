---

<BaseLayout
  title="Tarifs AQA 2025 — Formules Natation, Apnée & Coaching Algérie"
  description="Consultez les tarifs AQA 2025 : groupes G10, MAX5 et sessions individuelles. 1, 3, 6 ou 9 mois. Formules Homme, Femme, Enfants et Apnée."
  keywords="tarifs natation algérie, prix coaching natation, abonnement piscine algérie, formules aqa 2025"
  currentPage="/tarifs"
  lang={lang}
>
  <Navbar currentPage="/tarifs" lang={lang} />

<div class="container">
        <section class="hero">
            <h1>Formules AQA 2025</h1>
            <p>Des programmes d'entraînement personnalisés pour tous les niveaux, avec des prix transparents et des économies attractives</p>
        </section>

        <nav class="category-nav">
            <button class="category-btn active" data-category="homme">Homme</button>
            <button class="category-btn" data-category="femme">Femme</button>
            <button class="category-btn" data-category="enfants">Enfants</button>
            <button class="category-btn" data-category="apnea">Apnée</button>
        </nav>

        <section class="content-section active" id="homme">
            <!-- Promo Banner (Visible by default) -->
            <div id="quizPromoBanner" class="quiz-promo-banner glass-panel">
                <div class="promo-content">
                    <span class="promo-badge">{qT.newPromoBadge}</span>
                    <h3 class="promo-title">{qT.quizPromoTitle}</h3>
                    <p class="promo-desc">{qT.quizPromoDesc}</p>
                </div>
                <button type="button" class="promo-btn" id="openQuizBtn">{qT.quizPromoBtn}</button>
            </div>

            <!-- Recommended For You Quiz Section (Hidden by default) -->
            <div id="recQuizSection" class="rec-quiz-container glass-panel hidden">
                <!-- Step 1: Goals -->
                <div class="quiz-step" id="quizStep1">
                    <h3 class="quiz-step-title">{qT.q1Title}</h3>
                    <div class="quiz-options-grid">
                        <button type="button" class="quiz-opt-btn" data-q="1" data-val="beginner">
                            <span class="opt-text">{qT.q1Opt1}</span>
                        </button>
                        <button type="button" class="quiz-opt-btn" data-q="1" data-val="progress">
                            <span class="opt-text">{qT.q1Opt2}</span>
                        </button>
                        <button type="button" class="quiz-opt-btn" data-q="1" data-val="perfect">
                            <span class="opt-text">{qT.q1Opt3}</span>
                        </button>
                        <button type="button" class="quiz-opt-btn" data-q="1" data-val="individual">
                            <span class="opt-text">{qT.q1Opt4}</span>
                        </button>
                    </div>
                </div>

                <!-- Step 2: Attention Level -->
                <div class="quiz-step" id="quizStep2">
                    <h3 class="quiz-step-title">{qT.q2Title}</h3>
                    <div class="quiz-options-grid">
                        <button type="button" class="quiz-opt-btn" data-q="2" data-val="g10">
                            <span class="opt-text"><strong>{qT.q2Opt1Title}</strong><br><small>{qT.q2Opt1Sub}</small></span>
                        </button>
                        <button type="button" class="quiz-opt-btn" data-q="2" data-val="max5">
                            <span class="opt-text"><strong>{qT.q2Opt2Title}</strong><br><small>{qT.q2Opt2Sub}</small></span>
                        </button>
                        <button type="button" class="quiz-opt-btn" data-q="2" data-val="individ">
                            <span class="opt-text"><strong>{qT.q2Opt3Title}</strong><br><small>{qT.q2Opt3Sub}</small></span>
                        </button>
                    </div>
                </div>

                <!-- Step 3: Frequency -->
                <div class="quiz-step" id="quizStep3">
                    <h3 class="quiz-step-title">{qT.q3Title}</h3>
                    <div class="quiz-options-grid">
                        <button type="button" class="quiz-opt-btn" data-q="3" data-val="1">
                            <span class="opt-text"><strong>{qT.q3Opt1Title}</strong><br><small>{qT.q3Opt1Sub}</small></span>
                        </button>
                        <button type="button" class="quiz-opt-btn" data-q="3" data-val="2">
                            <span class="opt-text"><strong>{qT.q3Opt2Title}</strong><br><small>{qT.q3Opt2Sub}</small></span>
                        </button>
                        <button type="button" class="quiz-opt-btn" data-q="3" data-val="3">
                            <span class="opt-text"><strong>{qT.q3Opt3Title}</strong><br><small>{qT.q3Opt3Sub}</small></span>
                        </button>
                    </div>
                </div>

                <!-- Step 3.5: Calculating Screen -->
                <div class="quiz-step" id="quizStepCalc" style="text-align:center; padding: 2rem 0;">
                    <div class="quiz-spinner"></div>
                    <h3 class="quiz-step-title" style="margin-top:1.5rem;">{qT.calcText}</h3>
                </div>

                <!-- Step 4: Results (Recommendation Card) -->
                <div class="quiz-step" id="quizStep4">
                    <div class="rec-badge">{qT.recBadge}</div>
                    <h3 class="rec-title" id="recTitle">MAX5 - 2 fois par semaine</h3>
                    
                    <div class="rec-price-box">
                        <div class="rec-price" id="recPrice">48,900 DA</div>
                        <div class="rec-price-saving" id="recSaving">Économisez 2,100 DA</div>
                    </div>

                    <div class="duration-selector">
                        <button type="button" class="dur-btn" data-dur="1">{qT.month1}</button>
                        <button type="button" class="dur-btn active" data-dur="3">{qT.month3}</button>
                        <button type="button" class="dur-btn" data-dur="6">{qT.month6}</button>
                        <button type="button" class="dur-btn" data-dur="9">{qT.month9}</button>
                    </div>

                    <div class="rec-details">
                        <div class="detail-bullet">
                            <span id="recGroupTypeDesc"></span>
                        </div>
                        <div class="detail-bullet">
                            <span id="recFrequenceDesc"></span>
                        </div>
                        <div class="detail-bullet">
                            <span>{qT.descGeneral}</span>
                        </div>
                    </div>

                    <div class="rec-actions">
                        <a href={getRelativePath('/inscription', lang)} id="recBookLink" class="rec-book-btn">{qT.bookBtn}</a>
                        <button type="button" class="rec-reset-btn" id="restartQuizBtn2">{qT.resetBtn}</button>
                    </div>

                    <button type="button" class="show-all-btn" id="showAllOptionsBtn">{qT.showAllBtn}</button>
                </div>

                <!-- Progress Indicator -->
                <div class="quiz-progress-container" id="quizProgressContainer">
                    <div class="quiz-progress-text"><span id="quizCurrentStep">1</span> / 3</div>
                    <div class="quiz-progress-bar">
                        <div class="quiz-progress-fill" id="quizProgressFill"></div>
                    </div>
                </div>
            </div>

            <!-- Full Tables Container (Visible by default) -->
            <div id="fullHommeTables" class="full-tables-container">
            <h3 class="section-title">Tarifs - Homme</h3>
            
            <div class="pricing-section">
                <h4 class="section-title" style="font-size: 1.5rem;">Une fois par semaine</h4>
