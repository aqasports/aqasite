    <script define:vars={{ lang, quizTranslations }}>
    document.addEventListener('astro:page-load', () => {

    (function(){
        // 1. Tab Switching Logic
        const buttons = document.querySelectorAll('.category-btn');
        const sections = document.querySelectorAll('.content-section');

        function setActive(category) {
            buttons.forEach(btn => {
                const isTarget = btn.getAttribute('data-category') === category;
                btn.classList.toggle('active', isTarget);
                btn.setAttribute('aria-selected', isTarget);
            });

            sections.forEach(sec => {
                const isTarget = sec.id === category;
                sec.classList.toggle('active', isTarget);
            });
        }

        buttons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const cat = btn.getAttribute('data-category');
                setActive(cat);
            });
        });

        // 2. Highlight Best Value in Tables
        function highlightBestValue(){
            const tables = document.querySelectorAll('table');
            tables.forEach(table => {
                const rows = table.querySelectorAll('tbody tr');
                rows.forEach(row => {
                    const cells = Array.from(row.querySelectorAll('td:not(:first-child)'));
                    let bestValue = null;
                    let bestCell = null;

                    cells.forEach(cell => {
                        const priceText = cell.querySelector('.price-value')?.textContent || cell.textContent;
                        if (priceText) {
                            const price = parseInt(String(priceText).replace(/[^0-9]/g, ''));
                            if (!isNaN(price)) {
                                if (bestValue === null || price < bestValue) {
                                    bestValue = price;
                                    bestCell = cell;
                                }
                            }
                        }
                    });

                    if (bestCell && cells.length > 1) {
                        bestCell.style.borderLeft = '4px solid #00ff88';
                    }
                });
            });
        }
        // 4. Global Info Popup
        window.showInfo = function(type){
            alert(`Plus d'informations sur ${type} - Contactez-nous au 0540454907 ou par email à aqa.sports.academy@gmail.com`);
        };

        // Initialize
        highlightBestValue();

        // --- 5. Interactive Quiz Logic ---
        let currentQuizStep = 1;
        const quizAnswers = { q1: null, q2: null, q3: null };
        let selectedDuration = 3; // default: 3 months
        let recommendationResult = null; // { type: 'max5', freq: 2 }

        const quizSteps = document.querySelectorAll('.quiz-step');
        const progressFill = document.getElementById('quizProgressFill');
        const currentStepText = document.getElementById('quizCurrentStep');
        const progressContainer = document.getElementById('quizProgressContainer');
        const fullTables = document.getElementById('fullHommeTables');
        const quizSection = document.getElementById('recQuizSection');
        const promoBanner = document.getElementById('quizPromoBanner');

        const PRICING_MATRIX = {
          g10: {
            1: { 1: 7300, 3: 19900, 6: 38800, 9: 57900 },
            2: { 1: 12700, 3: 36900, 6: 72000, 9: 105000 },
            3: { 1: 18700, 3: 53500, 6: 105000, 9: 153000 }
          },
          max5: {
            1: { 1: 9500, 3: 26700, 6: 51900, 9: 76000 },
            2: { 1: 17000, 3: 48900, 6: 96000, 9: 143000 },
            3: { 1: 24500, 3: 69500, 6: 135000, 9: 199000 }
          },
          individ: {
            1: { 1: 19900, 3: 58800, 6: 115000, 9: 170000 },
            2: { 1: 35900, 3: 105000, 6: 199000, 9: 295000 },
            3: { 1: 52000, 3: 149000, 6: 298000, 9: 454000 }
          }
        };

        const SAVINGS_MATRIX = {
          g10: {
            1: { 1: 0, 3: 2000, 6: 5000, 9: 7800 },
            2: { 1: 0, 3: 1200, 6: 4200, 9: 9300 },
            3: { 1: 0, 3: 2600, 6: 7200, 9: 15300 }
          },
          max5: {
            1: { 1: 0, 3: 1800, 6: 5100, 9: 9500 },
            2: { 1: 0, 3: 2100, 6: 6000, 9: 10000 },
            3: { 1: 0, 3: 4000, 6: 12000, 9: 21500 }
          },
          individ: {
            1: { 1: 0, 3: 900, 6: 4400, 9: 9100 },
            2: { 1: 0, 3: 2700, 6: 16400, 9: 28100 },
            3: { 1: 0, 3: 7000, 6: 14000, 9: 14000 }
          }
        };

        function showQuizStep(stepIdx) {
          quizSteps.forEach((step, idx) => {
            step.classList.toggle('active', idx === (stepIdx - 1));
          });
          currentQuizStep = stepIdx;

          if (stepIdx >= 1 && stepIdx <= 3) {
            if (progressContainer) progressContainer.style.display = 'block';
            if (progressFill) progressFill.style.width = ((stepIdx - 1) / 2) * 100 + '%';
            if (currentStepText) currentStepText.textContent = stepIdx;
          } else {
            if (progressContainer) progressContainer.style.display = 'none';
          }
        }

        // Open Quiz / Start Guide
        const openQuizBtn = document.getElementById('openQuizBtn');
        if (openQuizBtn) {
          openQuizBtn.addEventListener('click', () => {
            if (promoBanner) promoBanner.classList.add('hidden');
            if (fullTables) fullTables.classList.add('hidden');
            if (quizSection) quizSection.classList.remove('hidden');
            
            // Reset state
            quizAnswers.q1 = null;
            quizAnswers.q2 = null;
            quizAnswers.q3 = null;
            
            showQuizStep(1);
          });
        }

        // Handle option clicks
        const optionBtns = document.querySelectorAll('.quiz-opt-btn');
        optionBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const q = btn.dataset.q;
            const val = btn.dataset.val;
            quizAnswers['q' + q] = val;

            const nextStep = parseInt(q) + 1;
            if (nextStep <= 3) {
              showQuizStep(nextStep);
            } else {
              calculateRecommendation();
            }
          });
        });

        function calculateRecommendation() {
          showQuizStep(4); // Show step 3.5 (calculating spinner)

          setTimeout(() => {
            let points = { g10: 0, max5: 0, individ: 0 };
            
            if (quizAnswers.q1 === 'beginner') {
              points.individ += 2;
              points.max5 += 1;
            } else if (quizAnswers.q1 === 'progress') {
              points.max5 += 2;
              points.g10 += 1;
            } else if (quizAnswers.q1 === 'perfect') {
              points.g10 += 2;
              points.max5 += 1;
            } else if (quizAnswers.q1 === 'individual') {
              points.individ += 3;
            }

            if (quizAnswers.q2 === 'g10') {
              points.g10 += 4;
            } else if (quizAnswers.q2 === 'max5') {
              points.max5 += 4;
            } else if (quizAnswers.q2 === 'individ') {
              points.individ += 4;
            }

            let recommendedType = 'max5';
            let maxPoints = -1;
            for (let key in points) {
              if (points[key] > maxPoints) {
                maxPoints = points[key];
                recommendedType = key;
              }
            }

            const freq = parseInt(quizAnswers.q3 || '2');
            recommendationResult = { type: recommendedType, freq };

            selectedDuration = 3; // Reset to 3 months default
            renderRecommendation();
            showQuizStep(5); // Show result card
          }, 800);
        }

        const typeNames = {
          fr: { g10: 'G10', max5: 'MAX5', individ: 'INDIVIDUELLE' },
          ar: { g10: 'G10', max5: 'MAX5', individ: 'فردية (INDIVID)' },
          en: { g10: 'G10', max5: 'MAX5', individ: 'INDIVIDUAL' }
        };

        const typeDescs = {
          fr: {
            g10: quizTranslations.fr.descG10,
            max5: quizTranslations.fr.descMax5,
            individ: quizTranslations.fr.descIndivid
          },
          ar: {
            g10: quizTranslations.ar.descG10,
            max5: quizTranslations.ar.descMax5,
            individ: quizTranslations.ar.descIndivid
          },
          en: {
            g10: quizTranslations.en.descG10,
            max5: quizTranslations.en.descMax5,
            individ: quizTranslations.en.descIndivid
          }
        };

        const freqTexts = {
          fr: { 1: quizTranslations.fr.descFreq1, 2: quizTranslations.fr.descFreq2, 3: quizTranslations.fr.descFreq3 },
          ar: { 1: quizTranslations.ar.descFreq1, 2: quizTranslations.ar.descFreq2, 3: quizTranslations.ar.descFreq3 },
          en: { 1: quizTranslations.en.descFreq1, 2: quizTranslations.en.descFreq2, 3: quizTranslations.en.descFreq3 }
        };

        function renderRecommendation() {
          if (!recommendationResult) return;
          const { type, freq } = recommendationResult;
          
          const typeNameMap = typeNames[lang] || typeNames.fr;
          const typeDescMap = typeDescs[lang] || typeDescs.fr;
          const freqMap = freqTexts[lang] || freqTexts.fr;
          
          const title = `${typeNameMap[type]} - ${freqMap[freq]}`;
          const titleEl = document.getElementById('recTitle');
          if (titleEl) titleEl.textContent = title;

          const typeDescEl = document.getElementById('recGroupTypeDesc');
          if (typeDescEl) typeDescEl.textContent = typeDescMap[type];
          
          const freqDescEl = document.getElementById('recFrequenceDesc');
          if (freqDescEl) freqDescEl.textContent = freqMap[freq];

          updatePriceAndLink();
        }

        function updatePriceAndLink() {
          if (!recommendationResult) return;
          const { type, freq } = recommendationResult;
          
          const price = PRICING_MATRIX[type][freq][selectedDuration];
          const saving = SAVINGS_MATRIX[type][freq][selectedDuration];
          
          const priceEl = document.getElementById('recPrice');
          if (priceEl) priceEl.textContent = `${price.toLocaleString()} DA`;

          const savingEl = document.getElementById('recSaving');
          if (savingEl) {
            if (saving > 0) {
              const saveWord = quizTranslations[lang]?.save || quizTranslations.fr.save;
              savingEl.textContent = ` ${saveWord} ${saving.toLocaleString()} DA`;
              savingEl.style.display = 'block';
            } else {
              savingEl.style.display = 'none';
            }
          }

          const bookLink = document.getElementById('recBookLink');
          if (bookLink) {
            const base = bookLink.getAttribute('href').split('?')[0];
            const formuleCodes = { 1: 'starter', 3: 'silver', 6: 'gold', 9: 'diamond' };
            const formuleCode = formuleCodes[selectedDuration];
            bookLink.setAttribute('href', `${base}?category=men&formule=${formuleCode}&frequency=${freq}`);
          }
        }

        // Toggles for Durations
        const durBtns = document.querySelectorAll('.dur-btn');
        durBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            durBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            selectedDuration = parseInt(btn.dataset.dur);
            updatePriceAndLink();
          });
        });

        // Restart Quiz
        const resetBtn2 = document.getElementById('restartQuizBtn2');
        if (resetBtn2) {
          resetBtn2.addEventListener('click', () => {
            quizAnswers.q1 = null;
            quizAnswers.q2 = null;
            quizAnswers.q3 = null;
            showQuizStep(1);
          });
        }

        // Show all options / Collapse quiz
        const showAllBtn = document.getElementById('showAllOptionsBtn');
        if (showAllBtn) {
          showAllBtn.addEventListener('click', () => {
            if (quizSection) quizSection.classList.add('hidden');
            if (fullTables) fullTables.classList.remove('hidden');
            if (promoBanner) promoBanner.classList.remove('hidden');
            
            setTimeout(() => {
              fullTables.scrollIntoView({ behavior: 'smooth' });
            }, 100);
          });
        }

    })();
        });
  </script>

  <Footer lang={lang} />
</BaseLayout>

<style>

        /* ================= RESET & CORE ================= */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #000000;
            color: #ffffff;
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
            min-height: 100vh;
        }

        /* ================= BACKGROUND EFFECTS ================= */
        .bg-frame {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            border: none; z-index: -1; pointer-events: none; background: transparent;
        }
        .bg-logo {
            position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 80vw; height: 80vh;
            background-image: url('https://i.imgur.com/3dcksCn.png');
            background-size: contain; background-repeat: no-repeat; background-position: center;
            opacity: 0.05; z-index: -2; pointer-events: none;
        }
        body::before {
            content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(200deg, #00ffff, #0099ff, #0066ff, #3333ff, #6600ff, #9900ff, #cc00ff, #ff0099, #ff0066, #ff3333) border-box;
            -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor; mask-composite: exclude;
            z-index: -1; animation: neonGlow 4s ease-in-out infinite alternate;
        }

        /* ================= ANIMATIONS ================= */
        @keyframes neonGlow {
            0%, 100% { filter: drop-shadow(0 0 10px #00ffff) drop-shadow(0 0 20px #0099ff); }
            50% { filter: drop-shadow(0 0 20px #00ffff) drop-shadow(0 0 40px #0099ff); }
        }
        @keyframes slideIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
        @keyframes slideUp { from { opacity: 0; transform: translateY(50px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes shimmer {
            0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
            100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
        }
        @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }

        /* ================= HEADER ================= */
        header {
            background: rgba(0, 0, 0, 0.95); backdrop-filter: blur(20px);
            border-bottom: 2px solid #0099ff; box-shadow: 0 0 20px rgba(0, 153, 255, 0.3);
            padding: 1rem; position: sticky; top: 0; z-index: 1000;
        }
        .header-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
        .logo-section { display: flex; align-items: center; gap: 0.5rem; }
        .logo { height: 40px; filter: drop-shadow(0 0 10px #00ffff); }

        /* ================= LAYOUT & HERO ================= */
        .container { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem; }
        .hero { text-align: center; padding: 3rem 0; margin-bottom: 3rem; animation: slideIn 1s ease-out; }
        .hero h1 {
            font-size: clamp(2rem, 8vw, 3.5rem); font-weight: 800;
            background: linear-gradient(135deg, #00ffff, #0099ff, #ffffff);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
            margin-bottom: 1rem; text-shadow: 0 0 30px rgba(0, 255, 255, 0.3); line-height: 1.2;
        }
        .hero p {
            font-size: clamp(1rem, 3vw, 1.2rem); opacity: 0.9; max-width: 800px; margin: 0 auto 2.5rem;
            color: #ffffff; line-height: 1.6;
        }

        /* ================= NAVIGATION TABS ================= */
        .category-nav { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 3rem; padding: 0 1rem; }
        .category-btn {
            background: rgba(0, 153, 255, 0.1); border: 2px solid rgba(0, 153, 255, 0.3);
            color: #ffffff; padding: 1rem 2rem; border-radius: 50px;
            font-size: clamp(0.9rem, 2.5vw, 1.1rem); font-weight: 600; cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; backdrop-filter: blur(10px);
        }
        .category-btn:hover { background: rgba(0, 153, 255, 0.2); border-color: rgba(0, 255, 255, 0.6); transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0, 255, 255, 0.3); }
        .category-btn.active {
            background: linear-gradient(135deg, #0099ff, #00ffff); color: #000000;
            border-color: #00ffff; box-shadow: 0 0 30px rgba(0, 255, 255, 0.6); transform: translateY(-3px);
        }
        
        /* ================= SECTIONS & VISIBILITY ================= */
        .content-section { display: none; opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
        .content-section.active { display: block; opacity: 1; transform: translateY(0); animation: fadeIn 0.6s ease-out; }
        .section-title {
            font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; text-align: center; margin-bottom: 2rem;
            background: linear-gradient(135deg, #00ffff, #0099ff);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
            position: relative;
        }
        .section-title::after {
            content: ''; position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%);
            width: 100px; height: 3px; background: linear-gradient(90deg, transparent, #00ffff, transparent); border-radius: 3px;
        }

        /* ================= TABLES (HOMME) ================= */
        .pricing-section { margin-bottom: 4rem; }
        .table-container {
            background: rgba(0, 153, 255, 0.1); border-radius: 20px; backdrop-filter: blur(20px);
            border: 2px solid rgba(0, 153, 255, 0.3); overflow: hidden;
            box-shadow: 0 0 30px rgba(0, 153, 255, 0.2); margin-bottom: 2rem; position: relative;
            animation: slideUp 0.8s ease-out;
        }
        .table-container::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
            background: linear-gradient(90deg, #00ffff, #0099ff, #00ffff); border-radius: 20px 20px 0 0;
        }
        .table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        table { width: 100%; border-collapse: collapse; min-width: 600px; }
        th {
            background: linear-gradient(135deg, rgba(0, 153, 255, 0.3), rgba(0, 255, 255, 0.2));
            color: #00ffff; font-weight: 700; font-size: clamp(0.9rem, 2.5vw, 1.1rem);
            padding: 1.5rem 1rem; text-align: center; border: none; position: relative; border-bottom: 2px solid #0099ff;
        }
        td {
            padding: 1.5rem 1rem; text-align: center; border: none; border-bottom: 1px solid rgba(0, 153, 255, 0.3);
            font-size: clamp(0.8rem, 2vw, 1rem); font-weight: 600; transition: all 0.3s ease; position: relative;
        }
        td:first-child { background: rgba(0, 255, 255, 0.1); font-weight: 700; color: #00ffff; }
        
        .pricing-highlight { position: relative; overflow: hidden; }
        .pricing-highlight:hover { background: rgba(0, 153, 255, 0.2); transform: scale(1.02); box-shadow: 0 0 20px rgba(0, 255, 255, 0.3); }
        .price-value { font-size: clamp(1rem, 3vw, 1.3rem); font-weight: 800; color: #ffffff; display: block; margin-bottom: 0.5rem; text-shadow: 0 0 10px rgba(0, 255, 255, 0.5); }
        .price-savings { font-size: clamp(0.7rem, 2vw, 0.8rem); color: #00ff88; font-weight: 600; opacity: 0; transform: translateY(10px); transition: all 0.3s ease; }
        .pricing-highlight:hover .price-savings { opacity: 1; transform: translateY(0); }
        .session-duration {
            text-align: center; color: #00ffff; font-weight: 600; margin: 1rem 0;
            font-size: clamp(0.9rem, 2.5vw, 1.1rem); padding: 0.8rem;
            background: rgba(0, 255, 255, 0.1); border-radius: 15px; border: 2px solid rgba(0, 153, 255, 0.5);
        }

        /* ================= FEMME (Coming Soon) ================= */
        .coming-soon-card {
            background: linear-gradient(145deg, rgba(0, 153, 255, 0.15), rgba(0, 255, 255, 0.05));
            border: 2px dashed rgba(0, 255, 255, 0.3);
            border-radius: 20px; padding: 4rem 2rem; text-align: center;
            max-width: 600px; margin: 0 auto;
        }
        .coming-soon-card h3 { color: #00ffff; font-size: 1.5rem; margin-bottom: 1rem; }
        .coming-soon-card p { color: rgba(255, 255, 255, 0.7); }

        /* ================= ENFANTS ================= */
        .kids-pricing__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin: 3rem 0; }
        .kids-pricing__card {
            background: linear-gradient(135deg, rgba(0, 153, 255, 0.1), rgba(0, 255, 255, 0.1));
            border: 2px solid rgba(0, 153, 255, 0.3); border-radius: 20px; padding: 2.5rem 2rem;
            text-align: center; transition: all 0.4s ease; backdrop-filter: blur(10px);
            position: relative; overflow: hidden; cursor: pointer;
        }
        .kids-pricing__card::before {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: linear-gradient(45deg, transparent, rgba(0, 255, 255, 0.1), transparent);
            transform: rotate(45deg); transition: all 0.6s ease; opacity: 0;
        }
        .kids-pricing__card:hover {
            background: linear-gradient(135deg, rgba(0, 153, 255, 0.2), rgba(0, 255, 255, 0.2));
            border-color: #00ffff; transform: translateY(-10px) scale(1.02);
            box-shadow: 0 0 40px rgba(0, 255, 255, 0.5);
        }
        .kids-pricing__card:hover::before { opacity: 1; animation: shimmer 1.5s ease-in-out; }
        .kids-pricing__badge {
            background: linear-gradient(135deg, #0099ff, #00ffff); color: #000;
            padding: 0.5rem 1rem; border-radius: 20px; font-size: 0.9rem; font-weight: 600; margin-bottom: 1.5rem; display: inline-block;
        }
        .kids-pricing__title { font-size: 1.5rem; color: #00ffff; margin-bottom: 1rem; font-weight: 700; }
        .kids-pricing__price { font-size: 3rem; font-weight: 800; color: #ffffff; margin-bottom: 0.5rem; }
        .kids-pricing__period { color: rgba(255, 255, 255, 0.7); margin-bottom: 2rem; font-size: 1rem; }
        .kids-pricing__features { list-style: none; margin-bottom: 2rem; }
        .kids-pricing__feature { padding: 0.5rem 0; color: rgba(255, 255, 255, 0.9); display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
        .kids-pricing__feature::before { content: 'OK'; color: #00ffff; font-weight: bold; font-size: 1.2rem; }
        .kids-pricing__button {
            background: linear-gradient(135deg, #0099ff, #00ffff); color: #000000;
            padding: 1rem 2rem; text-decoration: none; border-radius: 15px; font-weight: 700;
            font-size: 1rem; transition: all 0.3s ease; display: inline-block;
            position: relative; overflow: hidden; box-shadow: 0 0 20px rgba(0, 153, 255, 0.4); border: 2px solid #00ffff;
        }
        .kids-pricing__button:hover { background: linear-gradient(135deg, #00ffff, #0099ff); transform: translateY(-2px); box-shadow: 0 0 30px rgba(0, 255, 255, 0.6); }

        /* ================= APNÉE ================= */
        .apnea-container { display: flex; justify-content: center; margin: 3rem 0; }
        .apnea-card {
            background: linear-gradient(145deg, rgba(0, 153, 255, 0.15), rgba(0, 255, 255, 0.1));
            backdrop-filter: blur(20px); border: 3px solid rgba(0, 153, 255, 0.4); border-radius: 25px;
            padding: 2.5rem; max-width: 600px; width: 100%; position: relative; overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 10px 40px rgba(0, 153, 255, 0.3);
            animation: slideUp 1s ease-out 0.3s both;
        }
        .apnea-card:hover { transform: translateY(-15px) scale(1.03); box-shadow: 0 20px 60px rgba(0, 255, 255, 0.5); border-color: #00ffff; }
        .apnea-header { display: flex; align-items: center; gap: 2rem; margin-bottom: 2rem; }
        .apnea-title h4 {
            font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 800;
            background: linear-gradient(135deg, #00ffff, #0099ff, #ffffff);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
            margin-bottom: 0.5rem; line-height: 1.2;
        }
        .apnea-title p { font-size: clamp(1rem, 3vw, 1.2rem); color: rgba(255, 255, 255, 0.8); font-weight: 600; }
        .feature-item {
            display: flex; align-items: center; gap: 1rem; margin: 1rem 0; padding: 0.8rem;
            background: rgba(0, 153, 255, 0.1); border-radius: 15px; border: 1px solid rgba(0, 153, 255, 0.3);
            transition: all 0.3s ease;
        }
        .feature-icon { font-size: 1.5rem; width: 2.5rem; text-align: center; }
        .apnea-pricing { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
        .price-main, .price-renewal {
            background: rgba(0, 255, 255, 0.1); border: 2px solid rgba(0, 153, 255, 0.4);
            border-radius: 20px; padding: 1.5rem; text-align: center; transition: all 0.3s ease;
        }
        .price-label { display: block; font-size: clamp(0.9rem, 2.5vw, 1.1rem); color: #00ffff; font-weight: 600; margin-bottom: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .price-amount { display: block; font-size: clamp(1.3rem, 4vw, 1.8rem); font-weight: 800; color: #ffffff; text-shadow: 0 0 15px rgba(0, 255, 255, 0.6); margin-bottom: 0.5rem; }
        .price-note { font-size: clamp(0.7rem, 2vw, 0.9rem); color: rgba(255, 255, 255, 0.7); font-style: italic; }

        /* ================= BUTTONS & FLOATING ================= */
        .btn {
            background: linear-gradient(135deg, #0099ff, #00ffff); color: #000000;
            padding: 1rem 2rem; border-radius: 50px; font-weight: 700;
            font-size: clamp(0.9rem, 2.5vw, 1rem); transition: all 0.3s ease;
            display: inline-block; position: relative; overflow: hidden;
            box-shadow: 0 0 30px rgba(0, 153, 255, 0.6); border: 2px solid #00ffff; cursor: pointer; width: 100%;
        }
        .btn:hover { background: linear-gradient(135deg, #00ffff, #0099ff); transform: translateY(-3px); box-shadow: 0 0 40px rgba(0, 255, 255, 0.8); }
        .floating-btn {
            position: fixed; bottom: 20px; right: 20px;
            background: linear-gradient(135deg, #0099ff, #00ffff); color: #000;
            padding: 0.8rem 1.2rem; border-radius: 50px; font-weight: 700; font-size: 0.9rem; text-decoration: none;
            box-shadow: 0 0 30px rgba(0, 153, 255, 0.6); z-index: 2000;
            transition: all 0.3s ease; border: 2px solid #00ffff; display: flex; align-items: center; gap: 0.5rem;
        }
        .floating-btn:hover { background: linear-gradient(135deg, #00ffff, #0099ff); transform: translateY(-3px); box-shadow: 0 0 40px rgba(0, 255, 255, 0.8); }

        /* ================= MEDIA QUERIES ================= */
        @media (max-width: 768px) {
            .category-nav { flex-direction: column; align-items: center; }
            .category-btn { width: 100%; max-width: 300px; }
            .apnea-header { flex-direction: column; gap: 1.5rem; text-align: center; }
            .apnea-pricing { grid-template-columns: 1fr; gap: 1rem; }
            .kids-pricing__grid { gap: 1rem; margin: 1.5rem 0; }
            .kids-pricing__card { padding: 1.5rem 1rem; }
            th, td { padding: 1rem 0.5rem; }
            .table-scroll::-webkit-scrollbar { height: 8px; }
            .table-scroll::-webkit-scrollbar-track { background: rgba(0, 153, 255, 0.1); border-radius: 10px; }
            .table-scroll::-webkit-scrollbar-thumb { background: linear-gradient(90deg, #0099ff, #00ffff); border-radius: 10px; }
        }
        @media (max-width: 480px) {
            .hero { padding: 1.5rem 0; }
            th, td { padding: 0.8rem 0.3rem; }
            .floating-btn { padding: 0.6rem 0.8rem; font-size: 0.75rem; bottom: 10px; right: 10px; }
        }
        @media print {
            .floating-btn, .category-nav, .content-section { display: block !important; page-break-after: always; }
            .table-container { break-inside: avoid; }
        }
           footer {
            background: #000;
            border-top: 2px solid #0099ff;
            padding: 0;
            margin-top: 0;
        }

        /* ================= RECOMMENDED QUIZ ================= */
        .rec-quiz-container {
            background: rgba(0, 153, 255, 0.05);
            border: 2px solid rgba(0, 153, 255, 0.3);
            border-radius: 24px;
            padding: 3rem 2rem;
            max-width: 720px;
            margin: 2rem auto 4rem auto;
            backdrop-filter: blur(20px);
            box-shadow: 0 0 40px rgba(0, 153, 255, 0.15);
            animation: fadeIn 0.8s ease-out;
            position: relative;
        }
        .quiz-step {
            display: none;
            opacity: 0;
            transform: scale(0.98);
            transition: all 0.4s ease-out;
        }
        .quiz-step.active {
            display: block;
            opacity: 1;
            transform: scale(1);
        }
        .quiz-step-title {
            font-size: clamp(1.3rem, 4vw, 1.8rem);
            font-weight: 800;
            color: #ffffff;
            margin-bottom: 1rem;
            text-align: center;
            line-height: 1.3;
        }
        .quiz-step-desc {
            font-size: 1.05rem;
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 2.5rem;
            text-align: center;
            max-width: 550px;
            margin-left: auto;
            margin-right: auto;
        }

        /* Promo Banner Styles */
        .quiz-promo-banner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 2rem;
            background: linear-gradient(135deg, rgba(0, 153, 255, 0.12), rgba(0, 255, 255, 0.08));
            border: 2px solid rgba(0, 255, 255, 0.25);
            border-radius: 24px;
            padding: 2rem 2.5rem;
            max-width: 900px;
            margin: 0 auto 3rem auto;
            backdrop-filter: blur(15px);
            box-shadow: 0 0 30px rgba(0, 255, 255, 0.1);
            animation: slideIn 0.8s ease-out;
        }
        .promo-content {
            flex: 1;
            text-align: left;
        }
        [dir="rtl"] .promo-content {
            text-align: right;
        }
        .promo-badge {
            font-size: 0.75rem;
            font-weight: 800;
            color: #00ffff;
            background: rgba(0, 255, 255, 0.1);
            padding: 0.4rem 1rem;
            border-radius: 50px;
            border: 1px solid rgba(0, 255, 255, 0.3);
            display: inline-block;
            margin-bottom: 0.8rem;
            letter-spacing: 0.5px;
        }
        .promo-title {
            font-size: 1.4rem;
            font-weight: 800;
            color: #ffffff;
            margin-bottom: 0.5rem;
        }
        .promo-desc {
            font-size: 0.95rem;
            color: rgba(255, 255, 255, 0.85);
            line-height: 1.5;
        }
        .promo-btn {
            background: linear-gradient(135deg, #0099ff, #00ffff);
            color: #000000;
            padding: 1.1rem 2.2rem;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1.05rem;
            border: 2px solid #00ffff;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 0 20px rgba(0, 255, 255, 0.3);
            white-space: nowrap;
        }
        .promo-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 30px rgba(0, 255, 255, 0.6);
        }
        @media (max-width: 768px) {
            .quiz-promo-banner {
                flex-direction: column;
                text-align: center;
                gap: 1.5rem;
                padding: 2rem;
            }
            .promo-content {
                text-align: center !important;
            }
            .promo-btn {
                width: 100%;
            }
        }
        
        /* Options Grid */
        .quiz-options-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-top: 2rem;
        }
        .quiz-opt-btn {
            background: rgba(0, 153, 255, 0.08);
            border: 1.5px solid rgba(0, 153, 255, 0.3);
            color: #ffffff;
            padding: 1.25rem 1.5rem;
            border-radius: 16px;
            font-size: 1.05rem;
            font-weight: 600;
            text-align: left;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 1.25rem;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            width: 100%;
        }
        [dir="rtl"] .quiz-opt-btn {
            text-align: right;
        }
        .quiz-opt-btn:hover {
            background: rgba(0, 255, 255, 0.12);
            border-color: #00ffff;
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0, 255, 255, 0.2);
        }
        .opt-icon {
            font-size: 1.6rem;
            filter: drop-shadow(0 0 5px rgba(0, 255, 255, 0.4));
        }
        .opt-text {
            flex: 1;
            line-height: 1.4;
        }
        .opt-text strong {
            color: #00ffff;
        }
        .opt-text small {
            color: rgba(255, 255, 255, 0.7);
            font-weight: 500;
        }

        /* Progress Bar */
        .quiz-progress-container {
            margin-top: 2.5rem;
            border-top: 1px solid rgba(0, 153, 255, 0.2);
            padding-top: 1.5rem;
        }
        .quiz-progress-text {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.6);
            margin-bottom: 0.5rem;
            font-weight: 600;
            text-align: right;
        }
        [dir="rtl"] .quiz-progress-text {
            text-align: left;
        }
        .quiz-progress-bar {
            width: 100%;
            height: 5px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 3px;
            overflow: hidden;
        }
        .quiz-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #00ffff, #0099ff);
            width: 0%;
            transition: width 0.3s ease;
            box-shadow: 0 0 10px rgba(0, 255, 255, 0.4);
        }

        /* Spinner */
        .quiz-spinner {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(0, 255, 255, 0.1);
            border-top-color: #00ffff;
            border-radius: 50%;
            margin: 0 auto;
            animation: spin 1s linear infinite;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.1);
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Recommendation Results Card */
        .rec-badge {
            background: linear-gradient(135deg, #0099ff, #00ffff);
            color: #000000;
            padding: 0.5rem 1.25rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 800;
            display: inline-block;
            margin-bottom: 1.5rem;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.4);
            letter-spacing: 0.5px;
        }
        .rec-title {
            font-size: clamp(1.6rem, 5vw, 2.2rem);
            font-weight: 800;
            color: #ffffff;
            margin-bottom: 1.5rem;
            text-shadow: 0 0 20px rgba(0, 255, 255, 0.4);
            line-height: 1.2;
        }
        .rec-price-box {
            margin-bottom: 2rem;
        }
        .rec-price {
            font-size: clamp(2.8rem, 8vw, 3.8rem);
            font-weight: 800;
            color: #00ffff;
            text-shadow: 0 0 25px rgba(0, 255, 255, 0.6);
            line-height: 1;
            margin-bottom: 0.5rem;
        }
        .rec-price-saving {
            font-size: 1.1rem;
            color: #00ff88;
            font-weight: 700;
            text-shadow: 0 0 10px rgba(0, 255, 136, 0.3);
        }
        
        /* Duration Selector */
        .duration-selector {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            background: rgba(0, 0, 0, 0.4);
            padding: 0.4rem;
            border-radius: 50px;
            border: 1px solid rgba(0, 153, 255, 0.25);
            max-width: 440px;
            margin: 0 auto 2.5rem auto;
        }
        .dur-btn {
            flex: 1;
            background: transparent;
            color: #ffffff;
            border: none;
            padding: 0.75rem 1rem;
            border-radius: 50px;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .dur-btn:hover {
            background: rgba(255, 255, 255, 0.05);
        }
        .dur-btn.active {
            background: linear-gradient(135deg, #0099ff, #00ffff);
            color: #000000;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.4);
        }
        
        /* Bullet Details */
        .rec-details {
            max-width: 520px;
            margin: 0 auto 2.5rem auto;
            text-align: left;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        [dir="rtl"] .rec-details {
            text-align: right;
        }
        .detail-bullet {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            background: rgba(0, 153, 255, 0.08);
            border: 1px solid rgba(0, 153, 255, 0.2);
            border-radius: 16px;
            padding: 1rem 1.25rem;
            font-size: 1rem;
            line-height: 1.5;
            color: rgba(255, 255, 255, 0.9);
        }
        .bullet-icon {
            font-size: 1.4rem;
            filter: drop-shadow(0 0 5px rgba(0, 255, 255, 0.4));
        }

        /* Actions */
        .rec-actions {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            max-width: 380px;
            margin: 0 auto 2rem auto;
        }
        .rec-book-btn {
            background: linear-gradient(135deg, #0099ff, #00ffff);
            color: #000000;
            width: 100%;
            padding: 1.1rem;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1.1rem;
            text-decoration: none;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: 0 0 25px rgba(0, 255, 255, 0.5);
            border: 2px solid #00ffff;
        }
        .rec-book-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 35px rgba(0, 255, 255, 0.7);
        }
        .rec-reset-btn {
            background: transparent;
            color: rgba(255, 255, 255, 0.6);
            border: none;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .rec-reset-btn:hover {
            color: #ffffff;
        }
        .show-all-btn {
            background: transparent;
            color: #00ffff;
            border: none;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            margin-top: 1rem;
            transition: all 0.3s ease;
            opacity: 0.8;
            width: 100%;
        }
        .show-all-btn:hover {
            opacity: 1;
            transform: translateY(-2px);
            text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
        }

