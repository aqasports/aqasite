                            </tbody>
                        </table>
                    </div>
                    <div class="session-duration">Durée de séance: Deux heures</div>
                </div>
            </div>

            <div class="pricing-section">
                <h4 class="section-title" style="font-size: 1.5rem;">Deux fois par semaine</h4>
                <div class="table-container">
                    <div class="table-scroll">
