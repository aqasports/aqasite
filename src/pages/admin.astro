---
import BaseLayout from '../layouts/BaseLayout.astro';
import scheduleData from '../data/schedule.json';
import Page404 from './404.astro';

const isProd = import.meta.env.PROD;
---

{isProd ? (
  <Page404 />
) : (
  <BaseLayout
    title="Administration AQA 2.0 | Control Center"
    description="Interface d'administration pour la gestion des créneaux et des capacités AQA Sports Academy."
    currentPage="/admin"
  >
    <div class="admin-header">
      <div class="logo-section">
        <a href="/">
          <img src="https://i.ibb.co/08WDCFj/Turquoise-Modern-Warning-with-Rays-Instagram-Post.png" alt="AQA Logo" class="logo">
        </a>
        <h1 class="admin-title">AQA Control Center <span class="version-badge">v2.0</span></h1>
      </div>
      <div class="nav-links">
        <a href="/groupes" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          Voir les créneaux
        </a>
      </div>
    </div>

    <div class="admin-container">
      <!-- STATS DASHBOARD -->
      <div class="stats-panel glass-panel">
        <h2>📊 Statistiques Globales</h2>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon icon-blue">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <div class="stat-info">
              <span class="stat-label">Capacité Totale</span>
              <span class="stat-value" id="statTotal">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-cyan">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            </div>
            <div class="stat-info">
              <span class="stat-label">Total Inscrits</span>
              <span class="stat-value text-blue" id="statTaken">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-teal">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div class="stat-info">
              <span class="stat-label">Places Libres</span>
              <span class="stat-value text-teal" id="statFree">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-purple">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
            </div>
            <div class="stat-info">
              <span class="stat-label">Taux d'Occupation</span>
              <span class="stat-value" id="statPercent">0%</span>
            </div>
          </div>
        </div>
        <div class="progress-container">
          <div class="progress-bar" id="statProgressBar" style="width: 0%"></div>
        </div>
      </div>

      <!-- CONTROL ACTIONS -->
      <div class="control-panel glass-panel">
        <div class="selectors">
          <div class="field-group">
            <label for="locationSelect">📍 Emplacement :</label>
            <select id="locationSelect" class="form-control">
              <!-- Populated dynamically -->
            </select>
          </div>
          <div class="field-group">
            <label for="categorySelect">👥 Catégorie :</label>
            <select id="categorySelect" class="form-control">
              <!-- Populated dynamically -->
            </select>
          </div>
        </div>

        <div class="action-buttons">
          <button id="addCoachBtn" class="btn btn-secondary btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="19" y2="14"></line><line x1="22" y1="11" x2="16" y2="11"></line></svg>
            Ajouter Coach
          </button>
          <button id="downloadBtn" class="btn btn-secondary btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 13 7 8"></polyline><line x1="12" y1="13" x2="12" y2="3"></line></svg>
            Télécharger JSON
          </button>
          <button id="copyBtn" class="btn btn-secondary btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            Copier JSON
          </button>
        </div>
      </div>

      <!-- MAIN EDITOR -->
      <div id="editorContainer" class="editor-container">
        <!-- Visually populated coach cards -->
      </div>

      <!-- SAVE BAR -->
      <div class="save-bar">
        <button id="saveBtn" class="btn btn-primary btn-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
          Enregistrer le Planning
        </button>
        <span id="saveStatus" class="save-status"></span>
      </div>
    </div>
  </BaseLayout>
)}

<script is:inline define:vars={{ scheduleData }}>
  // Initialize state and clean up legacy complet type references
  let currentSchedule = JSON.parse(JSON.stringify(scheduleData));

  // Load live schedule data in the background
  async function loadLiveSchedule() {
    try {
      const response = await fetch('/api/schedule');
      if (response.ok) {
        const liveData = await response.json();
        
        // Clean up legacy complet references in the fetched data
        Object.keys(liveData).forEach(locKey => {
          const loc = liveData[locKey];
          if (loc && loc.categories) {
            Object.keys(loc.categories).forEach(catKey => {
              const cat = loc.categories[catKey];
              if (cat && cat.coaches) {
                cat.coaches.forEach(coach => {
                  if (coach.slots) {
                    coach.slots.forEach(slot => {
                      if (slot.type === 'complet') {
                        slot.type = slot.total <= 5 ? 'max5' : 'g10';
                      }
                    });
                  }
                });
              }
            });
          }
        });

        currentSchedule = liveData;
        initSelectors();
        renderEditor();
      }
    } catch (e) {
      console.warn("Failed to load live schedule, using static data instead:", e);
    }
  }
  loadLiveSchedule();
  Object.keys(currentSchedule).forEach(locKey => {
    const loc = currentSchedule[locKey];
    if (loc && loc.categories) {
      Object.keys(loc.categories).forEach(catKey => {
        const cat = loc.categories[catKey];
        if (cat && cat.coaches) {
          cat.coaches.forEach(coach => {
            if (coach.slots) {
              coach.slots.forEach(slot => {
                if (slot.type === 'complet') {
                  slot.type = slot.total <= 5 ? 'max5' : 'g10';
                }
              });
            }
          });
        }
      });
    }
  });
  let currentLocation = 'reghaia';
  let currentCategory = 'homme';

  // DOM Elements
  const locationSelect = document.getElementById('locationSelect');
  const categorySelect = document.getElementById('categorySelect');
  const editorContainer = document.getElementById('editorContainer');
  const addCoachBtn = document.getElementById('addCoachBtn');
  const downloadBtn = document.getElementById('downloadBtn');
  const copyBtn = document.getElementById('copyBtn');
  const saveBtn = document.getElementById('saveBtn');
  const saveStatus = document.getElementById('saveStatus');

  // Load configuration selectors
  function initSelectors() {
    locationSelect.innerHTML = '';
    Object.keys(currentSchedule).forEach(locKey => {
      const opt = document.createElement('option');
      opt.value = locKey;
      opt.textContent = currentSchedule[locKey].name || locKey;
      locationSelect.appendChild(opt);
    });

    updateCategorySelect();
  }

  function updateCategorySelect() {
    categorySelect.innerHTML = '';
    const locData = currentSchedule[currentLocation];
    if (locData && locData.categories) {
      Object.keys(locData.categories).forEach(catKey => {
        const opt = document.createElement('option');
        opt.value = catKey;
        let displayName = locData.categories[catKey].name || catKey;
        if (catKey === 'enfants' || catKey === 'kids') {
          displayName = 'Enfants (AQA Kids)';
        }
        opt.textContent = displayName;
        categorySelect.appendChild(opt);
      });
    }
    
    // Set default category
    const availableCats = Object.keys(locData?.categories || {});
    if (availableCats.length > 0) {
      if (!availableCats.includes(currentCategory)) {
        currentCategory = availableCats[0];
      }
      categorySelect.value = currentCategory;
    }
  }

  // Populate visual cards
  function renderEditor() {
    editorContainer.innerHTML = '';
    
    const locData = currentSchedule[currentLocation];
    const catData = locData?.categories?.[currentCategory];
    
    if (!catData || !catData.coaches || catData.coaches.length === 0) {
      editorContainer.innerHTML = `<div class="no-coaches">Aucun coach configuré pour cette sélection. Cliquez sur "+ Ajouter un Coach" pour commencer.</div>`;
      updateStats();
      return;
    }

    catData.coaches.forEach((coach, coachIdx) => {
      const coachCard = document.createElement('div');
      coachCard.className = 'coach-card glass-panel';
      coachCard.innerHTML = `
        <div class="coach-header">
          <div class="field-group-inline">
            <span class="avatar">👤</span>
            <input type="text" class="coach-name-input form-control" value="${coach.name}" data-coach-idx="${coachIdx}">
          </div>
          <button class="btn btn-danger btn-sm delete-coach-btn" data-coach-idx="${coachIdx}">Supprimer</button>
        </div>

        <div class="slots-container" id="slots-container-${coachIdx}">
          <!-- Slot rows -->
        </div>

        <button class="btn btn-outline btn-sm add-slot-btn" data-coach-idx="${coachIdx}">+ Ajouter un Créneau</button>
      `;

      const slotsContainer = coachCard.querySelector(`.slots-container`);

      if (coach.slots && coach.slots.length > 0) {
        const slotsHeader = document.createElement('div');
        slotsHeader.className = 'slots-header';
        slotsHeader.innerHTML = `
          <span>Jour</span>
          <span>Horaire</span>
          <span>Inscrits</span>
          <span>Total</span>
          <span>Formule</span>
          <span>Actions</span>
        `;
        slotsContainer.appendChild(slotsHeader);
      }

      coach.slots.forEach((slot, slotIdx) => {
        const slotRow = document.createElement('div');
        slotRow.className = 'slot-row';
        slotRow.innerHTML = `
          <div class="slot-field">
            <label class="mobile-label">Jour</label>
            <input type="text" class="form-control slot-day" value="${slot.day}" data-coach-idx="${coachIdx}" data-slot-idx="${slotIdx}">
          </div>
          <div class="slot-field">
            <label class="mobile-label">Horaire</label>
            <input type="text" class="form-control slot-time" value="${slot.time}" data-coach-idx="${coachIdx}" data-slot-idx="${slotIdx}">
          </div>
          <div class="slot-field size-small">
            <label class="mobile-label">Inscrits</label>
            <input type="number" min="0" class="form-control slot-taken" value="${slot.taken}" data-coach-idx="${coachIdx}" data-slot-idx="${slotIdx}">
          </div>
          <div class="slot-field size-small">
            <label class="mobile-label">Total</label>
            <input type="number" min="1" class="form-control slot-total" value="${slot.total}" data-coach-idx="${coachIdx}" data-slot-idx="${slotIdx}">
          </div>
          <div class="slot-field">
            <label class="mobile-label">Formule</label>
            <select class="form-control slot-type" data-coach-idx="${coachIdx}" data-slot-idx="${slotIdx}">
              <option value="g10" ${slot.type === 'g10' ? 'selected' : ''}>G10 (Groupe 10)</option>
              <option value="max5" ${slot.type === 'max5' ? 'selected' : ''}>MAX5 (Max 5)</option>
              <option value="apnea" ${slot.type === 'apnea' ? 'selected' : ''}>Apnée</option>
              <option value="elite" ${slot.type === 'elite' ? 'selected' : ''}>Elite</option>
            </select>
          </div>
          <button class="btn btn-danger btn-square delete-slot-btn" data-coach-idx="${coachIdx}" data-slot-idx="${slotIdx}">✕</button>
        `;
        slotsContainer.appendChild(slotRow);
      });

      editorContainer.appendChild(coachCard);
    });

    // Add event listeners to visual elements dynamically
    attachInputListeners();
    updateStats();
  }

  // Update statistics values
  function updateStats() {
    let totalCapacity = 0;
    let totalTaken = 0;

    const locData = currentSchedule[currentLocation];
    const catData = locData?.categories?.[currentCategory];

    if (catData && catData.coaches) {
      catData.coaches.forEach(coach => {
        if (coach.slots) {
          coach.slots.forEach(slot => {
            totalCapacity += parseInt(slot.total) || 0;
            totalTaken += parseInt(slot.taken) || 0;
          });
        }
      });
    }

    const freeSlots = Math.max(0, totalCapacity - totalTaken);
    const occupancyPercent = totalCapacity > 0 ? Math.round((totalTaken / totalCapacity) * 100) : 0;

    document.getElementById('statTotal').textContent = totalCapacity;
    document.getElementById('statTaken').textContent = totalTaken;
    document.getElementById('statFree').textContent = freeSlots;
    document.getElementById('statPercent').textContent = occupancyPercent + '%';
    
    const bar = document.getElementById('statProgressBar');
    bar.style.width = occupancyPercent + '%';
    if (occupancyPercent > 85) {
      bar.className = 'progress-bar bg-danger';
    } else {
      bar.className = 'progress-bar bg-teal';
    }
  }

  // Set up listeners for the DOM inputs
  function attachInputListeners() {
    // Coach Name edit
    document.querySelectorAll('.coach-name-input').forEach(input => {
      input.addEventListener('input', () => {
        const coachIdx = parseInt(input.dataset.coachIdx);
        currentSchedule[currentLocation].categories[currentCategory].coaches[coachIdx].name = input.value;
      });
    });

    // Slot edits
    document.querySelectorAll('.slot-day').forEach(input => {
      input.addEventListener('input', () => {
        const cIdx = parseInt(input.dataset.coachIdx);
        const sIdx = parseInt(input.dataset.slotIdx);
        currentSchedule[currentLocation].categories[currentCategory].coaches[cIdx].slots[sIdx].day = input.value;
      });
    });

    document.querySelectorAll('.slot-time').forEach(input => {
      input.addEventListener('input', () => {
        const cIdx = parseInt(input.dataset.coachIdx);
        const sIdx = parseInt(input.dataset.slotIdx);
        currentSchedule[currentLocation].categories[currentCategory].coaches[cIdx].slots[sIdx].time = input.value;
      });
    });

    document.querySelectorAll('.slot-taken').forEach(input => {
      input.addEventListener('input', () => {
        const cIdx = parseInt(input.dataset.coachIdx);
        const sIdx = parseInt(input.dataset.slotIdx);
        currentSchedule[currentLocation].categories[currentCategory].coaches[cIdx].slots[sIdx].taken = parseInt(input.value) || 0;
        updateStats();
      });
    });

    document.querySelectorAll('.slot-total').forEach(input => {
      input.addEventListener('input', () => {
        const cIdx = parseInt(input.dataset.coachIdx);
        const sIdx = parseInt(input.dataset.slotIdx);
        currentSchedule[currentLocation].categories[currentCategory].coaches[cIdx].slots[sIdx].total = parseInt(input.value) || 10;
        updateStats();
      });
    });

    document.querySelectorAll('.slot-type').forEach(select => {
      select.addEventListener('change', () => {
        const cIdx = parseInt(select.dataset.coachIdx);
        const sIdx = parseInt(select.dataset.slotIdx);
        currentSchedule[currentLocation].categories[currentCategory].coaches[cIdx].slots[sIdx].type = select.value;
      });
    });

    // Delete buttons
    document.querySelectorAll('.delete-coach-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (confirm('Voulez-vous vraiment supprimer ce coach et tous ses créneaux ?')) {
          const coachIdx = parseInt(btn.dataset.coachIdx);
          currentSchedule[currentLocation].categories[currentCategory].coaches.splice(coachIdx, 1);
          renderEditor();
        }
      });
    });

    document.querySelectorAll('.delete-slot-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cIdx = parseInt(btn.dataset.coachIdx);
        const sIdx = parseInt(btn.dataset.slotIdx);
        currentSchedule[currentLocation].categories[currentCategory].coaches[cIdx].slots.splice(sIdx, 1);
        renderEditor();
      });
    });

    // Add slot buttons
    document.querySelectorAll('.add-slot-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const coachIdx = parseInt(btn.dataset.coachIdx);
        currentSchedule[currentLocation].categories[currentCategory].coaches[coachIdx].slots.push({
          day: 'Samedi',
          time: '21h30-23h30',
          type: 'g10',
          total: 10,
          taken: 0
        });
        renderEditor();
      });
    });
  }

  // Handle locations & categories change
  locationSelect.addEventListener('change', (e) => {
    currentLocation = e.target.value;
    updateCategorySelect();
    currentCategory = categorySelect.value || '';
    renderEditor();
  });

  categorySelect.addEventListener('change', (e) => {
    currentCategory = e.target.value;
    renderEditor();
  });

  // Add Coach Action
  addCoachBtn.addEventListener('click', () => {
    if (!currentSchedule[currentLocation].categories) {
      currentSchedule[currentLocation].categories = {};
    }
    if (!currentSchedule[currentLocation].categories[currentCategory]) {
      currentSchedule[currentLocation].categories[currentCategory] = { name: currentCategory, coaches: [] };
    }
    currentSchedule[currentLocation].categories[currentCategory].coaches.push({
      name: 'Nouveau Coach',
      slots: []
    });
    renderEditor();
  });

  // Download JSON
  downloadBtn.addEventListener('click', () => {
    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(currentSchedule, null, 2));
    const dlAnchorElem = document.createElement('a');
    dlAnchorElem.setAttribute("href", dataStr);
    dlAnchorElem.setAttribute("download", "schedule.json");
    dlAnchorElem.click();
  });

  // Copy to clipboard
  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(JSON.stringify(currentSchedule, null, 2))
      .then(() => alert('JSON copié dans le presse-papiers avec succès !'))
      .catch(err => alert('Erreur de copie: ' + err.message));
  });

  // Save to backend API
  saveBtn.addEventListener('click', async () => {
    saveStatus.textContent = 'Enregistrement en cours...';
    saveStatus.className = 'save-status';

    const headers = { 'Content-Type': 'application/json' };

    try {
      const response = await fetch('/api/save-schedule', {
        method: 'POST',
        headers: headers,
        body: JSON.stringify({ schedule: currentSchedule })
      });

      const responseText = await response.text();
      let resData;
      try {
        resData = JSON.parse(responseText);
      } catch (parseErr) {
        saveStatus.textContent = `❌ Erreur: Réponse non-JSON du serveur (Status: ${response.status}).`;
        saveStatus.className = 'save-status error';
        console.error('Server returned non-JSON:', responseText);
        return;
      }

      if (response.ok && resData.success) {
        saveStatus.textContent = '✓ Planning enregistré avec succès !';
        saveStatus.className = 'save-status success';
      } else {
        saveStatus.textContent = '❌ Erreur: ' + (resData.message || response.statusText || 'Erreur inconnue');
        saveStatus.className = 'save-status error';
      }
    } catch (err) {
      saveStatus.textContent = '❌ Erreur réseau: ' + err.message;
      saveStatus.className = 'save-status error';
    }
  });

  // Load initial view
  initSelectors();
  renderEditor();
</script>

<style is:global>
  :root {
    --color-primary: #00f2ff;
    --color-secondary: #0088ff;
    --color-success: #10b981;
    --color-danger: #ef4444;
    --bg-glass: rgba(15, 23, 42, 0.45);
    --border-glass: 1px solid rgba(255, 255, 255, 0.08);
    --shadow-glow: 0 0 20px rgba(0, 242, 255, 0.15);
    --shadow-glow-active: 0 0 35px rgba(0, 242, 255, 0.35);
  }

  .admin-header {
    background: rgba(3, 7, 18, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: var(--border-glass);
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 1000;
  }
  .logo-section {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .logo {
    height: 44px;
    filter: drop-shadow(0 0 8px var(--color-primary));
    transition: transform 0.3s ease;
  }
  .logo:hover {
    transform: rotate(5deg) scale(1.05);
  }
  .admin-title {
    font-size: 1.5rem;
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    margin: 0;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.03em;
  }
  .version-badge {
    background: rgba(0, 242, 255, 0.1);
    color: var(--color-primary);
    font-size: 0.75rem;
    padding: 3px 8px;
    border-radius: 6px;
    border: 1px solid rgba(0, 242, 255, 0.2);
    margin-left: 0.5rem;
    vertical-align: middle;
    font-weight: 600;
  }
  .back-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    border: 1px solid var(--color-primary);
    padding: 0.6rem 1.2rem;
    border-radius: 30px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 4px 15px rgba(0, 242, 255, 0.05);
  }
  .back-link:hover {
    background: rgba(0, 242, 255, 0.08);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  .admin-container {
