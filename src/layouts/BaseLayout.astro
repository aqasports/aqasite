---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import NotificationToast from '../components/NotificationToast.astro';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  currentPage?: string;
  lang?: string;
  robots?: string;
}

const {
  title,
  description = "AQA Sports Academy — Coaching d'élite, natation, apnée en Algérie. Du débutant au professionnel.",
  keywords = 'natation algérie, apnée, coaching sport, académie natation alger, aqa sports',
  ogImage = 'https://i.ibb.co/08WDCFj/Turquoise-Modern-Warning-with-Rays-Instagram-Post.png',
  currentPage = '',
  lang = 'fr',
  robots = 'index, follow',
} = Astro.props;

const siteUrl = 'https://aqasports.com';
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
  <ViewTransitions />
  <meta name="google-site-verification" content="inKPL762nSBpYj4IE7DSnI3Q6TGbirWbyLJxMRjpymg" />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="robots" content={robots} />
  <meta name="author" content="AQA Sports Academy" />
  {robots.includes('noindex') ? null : (
    <>
      <link rel="canonical" href={`${siteUrl}${currentPage}`} />
      <meta property="og:url" content={`${siteUrl}${currentPage}`} />
    </>
  )}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="AQA Sports Academy" />
  <meta property="og:locale" content={lang === 'ar' ? 'ar_DZ' : (lang === 'en' ? 'en_US' : 'fr_DZ')} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Navbar CSS (same file the original pages use) -->
  <link rel="stylesheet" href="/css/navbar.css" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-P540VBDLT5"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-P540VBDLT5');
  </script>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SportsActivityLocation",
      "name": "AQA Sports Academy",
      "url": "https://aqasports.com",
      "description": "Académie de natation et d'apnée en Algérie — du débutant au professionnel",
      "address": { "@type": "PostalAddress", "addressCountry": "DZ", "addressLocality": "Alger" },
      "telephone": "+213540454907",
      "sameAs": ["https://www.instagram.com/aqa.sports", "https://web.facebook.com/p/AQA-sports-academy-100063686885387"]
    }
  </script>

  <!-- Language persistence & redirection script -->
  <script is:inline>
    (function() {
      let astroReferrer = '';
      
      // Track previous page client-side when using Astro's view transitions
      document.addEventListener('astro:before-preparation', function() {
        astroReferrer = window.location.pathname;
      });

      // Listen to language switcher clicks to update the preference before navigation
      if (!window.aqaLangListenerInit) {
        document.addEventListener('click', function(e) {
          const btn = e.target.closest('[data-lang-btn]');
          if (btn) {
            const targetLang = btn.getAttribute('data-lang-btn');
            if (targetLang) {
              localStorage.setItem('aqa_lang', targetLang);
            }
          }
        });
        window.aqaLangListenerInit = true;
      }

      function checkLang() {
        if (typeof localStorage === 'undefined') return;
        
        const path = window.location.pathname;
        const currentLang = document.documentElement.lang || 'fr';
        const isFrenchPage = !path.startsWith('/ar') && !path.startsWith('/en');
        const supportedLangs = ['ar', 'en'];
        
        if (isFrenchPage) {
          const savedLang = localStorage.getItem('aqa_lang');
          
          if (savedLang && supportedLangs.includes(savedLang)) {
            const referrer = document.referrer;
            const currentOrigin = window.location.origin;
            const isFromOurSite = (referrer && referrer.startsWith(currentOrigin)) || !!astroReferrer;
            
            // Check if the previous page (client-side or full-reload) had a language prefix
            const prevPath = astroReferrer || (isFromOurSite ? new URL(referrer).pathname : '');
            const isExplicitFR = prevPath.startsWith('/ar') || prevPath.startsWith('/en');
            
            if (isExplicitFR) {
              localStorage.setItem('aqa_lang', 'fr');
              astroReferrer = ''; // reset after handling
            } else {
              const targetPath = '/' + savedLang + (path === '/' ? '' : path);
              window.location.href = targetPath;
            }
          } else if (!savedLang) {
            const browserLang = (navigator.language || 'fr').split('-')[0].toLowerCase();
            if (supportedLangs.includes(browserLang)) {
              const targetPath = '/' + browserLang + (path === '/' ? '' : path);
              window.location.href = targetPath;
            } else {
              localStorage.setItem('aqa_lang', 'fr');
            }
          }
        } else {
          localStorage.setItem('aqa_lang', currentLang);
        }
      }
      
      checkLang();
      document.addEventListener('astro:after-swap', checkLang);
      document.addEventListener('astro:page-load', checkLang);
    })();
  </script>

  <!-- Slot for page-specific <style> or <link> tags -->
  <slot name="head" />
</head>
<body>
  <iframe src="/scroll.html" class="bg-frame" tabindex="-1" aria-hidden="true" transition:persist transition:animate="none"></iframe>
  <div class="bg-logo" transition:persist transition:animate="none"></div>
  <slot />
  <NotificationToast />
</body>
</html>
