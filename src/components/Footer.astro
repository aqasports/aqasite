---
// Footer.astro — Translated and styled footer component
import frDict from '../../lang/fr.json';
import arDict from '../../lang/ar.json';
import enDict from '../../lang/en.json';

export interface Props {
  lang?: string;
}

const { lang = 'fr' } = Astro.props;

const dicts = { fr: frDict, ar: arDict, en: enDict };
const dict = dicts[lang] || frDict;

function t(key, fallbackText) {
  return dict[key] !== undefined ? dict[key] : fallbackText;
}

const footerTranslations = {
  fr: {
    aboutTitle: "À Propos d'AQA",
    aboutText1: "AQA Sports Academy est un établissement sportif dédié à transformer les débutants en athlètes confiants à travers un coaching d'élite et un suivi personnalisé.",
    aboutText2: "Notre mission : Du zéro au pro avec science et technologie.",
    linksTitle: "Liens Rapides",
    contactTitle: "Contact",
    newsletterTitle: "Newsletter",
    newsletterText: "Restez informé de nos dernières actualités et offres.",
    placeholderEmail: "Votre email",
    btnSubscribe: "S'abonner",
    copyright: "AQA Sports Academy. Tous droits réservés.",
    newsletterSuccess: "Merci, vous êtes abonné !",
    newsletterError: "Erreur: impossible d'envoyer.",
    newsletterNetwork: "Erreur réseau, réessayez.",
    validationError: "Veuillez entrer une adresse email."
  },
  ar: {
    aboutTitle: "حول أكا",
    aboutText1: "أكاديمية أكا الرياضية هي مؤسسة مخصصة لتحويل المبتدئين إلى رياضيين واثقين من خلال التدريب النخبوي والمتابعة الشخصية.",
    aboutText2: "مهمتنا: من الصفر إلى الاحتراف بالعلم والتكنولوجيا.",
    linksTitle: "روابط سريعة",
    contactTitle: "اتصل بنا",
    newsletterTitle: "النشرة الإخبارية",
    newsletterText: "اشترك معنا ليصلك كل جديد من الأخبار والعروض.",
    placeholderEmail: "بريدك الإلكتروني",
    btnSubscribe: "اشتراك",
    copyright: "أكاديمية أكا الرياضية. جميع الحقوق محفوظة.",
    newsletterSuccess: "شكرًا لك، لقد تم الاشتراك بنجاح!",
    newsletterError: "خطأ: لم نتمكن من الإرسال.",
    newsletterNetwork: "خطأ في الشبكة، يرجى المحاولة مرة أخرى.",
    validationError: "يرجى إدخال عنوان بريد إلكتروني صالح."
  },
  en: {
    aboutTitle: "About AQA",
    aboutText1: "AQA Sports Academy is a premier sports facility dedicated to transforming beginners into confident athletes through elite coaching and personalized guidance.",
    aboutText2: "Our mission: From zero to pro with science and technology.",
    linksTitle: "Quick Links",
    contactTitle: "Contact Us",
    newsletterTitle: "Newsletter",
    newsletterText: "Stay informed about our latest news and offers.",
    placeholderEmail: "Your email",
    btnSubscribe: "Subscribe",
    copyright: "AQA Sports Academy. All rights reserved.",
    newsletterSuccess: "Thank you, you are subscribed!",
    newsletterError: "Error: unable to submit.",
    newsletterNetwork: "Network error, please try again.",
    validationError: "Please enter a valid email address."
  }
};

const localT = footerTranslations[lang] || footerTranslations.fr;

const getRelativePath = (path, targetLang) => {
  if (targetLang === 'fr') return path;
  return `/${targetLang}${path === '/' ? '' : path}`;
};
---

<footer class="aqa-footer">
    <div class="footer-content">
        <!-- About Section -->
        <div class="footer-section">
            <h4>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="16" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12" y2="8"></line>
                </svg>
                {localT.aboutTitle}
            </h4>
            <p>{localT.aboutText1}</p>
            <p style="margin-top:0.8rem;">{localT.aboutText2}</p>
        </div>

        <!-- Quick Links -->
        <div class="footer-section">
            <h4>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 11H5a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h4l-3-7zM22 9c0-3.87-3.13-7-7-7l-3 7h4a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-4l3 7c3.87 0 7-3.13 7-7V9z"></path>
                </svg>
                {localT.linksTitle}
            </h4>
            <ul>
                <li><a href={getRelativePath('/tarifs', lang)}>{t('nav_tarifs', 'Tarifs')}</a></li>
                <li><a href={getRelativePath('/groupes', lang)}>{t('nav_groupes', 'Groupes')}</a></li>
                <li><a href={getRelativePath('/inscription', lang)}>{t('nav_inscription', 'Inscription')}</a></li>
                <li><a href={getRelativePath('/piscines', lang)}>{t('nav_piscines', 'Piscines')}</a></li>
                <li><a href={getRelativePath('/events', lang)}>{t('nav_events', 'Events')}</a></li>
                <li><a href={getRelativePath('/webtv', lang)}>{t('btn_webtv', 'WebTV')}</a></li>
                <li><a href={getRelativePath('/store', lang)}>{t('nav_store', 'Store')}</a></li>
            </ul>
        </div>

        <!-- Contact -->
        <div class="footer-section">
            <h4>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
                {localT.contactTitle}
            </h4>
            <div class="contact-info">
                <a href="https://maps.app.goo.gl/AJVe5WiLeSntrovE7" target="_blank" rel="noopener noreferrer">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                    <span>Réghaia, Cheraga</span>
                </a>
            </div>
            <div class="contact-info">
                <a href="tel:+213540454907">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    </svg>
                    <span>+213 540 45 49 07</span>
                </a>
            </div>
            <div class="contact-info">
                <a href="mailto:aqa.sports.academy@gmail.com">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    <span>aqa.sports.academy@gmail.com</span>
                </a>
            </div>
        </div>

        <!-- Newsletter & Social -->
        <div class="footer-section">
            <h4>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
                {localT.newsletterTitle}
            </h4>
            <p>{localT.newsletterText}</p>
            <form id="newsletterForm" class="newsletter-form" data-success={localT.newsletterSuccess} data-error={localT.newsletterError} data-network={localT.newsletterNetwork} data-validation={localT.validationError}>
                <input type="email" name="email" placeholder={localT.placeholderEmail} required class="newsletter-input" />
                <button type="submit" class="newsletter-btn">{localT.btnSubscribe}</button>
            </form>
            <p id="newsletterMessage" class="hidden"></p>
            <div class="socials">
                <a href="https://web.facebook.com/p/AQA-sports-academy-100063686885387" target="_blank" rel="noopener noreferrer" title="Facebook" aria-label="Facebook">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                </a>
                <a href="https://www.instagram.com/aqa.sports" target="_blank" rel="noopener noreferrer" title="Instagram" aria-label="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </a>
                <a href="https://www.youtube.com/@AQASPORTS1" target="_blank" rel="noopener noreferrer" title="YouTube" aria-label="YouTube">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75,15.02 15.5,11.75 9.75,8.48"></polygon></svg>
                </a>
                <a href="https://www.tiktok.com/@aqa.sports.academ" target="_blank" rel="noopener noreferrer" title="TikTok" aria-label="TikTok">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V8.5a5 5 0 0 0 5-5"></path></svg>
                </a>
            </div>
        </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
        <img src="https://i.ibb.co/08WDCFj/Turquoise-Modern-Warning-with-Rays-Instagram-Post.png" alt="AQA Logo" class="footer-logo">
        <div class="copyright">
            <p>&copy; {localT.copyright}</p>
        </div>
    </div>
</footer>

<script is:inline>
  // Handle newsletter dynamically
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('newsletterForm');
    if (!form) return;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const input = form.querySelector("input[name='email']");
      const btn = form.querySelector("button");
      const msg = document.getElementById("newsletterMessage");
      const email = input.value.trim();

      const valError = form.getAttribute('data-validation');
      const succMsg = form.getAttribute('data-success');
      const errMsg = form.getAttribute('data-error');
      const netErr = form.getAttribute('data-network');

      if (!email) {
        msg.textContent = valError;
        msg.className = "status-message error";
        msg.classList.remove("hidden");
        return;
      }

      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = "...";

      try {
        const resp = await fetch("https://formspree.io/f/xeolyonl", {
          method: "POST",
          headers: { "Accept": "application/json", "Content-Type": "application/json" },
          body: JSON.stringify({ email })
        });
        if (resp.ok) {
          msg.textContent = succMsg;
          msg.className = "status-message success";
          msg.classList.remove("hidden");
          form.reset();
        } else {
          msg.textContent = errMsg;
          msg.className = "status-message error";
          msg.classList.remove("hidden");
        }
      } catch (err) {
        msg.textContent = netErr;
        msg.className = "status-message error";
        msg.classList.remove("hidden");
      }
      btn.textContent = originalText;
      btn.disabled = false;
    });
  });
</script>

<style>
    /* Footer styles pulled into layout context */
    .aqa-footer {
        background: rgba(3, 7, 18, 0.95);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 4rem 1rem 3rem;
        width: 100%;
        color: var(--text-primary);
        margin-top: 4rem;
        box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.5);
    }
    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 2.5rem;
    }
    .footer-section h4 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--color-teal);
        margin-bottom: 1.5rem;
        text-shadow: 0 0 10px rgba(0, 242, 255, 0.3);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .footer-section h4 svg {
        width: 20px;
        height: 20px;
        stroke: var(--color-teal);
    }
    .footer-section p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--text-secondary);
    }
    .footer-section ul {
        list-style: none;
    }
    .footer-section li {
        margin-bottom: 0.6rem;
    }
    .footer-section a {
        color: var(--text-secondary);
        font-size: 0.95rem;
    }
    .footer-section a:hover {
        color: var(--color-teal);
        text-shadow: 0 0 8px rgba(0, 242, 255, 0.4);
    }
    .contact-info {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 0.8rem;
    }
    .contact-info a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .contact-info svg {
        width: 18px;
        height: 18px;
        stroke: var(--color-teal);
        flex-shrink: 0;
    }
    .socials {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.25rem;
    }
    .socials a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 50%;
        transition: var(--transition-smooth);
    }
    .socials a:hover {
        background: var(--color-teal);
        color: #030712;
        box-shadow: var(--shadow-glow-active);
        transform: translateY(-2px);
    }
    .socials svg {
        width: 20px;
        height: 20px;
        stroke: currentColor;
    }
    .newsletter-form {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
    }
    .newsletter-input {
        flex: 1;
        padding: 0.75rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        background: rgba(0, 0, 0, 0.4);
        color: var(--text-primary);
        font-size: 0.9rem;
    }
    .newsletter-input:focus {
        outline: none;
        border-color: var(--color-teal);
        box-shadow: var(--shadow-glow);
    }
    .newsletter-btn {
        background: linear-gradient(135deg, var(--color-blue), var(--color-teal));
        color: #030712;
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 30px;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: var(--transition-smooth);
    }
    .newsletter-btn:hover {
        box-shadow: var(--shadow-glow-active);
        transform: translateY(-1px);
    }
    
    .status-message {
      font-size: 0.85rem;
      margin-top: 0.5rem;
      font-weight: 600;
    }
    .status-message.success { color: #10b981; }
    .status-message.error { color: #ef4444; }

    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        margin-top: 3rem;
        padding-top: 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
    }
    .footer-logo {
        width: 50px;
        height: auto;
        opacity: 0.8;
        transition: var(--transition-smooth);
    }
    .footer-logo:hover {
        opacity: 1;
        transform: scale(1.05);
        filter: drop-shadow(0 0 10px var(--color-teal));
    }
    .copyright {
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    @media (max-width: 768px) {
        .footer-content {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .contact-info {
            justify-content: center;
        }
        .socials {
            justify-content: center;
        }
    }
</style>
