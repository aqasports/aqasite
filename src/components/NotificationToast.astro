<!-- Global Containers -->
<div id="toastContainer" class="toast-container"></div>

<script>
  // Dynamic type detection for alert overrides
  const detectAlertType = (message) => {
    const msg = message.toLowerCase();
    if (msg.includes('erreur') || msg.includes('impossible') || msg.includes('échoué') || msg.includes('expiré') || msg.includes('requis')) {
      return 'error';
    }
    if (msg.includes('attention') || msg.includes('avertissement') || msg.includes('sélectionner') || msg.includes('bientôt') || msg.includes('⏳')) {
      return 'warning';
    }
    if (msg.includes('succès') || msg.includes('réussi') || msg.includes('bravo') || msg.includes('✓')) {
      return 'success';
    }
    return 'info';
  };

  // 1. AQA PREMIUM POP-UP MODAL SYSTEM
  const showAqaAlert = (title, message, type = 'info', callback = null) => {
    const overlay = document.createElement('div');
    overlay.className = 'aqa-modal-overlay';
    
    let icon = '';
    let color = '#00f2ff'; // default teal
    let eyebrow = 'NOTIFICATION';
    
    if (type === 'success') {
      icon = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
      color = '#10b981';
      eyebrow = 'SUCCÈS';
    } else if (type === 'error') {
      icon = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;
      color = '#ef4444';
      eyebrow = 'ERREUR';
    } else if (type === 'warning') {
      icon = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>`;
      color = '#f59e0b';
      eyebrow = 'ATTENTION';
    } else {
      icon = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="8"></line></svg>`;
      color = '#00f2ff';
      eyebrow = 'INFORMATION';
    }

    overlay.innerHTML = `
      <div class="aqa-modal-bezel">
        <div class="aqa-modal-core">
          <div class="aqa-modal-icon-wrap" style="color: ${color}; border-color: ${color}30; box-shadow: 0 0 20px ${color}15; background: ${color}08;">
            ${icon}
          </div>
          <span class="aqa-modal-eyebrow" style="color: ${color};">${eyebrow}</span>
          <h3 class="aqa-modal-title">${title}</h3>
          <p class="aqa-modal-text">${message}</p>
          <button class="aqa-modal-btn" style="background: linear-gradient(135deg, ${color}cc, ${color}); box-shadow: 0 6px 20px ${color}25;">
            <span>D'ACCORD</span>
          </button>
        </div>
      </div>
    `;

    document.body.appendChild(overlay);
    
    // Animate in
    setTimeout(() => {
      overlay.classList.add('active');
    }, 10);

    const closeAlert = () => {
      overlay.classList.remove('active');
      overlay.classList.add('closing');
      overlay.addEventListener('transitionend', () => {
        overlay.remove();
        if (callback) callback();
      });
    };

    overlay.querySelector('.aqa-modal-btn').addEventListener('click', closeAlert);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeAlert();
    });
  };

  // 2. TOAST NOTIFICATION SYSTEM
  const showToast = (message, type = 'info') => {
    const container = document.getElementById('toastContainer');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    
    let icon = '';
    if (type === 'success') {
      icon = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
    } else if (type === 'error') {
      icon = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;
    } else {
      icon = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="8"></line></svg>`;
    }

    toast.innerHTML = `
      <span class="toast-icon">${icon}</span>
      <span class="toast-message">${message}</span>
      <button class="toast-close-btn">&times;</button>
    `;

    container.appendChild(toast);

    const timer = setTimeout(() => {
      removeToast(toast);
    }, 4500);

    toast.querySelector('.toast-close-btn').addEventListener('click', () => {
      clearTimeout(timer);
      removeToast(toast);
    });
  };

  const removeToast = (toast) => {
    toast.classList.add('removing');
    toast.addEventListener('transitionend', () => {
      toast.remove();
    });
  };

  // Bind APIs globally
  window.showToast = showToast;
  window.showAqaAlert = showAqaAlert;

  // Intercept default browser alert()
  window.alert = (message) => {
    const type = detectAlertType(message);
    const title = type === 'error' ? 'Erreur' : (type === 'warning' ? 'Attention' : 'AQA Sports');
    showAqaAlert(title, message, type);
  };
</script>

<style>
  /* --- TOAST NOTIFICATIONS --- */
  .toast-container {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 10010;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 380px;
    width: calc(100% - 48px);
    pointer-events: none;
  }
  
  :global(.toast) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 
      0 10px 30px -5px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    color: #fff;
    pointer-events: auto;
    transform: translateX(120%) scale(0.9);
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    animation: slideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  :global(.toast.removing) {
    transform: translateX(120%) scale(0.9);
    opacity: 0;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(.toast-success) {
    border-color: rgba(16, 185, 129, 0.3);
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.1), 0 10px 30px -5px rgba(0, 0, 0, 0.5);
  }
  :global(.toast-success .toast-icon) { color: #10b981; }

  :global(.toast-error) {
    border-color: rgba(239, 68, 68, 0.3);
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.1), 0 10px 30px -5px rgba(0, 0, 0, 0.5);
  }
  :global(.toast-error .toast-icon) { color: #ef4444; }

  :global(.toast-info) {
    border-color: rgba(0, 242, 255, 0.3);
    box-shadow: 0 0 20px rgba(0, 242, 255, 0.1), 0 10px 30px -5px rgba(0, 0, 0, 0.5);
  }
  :global(.toast-info .toast-icon) { color: #00f2ff; }

  :global(.toast-icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  :global(.toast-message) {
    font-size: 0.88rem;
    line-height: 1.4;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  :global(.toast-close-btn) {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.35);
    font-size: 1.3rem;
    cursor: pointer;
    margin-left: auto;
    line-height: 1;
    padding: 0 4px;
    transition: color 0.2s ease;
  }
  :global(.toast-close-btn:hover) { color: #fff; }

  @keyframes slideIn {
    to {
      transform: translateX(0) scale(1);
      opacity: 1;
    }
  }

  /* --- AQA STYLED MODAL/OVERLAY --- */
  :global(.aqa-modal-overlay) {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(3, 7, 18, 0.0);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease, opacity 0.4s ease;
  }

  :global(.aqa-modal-overlay.active) {
    background: rgba(3, 7, 18, 0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    opacity: 1;
  }

  :global(.aqa-modal-overlay.closing) {
    background: rgba(3, 7, 18, 0.0);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    opacity: 0;
  }

  :global(.aqa-modal-bezel) {
    background: rgba(255, 255, 255, 0.015);
    border: 1px solid rgba(255, 255, 255, 0.04);
    padding: 6px;
    border-radius: 28px;
    box-shadow: 0 24px 60px -15px rgba(0, 0, 0, 0.9);
    max-width: 420px;
    width: 100%;
    transform: scale(0.9) translateY(20px);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
  }

  :global(.aqa-modal-overlay.active .aqa-modal-bezel) {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  :global(.aqa-modal-overlay.closing .aqa-modal-bezel) {
    transform: scale(0.95) translateY(15px);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  :global(.aqa-modal-core) {
    background: rgba(15, 23, 42, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 22px;
    padding: 32px 24px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  :global(.aqa-modal-icon-wrap) {
    width: 54px;
    height: 54px;
    border-radius: 16px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  :global(.aqa-modal-eyebrow) {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 0.4rem;
  }

  :global(.aqa-modal-title) {
    font-family: 'Outfit', -apple-system, sans-serif;
    font-size: 1.35rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  :global(.aqa-modal-text) {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    margin: 0 0 1.75rem;
  }

  :global(.aqa-modal-btn) {
    border: none;
    border-radius: 50px;
    padding: 0.85rem 2.25rem;
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 0.82rem;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    width: 100%;
  }

  :global(.aqa-modal-btn:hover) {
    transform: translateY(-2px);
    filter: brightness(1.1);
  }

  :global(.aqa-modal-btn:active) {
    transform: translateY(0);
  }
</style>
